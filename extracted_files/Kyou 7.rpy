label stagename: #Allows the player to submit their own stage name for Hiroko and checks it against a few common sense criteria for validity
    $stagename_valid = False
    while stagename_valid == False:
        menu:
            "Ayumu":
                $stagename = "Ayumu"
            "(Invent my own)":
                $stagename = renpy.input(_("Type a stage name for Hiroko (12 characters or fewer):"), length=12)
                $stagename = stagename.strip() #Strip out empty spaces
                $stagename = stagename.capitalize() #And capitalize the first letter
        # The following checks the string presented for names that Kyou would consider inappropriate for use
        if stagename == "Hiroko" or stagename == "Hiro" or stagename == "Homura":
            "... Not her name. A DIFFERENT name."
        elif stagename == "Sayori" or stagename == "Watanabe" or stagename == "Nozomi" or stagename == "Nozo" or stagename == "Akemi" or stagename == "Risa" or stagename == "Ris":
            "Naming her after one of her friends would be just too weird. And confusing."
        elif stagename == "Kobayashi": # How about naming her after the homeroom teacher? :D
            "What, my homeroom teacher? Pass."
        elif stagename == "Kyou": # Err....
            "... Wait, no, that's MY name!"
        elif stagename == "Penlight" or stagename == "Fembot" or stagename == "Gynoid" or stagename == "Ginoide" or stagename == "Robot" or stagename == "Linterna": #Uhh...
            "I don't think naming her after a thing would go down very well."
        elif len(stagename) < 2: #Put some effort into it, geez
            "That's not a name..."
        else:
            $stagename_valid = True
        if stagename_valid == True:
            $stagename = stagename.lower() # Here's a rudimentary attempt to stop the player from calling Hiroko really rude names >:(
            if (stagename.count("bitch") > 0 or stagename.count("fuck") > 0 or stagename.count("cunt") > 0 or stagename.count("slut") > 0 or stagename.count("retard") > 0
            or stagename.count("whore") > 0 or stagename.count("cum") > 0 or stagename.count("slave") > 0 or stagename.count("thrall") > 0
            #Really not going to be an exhaustive list, but can't hurt to call out a few slurs someone might mindlessly try entering. The anti-asian ones in particular
            or stagename.count("tranny") > 0 or stagename.count("faggot") > 0 or stagename.count("nigger") > 0 or stagename.count("chink") > 0 or stagename.count("jap") > 0
            or stagename.count("esclav") > 0 or stagename.count("perra") > 0 or stagename.count("zorra") > 0 or stagename.count("puta") > 0
            or stagename.count("mierda") > 0 or stagename.count("gilipollas") > 0 or stagename.count("pendej") > 0 #Including some derogatory Spanish words too
            or stagename.count("coño") > 0 or stagename.count("culer") > 0 or stagename.count("puñetas") > 0 or stagename.count("pelotud") > 0
            or stagename.count("bolud") > 0 or stagename.count("conche") > 0):
                "I... fuck, no, I'm not calling her that on camera."
                $stagename_valid = False
            elif stagename.count("hiroko") > 0 or stagename.count("homura") > 0: #Checks to see if Hiroko's names are included anywhere in the string submitted
                "Eh, I'd better not mention her name at all, really."
                $stagename_valid = False
            elif stagename.count("servant") > 0 or stagename.count("maid") > 0 or stagename.count("sirviente") > 0:
                "That's a little bit much. Don't want to give these guys the wrong idea or anything."
                $stagename_valid = False
            elif (stagename.count("a") == 0 and stagename.count("e") == 0 and stagename.count("i") == 0 and stagename.count("o") == 0 and stagename.count("u") == 0
                and stagename.count("y") == 0 and stagename.count("á") == 0 and stagename.count("é") == 0 #If there's none of these characters in the name, it's probably nonsense.
                and stagename.count("í") == 0 and stagename.count("ó") == 0 and stagename.count("ü") == 0 and stagename.count("ú") == 0):
                "That doesn't make any sense."
                $stagename_valid = False
            else:
                $stagename = stagename.title()
            if stagename.isalpha() == False: # No numbers or other weird characters. Only letters and spaces
                $namecheck = stagename
                $namecheck = namecheck.replace(" ", "")
                if namecheck.isalpha() == False:
                    "That sounds more like the kind of name you'd give to a robot or something."
                    $stagename_valid = False
            if stagename == "Assistant" or stagename == "Asistente":
                "A little on the nose, but... sure, why the hell not."
            elif stagename == "Okorih": #Hiroko spelled backwards? Fine...
                "What? That's... oh, I see what's going on. Alright, then."
        if stagename_valid == False:
            "Gotta think of something else..."
        # Yes, the script doesn't check for the name "Akiko". Kyou doesn't know her well enough to think it weird if he calls Hiroko that
        # Ditto for any other named extras in the script.
        # Still though, possible easter eggs abound if Kyou names her after anyone known to the other girls...
    return
