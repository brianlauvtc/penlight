    h entranced_talk "[hypno2!t]." with dissolve

# game/kyou 2.rpy:1194
translate spanish Day2_Villain_Kyou_2ad42021:

    # "Chuckling at her machine-like response, I continue." with dissolve
    "Riéndome ante su respuesta de máquina, continúo." with dissolve

# game/kyou 2.rpy:1356
translate spanish Day2_Villain_Kyou_36772431:

    # k "Excellent. And in return, instead of asking if you understand I will say..."
    k "Excelente. Y por mi parte, en lugar de preguntar si entendiste, diré..."

# game/kyou 2.rpy:1367
translate spanish Day2_Villain_Kyou_ae47861b:

    # k "You will acknowledge you understand and obey. [hypno3]."
    k "Reconocerás que entiendes y obedeces. [hypno3!t]."

# game/kyou 2.rpy:1207
