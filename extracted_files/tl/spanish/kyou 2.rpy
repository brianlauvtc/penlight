    ncg "... Un poco nerviosa, a decir verdad." with dissolve

# game/kyou 2.rpy:2366
translate spanish Day2_Con_Kyou_Nozomi_bfe755d3:

    # ncg standing uniform stern "I know this is what I came here for, but to be actually going through with it feels... weird. And tense." with dissolve
    ncg standing uniform stern "Sé que vine para esto, pero llevarlo a cabo de verdad se siente... extraño. Y tenso." with dissolve

# game/kyou 2.rpy:1759
translate spanish Day2_Con_Kyou_Nozomi_4c6b2e69:

