    h entranced_talk "Sí..." with dissolve

# game/kyou 2.rpy:1339
translate spanish Day2_Villain_Kyou_2ac60754:

    # k "Good, Hiroko. But you must realize that \"Yeah\" is a faulty response for a [hypno6] in maintenance mode. Maintenance mode being the state you're currently in." with dissolve
    k "Bien, Hiroko. Pero debes darte cuenta de que \"Sí\" es una respuesta deficiente para un[genero_a] [hypno6!t] en modo de mantenimiento." with dissolve
    k "Siendo dicho modo el estado en el que estás ahora."

# game/kyou 2.rpy:1340
translate spanish Day2_Villain_Kyou_7e24bc33:

    # k "When you have understood and processed a command, you must respond with..."
    k "Cuando hayas entendido y procesado un comando, debes responder con..."

# game/kyou 2.rpy:1351
translate spanish Day2_Villain_Kyou_17669cc1:

    # k "Understand?"
    k "¿Entiendes?"

# game/kyou 2.rpy:1192
