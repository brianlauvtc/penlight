    h entranced_talk "[hypno2!t]." with dissolve

# game/kyou 2.rpy:1371
translate spanish Day2_Villain_Kyou_b575f9f6:

    # k "Very good, Hiroko. Processing my instructions makes you more robotic, less human, every time you acknowledge my commands. [hypno3]." with dissolve
    k "Muy bien, Hiroko. Procesar mis instrucciones te vuelve más robótica, menos humana, cada vez que reconoces mis comandos. [hypno3!t]" with dissolve

# game/kyou 2.rpy:1210
translate spanish Day2_Villain_Kyou_41207cb8_2:

    # h entranced_talk "[hypno2!t]." with dissolve
    h entranced_talk "[hypno2!t]." with dissolve

# game/kyou 2.rpy:1375
translate spanish Day2_Villain_Kyou_ce3f39a9:

    # k "Every time you process an instruction you will feel a pleasurable jolt of electricity ripple through the circuitry of your body." with dissolve
    k "Cada vez que procesas una instrucción sentirás un placentero choque de energía recorrer el circuito en tu cuerpo." with dissolve

# game/kyou 2.rpy:1376
translate spanish Day2_Villain_Kyou_94e0fe76:

    # k "It will begin from your crotch, crackle pleasantly up your spine before registering deep within your CPU. [hypno3]."
    k "Comenzará por tu entrepierna, crepitará plácidamente por tu columna para posteriormente registrarse en lo profundo de tu CPU. [hypno3!t]."

# game/kyou 2.rpy:1214
translate spanish Day2_Villain_Kyou_41207cb8_3:

    # h entranced_talk "[hypno2!t]." with dissolve
    h entranced_talk "[hypno2!t]." with dissolve

# game/kyou 2.rpy:1417
translate spanish Day2_Villain_Kyou_0ec742fc:

    # "I take a moment to smile in satisfaction. Hiroko isn't resisting any of my programming, just as I suspected." with dissolve
    "Me tomo un momento para sonreír con satisfacción. Hiroko no se está resistiendo a mi condicionamiento, como sospeché." with dissolve

# game/kyou 2.rpy:1229
translate spanish Day2_Villain_Kyou_0b49e42a:

    # "All I have to do is break things down simply enough for her uncritical mind to digest."
    "Solo tengo que simplificar las cosas lo suficiente para que su mente sin criterio lo digiera."

# game/kyou 2.rpy:1394
translate spanish Day2_Villain_Kyou_d370168f:

    # k "Now in a moment I'm going to bring you back online, where you will once again be fully awake and aware, as if you were human."
    k "En un momento volveré a ponerte en línea, donde de nuevo estarás completamente despierta y consciente, como si fueras humana."

# game/kyou 2.rpy:1395
translate spanish Day2_Villain_Kyou_db886cf5:

    # k "From now on when you are in maintenance mode and I say the phrase \"power up\", you will return to your waking \"online\" state as I just described."
    k "De ahora en adelante, cuando estés en modo mantenimiento y diga la frase \"encender ahora\", estarás de nuevo \"en línea\" tal como describí."

# game/kyou 2.rpy:1396
translate spanish Day2_Villain_Kyou_481cef2a:

    # k "Processing your thoughts perfectly normally, as you naturally accept what you are. [hypno3]."
    k "Procesando tus pensamientos con perfecta normalidad, aceptando naturalmente lo que eres. [hypno3!t]."

# game/kyou 2.rpy:1233
translate spanish Day2_Villain_Kyou_41207cb8_4:

    # h entranced_talk "[hypno2!t]." with dissolve
    h entranced_talk "[hypno2!t]." with dissolve

# game/kyou 2.rpy:1403
translate spanish Day2_Villain_Kyou_bdc8b00e:

    # k "Very good, Hiroko. Power up."
    k "Muy bien, Hiroko. Encender ahora."

# game/kyou 2.rpy:1407
translate spanish Day2_Villain_Kyou_2fded262_1:

    # h "..."
    h "..."

# game/kyou 2.rpy:1408
translate spanish Day2_Villain_Kyou_0d57e318:

    # k "Hiroko? You there?"
    k "¿Hiroko? ¿Estás ahí?"

# game/kyou 2.rpy:1239
translate spanish Day2_Villain_Kyou_90a7dfd5:

    # h surprised uniform_arm "Huh?" with dissolve
    h surprised uniform_arm "¿Eh?" with dissolve

# game/kyou 2.rpy:1412
translate spanish Day2_Villain_Kyou_a6ab09e6:

    # h "O-oh, yeah, I just got online again. What's up?"
    h "O-oh, sí. Ya estoy en línea otra vez. ¿Qué pasa?"

# game/kyou 2.rpy:1241
translate spanish Day2_Villain_Kyou_e2cda7c2:

    # "That response draws another grin out of me."
    "Esa respuesta dibuja otra sonrisa en mi rostro."

# game/kyou 2.rpy:1414
translate spanish Day2_Villain_Kyou_7de74fb8:

    # k "I think you need to get going now; it's starting to get late."
    k "Creo que ya deberías irte; se está haciendo tarde."

# game/kyou 2.rpy:1415
translate spanish Day2_Villain_Kyou_0751b001:

    # h "Yeah, right. Can I ask you something, though?"
    h "Sí, claro. ¿Pero puedo preguntarte algo?"

# game/kyou 2.rpy:1416
translate spanish Day2_Villain_Kyou_224eeec0:

    # k "What is it?"
    k "¿Qué cosa?"

# game/kyou 2.rpy:1245
translate spanish Day2_Villain_Kyou_1dcfbd0e:

    # h "You're not gonna tell anyone are you? About me being a [hypno6!t]?"
    h "No le dirás a nadie, ¿o sí? ¿Que soy un[genero_a] [hypno6!t]?"

# game/kyou 2.rpy:1418
translate spanish Day2_Villain_Kyou_f8bdd83b:

    # k "Why would I do that? I think I'll keep you to myself."
    k "¿Por qué haría eso? Creo que te conservaré para mí solo."

# game/kyou 2.rpy:1486
translate spanish Day2_Villain_Kyou_0e559400:

    # h uniform_headhold2 annoyed "Creepy. But I guess I got no choice but to trust you, mister sysadmin." with dissolve
    h uniform_headhold2 annoyed "Eso da miedo. Pero supongo que no tengo más opción que confiar en ti, señor administrador." with dissolve

# game/kyou 2.rpy:1429
translate spanish Day2_Villain_Kyou_9c6291a8:

    # ks smirk "No choice at all. I'll see you tomorrow, Hiroko."
    ks smirk "Ninguna otra opción. Te veo mañana, Hiroko."

# game/kyou 2.rpy:1249
translate spanish Day2_Villain_Kyou_d3f79ef1:

    # h neutral "'Kay, seeya." with dissolve
    h neutral "Bien, nos vemos." with dissolve

# game/kyou 2.rpy:1354
translate spanish Day2_Villain_Kyou_cb70ff5c:

    # "She sees herself out and I let out a hearty laugh."
    "Ella se va y yo río a todo volumen."

# game/kyou 2.rpy:1253
translate spanish Day2_Villain_Kyou_aaa41d60:

    # "So this is my life, now. I started out chasing my crush and I came home with her robotized friend."
    "Conque esta es mi vida ahora. Comencé persiguiendo a una chica linda y regresé con una amiga robot."

# game/kyou 2.rpy:1254
translate spanish Day2_Villain_Kyou_6c55034d:

    # "Would I do the same to Nozomi if I could?"
    "¿Le haría lo mismo a Nozomi si pudiera?"

# game/kyou 2.rpy:1255
translate spanish Day2_Villain_Kyou_fb00b3c6:

    # "Man, I don't even know right now. That thought bothers me, so I'll forget about it for now."
    "Cielos, ahora mismo ni siquiera lo sé. Esa idea me molesta, así que la olvidaré por ahora."

# game/kyou 2.rpy:1256
translate spanish Day2_Villain_Kyou_16a61bbf:

    # "I'd rather focus on my new project."
    "Mejor me concentro en mi nuevo proyecto."

# game/kyou 2.rpy:1257
translate spanish Day2_Villain_Kyou_eff9dbc2:

    # "And what a project it is..."
    "Y vaya proyecto..."

# game/kyou 2.rpy:1258
translate spanish Day2_Villain_Kyou_9541d75c:

    # "I think I'll place an online order for some gadgets. I have in mind a couple of things that should be fun to try out on her."
    "Creo que ordenaré algunos aparatos por internet. Tengo algunas cosas en mente que podría ser divertido probar en ella."

# game/kyou 2.rpy:1259
translate spanish Day2_Villain_Kyou_41796a94:

    # "And while I'm waiting for those to arrive I'm sure I'm sure I can find enough things to work on in the meantime..."
    "Y en lo que espero a que lleguen, estoy seguro de que puedo encontrar cosas por hacer..."

# game/kyou 2.rpy:1266
translate spanish Day2_Villain_Kyou_7bb75b3e:

    # "But I can't forget why I started all this in the first place."
    "Pero no puedo olvidar por qué comencé todo esto en primer lugar."

# game/kyou 2.rpy:1267
translate spanish Day2_Villain_Kyou_ca8b14d6:

    # "It's Nozomi I wanted to do this with, not this brat."
    "Es Nozomi con quien quería hacer esto, no esta mocosa."

# game/kyou 2.rpy:1268
translate spanish Day2_Villain_Kyou_69aff5c5:

    # "But if I approach things in just the right way, Hiroko will help me with her and not even realize it."
    "Pero si hago esto correctamente, Hiroko me ayudará y ni siquiera se dará cuenta."

# game/kyou 2.rpy:1269
translate spanish Day2_Villain_Kyou_56cb9d3e:

    # "Hell, she could end up helping me with a lot of things..."
    "Es más, podría terminar ayudándome con muchísimas cosas..."

# game/kyou 2.rpy:1270
translate spanish Day2_Villain_Kyou_793aaa24:

    # "Alright, so I have a plan in mind. First I need to get her phone."
    "Bien, ya tengo un plan en mente. Primero necesito su teléfono."

# game/kyou 2.rpy:1271
translate spanish Day2_Villain_Kyou_5aabb318:

    # ks "Now, Hiroko, as you listen and obey, I want you to focus on how natural and right this feels."
    ks "Ahora, Hiroko, vas a escuchar y obedecer, y quiero que te concentres en lo natural y correcto que eso se siente."

# game/kyou 2.rpy:1272
translate spanish Day2_Villain_Kyou_a8d1dcb4:

    # "As I talk, I pat her down gently, hoping to find... there it is."
    "Mientras hablo, le doy unas cuantas palmadas suaves, esperando encontrar... aquí está."

# game/kyou 2.rpy:1273
translate spanish Day2_Villain_Kyou_406b8c16:

    # ks "Just allowing yourself to stay in this blissful state of deep relaxation. Remaining so wonderfully deep in trance for me."
    ks "Mantente en este maravilloso estado de profunda relajación. En un trance maravillosamente profundo."

# game/kyou 2.rpy:1274
translate spanish Day2_Villain_Kyou_377347de:

    # "Pulling her phone from out of her blazer pocket, I switch it on and note that she's locked it with a fingerprint ID. Shouldn't be too much trouble..."
    "Sacando su teléfono de su chaqueta, lo enciendo y noto que está bloqueado con huella dactilar. No debería ser mucho problema..."

# game/kyou 2.rpy:1275
translate spanish Day2_Villain_Kyou_86fde62a:

    # "Gently taking her hand, I run her fingertip over the sensor and sure enough, her phone unlocks for me."
    "Tomo su mano con delicadeza, pongo su dedo sobre el sensor y, por su puesto, su teléfono se desbloquea para mí."

# game/kyou 2.rpy:1276
translate spanish Day2_Villain_Kyou_ddd0ce0f:

    # "Casting her a glance, she seems completely oblivious as I go into her address book and add myself to it, and add her own number to my phone."
    "Le doy otro vistazo y no parece darse cuenta de lo que ocurre. Entro a sus contactos y me añado a mí mismo, luego añado su número a mi teléfono."

# game/kyou 2.rpy:1277
translate spanish Day2_Villain_Kyou_edbcb746:

    # ks "And now, while you are in this deeply relaxing trance, I need you to listen very carefully to me. Listen and obey, Hiroko."
    ks "Y ahora, mientras estás en este relajante y profundo trance, necesito que escuches con mucho cuidado. Debes escuchar y obedecer, Hiroko."

# game/kyou 2.rpy:1278
translate spanish Day2_Villain_Kyou_53f2c3b5:

    # h entranced_talk "Listen... and obey..." with dissolve
    h entranced_talk "Escuchar... y obedecer..." with dissolve

# game/kyou 2.rpy:1280
translate spanish Day2_Villain_Kyou_84fb29e4:

    # "Smiling, I switch off her phone and place it back in her pocket where I found it." with dissolve
    "Sonriente, apago su teléfono y lo coloco de vuelta en el bolsillo donde lo encontré." with dissolve

# game/kyou 2.rpy:1281
translate spanish Day2_Villain_Kyou_22d9ee45:

    # ks smile "That's right. So now, you may find on your phone that \"Kyou\" is listed as a contact. You need to consciously ignore it for me. It may as well not exist."
    ks smile "Eso es. Y ahora, puede que encuentres en tu teléfono a \"Kyou\" en tu lista de contactos. Debes ignorarlo conscientemente por mí. Bien podría no existir."

# game/kyou 2.rpy:1282
translate spanish Day2_Villain_Kyou_3c6441a1:

    # ks "However, whenever you receive a message from this contact..."
    ks "Sin embargo, siempre que recibas un mensaje de este contacto..."

# game/kyou 2.rpy:1283
translate spanish Day2_Villain_Kyou_571ac351:

    # ks "... you will read it, absorb every word contained within and delete the message as soon as you have done so."
    ks "... lo leerás, absorberás cada palabra que contenga y borrarás el mensaje en cuanto lo hayas hecho."

# game/kyou 2.rpy:1284
translate spanish Day2_Villain_Kyou_3ec7a57f:

    # ks "You will immediately forget ever having received a message..."
    ks "Olvidarás inmediatamente haber recibido un mensaje..."

# game/kyou 2.rpy:1285
translate spanish Day2_Villain_Kyou_6c162612:

    # ks "... But at your earliest convenience you will automatically obey the instructions the message contained as if it were your own thinking."
    ks "... Pero tan pronto como sea posible vas a obedecer automáticamente las instrucciones del mensaje como si fueran tus propias ideas."

# game/kyou 2.rpy:1286
translate spanish Day2_Villain_Kyou_1f64aebc:

    # ks "And as soon as you have obeyed, you will immediately forget ever having done so, and will continue your day as if nothing had happened."
    ks "En cuanto hayas obedecido, olvidarás inmediatamente haberlo hecho, y continuarás con tu día como si nada hubiera pasado."

# game/kyou 2.rpy:1287
translate spanish Day2_Villain_Kyou_646879f0:

    # ks "Do you understand everything you were just told, Hiroko?"
    ks "¿Entendiste todo lo que te dije, Hiroko?"

# game/kyou 2.rpy:1288
translate spanish Day2_Villain_Kyou_bdb8199a_5:

    # h entranced_talk "Yeah..." with dissolve
    h entranced_talk "Sí..." with dissolve

# game/kyou 2.rpy:1290
translate spanish Day2_Villain_Kyou_10e4cdc5:

    # "Man, I really hope so. This sounds insane to expect it to work, yet looking at her blank eyes and vacant affirmation gives me hope." with dissolve
    "Cielos, eso espero. Esperar que esto funcione suena a una locura, mas ver esos ojos en blanco y sus vacías expresiones me da esperanza." with dissolve

# game/kyou 2.rpy:1291
translate spanish Day2_Villain_Kyou_94e7bfb1:

    # ks "That's wonderful, Hiroko. It feels so amazing to listen and obey like this."
    ks "Maravilloso, Hiroko. Se siente maravilloso escuchar y obedecer de este modo."

# game/kyou 2.rpy:1292
translate spanish Day2_Villain_Kyou_90636d35:

    # ks "And it feels very good to let these suggestions sink deep into your subconscious, letting them become an inseparable part of who you are."
    ks "Y se siente muy bien dejar estas sugestiones entrar profundamente en tu subconsciente, permitiendo que se vuelvan una parte inseparable de lo que eres."

# game/kyou 2.rpy:1293
translate spanish Day2_Villain_Kyou_c63934a9:

    # "I pause a moment to allow her to do just that, then continue."
    "Hago una pausa para dejar que haga justo eso, luego continúo."

# game/kyou 2.rpy:1294
translate spanish Day2_Villain_Kyou_145c3468:

    # ks "Now, in a few moments I am going to wake you up, Hiroko, but first you need to do something else for me."
    ks "Ahora, voy a despertarte en unos momentos, Hiroko, pero necesitas hacer algo más."

# game/kyou 2.rpy:1295
translate spanish Day2_Villain_Kyou_4f281d68:

    # ks "You need to forget about seeing the penlight I shone in your face, just as you need to forget sinking into a deep tranced sleep at my suggestion."
    ks "Necesitas olvidar que viste la linterna que encendí sobre tu rostro, así como olvidar que dormiste en un profundo trance como te dije."

# game/kyou 2.rpy:1296
translate spanish Day2_Villain_Kyou_79fbd937:

    # ks "This entire talk, as far as you are consciously concerned, never happened. Consciously, you never need to think about this at all."
    ks "Esta charla, en lo que a ti concierne conscientemente, nunca ocurrió. Conscientemente, nunca tendrás que pensar en nada de esto."

# game/kyou 2.rpy:1297
translate spanish Day2_Villain_Kyou_c585bf58:

    # ks "So on the count of five, you will awaken with no conscious memory of this trance, or my penlight, counting up from one..."
    ks "Así que, a la cuenta de cinco, despertarás sin memoria consciente de este trance, o mi linterna. Contaré desde uno..."

# game/kyou 2.rpy:1299
translate spanish Day2_Villain_Kyou_d6a8a863:

    # ks "Two... letting yourself gently rise from your deep sleep, Hiroko."
    ks "Dos... empiezas a salir de este profundo sueño, Hiroko."

# game/kyou 2.rpy:1300
translate spanish Day2_Villain_Kyou_189b22f2:

    # ks "Three... feeling the air brush your face as you slowly allow yourself to be aware of everything else."
    ks "Tres... sientes el aire acariciando tu rostro y estás poco a poco más consciente de todo lo demás."

# game/kyou 2.rpy:1301
translate spanish Day2_Villain_Kyou_8b342f54:

    # ks "Four... blinking slowly, ready to wake feeling refreshed and alert once more."
    ks "Cuatro... parpadea lentamente, lista para despertar, sintiéndote una vez más fresca y alerta."

# game/kyou 2.rpy:1302
translate spanish Day2_Villain_Kyou_c2af17ab:

    # ks "And... five."
    ks "Y... cinco."

# game/kyou 2.rpy:1303
translate spanish Day2_Villain_Kyou_43e03a49:

    # h neutral "... " with dissolve
    h neutral "..." with dissolve

