# game/Kyou 8.rpy:1648
translate spanish Day8_Con_Kyou_Nozomi_Reversal_5daf20dc:

    # "I can feel her hand pressing firmly against my shoulder as she draws closer to me, and I can only look past her glasses and into those eyes that are suddenly filled with purpose."
    " Siento su mano presionar suavemente mi hombro, mientras se acerca a mí, y solo puedo mirar a través de sus gafas esos ojos súbitamente llenos de propósito."

# game/Kyou 8.rpy:1725
translate spanish Day8_Con_Kyou_Nozomi_Reversal_44bc72ae:

    # "With a trembling hand, Nozomi lowers her penlight from my face as those bitter tears return to her eyes." with dissolve
    "Con temblor en su mano, Nozomi baja su linterna, alejándola de mi rostro, y esas amargas lágrimas retornan a sus ojos." with dissolve

# game/Kyou 8.rpy:1726
translate spanish Day8_Con_Kyou_Nozomi_Reversal_32d0b557:

    # "She's not going to hypnotize me? But..."
    "¿No va a hipnotizarme? Pero..."

# game/Kyou 8.rpy:1727
translate spanish Day8_Con_Kyou_Nozomi_Reversal_a7eca130:

    # k "I don't... understand."
    k "No... no entiendo..."

# game/Kyou 8.rpy:1729
translate spanish Day8_Con_Kyou_Nozomi_Reversal_46e7b042:

    # n cry "O-ohh, Kyou. I don't understand either. But we can't..." with dissolve
    n cry "O-ooh, Kyou. Yo tampoco entiendo. Pero no podemos..." with dissolve

# game/Kyou 8.rpy:1730
translate spanish Day8_Con_Kyou_Nozomi_Reversal_147fe014:

    # n "We can't... k-keep doing this..."
    n "No podemos... s-seguir haciendo esto..."

# game/Kyou 8.rpy:1732
translate spanish Day8_Con_Kyou_Nozomi_Reversal_d1c76b8b:

    # n frightened "I CAN'T DO THIS!" with dissolve
    n frightened "¡NO PUEDO HACER ESTO!" with dissolve

# game/Kyou 8.rpy:1735
translate spanish Day8_Con_Kyou_Nozomi_Reversal_bfe042e0:

    # "Nozomi's cry sends a jolt up my spine, and I almost feel like I've awakened from a long daydream..."
    "El grito de Nozomi envía una sacudida por mi columna, y casi siento como si hubiera desperado de un sueño."

# game/Kyou 8.rpy:1736
translate spanish Day8_Con_Kyou_Nozomi_Reversal_1a1df87d:

    # "... Just in time to register the sight of the penlight leaving her hand as she throws it aside!"
    "... ¡Justo a tiempo para presenciar la linterna abandonando su mano al arrojarla hacia su costado!"

# game/Kyou 8.rpy:1737
translate spanish Day8_Con_Kyou_Nozomi_Reversal_6dca5ac5:

    # ks surprised "N-NOZOMI!"
    ks surprised "¡N-NOZOMI!"

# game/Kyou 8.rpy:1738
translate spanish Day8_Con_Kyou_Nozomi_Reversal_3d78b5a7:

    # "I cry out, but it's far too late."
    "Exclamo, pero es demasiado tarde."

# game/Kyou 8.rpy:1740
translate spanish Day8_Con_Kyou_Nozomi_Reversal_0be17d69:

    # "The school bell rings loud as I helplessly watch the device tumble in the air, off the rooftop and out of sight."
    "La campana de la escuela suena con fuerza, y yo veo impotente cómo el dispositivo gira en el aire, saliendo de la azotea y de mi vista."

# game/Kyou 8.rpy:1741
translate spanish Day8_Con_Kyou_Nozomi_Reversal_fffda018:

    # "That ringing may as well have been a death knell to my ears."
    "Esas campanadas bien podrían ser una sentencia de muerte para mis oídos."

# game/Kyou 8.rpy:1742
translate spanish Day8_Con_Kyou_Nozomi_Reversal_06027255:

    # "The penlight is... it's gone. My gift to her. The only reason we even got together..."
    "La linterna se... ha ido. Mi regalo para ella. La única razón por la que estamos juntos..."

# game/Kyou 8.rpy:1743
translate spanish Day8_Con_Kyou_Nozomi_Reversal_0a8c36ce:

    # ks "Why... oh my god, why?"
    ks "¿Por qué?... Oh, por Dios, ¿por qué?"

# game/Kyou 8.rpy:1744
translate spanish Day8_Con_Kyou_Nozomi_Reversal_d14624e8:

    # "I'll surely never see its light again..."
    "Es seguro que nunca volveré a ver la luz..."

# game/Kyou 8.rpy:1747
translate spanish Day8_Con_Kyou_Nozomi_Reversal_e40fe562:

    # "My eyes fall closed as I let an emptiness envelop me. An emptiness from which it feels there's no escape."
    "Mis ojos se cierran y un vacío que me invade. Un vacío del cual siento que no hay escape."

# game/Kyou 8.rpy:1748
translate spanish Day8_Con_Kyou_Nozomi_Reversal_50639673:

    # "... Until I feel a tender warmth envelop me."
    "... Hasta que siento un tierno calor envolverme."

# game/Kyou 8.rpy:1750
translate spanish Day8_Con_Kyou_Nozomi_Reversal_9b250937:

    # "She's... hugging me."
    "Está... abrazándome."

# game/Kyou 8.rpy:1755
translate spanish Day8_Con_Kyou_Nozomi_Reversal_62992921:

    # n "I'm sorry, Kyou... I'm s-so sorry. For everything..." with dissolve
    n "Lo siento, Kyou... En s-serio lo siento. Por todo..." with dissolve

# game/Kyou 8.rpy:1758
translate spanish Day8_Con_Kyou_Nozomi_Reversal_53e07b0a:

    # n "It's going to be alright... I-it's going to be alright..." with dissolve
    n "Todo estará bien... T-todo estará bien..." with dissolve

# game/Kyou 8.rpy:1791
translate spanish Day8_Con_Kyou_Nozomi_Reversal_29055142:

    # "The rest of the afternoon passed like an uneasy dream."
    "El resto de la tarde transcurrió como un desasosegado sueño."

# game/Kyou 8.rpy:1792
translate spanish Day8_Con_Kyou_Nozomi_Reversal_d7e81dfd:

    # "Nozomi walked me back to class, and I spent the rest of the school day lost in my thoughts about what happened on that rooftop."
    "Nozomi me escoltó de regreso a clase, y yo pasé el resto del día perdido en mis pensamientos sobre lo que pasó en la azotea."

# game/Kyou 8.rpy:1793
translate spanish Day8_Con_Kyou_Nozomi_Reversal_15c2c8d2:

    # "Thinking back to how she enticed me with the prospect of being hypnotized by her penlight again... until she took it away."
    "Pensando en cómo me tentó con la expectativa de ser hipnotizado por su linterna una vez más... hasta que me lo arrebató."

# game/Kyou 8.rpy:1795
translate spanish Day8_Con_Kyou_Nozomi_Reversal_0b2ef04e:

    # "I close my eyes, and I feel like I can almost see the light again..."
    "Cierro los ojos, y siento que casi puedo ver la luz otra vez."

# game/Kyou 8.rpy:1797
translate spanish Day8_Con_Kyou_Nozomi_Reversal_854853cf:

    # "It brings me some small comfort at least..."
    "Eso al menos me trae un poco de consuelo..."

# game/Kyou 8.rpy:1798
translate spanish Day8_Con_Kyou_Nozomi_Reversal_5ab56228:

    # n "Kyou? How are you feeling? Any differently from before?"
    n "¿Kyou? ¿Cómo te sientes? ¿Igual que antes?"

# game/Kyou 8.rpy:1801
translate spanish Day8_Con_Kyou_Nozomi_Reversal_47d817da:

    # "... But as Nozomi wanders into view, I quickly snap myself back to reality."
    "... Pero cuando Nozomi aparece frente a mí, rápidamente regreso a la realidad."

# game/Kyou 8.rpy:1802
translate spanish Day8_Con_Kyou_Nozomi_Reversal_edfbf88a:

    # ks surprised "Uh..."
    ks surprised "Eh..."

# game/Kyou 8.rpy:1803
translate spanish Day8_Con_Kyou_Nozomi_Reversal_89f8833a:

    # "Right. She was talking about doing better for me? That's why she insisted on walking me home as well."
    "Cierto. ¿Estaba hablando de hacer las cosas bien? Por eso también insistió en acompañarme a casa."

# game/Kyou 8.rpy:1804
translate spanish Day8_Con_Kyou_Nozomi_Reversal_5f138e02:

    # ks sigh "I don't know."
    ks sigh "No lo sé."

# game/Kyou 8.rpy:1805
translate spanish Day8_Con_Kyou_Nozomi_Reversal_63d39bfb:

    # n side sad "Well, do you still want me to hypnotize you? Even after everything that's happened?" with dissolve
    n side sad "Bueno, ¿aún quieres que te hipnotice? ¿Incluso después de todo lo que pasó?" with dissolve

# game/Kyou 8.rpy:1806
translate spanish Day8_Con_Kyou_Nozomi_Reversal_f1e8df9a:

    # "She asks, and I find myself helplessly nodding."
    "Pregunta ella, y no puedo evitar asentir."

# game/Kyou 8.rpy:1807
translate spanish Day8_Con_Kyou_Nozomi_Reversal_c91f51c6:

    # ks neutral blush "Yeah..."
    ks neutral blush "Sí..."

# game/Kyou 8.rpy:1808
translate spanish Day8_Con_Kyou_Nozomi_Reversal_8c74c94b:

    # n front2 concerned "And you understand how unnatural it is that you feel this way? After how I've been treating you?" with dissolve
    n front2 concerned "¿Y entiendes lo antinatural que es que te sientas así? ¿Después del trato que te he dado?" with dissolve

# game/Kyou 8.rpy:1809
translate spanish Day8_Con_Kyou_Nozomi_Reversal_4571ed75:

    # "I close my eyes and nod again. It doesn't make any logical sense, but..."
    "Cierro los ojos y vuelvo a asentir. No tiene lógica ni sentido, pero..."

# game/Kyou 8.rpy:1811
translate spanish Day8_Con_Kyou_Nozomi_Reversal_0c8cdc43:

    # ks sleep "That light..."
    ks sleep "Esa luz..."

# game/Kyou 8.rpy:1812
translate spanish Day8_Con_Kyou_Nozomi_Reversal_06398373:

    # "She sighs."
    "Ella suspira."

# game/Kyou 8.rpy:1813
translate spanish Day8_Con_Kyou_Nozomi_Reversal_dc2b622e:

    # n sleeptalk_concerned "Yeah... that light." with dissolve
    n sleeptalk_concerned "Sí... esa luz." with dissolve

# game/Kyou 8.rpy:1814
translate spanish Day8_Con_Kyou_Nozomi_Reversal_71318bf2:

    # n side sad_closed "I still remember how it felt, that one time you used it on me." with dissolve
    n side sad_closed "Aún recuerdo cómo se sintió, la vez que la usaste en mí." with dissolve

# game/Kyou 8.rpy:1815
translate spanish Day8_Con_Kyou_Nozomi_Reversal_a3a4cf3f:

    # n sad_side "I remember how intense it got when the light hit my eyes. And how quickly I found myself slipping away under your words, almost with no effort at all." with dissolve
    n sad_side "Aún recuerdo lo intenso que fue cuando la luz tocó mis ojos. Y lo rápido que me encontré desvaneciéndome bajo tus palabras, casi sin ningún esfuerzo." with dissolve

# game/Kyou 8.rpy:1816
translate spanish Day8_Con_Kyou_Nozomi_Reversal_7d0502b4:

    # n neutral_side "It felt so easy, and right and so... seductive. Like I couldn't have fought to stop myself from dropping into trance even if I tried my very best." with dissolve
    n neutral_side "Se sintió tan fácil, tan bien, tan... seductor. Como si no hubiera podido luchar por evitar caer en trance por más que me hubiese esforzado." with dissolve

# game/Kyou 8.rpy:1818
translate spanish Day8_Con_Kyou_Nozomi_Reversal_b1789df0:

    # n neutral "You only told me to forget a number, but I imagined you could've told me anything you wanted and I would've believed it without a second thought." with dissolve
    n neutral "Solo me dijiste que olvidara un número, pero pareciera que podrías haberme dicho cualquier cosa y lo habría creído sin pensarlo dos veces." with dissolve

# game/Kyou 8.rpy:1820
translate spanish Day8_Con_Kyou_Nozomi_Reversal_5800cd2f:

    # n neutral "You only had me think my name was something else, but I imagined you could've changed anything about me and I would've accepted it without a second thought." with dissolve
    n neutral "Solo me hiciste creer que mi nombre era uno distinto, pero pareciera que podrías haberme dicho cualquier cosa y lo habría creído sin pensarlo dos veces." with dissolve

# game/Kyou 8.rpy:1821
translate spanish Day8_Con_Kyou_Nozomi_Reversal_8def7dbe:

    # n front2 surprised "I-I mean, it's like something out of my wildest fantasies, so it couldn't have possibly been true!" with dissolve
    n front2 surprised "¡D-digo, es como algo salido de mis más locas fantasías, así que no podía ser verdad!" with dissolve

# game/Kyou 8.rpy:1822
translate spanish Day8_Con_Kyou_Nozomi_Reversal_a0558351:

    # n concerned "But I only have to look at you and what I've put you through..." with dissolve
    n concerned "Pero solo me hace falta mirarte a ti y por lo que te he hecho pasar..." with dissolve

# game/Kyou 8.rpy:1823
translate spanish Day8_Con_Kyou_Nozomi_Reversal_06398373_1:

    # "She sighs."
    "Suspira."

# game/Kyou 8.rpy:1824
translate spanish Day8_Con_Kyou_Nozomi_Reversal_734e32d4:

    # n sleeptalk_concerned "I'm going to fix this, Kyou. I swear." with dissolve
    n sleeptalk_concerned "Arreglaré esto, Kyou. Lo juro." with dissolve

# game/Kyou 8.rpy:1825
translate spanish Day8_Con_Kyou_Nozomi_Reversal_4d05d307:

    # "Yeah. There's no doubt in my mind that Nozomi could've done whatever she wanted with me. She proved as much."
    "Sí. No cabe duda en mi mente de que Nozomi me podría haber hecho lo que quisiera. Lo ha demostrado."

# game/Kyou 8.rpy:1826
translate spanish Day8_Con_Kyou_Nozomi_Reversal_4a6e0c4c:

    # "I don't understand it at all but somehow, the penlight I made really had that effect on us."
    "No lo entiendo, pero de algún modo, la pluma linterna que hice realmente tuvo un efecto en nosotros."

# game/Kyou 8.rpy:1827
translate spanish Day8_Con_Kyou_Nozomi_Reversal_4f8c0d42:

    # "There's just one small problem when it comes to fixing all of this..."
    "Solo hay un pequeño problema respecto a arreglar esto..."

# game/Kyou 8.rpy:1829
translate spanish Day8_Con_Kyou_Nozomi_Reversal_04fc30e5:

    # ks neutral noblush "How can you fix this, Nozomi? You threw the penlight over the roof, remember?" with dissolve
    ks neutral noblush "¿Cómo puedes arreglarlo, Nozomi? Arrojaste la linterna del techo, ¿recuerdas?" with dissolve

# game/Kyou 8.rpy:1830
translate spanish Day8_Con_Kyou_Nozomi_Reversal_03d8d728:

    # n side sad_side "Y-yeah, well... it just seemed like the right thing to do, you know?" with dissolve
    n side sad_side "S-sí, bueno... parecía lo correcto, ¿sabes?" with dissolve

# game/Kyou 8.rpy:1831
translate spanish Day8_Con_Kyou_Nozomi_Reversal_a427b50e:

    # n sad "I was only trying to prove that you weren't just playing along with my hypnosis fantasies to please me or something, but the more I was testing you, the more I thought..." with dissolve
    n sad "Solo intentaba comprobar que no estuvieras simplemente siguiendo la corriente a mis fantasías hipnóticas o algo, pero entre más te ponía a prueba, más pensaba..." with dissolve

# game/Kyou 8.rpy:1832
translate spanish Day8_Con_Kyou_Nozomi_Reversal_4a5232d6:

    # n sad_closed blush "W-well, you know what they say. Power corrupts." with dissolve
    n sad_closed blush "B-bueno, ya sabes lo que dicen. El poder corrompe." with dissolve

# game/Kyou 8.rpy:1767
translate spanish Day8_Con_Kyou_Nozomi_Reversal_b0623999:

    # "... Wait, was she seriously thinking about going through with those creepy threats back then?"
    "... Espera, ¿en serio pensaba cumplir todas esas macabras amenazas?"

# game/Kyou 8.rpy:1834
translate spanish Day8_Con_Kyou_Nozomi_Reversal_2eadf9de:

    # n front2 sleeptalk "I couldn't be tempted any more. I just couldn't!" with dissolve
    n front2 sleeptalk "No podía seguir exponiéndome a la tentación. ¡No podía!" with dissolve

# game/Kyou 8.rpy:1835
translate spanish Day8_Con_Kyou_Nozomi_Reversal_18877f70:

    # ks sigh "Right... Yeah, I get that. But still..."
    ks sigh "Claro... Sí, lo entiendo. Pero aún sí..."

# game/Kyou 8.rpy:1836
translate spanish Day8_Con_Kyou_Nozomi_Reversal_de2e1cf9:

    # "I hesitate to say it, but..."
    "Dudo en decirlo, pero..."

# game/Kyou 8.rpy:1838
translate spanish Day8_Con_Kyou_Nozomi_Reversal_0aec7b0b:

    # ks neutral "If the only reason you made me like this is because of the penlight, then how can you possibly help me without it?" with dissolve
    ks neutral "Si solo me pusiste en este estado gracias a la linterna, ¿cómo será posible que me ayudes sin ella?" with dissolve

# game/Kyou 8.rpy:1840
translate spanish Day8_Con_Kyou_Nozomi_Reversal_895721d6:

    # ks "So how..."
    ks "Entonces, ¿cómo...?"

# game/Kyou 8.rpy:1842
translate spanish Day8_Con_Kyou_Nozomi_Reversal_63af28c2:

    # n frown "Kyou, that's enough." with dissolve
    n frown "Kyou, suficiente." with dissolve

# game/Kyou 8.rpy:1843
translate spanish Day8_Con_Kyou_Nozomi_Reversal_ec520775:

    # n front2 frown "You still want to experience hypnosis again, don't you?" with dissolve
    n front2 frown "Aún quieres volver a experimentar la hipnosis, ¿no?" with dissolve

# game/Kyou 8.rpy:1845
translate spanish Day8_Con_Kyou_Nozomi_Reversal_11c8035d:

    # ks "Well... yeah."
    ks "Pues... sí."

# game/Kyou 8.rpy:1846
translate spanish Day8_Con_Kyou_Nozomi_Reversal_a2f1c248:

    # n neutral "It still... excites you, thinking I can hypnotize you, doesn't it? More than anything you can imagine?" with dissolve
    n neutral "Aún te... pone ansioso, pensar que puedo hipnotizarte, ¿no es así?" with dissolve

# game/Kyou 8.rpy:1847
translate spanish Day8_Con_Kyou_Nozomi_Reversal_90620987:

    # ks "O... of course it does. You know it does."
    ks "P-por supuesto que sí. Tú sabes que sí."

# game/Kyou 8.rpy:1849
translate spanish Day8_Con_Kyou_Nozomi_Reversal_64e13739:

    # "Just then, Nozomi starts to smile gently as she pats me delicately on the shoulder." with dissolve
    "Entonces, Nozomi pone su mano delicadamente en mi hombro, sonriendo con gentileza." with dissolve

# game/Kyou 8.rpy:1850
translate spanish Day8_Con_Kyou_Nozomi_Reversal_0eadd551:

    # n "Okay, well... let's use that."
    n "Muy bien, pues... usemos eso."

# game/Kyou 8.rpy:1716
translate spanish Day8_Con_Kyou_Nozomi_Reversal_7e0c18d0:

    # ks confused "What? What do you mean?"
    ks confused "¿Qué? ¿A qué te refieres?"

# game/Kyou 8.rpy:1852
translate spanish Day8_Con_Kyou_Nozomi_Reversal_b80e4320:

    # n "Don't fight those feelings, Kyou. Lean into them."
    n "No luches contra esos sentimientos, Kyou. Déjate llevar por ellos."

# game/Kyou 8.rpy:1853
translate spanish Day8_Con_Kyou_Nozomi_Reversal_168cd06e:

    # ks surprised "N-Nozomi?"
    ks surprised "¿N-Nozomi?"

# game/Kyou 8.rpy:1854
translate spanish Day8_Con_Kyou_Nozomi_Reversal_1a5a8215:

    # n "Why don't you lie down on the couch. There's something I want to try."
    n "¿Por qué no te recuestas en el sofá? Hay algo que quiero intentar."

# game/Kyou 8.rpy:1855
translate spanish Day8_Con_Kyou_Nozomi_Reversal_24846d3b:

    # "She's... she's going to try hypnotizing me again, that much is obvious."
    "Está... está intentando hipnotizarme de nuevo, eso es más que obvio."

# game/Kyou 8.rpy:1858
translate spanish Day8_Con_Kyou_Nozomi_Reversal_d7779dae:

    # "So of course I lie down on my living room couch. I can hardly help myself."
    "Así que desde luego me recuesto en el sofá de mi sala. Apenas puedo resistirme."

# game/Kyou 8.rpy:1861
translate spanish Day8_Con_Kyou_Nozomi_Reversal_73afb04a:

    # "And as I put my feet up on the cushions, I notice Nozomi kneeling down on the floor by my side."
    "Y al subir mis pies a los cojines, noto a Nozomi poniéndose a mi lado sobre sus rodillas."

# game/Kyou 8.rpy:1862
translate spanish Day8_Con_Kyou_Nozomi_Reversal_46e9baf8:

    # n "Yes, the penlight might be gone but... I don't know, I think we have a lot to work with. So let me worry about fixing this mess, okay?"
    n "Sí, la luz se habrá ido, pero... No sé, creo que tenemos mucho con lo que trabajar. Así que déjame a mí preocuparme por arreglar este desastre, ¿sí?"

# game/Kyou 8.rpy:1863
translate spanish Day8_Con_Kyou_Nozomi_Reversal_f0bb1096:

    # "I feel her hand gently resting over mine..."
    "Siento su mano posarse suavemente sobre la mía..."

# game/Kyou 8.rpy:1864
translate spanish Day8_Con_Kyou_Nozomi_Reversal_cf9a4541:

    # n "All you need to do is relax your mind. And I'll take care of the rest."
    n "Solo debes relajar tu mente. Y yo me encargaré del resto."

# game/Kyou 8.rpy:1865
translate spanish Day8_Con_Kyou_Nozomi_Reversal_22b5ce9a:

    # "... And I hear her voice, as alluring to me as ever."
    "... Y escucho su voz, tan cautivadora como siempre."

# game/Kyou 8.rpy:1867
translate spanish Day8_Con_Kyou_Nozomi_Reversal_d8b30f29:

    # n "Can you do that for me?" with dissolve
    n "¿Puedes hacer eso por mí?" with dissolve

# game/Kyou 8.rpy:1868
translate spanish Day8_Con_Kyou_Nozomi_Reversal_0bb8ce8e:

    # "She's being so kindly with me right now. Like she really does want the very best for me."
    "Está siendo tan dulce conmigo. Siento que realmente quiere solo lo mejor para mí."

# game/Kyou 8.rpy:1870
translate spanish Day8_Con_Kyou_Nozomi_Reversal_49b5d91f:

    # ks smile "Yeah. Of course."
    ks smile "Sí. Por supuesto."

# game/Kyou 8.rpy:1871
translate spanish Day8_Con_Kyou_Nozomi_Reversal_b1948c7d:

    # n "Good, so..."
    n "Bien, entonces..."

# game/Kyou 8.rpy:1873
translate spanish Day8_Con_Kyou_Nozomi_Reversal_39533705:

    # "Nozomi pauses to gently clear her throat, like she's steeling herself for what she's about to do." with dissolve
    "Nozomi hace una pausa para aclararse gentilmente la garganta, como si estuviera recolectando confianza para lo que está a punto de hacer." with dissolve

# game/Kyou 8.rpy:1874
translate spanish Day8_Con_Kyou_Nozomi_Reversal_ecbd24bb:

    # "After all, neither of us have tried to hypnotize without the penlight before. We didn't realize before how easy it made things for us."
    "Después de todo, ninguno de nosotros ha intentado hipnotizar sin la linterna antes. Nunca nos dimos cuenta de lo fácil que nos ponía las cosas."

# game/Kyou 8.rpy:1875
translate spanish Day8_Con_Kyou_Nozomi_Reversal_a56f6dce:

    # "Will anything she does now have any effect on me at all?"
    "¿Tendrá algo de lo que haga ahora algún efecto?"

# game/Kyou 8.rpy:1876
translate spanish Day8_Con_Kyou_Nozomi_Reversal_7ecea480:

    # n "So... o-okay, so I'm going to be lifting your arm at a few points during this, just so you know."
    n "Bien... d-de acuerdo, pues voy a levantar tu brazo un par de veces en el transcurso de esto, solo para que sepas."

# game/Kyou 8.rpy:1877
translate spanish Day8_Con_Kyou_Nozomi_Reversal_677520c8:

    # n "And in a moment I'll want you to take a nice deep breath. You'll need to hold it while I count to three, and on three I want you to let it all out, nice and slowly."
    n "Y en un momento, quiero que respires profundo. Deberás sostener el aire mientras cuento hasta tres, y a las tres quiero que lo dejes salir lentamente."

# game/Kyou 8.rpy:1878
translate spanish Day8_Con_Kyou_Nozomi_Reversal_31005771:

    # n "As you breathe out, close your eyes and feel all the tension start to drain out of your body. Does that sound okay to you?"
    n "Al sacar el aire, cierra los ojos y siente cómo la tensión comienza a escapar de tu cuerpo. ¿Suena bien para ti?"

# game/Kyou 8.rpy:1879
translate spanish Day8_Con_Kyou_Nozomi_Reversal_e25750c3:

    # ks neutral "Okay. Sure."
    ks neutral "De acuerdo. Sí."

# game/Kyou 8.rpy:1881
translate spanish Day8_Con_Kyou_Nozomi_Reversal_79954d07:

    # n "Good... Good. This is going to work, Kyou." with dissolve
    n "Bien... Bien. Esto va a funcionar, Kyou." with dissolve

# game/Kyou 8.rpy:1883
translate spanish Day8_Con_Kyou_Nozomi_Reversal_f54c8f03:

    # "But I have to admit, it feels nice lying here with Nozomi beside me all the same."
    "Pero he de admitir, se siente bien estar aquí recostado con Nozomi a mi lado."

# game/Kyou 8.rpy:1885
translate spanish Day8_Con_Kyou_Nozomi_Reversal_f7e9a330:

    # n "Now deep breath. Nice and deep... that's it." with dissolve
    n "Ahora respira hondo. Muy profundo... eso es." with dissolve

# game/Kyou 8.rpy:1886
translate spanish Day8_Con_Kyou_Nozomi_Reversal_0e6bf005:

    # n "And one, two... three."
    n "Y uno, dos... tres."

# game/Kyou 8.rpy:1889
translate spanish Day8_Con_Kyou_Nozomi_Reversal_b11ecf3f:

    # "I let the breath slowly leave my just-filled lungs as I let my eyes fall closed."
    "Libero lentamente el aire de mis pulmones, dejando que mis ojos se cierren."

# game/Kyou 8.rpy:1890
translate spanish Day8_Con_Kyou_Nozomi_Reversal_69522323:

    # n "That's good, Kyou. Now again, eyes open, deep breath."
    n "Muy bien, Kyou. Ahora otra vez, ojos abiertos, respira hondo."

# game/Kyou 8.rpy:1894
translate spanish Day8_Con_Kyou_Nozomi_Reversal_aeca0d7f:

    # "It takes me a little effort to pull my eyelids back as I find Nozomi staring back at me, her face a picture of focused concentration now."
    "Me toma algo de esfuerzo alzar mis párpados, desvelando a Nozomi quien me mira con enfocada concentración pintada en su rostro."

# game/Kyou 8.rpy:1895
translate spanish Day8_Con_Kyou_Nozomi_Reversal_88188c16:

    # n "One... two... three."
    n "Uno... dos... tres."

# game/Kyou 8.rpy:1898
translate spanish Day8_Con_Kyou_Nozomi_Reversal_3b6faec4:

    # n "That's right. Relaxing more deeply now. Feeling every muscle in your body grow more and more loose."
    n "Eso es. Relájate más profundamente. Sintiendo cada músculo de tu cuerpo más y más suelto."

# game/Kyou 8.rpy:1899
translate spanish Day8_Con_Kyou_Nozomi_Reversal_cfeb73b8:

    # n "But none more so than all the little muscles around your eyes."
    n "Pero ninguno tanto como todos los pequeños músculos que hay alrededor de tus ojos."

# game/Kyou 8.rpy:1900
translate spanish Day8_Con_Kyou_Nozomi_Reversal_ad3c634c:

    # n "Take another deep breath, Kyou, but this time pay special attention to those muscles in and around your eyelids."
    n "Respira profundamente de nuevo, Kyou; pero esta vez presta especial atención a esos músculos que rodean tus ojos."

# game/Kyou 8.rpy:1901
translate spanish Day8_Con_Kyou_Nozomi_Reversal_bc26168c:

    # n "Relaxing them so completely in one, two, three."
    n "Completamente relajados en uno, dos, tres."

# game/Kyou 8.rpy:1902
translate spanish Day8_Con_Kyou_Nozomi_Reversal_7bbb0851:

    # n "Your eyelids are so completely relaxed now that you will find that they have become impossible for you to open."
    n "Tus párpados están tan plenamente relajados que notarás que te es imposible abrirlos."

# game/Kyou 8.rpy:1903
translate spanish Day8_Con_Kyou_Nozomi_Reversal_1a42a24a:

    # n "And I want to prove that to you, Kyou. Try now and see if you can open those heavy, relaxed eyelids of yours."
    n "Y quiero demostrártelo, Kyou. Haz el intento y ve si puedes abrir esos pesados y relajados párpados."

# game/Kyou 8.rpy:1904
translate spanish Day8_Con_Kyou_Nozomi_Reversal_32bfb378:

    # "She asks me to try, but I'm not sure I even want to open my eyes again. It feels so nice to stay like this."
    "Me pide que lo intente, pero no sé si siquiera quiero volverlos a abrir. Se siente muy bien estar así."

# game/Kyou 8.rpy:1905
translate spanish Day8_Con_Kyou_Nozomi_Reversal_8e3f4c0b:

    # "But I'll try for her. Just a little bit."
    "Pero lo intentaré por ella. Al menos un poco."

# game/Kyou 8.rpy:1906
translate spanish Day8_Con_Kyou_Nozomi_Reversal_e9ec60ee:

    # "I'll try to lift my eyelids gently, but... huh. They don't seem to budge."
    "Intentaré abrir suavemente mis ojos, pero... ah. No parecen moverse."

# game/Kyou 8.rpy:1773
translate spanish Day8_Con_Kyou_Nozomi_Reversal_d638e572:

    # "Guess I'll need to make a little more effort, at least enough to get my eyes partially open. I can do that much..."
    "Creo que tendré que esforzarme un poco más, al menos tratar de abrirlos parcialmente. Tal vez pueda al menos..."

# game/Kyou 8.rpy:1908
translate spanish Day8_Con_Kyou_Nozomi_Reversal_a711628e:

    # n "Very good, Kyou. You can stop trying now."
    n "Muy bien, Kyou. Ya puedes parar."

# game/Kyou 8.rpy:1909
translate spanish Day8_Con_Kyou_Nozomi_Reversal_0ee8cf47:

    # "But a gentle word from Nozomi is all it takes to dissuade me from trying any harder."
    "Pero solo un par de suaves palabras de Nozomi hacen falta para disuadirme de seguir intentando."

# game/Kyou 8.rpy:1910
translate spanish Day8_Con_Kyou_Nozomi_Reversal_9bd953d1:

    # n "Let that completely relaxed feeling you have around your eyelids spread over your face and down your neck."
    n "Deja que ese sentimiento de completa relajación alrededor de tus ojos se esparza por tu rostro y baje por tu cuello."

# game/Kyou 8.rpy:1911
translate spanish Day8_Con_Kyou_Nozomi_Reversal_263cc5c1:

    # "Maybe I really am becoming hypnotized?"
    "¿Tal vez sí estoy siendo hipnotizado?"

# game/Kyou 8.rpy:1912
translate spanish Day8_Con_Kyou_Nozomi_Reversal_188cf972:

    # n "Feeling it spread further down your body, down your chest and arms... down your waist... spreading further down your legs, all the way down to your feet."
    n "Siente cómo se extiende por todo tu cuerpo, por tu torso y tus brazos... pasando por tu cintura... avanzando por tus piernas hasta llegar a tus pies."

# game/Kyou 8.rpy:1913
translate spanish Day8_Con_Kyou_Nozomi_Reversal_d067e500:

    # "That's a nice thing to think about. I want to believe that's true."
    "Es lindo pensar eso. Quiero creer que es cierto."

# game/Kyou 8.rpy:1914
translate spanish Day8_Con_Kyou_Nozomi_Reversal_ae3e3c6e:

    # n "You're doing so well, Kyou. Now again I'm going to count to three, but this time on three, I want you to open your eyes again."
    n "Lo estás haciendo bien, Kyou. Y nuevamente, contaré hasta tres; pero, esta vez, a las tres quiero que vuelvas a abrir los ojos."

# game/Kyou 8.rpy:1915
translate spanish Day8_Con_Kyou_Nozomi_Reversal_88fbccb7:

    # "So I will. And I'll keep listening to Nozomi's soothing tone of voice as she continues to speak the whole time..."
    "Y eso haré. Y seguiré escuchando la arrulladora voz de Nozomi mientras continúa hablando."

# game/Kyou 8.rpy:1916
translate spanish Day8_Con_Kyou_Nozomi_Reversal_5f65e187:

    # n "It'll be okay to do this, because you'll soon be closing them again."
    n "No te preocupes, pronto volverás a cerrarlos."

# game/Kyou 8.rpy:1917
translate spanish Day8_Con_Kyou_Nozomi_Reversal_a64ef9a0:

    # n "And when you do, you will feel yourself dropping ten times as deep, feeling ten times more relaxed than you are now."
    n "Y cuando lo hagas, sentirás que caes diez veces más profundo, y te sentirás diez veces más relajado que ahora."

# game/Kyou 8.rpy:1918
translate spanish Day8_Con_Kyou_Nozomi_Reversal_100c5622:

    # n "So, opening your eyes on three, closing them again on my say and relaxing ten times as deeply."
    n "Así que, abre los ojos a las tres, para después volverlos a cerrar a mi señal, relajándote diez veces más profundamente."

# game/Kyou 8.rpy:1919
translate spanish Day8_Con_Kyou_Nozomi_Reversal_3ecb190c:

    # n "One, two, three."
    n "Uno, dos, tres."

# game/Kyou 8.rpy:1923
translate spanish Day8_Con_Kyou_Nozomi_Reversal_3b29cfc4:

    # "My eyelids quietly pull themselves open almost by themselves and I'm greeted by the sight of Nozomi once again and, huh?"
    "Mis párpados se elevan casi por su cuenta, y me recibe una vez más la imagen de Nozomi y, ¿eh?"

# game/Kyou 8.rpy:1931
translate spanish Day8_Con_Kyou_Nozomi_Reversal_7d4a8f0e:

    # "{cps=20}I can just make out her hand above my forehead, hovering there as she- {/cps}{w=1.0}{nw}"
    "{cps=20}Noto lo que parece ser su mano sobre mi frente, flotando como- {/cps}{w=1.0}{nw}"

# game/Kyou 8.rpy:1927
translate spanish Day8_Con_Kyou_Nozomi_Reversal_9126b4dc:

    # n "And eyes closed, Kyou. Going deeper."
    n "Y ojos cerrados, Kyou. Más profundo."

# game/Kyou 8.rpy:1928
translate spanish Day8_Con_Kyou_Nozomi_Reversal_c37dddbd:

    # "I dimly register that hand dropping down over my face, as my eyelids instinctively close right along with it."
    "Percibo difusamente esa mano bajando hacia mi rostro, haciendo que mis párpados se cierren instintivamente."

# game/Kyou 8.rpy:1929
translate spanish Day8_Con_Kyou_Nozomi_Reversal_8659181f:

    # n "Ten times deeper. Ten times more relaxed. Very good."
    n "Diez veces más profundo. Diez veces más relajado. Muy bien."

# game/Kyou 8.rpy:1930
translate spanish Day8_Con_Kyou_Nozomi_Reversal_ec9f0e42:

    # "I didn't have to think at all. They just... closed."
    "Ni siquiera tuve que pensarlo. Simplemente... se cerraron."

# game/Kyou 8.rpy:1931
translate spanish Day8_Con_Kyou_Nozomi_Reversal_3cc41b07:

    # n "And again, opening your eyes on one, two... three."
    n "Y una vez más, abre los ojos a la cuenta de uno, dos... tres."

# game/Kyou 8.rpy:1938
translate spanish Day8_Con_Kyou_Nozomi_Reversal_e375e729:

    # n "And closed. Falling ten times deeper. Ten times more relaxed."
    n "Y cierra. Cayendo diez veces más profundo. Diez veces más relajado."

# game/Kyou 8.rpy:1946
translate spanish Day8_Con_Kyou_Nozomi_Reversal_0d2ffbc6:

    # "I didn't do anything. My eyelids felt like they opened by themselves only for a hand to sweep down my face and compel them to shut, more firmly than before."
    "Yo no hice nada. Se sintió como si mis párpados se abrieran por sí solos, solo para que una mano pasara por mi rostro y los obligara a cerrarse, más firmemente que antes."

# game/Kyou 8.rpy:1940
translate spanish Day8_Con_Kyou_Nozomi_Reversal_d067d952:

    # "I... I'm not doing anything now, except to listen."
    "No... no estoy haciendo nada, más que escuchar."

# game/Kyou 8.rpy:1941
translate spanish Day8_Con_Kyou_Nozomi_Reversal_9e33eb64:

    # n "But even as deeply relaxed as you are, you are going to find you can relax even deeper."
    n "Pero, por más profundamente relajado que estés, siempre podrás relajarte más."

# game/Kyou 8.rpy:1942
translate spanish Day8_Con_Kyou_Nozomi_Reversal_243452fe:

    # "Just listening to that gentle voice, as I dimly sense my left wrist being pulled from my lap."
    "Nada más que escuchar esa gentil voz, sintiendo vagamente cómo mi muñeca izquierda es levantada de mi regazo."

# game/Kyou 8.rpy:1943
translate spanish Day8_Con_Kyou_Nozomi_Reversal_651c120b:

    # n "You can feel how limp and heavy your arm is, can't you, Kyou?"
    n "Puedes sentir lo flojito y pesado que está tu brazo, ¿no es así, Kyou?"

# game/Kyou 8.rpy:1944
translate spanish Day8_Con_Kyou_Nozomi_Reversal_aae01662:

    # "My arm... yes, it feels so limp. So heavy."
    "Mi brazo... sí, si siente muy flojo. Muy pesado."

# game/Kyou 8.rpy:1945
translate spanish Day8_Con_Kyou_Nozomi_Reversal_d31b091f:

    # "I can just make out the sensation of my fingertips dragging weakly over my pants."
    "Puedo apenas distinguir la sensación de las yemas de mis dedos arrastrándose débilmente por mis pantalones."

# game/Kyou 8.rpy:1946
translate spanish Day8_Con_Kyou_Nozomi_Reversal_e22da2fc:

    # n "It's alright, Kyou. You don't need to say or do anything. It's fine to let me do all the work for you."
    n "Está bien, no tienes que decir nada. Está bien dejarme hacer todo el trabajo por ti "

# game/Kyou 8.rpy:1947
translate spanish Day8_Con_Kyou_Nozomi_Reversal_ba898726:

    # n "And as I drop your arm back into your lap you find yourself relaxing ten times deeper yet again. In one, two... three."
    n "Y cuando deje tu brazo caer sobre tu regazo, una vez más podrás relajarte diez veces más profundo. En uno, dos..."

# game/Kyou 8.rpy:1949
translate spanish Day8_Con_Kyou_Nozomi_Reversal_58d83418:

    # "My arm... it sinks back down to my lap. But it feels like my entire being just sunk beneath the couch itself."
    "Mi brazo... se desploma de vuelta a mi regazo. Pero siento que todo mi ser se hunde por debajo del mismo sofá."

# game/Kyou 8.rpy:1950
translate spanish Day8_Con_Kyou_Nozomi_Reversal_ff943690:

    # n "Ten times deeper, Kyou. You are doing so well at this. Finding it so good and natural to relax and drop so deeply as you are."
    n "Diez veces más profundo, Kyou. Lo estás haciendo muy bien. Se siente muy bien y muy natural relajarte y caer tan profundamente."

# game/Kyou 8.rpy:1951
translate spanish Day8_Con_Kyou_Nozomi_Reversal_b42bc3be:

    # n "And I'm going to lift your arm again, while you're going to let me do all the work again."
    n "Y ahora levantaré tu brazo de nuevo, y una vez más, permíteme hacer todo el trabajo."

# game/Kyou 8.rpy:1952
translate spanish Day8_Con_Kyou_Nozomi_Reversal_5ec7d2cd:

    # "Once again, I find my hand being slowly risen to hang weakly in the air."
    "Una vez más, mi mano es elevada con cuidado para colgar débilmente en el aire."

# game/Kyou 8.rpy:1953
translate spanish Day8_Con_Kyou_Nozomi_Reversal_370f51f9:

    # "I can't resist."
    "No puedo resistir."

# game/Kyou 8.rpy:1954
translate spanish Day8_Con_Kyou_Nozomi_Reversal_e2bf3bd1:

    # n "No need to do anything. Just allowing yourself to feel how loose and limp you are. How deeply relaxed you are. One, two and..."
    n "No hace falta hacer nada. Tan solo siente lo flojito que estás. Profundamente relajado. Uno, dos y..."

# game/Kyou 8.rpy:1955
translate spanish Day8_Con_Kyou_Nozomi_Reversal_b9b82cbf:

    # "I don't want to resist."
    "No quiero resistir."

# game/Kyou 8.rpy:1956
translate spanish Day8_Con_Kyou_Nozomi_Reversal_b2ea7859:

    # n "Three, ten times deeper still. Your body now fully, completely relaxed."
    n " Tres, otras diez veces más profundo. Tu cuerpo se encuentra totalmente relajado. "

# game/Kyou 8.rpy:1957
translate spanish Day8_Con_Kyou_Nozomi_Reversal_fa81b5d7:

    # n "But your mind can relax even deeper still, and we're going to take care of that now, Kyou."
    n " Pero tu mente se puede relajar todavía más, y nos encargaremos de eso, Kyou."

# game/Kyou 8.rpy:1958
translate spanish Day8_Con_Kyou_Nozomi_Reversal_836ebacd:

    # "I just want to listen."
    "Solo quiero escuchar."

# game/Kyou 8.rpy:1959
translate spanish Day8_Con_Kyou_Nozomi_Reversal_03cd37b0:

    # n "When I tell you to, I want you to count down from one hundred."
    n "Cuando te indique, quiero que cuentes hacia atrás desde el cien."

# game/Kyou 8.rpy:1960
translate spanish Day8_Con_Kyou_Nozomi_Reversal_bd3a23da:

    # n "You will count down, speaking each number aloud as you go, followed by the words \"and deeper still\"."
    n "Contarás, diciendo cada número en voz alta, seguido de las palabras \"y más profundo\"."

# game/Kyou 8.rpy:1961
translate spanish Day8_Con_Kyou_Nozomi_Reversal_b5814c60:

    # n "I will be talking as you do this, but that's okay. You won't need to pay any conscious attention to what I say, just focus on counting down and relaxing your mind."
    n "Estaré hablando mientras cuentas, pero está bien. No hace falta que prestes atención conscientemente a lo que digo, solo concéntrate en contar y en relajar tu mente."

# game/Kyou 8.rpy:1962
translate spanish Day8_Con_Kyou_Nozomi_Reversal_0b17dbe4:

    # n "Relaxing your mind so much that each number becomes harder and harder to recall. And when you find the next number is too hard to remember, it's alright."
    n "Relajando tanto tu mente que cada número se vuelve más y más difícil de recordar. Y cuando el siguiente número te sea demasiado difícil de recordar, no te preocupes."

# game/Kyou 8.rpy:1963
translate spanish Day8_Con_Kyou_Nozomi_Reversal_9b0af45b:

    # n "You can just stop and let all the numbers in your head disappear. Now start counting for me, Kyou."
    n "Puedes simplemente parar y dejar que todos los números en tu cabeza desaparezcan. Ahora cuenta para mí, Kyou."

# game/Kyou 8.rpy:1964
translate spanish Day8_Con_Kyou_Nozomi_Reversal_04fa840d:

    # "Count, she says... from a hundred... okay..."
    "Contar, dice... desde cien... está bien..."

# game/Kyou 8.rpy:1966
translate spanish Day8_Con_Kyou_Nozomi_Reversal_da83b8d3:

    # ks sleep "One-hundred... and deeper still."
    ks sleep "Cien... y más profundo."

# game/Kyou 8.rpy:1967
translate spanish Day8_Con_Kyou_Nozomi_Reversal_139e8236:

    # n "That's perfect, Kyou."
    n "Perfecto, Kyou."

# game/Kyou 8.rpy:1968
translate spanish Day8_Con_Kyou_Nozomi_Reversal_b76d235b:

    # ks "Ninety-nine, and deeper still."
    ks "Noventa y nueve, y más profundo."

# game/Kyou 8.rpy:1969
translate spanish Day8_Con_Kyou_Nozomi_Reversal_165b9c50:

    # n "Your mind relaxing more deeply with every number you count."
    n "Tu mente se relaja más profundo con cada número."

# game/Kyou 8.rpy:1970
translate spanish Day8_Con_Kyou_Nozomi_Reversal_e64a6f0c:

    # ks "Ninety-eight, and deeper still."
    ks "Noventa y ocho, y más profundo."

# game/Kyou 8.rpy:1971
translate spanish Day8_Con_Kyou_Nozomi_Reversal_227cc7f7:

    # n "Finding each number so much harder to recall than the next."
    n "Y cada número es más y más difícil de recordar que el anterior."

# game/Kyou 8.rpy:1972
translate spanish Day8_Con_Kyou_Nozomi_Reversal_e7661435:

    # ks "Ninety-seven, and deeper still."
    ks "Noventa y siete, y más profundo."

# game/Kyou 8.rpy:1973
translate spanish Day8_Con_Kyou_Nozomi_Reversal_dcc10fa6:

    # n "As if the image of every number in your head were fading."
    n "Como si la imagen de cada número se estuviera desvaneciendo en tu cabeza."

# game/Kyou 8.rpy:1974
translate spanish Day8_Con_Kyou_Nozomi_Reversal_411efc0d:

    # ks "Ninety-six, and deeper still."
    ks "Noventa y seis, y más profundo."

# game/Kyou 8.rpy:1975
translate spanish Day8_Con_Kyou_Nozomi_Reversal_f6f220fb:

    # n "And if the numbers are really so hard to recall..."
    n "Y si los números son tan difíciles de recordar..."

# game/Kyou 8.rpy:1976
translate spanish Day8_Con_Kyou_Nozomi_Reversal_a56d3166:

    # ks "Ninety-five, and deeper still."
    ks "Noventa y cinco, y más profundo."

# game/Kyou 8.rpy:1977
translate spanish Day8_Con_Kyou_Nozomi_Reversal_8d319468:

    # n "Maybe it would be best..."
    n "Quizá sería mejor..."

# game/Kyou 8.rpy:1978
translate spanish Day8_Con_Kyou_Nozomi_Reversal_4e24ad5d:

    # ks "Ninety-four, and deeper still."
    ks "Noventa y cuatro, y más profundo."

# game/Kyou 8.rpy:1979
translate spanish Day8_Con_Kyou_Nozomi_Reversal_0160c457:

    # n "To avoid spending all that effort to recall them..."
    n "No gastar tanto esfuerzo recordándolos..."

# game/Kyou 8.rpy:1980
translate spanish Day8_Con_Kyou_Nozomi_Reversal_55ed2fd3:

    # ks "Ninety... ninety-three, and deeper still."
    ks "Noventa... noventa y tres, y más profundo."

# game/Kyou 8.rpy:1981
translate spanish Day8_Con_Kyou_Nozomi_Reversal_fe0cbe9d:

    # n "And just let them spill out of your mind."
    n "Y simplemente dejar que se vayan de tu mente."

# game/Kyou 8.rpy:1982
translate spanish Day8_Con_Kyou_Nozomi_Reversal_18abd3b2:

    # ks "Ninety... two, and deeper still."
    ks "Noventa y... dos, y más profundo."

# game/Kyou 8.rpy:1983
translate spanish Day8_Con_Kyou_Nozomi_Reversal_31ff2951:

    # n "Finding it so easy to just..."
    n "Es muy fácil simplemente..."

# game/Kyou 8.rpy:1984
translate spanish Day8_Con_Kyou_Nozomi_Reversal_057a0651:

    # ks "Nine... Ninety-one... and deeper still."
    ks "Noven-... noventa y uno... y más profundo."

# game/Kyou 8.rpy:1985
translate spanish Day8_Con_Kyou_Nozomi_Reversal_35e8b5f7:

    # n "Let them all..."
    n "Dejar que todos..."

# game/Kyou 8.rpy:1986
translate spanish Day8_Con_Kyou_Nozomi_Reversal_5472818c:

    # ks "Ninety..."
    ks "Noventa..."

# game/Kyou 8.rpy:1987
translate spanish Day8_Con_Kyou_Nozomi_Reversal_5f93cfe3:

    # n "Disappear."
    n "Desaparezcan."

# game/Kyou 8.rpy:1988
translate spanish Day8_Con_Kyou_Nozomi_Reversal_2bc0deaa:

    # ks "Nine..."
    ks "Noven-..."

# game/Kyou 8.rpy:1989
translate spanish Day8_Con_Kyou_Nozomi_Reversal_2ab1df1b:

    # ks "N... nine..."
    ks "N-... noven-..."

# game/Kyou 8.rpy:1992
translate spanish Day8_Con_Kyou_Nozomi_Reversal_f2fe72ce:

    # n "That's enough, Kyou. You can stop counting and let those numbers all fall out of your head. Letting your mind relax so deeply and so completely, just as deeply as your body."
    n "Con eso basta, Kyou. Puedes dejar de contar y dejar que esos números salgan de tu cabeza."

# game/Kyou 8.rpy:1993
translate spanish Day8_Con_Kyou_Nozomi_Reversal_bc38bb40:

    # n "And now that you are so relaxed in both mind and body, you may notice how good it feels to be like this, and that I was the one who brought you to this deep, perfect, relaxed state."
    n "Y ahora que estás tan relajado tanto en mente como en cuerpo, notas lo bien que se siente estar así, y que fui yo quien te trajo a este profundo, perfecto y relajado estado."

# game/Kyou 8.rpy:1994
translate spanish Day8_Con_Kyou_Nozomi_Reversal_c02102a9:

    # n "It feels so good to be hypnotized by Nozomi... doesn't it?"
    n "Se siente muy bien ser hipnotizado por Nozomi... ¿no es así?"

# game/Kyou 8.rpy:1995
translate spanish Day8_Con_Kyou_Nozomi_Reversal_3b5effe7:

    # ks "{size=16}Y... yes...{/size}"
    ks "{size=16}S-... sí...{/size}"

# game/Kyou 8.rpy:1996
translate spanish Day8_Con_Kyou_Nozomi_Reversal_0357ad58:

    # n "Yes, it really does. And I love that you feel that way."
    n "Sí, se siente muy, muy bien. Y adoro que te sientas así."

# game/Kyou 8.rpy:1997
translate spanish Day8_Con_Kyou_Nozomi_Reversal_3a44eb78:

    # n "Hypnosis is supposed to feel good. It's supposed to be fun and... and exciting. It really is an amazing experience."
    n "Se supone que la hipnosis se sienta bien. Se supone que sea divertida... y emocionante. Es verdaderamente una experiencia asombrosa."

# game/Kyou 8.rpy:1998
translate spanish Day8_Con_Kyou_Nozomi_Reversal_2e8d86c1:

    # n "But... Kyou, what I'm about to tell you is extremely important. So I want you to focus as deeply as you can and internalize everything I say."
    n "Pero... Kyou, lo que estoy por decirte es muy importante. Así que quiero que te concentres tan profundamente como puedas e internalices todo lo que diga."

# game/Kyou 8.rpy:1999
translate spanish Day8_Con_Kyou_Nozomi_Reversal_baa3d05b:

    # n "Because what's important is you never have to feel this way. All the suggestions I made to you until now... they're only suggestions."
    n "Porque lo importante es que no tienes nunca que sentirse así. Todas las sugestiones que te di hasta ahora... son solo sugestiones."

# game/Kyou 8.rpy:2000
translate spanish Day8_Con_Kyou_Nozomi_Reversal_b7a26077:

    # n "If you don't want to be hypnotized, if you don't want to follow along to anything I or anyone else were to suggest to you while you're in this deep state of trance..."
    n "Si no quieres ser hipnotizado, si no quieres seguir algo que yo o cualquiera te diga mientras estés en este profundo estado de trance..."

# game/Kyou 8.rpy:2001
translate spanish Day8_Con_Kyou_Nozomi_Reversal_5f8f2f4c:

    # n "... You will always be able to simply do as your heart desires. There is nothing I or anyone else can say to make you do anything you don't truly wish to do."
    n "... Siempre serás capaz de simplemente hacer lo que tu corazón desee. No hay nada que yo ni nadie más pueda decir para obligarte a hacer nada que realmente no desees."

# game/Kyou 8.rpy:2002
translate spanish Day8_Con_Kyou_Nozomi_Reversal_8346a0c3:

    # n "So as you're internalizing all of this, feel your unnatural compulsions to desire hypnosis, to always feel good about being hypnotized by me or anyone else fade away."
    n "Así que, al internalizar todo esto, siente tu impulso antinatural de desear la hipnosis, de siempre sentirte bien al ser hipnotizado por mí o quien sea desvanecerse."

# game/Kyou 8.rpy:2003
translate spanish Day8_Con_Kyou_Nozomi_Reversal_bc8edfd9:

    # n "Letting them all fade away until there's nothing left."
    n "Deja que todo se esfume hasta que no quede nada."

# game/Kyou 8.rpy:2004
translate spanish Day8_Con_Kyou_Nozomi_Reversal_897ba6e1:

    # n "There's only you now, Kyou. Only you and your true, honest desires."
    n "Solo quedas tú, Kyou. Solo tú y tus verdaderos y honestos deseos."

# game/Kyou 8.rpy:2005
translate spanish Day8_Con_Kyou_Nozomi_Reversal_22a51293:

    # n "So now I'm... I'm going to count up slowly to three and snap my fingers."
    n "Así que ahora... contaré lentamente a las tres y chasquearé mis dedos."

# game/Kyou 8.rpy:2006
translate spanish Day8_Con_Kyou_Nozomi_Reversal_3053cbd6:

    # n "And as I do I want you to feel more and more awake, until on the snap of my fingers you'll no longer be hypnotized."
    n "Y cuando lo haga, te sentirás más y más despierto, hasta que al oír mi chasquido ya no estés hipnotizado."

# game/Kyou 8.rpy:2008
translate spanish Day8_Con_Kyou_Nozomi_Reversal_97a489c9:

    # n "Counting up now... one, feeling more aware, more awake."
    n "Despertando poco a poco... en uno, sintiéndote más consciente, más despierto."

# game/Kyou 8.rpy:2009
translate spanish Day8_Con_Kyou_Nozomi_Reversal_ca7eb1e2:

    # n "Two... feeling the life return to your muscles. Your eyes beginning to open, ready to wake up on..."
    n "Dos... sintiendo cómo la vida regresa a tus músculos. Tus párpados comienzan a abrirse, listos para despertar a las..."

# game/Kyou 8.rpy:2014
translate spanish Day8_Con_Kyou_Nozomi_Reversal_7fae66c9:

    # n "Three. Wide awake now, Kyou. Wide awake."
    n "Tres. Abre los ojos, Kyou. Despierta."

# game/Kyou 8.rpy:1899
translate spanish Day8_Con_Kyou_Nozomi_Reversal_092b1e5e:

    # "My eyelids peel back, and it feels like I've just awakened from a dream."
    "Mis párpados se abren y siento que acabo de despertar de un sueño."

# game/Kyou 8.rpy:2016
translate spanish Day8_Con_Kyou_Nozomi_Reversal_18a0018c:

    # "And the first thing I see is her face, looming large in front of me."
    "Y lo primero que veo es su rostro, apareciendo imponente ante mí."

# game/Kyou 8.rpy:2017
translate spanish Day8_Con_Kyou_Nozomi_Reversal_855b82d2:

    # n "So, um... how are you feeling now?"
    n "Pues, em... ¿cómo te sientes ahora?"

# game/Kyou 8.rpy:2018
translate spanish Day8_Con_Kyou_Nozomi_Reversal_aaaa33c7:

    # ks "Mmmn..."
    ks "Mmmn..."

# game/Kyou 8.rpy:2021
translate spanish Day8_Con_Kyou_Nozomi_Reversal_7536be68:

    # n "Don't feel like you have to answer right away. Just take your time." with dissolve
    n "No necesitas responder de inmediato. Tómate tu tiempo." with dissolve

# game/Kyou 8.rpy:2023
translate spanish Day8_Con_Kyou_Nozomi_Reversal_abf6c614:

    # ks smile "I'm... good. Yeah, I feel pretty good actually."
    ks smile "Estoy... bien. Sí, me siento muy bien, de hecho."

# game/Kyou 8.rpy:2024
translate spanish Day8_Con_Kyou_Nozomi_Reversal_7a210297:

    # "She really does care. And it makes me feel everything's going to be just fine."
    "Sí le importo. Y me hace sentir que todo estará bien."

# game/Kyou 8.rpy:2026
translate spanish Day8_Con_Kyou_Nozomi_Reversal_f4e6a288:

    # n "Mhmhmhm~ W-well, that's the main thing." with dissolve
    n "Jejeje. B-bueno, eso es lo importante." with dissolve

# game/Kyou 8.rpy:2027
translate spanish Day8_Con_Kyou_Nozomi_Reversal_c8cdcab1:

    # ks "So... all that just now? Where did you learn how to do hypnosis like that?"
    ks "Y... ¿todo eso? ¿Dónde aprendiste a hipnotizar así?"

# game/Kyou 8.rpy:2029
translate spanish Day8_Con_Kyou_Nozomi_Reversal_e182d09c:

    # n "Oh, um... it's something I picked up in a book I borrowed from the school library." with dissolve
    n "Oh, em... es algo que leí en un libro que tomé prestado de la biblioteca de la escuela." with dissolve

# game/Kyou 8.rpy:2031
translate spanish Day8_Con_Kyou_Nozomi_Reversal_b8f99e32:

    # n "At least, I think that's how it went. The idea is to use several induction methods at once to efficiently induce a deep trance state." with dissolve
    n "Al menos así creo que iba. La idea es utilizar múltiples métodos a la vez para inducir eficientemente un estado de trance profundo." with dissolve

# game/Kyou 8.rpy:2033
translate spanish Day8_Con_Kyou_Nozomi_Reversal_99d1addf:

    # n "Some relaxation, a little fractionation, arm drops... you know, all the good stuff." with dissolve
    n "Un poco de relajación, algo de fraccionamiento, tomar y dejar caer tu brazo... ya sabes, clásico y efectivo." with dissolve

# game/Kyou 8.rpy:2035
translate spanish Day8_Con_Kyou_Nozomi_Reversal_dfc3ad1f:

    # n "And from how you reacted to all of that, it looked like it worked on you pretty well~" with dissolve
    n "Y por como reaccionaste a todo eso, parece que funcionó muy bien en ti." with dissolve

# game/Kyou 8.rpy:2036
translate spanish Day8_Con_Kyou_Nozomi_Reversal_c7d572bd:

    # ks blush "I... y-yeah..."
    ks blush "S-... s-sí..."

# game/Kyou 8.rpy:2038
translate spanish Day8_Con_Kyou_Nozomi_Reversal_60707119:

    # n "So with that said... I'm going to ask you something and I want you to answer me honestly, alright?" with dissolve
    n "Dicho eso... voy a preguntarte algo y quiero que me contestes con honestidad, ¿de acuerdo?" with dissolve

# game/Kyou 8.rpy:2039
translate spanish Day8_Con_Kyou_Nozomi_Reversal_5351717b:

    # n "How would you feel about me hypnotizing you again? Like, right now?"
    n "¿Qué te parecería si yo te hipnotizara otra vez? O sea, ¿ahora mismo?"

# game/Kyou 8.rpy:2040
translate spanish Day8_Con_Kyou_Nozomi_Reversal_44b3bceb:

    # "She waits for my answer as I turn it over in my head."
    "Espera mi respuesta y yo le doy un par de vueltas en mi cabeza."

# game/Kyou 8.rpy:2041
translate spanish Day8_Con_Kyou_Nozomi_Reversal_595c830e:

    # "I'm not going to lie to myself; the thought of her taking me deep again is still enticing as hell."
    "Seré honesto conmigo mismo; la idea de ser arrastrado a lo más profundo por ella aún me es increíblemente tentadora."

# game/Kyou 8.rpy:2042
translate spanish Day8_Con_Kyou_Nozomi_Reversal_384d27e0:

    # "But well, after everything that's happened I feel I can honestly say..."
    "Pero bueno, después de todo lo que pasó, siento que puedo decir con sinceridad que..."

# game/Kyou 8.rpy:2066
translate spanish Day8_Con_Kyou_Nozomi_Reversal_2fcc37ea:

    # ks smile "I... I want you to hypnotize me again, Nozomi."
    ks smile "Qu-... quiero que me hipnotices otra vez, Nozomi."

# game/Kyou 8.rpy:2071
translate spanish Day8_Con_Kyou_Nozomi_Reversal_057fba94:

    # n "Urrrgh..."
    n "Ayyyy..."

# game/Kyou 8.rpy:2072
translate spanish Day8_Con_Kyou_Nozomi_Reversal_28f6680f:

    # ks "Seriously. You've got great technique, and your voice is so angelic to listen to when you're talking like a hypnotist."
    ks "En serio. Tienes una gran técnica, y tu voz es angelical cuando hablas como hipnotista."

# game/Kyou 8.rpy:2073
translate spanish Day8_Con_Kyou_Nozomi_Reversal_e236135f:

    # ks "I bet you could draw anyone in with a voice like that."
    ks "Apuesto a que podrías atrapar a cualquiera con una voz así."

# game/Kyou 8.rpy:2075
translate spanish Day8_Con_Kyou_Nozomi_Reversal_7e59611a:

    # "Nozomi lets out a resigned sigh."
    "Nozomi suelta un resignado suspiro."

# game/Kyou 8.rpy:2077
translate spanish Day8_Con_Kyou_Nozomi_Reversal_a6fd276f:

    # n "I... I'm sorry, Kyou. I tried my best, I really did." with dissolve
    n "Lo... lo siento, Kyou. Hice lo mejor que pude, de verdad." with dissolve

# game/Kyou 8.rpy:2009
translate spanish Day8_Con_Kyou_Nozomi_Reversal_09a493d0:

    # ks confused noblush "Nozomi?"
    ks confused noblush "¿Nozomi?"

# game/Kyou 8.rpy:1984
translate spanish Day8_Con_Kyou_Nozomi_Reversal_1953ee0c:

    # n "I thought if I could just tap into your existing hyper-suggestibility and place you under hypnosis again I could use it to pull that same suggestibility out of your mind." with dissolve
    n "Creí que si podía simplemente apelar a tu existente hiper-sugestionabilidad y ponerte de nuevo en hipnosis podría usarla para sacar la misma de tu mente." with dissolve

# game/Kyou 8.rpy:2081
translate spanish Day8_Con_Kyou_Nozomi_Reversal_57338f2b:

    # n "But I was wrong, and I don't know what else to do..." with dissolve
    n "Pero me equivoqué, y ya no sé qué más hacer..." with dissolve

# game/Kyou 8.rpy:2082
translate spanish Day8_Con_Kyou_Nozomi_Reversal_91e0c61e:

    # ks "Er... Nozomi?"
    ks "Em... ¿Nozomi?"

# game/Kyou 8.rpy:2084
translate spanish Day8_Con_Kyou_Nozomi_Reversal_fe0b72a5:

    # n "M-maybe we should see about getting you in touch with a real hypnotherapist? I could make some calls." with dissolve
    n "¿T-tal vez podamos ponerte en contacto con un verdadero hipnoterapeuta? Podría hacer algunas llamadas." with dissolve

# game/Kyou 8.rpy:2085
translate spanish Day8_Con_Kyou_Nozomi_Reversal_9f450600:

    # ks surprised "Hey Nozomi, hold up!"
    ks surprised "¡Hey, Nozomi, espera!"

# game/Kyou 8.rpy:2087
translate spanish Day8_Con_Kyou_Nozomi_Reversal_6bf26c5a:

    # n "No, it's okay. I swore to you that I'd fix this." with dissolve
    n "No, está bien. Te juré que arreglaría esto." with dissolve

# game/Kyou 8.rpy:2089
translate spanish Day8_Con_Kyou_Nozomi_Reversal_fd280919:

    # n "{cps=20}And I'm going to do whatever it takes, so-{/cps}{w=1.0}{nw}" with dissolve
    n "{cps=20}Y pienso hacer lo que sea necesario, así que-{/cps}{w=1.0}{nw}" with dissolve

# game/Kyou 8.rpy:2090
translate spanish Day8_Con_Kyou_Nozomi_Reversal_d5248589:

    # ks smile "I know. But you don't have to do anything."
    ks smile "Lo sé. Pero no tienes que hacer nada."

# game/Kyou 8.rpy:2092
translate spanish Day8_Con_Kyou_Nozomi_Reversal_60e79c56:

    # n "Kyou, you're not in your right mind. We need to fix this." with dissolve
    n "Kyou, no estás en pleno uso de tus facultades. Necesitamos arreglar esto." with dissolve

# game/Kyou 8.rpy:2093
translate spanish Day8_Con_Kyou_Nozomi_Reversal_9004d418:

    # ks "Nozomi, I was kidding. I think we've both had enough of hypnosis for a while, don't you?"
    ks "Nozomi, estaba bromeando. Me parece que ambos tuvimos suficiente hipnosis por un tiempo, ¿no crees?"

# game/Kyou 8.rpy:2095
translate spanish Day8_Con_Kyou_Nozomi_Reversal_9f546ffd:

    # n "You... huh?!" with dissolve
    n "Tú... ¡¿eh?!" with dissolve

# game/Kyou 8.rpy:2096
translate spanish Day8_Con_Kyou_Nozomi_Reversal_e502fbdc:

    # ks smile noblush "Seriously, my head's clear. I'm fine."
    ks smile noblush "En serio, mi cabeza está limpia. Estoy bien."

# game/Kyou 8.rpy:2098
translate spanish Day8_Con_Kyou_Nozomi_Reversal_64e139bc:

    # n "... S-so you're cured. You're telling me you're cured?"
    n "... O-o sea que estás curado. ¿Dices que estás curado?"

# game/Kyou 8.rpy:2099
translate spanish Day8_Con_Kyou_Nozomi_Reversal_aa0a9ce9:

    # "I grin as I give her an affirming nod."
    "Sonrío y afirmo con la cabeza."

# game/Kyou 8.rpy:2100
translate spanish Day8_Con_Kyou_Nozomi_Reversal_122703ed:

    # ks "I guess it's too early to say for sure but... yeah, I don't think I'm under any kind of influence now."
    ks "Supongo que es temprano para estar seguros, pero... sí, no creo estar bajo ninguna clase de influencia."

# game/Kyou 8.rpy:2101
translate spanish Day8_Con_Kyou_Nozomi_Reversal_eb596ab7:

    # n "Y-you..."
    n "T-tú..."

# game/Kyou 8.rpy:2103
translate spanish Day8_Con_Kyou_Nozomi_Reversal_dd7bec45:

    # n "Urrrgh, why did you have to scare me like that!?" with dissolve
    n "¡Aaaay, ¿por qué me asustas así?!" with dissolve

# game/Kyou 8.rpy:2104
translate spanish Day8_Con_Kyou_Nozomi_Reversal_3a2aed1d:

    # n "Honestly, of all the things to joke about. I've been terrified out of my wits for both of us and the least you could do is take this seriously!"
    n "¿No se te ocurrió un tema peor para bromear?. ¡Llevo toda la tarde angustiadísima por ambos y lo menos que puedes hacer es tomártelo en serio!"

# game/Kyou 8.rpy:2105
translate spanish Day8_Con_Kyou_Nozomi_Reversal_37c5311e:

    # ks happy "Hahaha, w-well, I thought it was about time I messed with your head for a change."
    ks happy "Jajaja, b-bueno, creí que podría ser yo quien jugara con tu cabeza una vez para variar."

# game/Kyou 8.rpy:2038
translate spanish Day8_Con_Kyou_Nozomi_Reversal_1f8066b8:

    # n "Oh my God, you big jerk! Why did I even bother?" with dissolve
    n "Oh, por Dios, eres un cretino, ¿para qué me molesto?" with dissolve

# game/Kyou 8.rpy:2109
translate spanish Day8_Con_Kyou_Nozomi_Reversal_b36b5344:

    # n "... I-I'm just glad you're okay." with dissolve
    n "... S-solo me alegro de que estés bien." with dissolve

# game/Kyou 8.rpy:2110
translate spanish Day8_Con_Kyou_Nozomi_Reversal_48e7d66f:

    # ks smile "Yeah me too, Nozomi."
    ks smile "Sí, yo también, Nozomi."

# game/Kyou 8.rpy:2111
translate spanish Day8_Con_Kyou_Nozomi_Reversal_66124837:

    # ks "But... well, I'm just going to say it."
    ks "Pero... bueno, voy a decirlo."

# game/Kyou 8.rpy:2113
translate spanish Day8_Con_Kyou_Nozomi_Reversal_98b8a7b2:

    # n "Hm?" with dissolve
    n "¿Mm?" with dissolve

# game/Kyou 8.rpy:2114
translate spanish Day8_Con_Kyou_Nozomi_Reversal_19d01768:

    # ks "You really are a good hypnotist, Nozomi. I wasn't kidding about that."
    ks "En serio eres una muy buena hipnotista, Nozomi. En eso no estaba bromeando."

# game/Kyou 8.rpy:2130
translate spanish Day8_Con_Kyou_Nozomi_Reversal_26037af7:

    # ks smile noblush "I think we've both had enough of hypnosis for a while, don't you?"
    ks smile noblush "Me parece que ambos tuvimos suficiente hipnosis por un tiempo, ¿no crees?"

# game/Kyou 8.rpy:2132
translate spanish Day8_Con_Kyou_Nozomi_Reversal_2026350e:

    # "The moment I say that, Nozomi sighs with visible relief." with dissolve
    "Tan pronto digo eso, Nozomi suspira aliviada." with dissolve

# game/Kyou 8.rpy:2133
translate spanish Day8_Con_Kyou_Nozomi_Reversal_e8d4c180:

    # n "Oh, thank goodness."
    n "Oh, gracias al cielo."

# game/Kyou 8.rpy:1942
translate spanish Day8_Con_Kyou_Nozomi_Reversal_e713f1a9:

    # n "I thought if I could just tap into your existing hyper-suggestibility and place you under hypnosis again I could use it to pull that same suggestibility out of your mind."
    n "Creí que si podía simplemente apelar a tu existente hiper-sugestionabilidad y ponerte de nuevo en hipnosis podría usarla para sacar la misma de tu mente."

# game/Kyou 8.rpy:2137
translate spanish Day8_Con_Kyou_Nozomi_Reversal_edc00431:

    # n "So you really are feeling better now, Kyou? You're feeling clear-headed?" with dissolve
    n "Entonces, ¿de verdad te sientes mejor ahora, Kyou. ¿Sientes la mente clara?" with dissolve

# game/Kyou 8.rpy:2138
translate spanish Day8_Con_Kyou_Nozomi_Reversal_86a20e58:

    # "I give her an affirming nod."
    "Afirmo con la cabeza."

# game/Kyou 8.rpy:2139
translate spanish Day8_Con_Kyou_Nozomi_Reversal_e877b27c:

    # ks "Maybe it's too early to say for sure but yeah, it doesn't feel like I'm under any kind of influence now."
    ks "Tal vez sea temprano para estar seguros, pero no siento que esté bajo ninguna influencia ahora."

# game/Kyou 8.rpy:2140
translate spanish Day8_Con_Kyou_Nozomi_Reversal_45210c8e:

    # ks "I just feel really relaxed after that hypnosis session you just pulled."
    ks "Tan solo relajado después de esa sesión que acabas de hacer."

# game/Kyou 8.rpy:2142
translate spanish Day8_Con_Kyou_Nozomi_Reversal_f61b2b06:

    # n "That's good. That really is good." with dissolve
    n "Qué bueno. En serio, qué bueno." with dissolve

# game/Kyou 8.rpy:2144
translate spanish Day8_Con_Kyou_Nozomi_Reversal_19656fda:

    # n "It's how hypnosis is supposed to feel." with dissolve
    n "Así es como se supone que se sienta la hipnosis." with dissolve

# game/Kyou 8.rpy:2145
translate spanish Day8_Con_Kyou_Nozomi_Reversal_00af7257_1:

    # ks "Yeah..."
    ks "Sí..."

# game/Kyou 8.rpy:2146
translate spanish Day8_Con_Kyou_Nozomi_Reversal_f4863dcc:

    # "And I hesitate to say it, but..."
    "Y dudo en decirlo, pero..."

# game/Kyou 8.rpy:2147
translate spanish Day8_Con_Kyou_Nozomi_Reversal_9e98a8ee:

    # ks "You really are a good hypnotist when it comes down to it, Nozomi."
    ks "Sí que eres una buena hipnotista al final del día."

# game/Kyou 8.rpy:2149
translate spanish Day8_Con_Kyou_Nozomi_Reversal_83c8a53c:

    # n "H-huh?" with dissolve
    n "¿E-eh?" with dissolve

# game/Kyou 8.rpy:2150
translate spanish Day8_Con_Kyou_Nozomi_Reversal_7e29daab:

    # ks "I mean sure, you made some mistakes, but that penlight was something else wasn't it?"
    ks "Digo, claro, cometiste algunos errores, pero esa linterna sí que era una locura, ¿no?"

# game/Kyou 8.rpy:2151
translate spanish Day8_Con_Kyou_Nozomi_Reversal_2c4ceb35:

    # ks "So I get that we've probably both had enough of hypnosis for a while."
    ks "Sé que ambos tuvimos suficiente hipnosis por un tiempo."

# game/Kyou 8.rpy:2152
translate spanish Day8_Con_Kyou_Nozomi_Reversal_8c5c666e:

    # ks "But maybe, uh... after all of this is over..."
    ks "Pero tal vez, eh... cuando todo esto haya terminado..."

# game/Kyou 8.rpy:2155
translate spanish Day8_Con_Kyou_Nozomi_Reversal_fd21f401:

    # n "Oh, Kyou..." with dissolve
    n "Oh, Kyou..." with dissolve

# game/Kyou 8.rpy:2156
translate spanish Day8_Con_Kyou_Nozomi_Reversal_65dd5f4f:

    # ks "Next time there won't be a penlight, and you could use everything you've learned."
    ks "La próxima ocasión no habrá linterna, y podrás usar todo lo que aprendiste."

# game/Kyou 8.rpy:2158
translate spanish Day8_Con_Kyou_Nozomi_Reversal_28a69d51:

    # ks "Just promise me you'll think about it, okay?" with dissolve
    ks "Solo prométeme que lo pensarás, ¿sí?" with dissolve

# game/Kyou 8.rpy:2159
translate spanish Day8_Con_Kyou_Nozomi_Reversal_85224205:

    # "Nozomi lets the moment linger, before a smile begins to form on her face."
    "Nozomi deja que el momento se prolongue, y entonces una sonrisa se dibuja en su rostro."

# game/Kyou 8.rpy:2161
translate spanish Day8_Con_Kyou_Nozomi_Reversal_93c277f0:

    # n "Well... on that note, I should get going." with dissolve
    n "Bueno... de momento, tengo que irme." with dissolve

# game/Kyou 8.rpy:2168
translate spanish Day8_Con_Kyou_Nozomi_Reversal_d7c416b1:

    # "Huh? After all that she's just going to leave me?"
    "¿Eh? ¿Después de todo eso simplemente se irá?"

# game/Kyou 8.rpy:2170
translate spanish Day8_Con_Kyou_Nozomi_Reversal_9e82e043:

    # n smile_side "I wouldn't say wrong, but... I want to live up to what you said." with dissolve
    n smile_side "No diría que algo malo, pero... quiero estar a la altura de lo que dijiste." with dissolve

# game/Kyou 8.rpy:2171
translate spanish Day8_Con_Kyou_Nozomi_Reversal_1f3614db:

    # n front2 smile "You're not the only person I need to work on, Kyou." with dissolve
    n front2 smile "No eres la única persona en la que debo trabajar, Kyou." with dissolve

# game/Kyou 8.rpy:2172
translate spanish Day8_Con_Kyou_Nozomi_Reversal_488d1ea4:

    # n chuckle "And a good hypnotist always cleans up after herself..." with dissolve
    n chuckle "Y una buena hipnotista siempre limpia su desorden..." with dissolve

translate spanish strings:

    # game/Kyou 8.rpy:1703
    old "It feels so good to be hypnotized by Nozomi"
    new "Se siente muy bien ser hipnotizado por Nozomi"

    # game/Kyou 8.rpy:2064
    old "I'd want that very much"
    new "Eso me gustaría mucho"

    # game/Kyou 8.rpy:2064
    old "I'll pass"
    new "Yo paso"
