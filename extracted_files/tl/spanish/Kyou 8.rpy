    ks confused "S-sí... es cierto."

# game/Kyou 8.rpy:2790
translate spanish Day8_Redemption_Spiral_08c7c3fa:

    # a "But now I have people who aren't even our classmates telling me I shouldn't have escalated things. That it's all my fault."
    a "Pero ahora hay gente que ni siquiera es de nuestra clase diciéndome que no debí haber hecho escalar las cosas. Que es todo culpa mía."

# game/Kyou 8.rpy:2791
