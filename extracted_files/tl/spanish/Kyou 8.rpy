    # "I just hope Hiroko can heal too..."
    "Solo espero que Hiroko pueda sanar también..."

# game/Kyou 8.rpy:3438
translate spanish Day8_TennisBot_b0ed41e9:

    # "No one around these parts, that's for sure."
