    # "Get this week done, one day a time..."
    " Terminar con esta semana, un día a la vez..."

# game/Kyou 8.rpy:2600
translate spanish Day8_Redemption_Spiral_771e676f:

    # r "Where the hell do you get off?"
    r "¿Y tú cómo diablos te saliste con la tuya?"

# game/Kyou 8.rpy:2601
translate spanish Day8_Redemption_Spiral_225e2c54:

    # "But the moment I walk in, I get Risa talking to me?"
    "Pero en cuanto entro, ¿Risa empieza a hablarme?"

# game/Kyou 8.rpy:4050
translate spanish Day8_Redemption_Spiral_6dec1ae1:

    # a uniform confused_side "R-Risa? What's going on?" with dissolve
    a uniform confused_side "¿R-Risa? ¿Qué ocurre?" with dissolve

