    # "She's never going to heal until I'm gone."
    "Nunca sanará hasta que me vaya."

# game/Kyou 8.rpy:3450
translate spanish Day8_TennisBot_b0dfcc26:

    # "And when I'm out of there... maybe I can heal myself too..."
    "Y cuando salga de ahí... tal vez yo también pueda sanar..."
