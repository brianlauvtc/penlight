    # "I halt in my tracks as Nozomi calls from behind."
    "Me detengo al oír a Nozomi llamarme por detrás."

# game/Kyou 8.rpy:323
translate spanish Day8_Con_Kyou_Sayori_Alter_fbbd610a:

    # n "You're going home, right?"
    n "Te irás a casa, ¿verdad?"

# game/Kyou 8.rpy:269
translate spanish Day8_Con_Kyou_Sayori_Alter_5719a656:

    # ks confused "Uh... yeah. I don't have anything to do until [alt_name]'s ready for me."
    ks confused "Eh... sí. No tengo nada que hacer hasta que [alt_name] esté lista."

# game/Kyou 8.rpy:270
translate spanish Day8_Con_Kyou_Sayori_Alter_488a59fb:

    # ks "... Why?"
    ks "... ¿Por qué"

# game/Kyou 8.rpy:328
translate spanish Day8_Con_Kyou_Sayori_Alter_a1959b44:

    # n front2 "Could I walk home with you?" with dissolve
    n front2 "¿Puedo caminar a casa contigo?" with dissolve

# game/Kyou 8.rpy:327
translate spanish Day8_Con_Kyou_Sayori_Alter_2a64cffe:

    # "I'm a little taken aback by that. But then I understand."
    "Eso me toma un poco por sorpresa. Pero luego entiendo."

# game/Kyou 8.rpy:328
translate spanish Day8_Con_Kyou_Sayori_Alter_1efe6042:

    # ks "S-sure. Let's go."
    ks "C-claro. Vamos."

# game/Kyou 8.rpy:330
translate spanish Day8_Con_Kyou_Sayori_Alter_b1debec8:

    # "As we pass the school gates and set off towards my home, Nozomi follows behind in silence."
    "Paso por las puertas de la escuela y camino en dirección a mi casa con Nozomi siguiéndome en silencio."

# game/Kyou 8.rpy:331
translate spanish Day8_Con_Kyou_Sayori_Alter_f3bb75a2:

    # "I feel like I should say something, but my stomach's in knots as I feel her eyes on me."
    "Tengo la sensación de que debería decir algo, pero mi estómago está hecho un nudo al sentir sus ojos sobre mí."

# game/Kyou 8.rpy:333
translate spanish Day8_Con_Kyou_Sayori_Alter_76a7fa19:

    # "And what's there even to say, anyway?"
    "Además, ¿qué podría decir?"

# game/Kyou 8.rpy:284
translate spanish Day8_Con_Kyou_Sayori_Alter_12bb05c0:

    # "As I swing the door open to my house, Nozomi lets herself in before letting out an anxious-sounding sigh and starts pacing around my living room."
    "Abro la puerta de mi casa y dejo entrar a Nozomi quien, acto seguido, suelta un suspiro lleno de ansiedad y comienza a caminar de un lado a otro por la sala."

# game/Kyou 8.rpy:340
translate spanish Day8_Con_Kyou_Sayori_Alter_78ee5508:

    # ks sigh "Can I... er, get you anything?"
    ks sigh "Puedo... em, ¿servirte algo?"

# game/Kyou 8.rpy:344
translate spanish Day8_Con_Kyou_Sayori_Alter_dc70763f:

    # n "W-we need to figure out what to say to her, don't we?"
    n "T-tenemos que pensar en qué decirle, ¿no?"

# game/Kyou 8.rpy:287
translate spanish Day8_Con_Kyou_Sayori_Alter_9fc07e99:

    # ks confused "We do?"
    ks confused "¿En serio?"

# game/Kyou 8.rpy:348
translate spanish Day8_Con_Kyou_Sayori_Alter_216ff415:

    # n front shocked "Of course we do!" with dissolve
    n front shocked "¡Por supuesto que sí!" with dissolve

# game/Kyou 8.rpy:349
translate spanish Day8_Con_Kyou_Sayori_Alter_c9212248:

    # n front2 surprised "Kyou, weren't you listening at all? Sayori isn't going to drop her [alt_name] persona quietly." with dissolve
    n front2 surprised "Kyou, ¿no estabas escuchando? Sayori no dejará ir su personalidad de [alt_name] así nada más." with dissolve

# game/Kyou 8.rpy:348
translate spanish Day8_Con_Kyou_Sayori_Alter_1c2da798:

    # n concerned "So you at least need to play along when she tries to negotiate with you." with dissolve
    n concerned "Por lo menos tienes que seguirle la corriente cuando intente negociar contigo." with dissolve

# game/Kyou 8.rpy:349
translate spanish Day8_Con_Kyou_Sayori_Alter_9de221de:

    # ks "Huh? P-play along?"
    ks "¿Eh? ¿S-seguirle la corriente?"

# game/Kyou 8.rpy:352
translate spanish Day8_Con_Kyou_Sayori_Alter_7492ba09:

    # n frown "Kyou, you don't really think \"[alt_name]\" is actually another person, do you?" with dissolve
    n frown "Kyou, no creerás de verdad que \"[alt_name] \" es otra persona, ¿o sí?" with dissolve

# game/Kyou 8.rpy:351
translate spanish Day8_Con_Kyou_Sayori_Alter_e1231249:

    # ks "Well..."
    ks "Pues..."

# game/Kyou 8.rpy:352
translate spanish Day8_Con_Kyou_Sayori_Alter_46ec4e81:

    # "Nozomi starts to pace around again as I turn her words over in my head."
    "Nozomi se pone a dar vueltas otra vez mientras yo les doy vueltas a sus palabras en mi cabeza."

# game/Kyou 8.rpy:353
translate spanish Day8_Con_Kyou_Sayori_Alter_2047bda7:

    # n side sad_side "She's... she's just playing out the role you gave her." with dissolve
    n side sad_side "Solo... solo está interpretando el papel que le diste." with dissolve

# game/Kyou 8.rpy:356
translate spanish Day8_Con_Kyou_Sayori_Alter_7fb29037:

    # n frown_side "If you can just convince her to go back into trance so you can bring her out of it, she'll be fine." with dissolve
    n frown_side "Si la logras convencer de ponerla en trance de nuevo, podrás despertarla y estará bien." with dissolve

# game/Kyou 8.rpy:357
translate spanish Day8_Con_Kyou_Sayori_Alter_a3e03f0b:

    # n neutral_side "So... you should just tell her whatever she needs to hear, then while she's under you can undo whatever you told her to put her in this state in the first place." with dissolve
    n neutral_side "Así que... deberías decirle lo que sea que necesite oír y luego, cuando esté hipnotizada, puedes deshacer lo que sea que le dijiste para ponerla en ese estado en primer lugar." with dissolve

# game/Kyou 8.rpy:356
translate spanish Day8_Con_Kyou_Sayori_Alter_8593bc72:

    # ks "... You really don't think [alt_name] is... is..."
    ks "... Entonces no crees que [alt_name] sea... sea..."

# game/Kyou 8.rpy:357
translate spanish Day8_Con_Kyou_Sayori_Alter_7f0f014c:

    # n front surprised "What? No, of course not!" with dissolve
    n front surprised "¿Qué? ¡Claro que no!" with dissolve

# game/Kyou 8.rpy:358
translate spanish Day8_Con_Kyou_Sayori_Alter_06429b29:

    # n concerned "... Do you?" with dissolve
    n concerned "... ¿Tú sí?" with dissolve

# game/Kyou 8.rpy:359
translate spanish Day8_Con_Kyou_Sayori_Alter_5bb218f8:

    # "Nozomi takes my silence with concern on her face as she continues."
    "Mi silencio impregna de preocupación el rostro de Nozomi y continúa."

# game/Kyou 8.rpy:360
translate spanish Day8_Con_Kyou_Sayori_Alter_550e2837:

    # n frown "Kyou, \"[alt_name]\" is just a construct in Sayori's mind." with dissolve
    n frown "Kyou, \"[alt_name] \" no es más que una construcción de la mente de Sayori." with dissolve

# game/Kyou 8.rpy:363
translate spanish Day8_Con_Kyou_Sayori_Alter_8886ad15:

    # n side frown_side "She's... She's not a real, separate entity. She can't be." with dissolve
    n side frown_side "Ella... no es una entidad independiente de verdad. No puede serlo." with dissolve

# game/Kyou 8.rpy:364
translate spanish Day8_Con_Kyou_Sayori_Alter_c7cbb551:

    # n frown "She's like... I mean, the very fact that you could remove the suggestion to \"Be [alt_name]\" from Sayori's head just like that?" with dissolve
    n frown "Es como... o sea, ¿el hecho de que puedas remover la sugestión de \"ser [alt_name] \" de la cabeza de Sayori en un santiamén?" with dissolve

# game/Kyou 8.rpy:365
translate spanish Day8_Con_Kyou_Sayori_Alter_e2b7d764:

    # n sad_side "I think if you can do that, it'll prove it was just Sayori acting out a persona all along. That there's nothing deeper going on than that." with dissolve
    n sad_side "Creo que, si puedes hacer eso, probará que Sayori solo estaba interpretando a un personaje. No tiene más profundidad." with dissolve

# game/Kyou 8.rpy:306
translate spanish Day8_Con_Kyou_Sayori_Alter_ac4b321f:

    # ks sad "Right..."
    ks sad "Claro..."

# game/Kyou 8.rpy:365
translate spanish Day8_Con_Kyou_Sayori_Alter_3e8c23d1:

    # n side frown "You don't think so?" with dissolve
    n side frown "¿No lo crees?" with dissolve

# game/Kyou 8.rpy:366
translate spanish Day8_Con_Kyou_Sayori_Alter_3ef6f381:

    # ks sigh "I..."
    ks sigh "Este..."

# game/Kyou 8.rpy:367
translate spanish Day8_Con_Kyou_Sayori_Alter_6c79a30e:

    # "I mean, I've spent the last few days with [alt_name] and she seemed pretty real to me."
    "Bueno, pasé estos últimos días con [alt_name] y a mí me parece bastante real."

# game/Kyou 8.rpy:368
translate spanish Day8_Con_Kyou_Sayori_Alter_e370d4c5:

    # "But before I can think on it further, Nozomi grabs my sleeves as her eyes glisten."
    "Pero antes de que pueda seguir pensándolo, Nozomi me toma de las mangas y sus ojos se ponen vidriosos."

# game/Kyou 8.rpy:371
translate spanish Day8_Con_Kyou_Sayori_Alter_2ded966a:

    # n front2 cry "Just bring her back to normal, Kyou. I'm begging you!" with dissolve
    n front2 cry "Solo regrésala a la normalidad, Kyou. ¡Te lo ruego!" with dissolve

# game/Kyou 8.rpy:370
translate spanish Day8_Con_Kyou_Sayori_Alter_dbe0d0f7:

    # n "I know we haven't been on the best of terms lately. Or... or ever."
    n "Sé que no hemos estado en los mejores términos últimamente. O... o nunca."

# game/Kyou 8.rpy:371
translate spanish Day8_Con_Kyou_Sayori_Alter_dfb4c499:

    # n frightened "But... But you have to bring Sayori back to how she was! You HAVE to!" with dissolve
    n frightened "Pero... ¡Pero tienes que hacer que Sayori vuelva a ser como era! ¡TIENES que hacerlo!" with dissolve

# game/Kyou 8.rpy:372
translate spanish Day8_Con_Kyou_Sayori_Alter_82a450c9:

    # ks surprised "A-alright."
    ks surprised "E-está bien."

# game/Kyou 8.rpy:373
translate spanish Day8_Con_Kyou_Sayori_Alter_6950a997:

    # "It's all I can do to answer her like that."
    "Apenas soy capaz de responder."

# game/Kyou 8.rpy:374
translate spanish Day8_Con_Kyou_Sayori_Alter_6e690081:

    # "As she trembles, I want to tell her not to worry about a thing; I'll fix this."
    "Viéndola temblar, quiero decirle que no se preocupe por nada; que lo arreglaré."

# game/Kyou 8.rpy:375
translate spanish Day8_Con_Kyou_Sayori_Alter_319d57ed:

    # "But what do I know?"
    "Pero ¿cómo puedo saberlo?"

# game/Kyou 8.rpy:399
translate spanish Day8_Con_Kyou_Sayori_Alter_2ca90083:

    # "After what feels like an eternity, the time comes and we walk ourselves back to school."
    "Después de lo que se siente como una eternidad, llega la hora de regresar a la escuela."

# game/Kyou 8.rpy:400
translate spanish Day8_Con_Kyou_Sayori_Alter_dfc7ac3f:

    # "I share a nod with Nozomi as I walk up to the door to the study room, while she waits at the end of the corridor."
    "Nozomi y yo nos asentimos el uno al otro y camino hasta la puerta del club de estudio, mientras que ella se queda esperando al final del pasillo."

# game/Kyou 8.rpy:404
translate spanish Day8_Con_Kyou_Sayori_Alter_194bc3a3:

    # "It had crossed mine and Nozomi's minds that she'd try to slip away..." with dissolve
    "Tanto a Nozomi como a mí se nos pasó por la mente que podría intentar escapar..." with dissolve

# game/Kyou 8.rpy:405
translate spanish Day8_Con_Kyou_Sayori_Alter_b0a2d2a9:

    # "But as I peer inside the study club room, I see [alt_name] sat alone inside and she cheerfully waves me in."
    "Pero cuando me asomo al club de estudio, veo a [alt_name] sentada sola, y con alegría me invita a pasar."

# game/Kyou 8.rpy:410
translate spanish Day8_Con_Kyou_Sayori_Alter_8004455f:

    # scg "It really is good to see you again, my love~"
    scg "Es bueno volver a verte, mi amor."

# game/Kyou 8.rpy:411
translate spanish Day8_Con_Kyou_Sayori_Alter_4e1b7798:

    # scg "Please, close the door behind you and we'll discuss this."
    scg "Por favor, cierra la puerta y lo discutiremos."

# game/Kyou 8.rpy:413
translate spanish Day8_Con_Kyou_Sayori_Alter_0cee6486:

    # "As I close the door and take a seat opposite her at the table, she sighs."
    "Cuando cierro la puerta y tomo asiento frente a ella, suelta un suspiro."

# game/Kyou 8.rpy:415
translate spanish Day8_Con_Kyou_Sayori_Alter_ddea66a5:

    # scg "It truly is exhausting to put up with such a level of tedium as this place."
    scg "Es agotador seguir el ritmo con este nivel de tedio."

# game/Kyou 8.rpy:412
translate spanish Day8_Con_Kyou_Sayori_Alter_5c030958:

    # scg standing alert_stern "And my club members would not shut up with the questions." with dissolve
    scg standing alert_stern "Y los miembros de mi club no dejan de hacer preguntas." with dissolve

# game/Kyou 8.rpy:413
translate spanish Day8_Con_Kyou_Sayori_Alter_9bc1ff50:

    # scg alert_irritated "I will never understand how anyone could willingly subject themselves to this torture day in, day out." with dissolve
    scg alert_irritated "Nunca entenderé cómo puede alguien someterse voluntariamente a esta tortura día tras día." with dissolve

# game/Kyou 8.rpy:418
translate spanish Day8_Con_Kyou_Sayori_Alter_bbce5129:

    # scg "But..."
    scg "Pero..."

# game/Kyou 8.rpy:419
translate spanish Day8_Con_Kyou_Sayori_Alter_26aa6b0a:

    # "She draws in another breath, then continues."
    "Vuelve a tomar aire, luego continúa."

# game/Kyou 8.rpy:416
translate spanish Day8_Con_Kyou_Sayori_Alter_38ec5331:

    # scg alert_smile "If I am to pass, I have no choice but to endure." with dissolve
    scg alert_smile "Si he de hacerme pasar, no tengo más opción que soportarlo." with dissolve

# game/Kyou 8.rpy:364
translate spanish Day8_Con_Kyou_Sayori_Alter_0dd8029e:

    # ks confused "Pass? What do you mean \"pass\"?"
    ks confused "¿Hacerte pasar? ¿A qué te refieres con \"hacerte pasar\"?"

# game/Kyou 8.rpy:424
translate spanish Day8_Con_Kyou_Sayori_Alter_1f0c908b:

    # "[alt_name] giggles, then leans in towards me while lowering her voice." with dissolve
    "[alt_name] se ríe, luego se inclina hacia mí bajando el volumen de su voz." with dissolve

# game/Kyou 8.rpy:422
translate spanish Day8_Con_Kyou_Sayori_Alter_858ad895:

    # scg alert_smile "{size=16}I mean, I could pass as the other girl.{/size}" with dissolve
    scg alert_smile "{size=16}Quiero decir que podría hacerme pasar por la otra chica.{/size}" with dissolve

# game/Kyou 8.rpy:423
translate spanish Day8_Con_Kyou_Sayori_Alter_5eb7e6f9:

    # scg alert_happy "{size=16}I could masquerade as Sayori.{/size}" with dissolve
    scg alert_happy "{size=16}Podría ponerme la máscara de Sayori.{/size}" with dissolve

# game/Kyou 8.rpy:428
translate spanish Day8_Con_Kyou_Sayori_Alter_e598c4d3:

    # ks surprised "W-what?"
    ks surprised "¿Qu-qué?"

# game/Kyou 8.rpy:429
translate spanish Day8_Con_Kyou_Sayori_Alter_fce4231f:

    # "[alt_name] puts a finger to her lips, then continues in hushed tones."
    "[alt_name] pone un dedo en sus labios, luego continúa silenciosamente."

# game/Kyou 8.rpy:426
translate spanish Day8_Con_Kyou_Sayori_Alter_8a315b6a:

    # scg alert_smile "{size=16}As you know, I possess every memory that she does, up to the point of my creation.{/size}" with dissolve
    scg alert_smile "{size=16}Como sabes, poseo todas los recuerdos que le pertenecen hasta el momento de mi creación.{/size}" with dissolve

# game/Kyou 8.rpy:431
translate spanish Day8_Con_Kyou_Sayori_Alter_862ff1f2:

    # scg "{size=16}And as far as I can ascertain, there is little difference between the two of us besides her studiousness and disdain for frivolous activity.{/size}"
    scg "{size=16}Y, hasta donde soy consciente, hay pocas diferencias entre nosotras dos, además de lo estudiosa que es y su desdén por las actividades frívolas.{/size}"

# game/Kyou 8.rpy:428
translate spanish Day8_Con_Kyou_Sayori_Alter_a3aeba7f:

    # scg alert_neutral "{size=16}So... It would be a severe challenge, but I know I could feign such characteristics to appease... certain individuals.{/size}" with dissolve
    scg alert_neutral "{size=16}Así que... sería un desafía severo, pero sé que puedo aparentar dichas características para apaciguar a...  ciertos individuos.{/size}" with dissolve

# game/Kyou 8.rpy:433
translate spanish Day8_Con_Kyou_Sayori_Alter_cddefccc:

    # "She then nods towards the door."
    "Luego hace un gento con la cabeza señalando la puerta."

# game/Kyou 8.rpy:430
translate spanish Day8_Con_Kyou_Sayori_Alter_7c0436c8:

    # scg alert_smile "{size=16}And once we have graduated, we can be free of all this.{/size}" with dissolve
    scg alert_smile "{size=16}Y una vez nos hayamos graduado, podemos liberarnos de todo esto.{/size}" with dissolve

# game/Kyou 8.rpy:435
translate spanish Day8_Con_Kyou_Sayori_Alter_bc3d7604:

    # "I can feel my blood run cold as she explains herself."
    "Puedo sentir que mi sangre se enfría mientras explica."

# game/Kyou 8.rpy:436
translate spanish Day8_Con_Kyou_Sayori_Alter_c82c1fb8:

    # scg "{size=16}If after graduation I happen to... loosen up a little, then who is to say it is anything other than a natural consequence of my new circumstances?{/size}"
    scg "{size=16}Si después de la graduación comienzo a... dejarme llevar un poco, ¿quién podrá decir que no son más que las consecuencias de mis nuevas circunstancias?{/size}"

# game/Kyou 8.rpy:437
translate spanish Day8_Con_Kyou_Sayori_Alter_626bba55:

    # "Not just her plan, but that I'm seriously turning it over in my head."
    "No solo por su plan, sino también porque de verdad lo estoy considerando."

# game/Kyou 8.rpy:439
translate spanish Day8_Con_Kyou_Sayori_Alter_7d0952d1:

    # "And [alt_name] must see it in my face as well, as she reaches across the table to hold her hands over mine." with dissolve
    "Cosa que [alt_name] debe estar viendo en mi rostro, y estira sus brazos sobre la mesa para tomar mis manos." with dissolve

# game/Kyou 8.rpy:440
translate spanish Day8_Con_Kyou_Sayori_Alter_4ba73608:

    # scg "{size=16}It is a way forward for us, Kyou. And you do not even have to do anything!{/size}"
    scg "{size=16}Será lo mejor para nosotros, Kyou. ¡Y ni siquiera tendrás que hacer nada!{/size}"

# game/Kyou 8.rpy:437
translate spanish Day8_Con_Kyou_Sayori_Alter_c1586f26:

    # scg alert_laugh "{size=16}I can take care of things for both of us.{/size}" with dissolve
    scg alert_laugh "{size=16}Yo haré todo el trabajo por ambos.{/size}" with dissolve

# game/Kyou 8.rpy:442
translate spanish Day8_Con_Kyou_Sayori_Alter_892a53dc:

    # ks "{size=16}So... so this is why you chose to meet here instead of...{/size}"
    ks "{size=16}Entonces... entonces por esto elegiste verme aquí en lugar de...{/size}"

# game/Kyou 8.rpy:439
translate spanish Day8_Con_Kyou_Sayori_Alter_db4f97e2:

    # scg alert_smile "{size=16}Instead of at your home, yes. I had wondered if you picked up on that.{/size}" with dissolve
    scg alert_smile "{size=16}En lugar de tu casa, sí. Me preguntaba si te habías dado cuenta.{/size}" with dissolve

# game/Kyou 8.rpy:444
translate spanish Day8_Con_Kyou_Sayori_Alter_c8ebdb6f:

    # "[alt_name] was brought into being at my place, not this room. But I guess she thought it'd be easier to talk Nozomi into letting us have a one-to-one here."
    "[alt_name] vio la luz por primera vez en mi casa, no en este salón. Pero supongo que pensó que sería más fácil convencer a Nozomi de dejarnos a solas aquí."

# game/Kyou 8.rpy:445
translate spanish Day8_Con_Kyou_Sayori_Alter_3129c01a:

    # "Everything she said on the rooftop... It wasn't out of consideration for Sayori at all."
    "Nada de lo que dijo en la azotea... fue en consideración de Sayori."

# game/Kyou 8.rpy:446
translate spanish Day8_Con_Kyou_Sayori_Alter_ebf33918:

    # scg alert_neutral "{size=16}Because Kyou, as sorry as I am for Sayori, I have no reason to believe I would be anything but destroyed were she to be brought back.{/size}" with dissolve
    scg alert_neutral "{size=16}Porque, Kyou, por mucho que lamente a Sayori, no tengo razón para creer que no seré destruida cuando ella regrese.{/size}" with dissolve

# game/Kyou 8.rpy:443
translate spanish Day8_Con_Kyou_Sayori_Alter_5e38d155:

    # scg alert_sleep "{size=16}After all, only she or I can be conscious at any point in time.{/size}" with dissolve
    scg alert_sleep "{size=16}Después de todo, solo una de nosotras puede estar consciente a la vez.{/size}" with dissolve

# game/Kyou 8.rpy:448
translate spanish Day8_Con_Kyou_Sayori_Alter_5c232735:

    # scg "{size=16}As soon as Sayori re-appears, I would be in no position to object.{/size}"
    scg "{size=16}En cuando Sayori reaparezca, no estaré en posición de objetar.{/size}"

# game/Kyou 8.rpy:445
translate spanish Day8_Con_Kyou_Sayori_Alter_d40b38b2:

    # scg alert_neutral "{size=16}So Kyou, do not pretend this is anything but a binary choice. My consciousness will always preclude Sayori's, and vice versa.{/size}" with dissolve
    scg alert_neutral "{size=16}Kyou, no finjas que esta no es una elección binaria. Mi consciencia siempre excluirá a la de Sayori y viceversa.{/size}" with dissolve

# game/Kyou 8.rpy:446
translate spanish Day8_Con_Kyou_Sayori_Alter_f9c89611:

    # scg alert_stern "{size=16}Or to put it simply... it is her or me.{/size}" with dissolve
    scg alert_stern "{size=16}O en términos simples... es ella o yo.{/size}" with dissolve

# game/Kyou 8.rpy:451
translate spanish Day8_Con_Kyou_Sayori_Alter_ce1a3399:

    # "As [alt_name] regards me cooly, I take a nervous glance at the door as I try to gather my thoughts."
    "Mientras [alt_name] me mira fríamente, nervioso, le echo un vistazo a la puerta, intentando pensar."

# game/Kyou 8.rpy:452
translate spanish Day8_Con_Kyou_Sayori_Alter_1567bbd4:

    # "Even if she can't hear us, I can imagine Nozomi must be waiting on the other side, fretting over why we're so quiet in here."
    "Aunque no pueda oírnos, imagino que Nozomi está esperando del otro lado, preguntándose con inquietud por qué estamos tan callados."

# game/Kyou 8.rpy:453
translate spanish Day8_Con_Kyou_Sayori_Alter_556ec306:

    # "And just then I feel [alt_name]'s fingers pressing a little firmer into my hands, snapping my attention back to her as she whispers to me once more."
    "Y de pronto, siento los dedos de [alt_name] presionar firmemente mis manos, volviendo mi atención hacia ella, y me susurra una vez más."

# game/Kyou 8.rpy:454
