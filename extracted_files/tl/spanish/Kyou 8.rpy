translate spanish Day8_Redemption_Spiral_9a3ccece:

    # a sad_side "... I met some of my student council friends at lunchtime." with dissolve
    a sad_side "... Me reuní con unos amigos del consejo estudiantil a la hora del almuerzo." with dissolve

# game/Kyou 8.rpy:2781
translate spanish Day8_Redemption_Spiral_87bc8ea9:

    # a neutral_side "And, you see, we were supposed to talk about the culture festival; get a head start on our official meeting this afternoon." with dissolve
    a neutral_side "Y, verás, se suponía que habláramos del festival cultural; adelantar un poco antes de nuestra reunión oficial esta tarde." with dissolve

# game/Kyou 8.rpy:2782
translate spanish Day8_Redemption_Spiral_8bfb03a3:

    # a neutral "I was so looking forward to getting stuck in after what happened this morning..." with dissolve
    a neutral "No podía esperar a ponernos manos a la obra después de lo que pasó esta mañana..." with dissolve

# game/Kyou 8.rpy:2783
translate spanish Day8_Redemption_Spiral_4c1e1b2e:

    # a frown "But no, someone brought up Risa and then that's ALL they wanted to talk about." with dissolve
    a frown "Pero no, alguien mencionó lo de Risa y entonces eso era TODO de lo que querían hablar." with dissolve

# game/Kyou 8.rpy:2786
translate spanish Day8_Redemption_Spiral_a24645da:

    # "She pushes her glasses up her nose and harshly blinks a couple times before suddenly throwing her arms out exasperatedly."
    "Se acomoda los anteojos y parpadea bruscamente un par de veces, para luego alzar súbita y exasperadamente los brazos."

# game/Kyou 8.rpy:2787
translate spanish Day8_Redemption_Spiral_95a11299:

    # a uniform armband angry "Agh, I mean, it's not like I WANTED her to get suspended from school, is it?" with dissolve
    a uniform armband angry "Aj, digo, yo tampoco QUERÍA que la suspendieran, ¿o sí?" with dissolve

# game/Kyou 8.rpy:2788
translate spanish Day8_Redemption_Spiral_c668962e:

    # a frown_side "We just got a little passionate, that's all." with dissolve
    a frown_side "Simplemente nos pusimos un poco coléricas, es todo." with dissolve

# game/Kyou 8.rpy:3941
translate spanish Day8_Redemption_Spiral_ff5ab2b7:

