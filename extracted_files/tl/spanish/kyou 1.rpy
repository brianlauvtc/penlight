# game/kyou 1.rpy:439
translate spanish Day1_Kyou_da1d711f:

    # "... The thought didn't repulse her. She HAS to be considering this."
    "... La idea no le causó repulción. TIENE que estarlo considerando."

# game/kyou 1.rpy:440
translate spanish Day1_Kyou_ad88b912:

    # "I'll push on."
    "Otro empujón."

# game/kyou 1.rpy:442
translate spanish Day1_Kyou_d0345214:

