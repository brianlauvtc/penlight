    ks "Nozomi..., ¿puedes oírme?"

# game/kyou 1.rpy:396
translate spanish Day1_Kyou_957a9c85:

    # "The sound that escapes her lips is barely audible, but clearly in the affirmative. It excites me."
    "El sonido que brota de sus labios es casi inaudible, pero claramente es afirmativo. Eso me genera emoción."

# game/kyou 1.rpy:397
