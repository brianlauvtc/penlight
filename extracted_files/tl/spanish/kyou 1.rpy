translate spanish Day1_Kyou_a1dd9ce4:

    # ks "One... beginning to stir."
    ks "Uno... comienzas a moverte."

# game/kyou 1.rpy:512
translate spanish Day1_Kyou_bea352da:

    # ks "Two... slowly feeling your senses return."
    ks "Dos... tus sentidos regresan lentamente."

