    # ncg sleeptalk "No..." with dissolve
    ncg sleeptalk "No..." with dissolve

# game/kyou 1.rpy:449
translate spanish Day1_Kyou_c8eff140:

    # ks "No denying how good and right it feels to be near me like this..." with dissolve
    ks "No puedes negar lo bien y lo correcto que se siente estar cerca de mí como ahora..." with dissolve

# game/kyou 1.rpy:450
translate spanish Day1_Kyou_38b28997:

    # ks "Is there?"
    ks "¿O sí?"

# game/kyou 1.rpy:451
translate spanish Day1_Kyou_8d82f55c:

    # ncg sleeptalk "No... no denying..." with dissolve
    ncg sleeptalk "No... no puedo..." with dissolve

# game/kyou 1.rpy:453
translate spanish Day1_Kyou_48c678fc:

    # ks smile "So then, {w=0.5}there's no reason to be scared of being in a relationship either, {w=0.5}is-{w=1.0}{nw}" with dissolve
    ks smile "Entonces, {w=0.5}tampoco hay por qué temer estar en una relación, {w=0.5}es-{w=1.0}{nw}" with dissolve

# game/kyou 1.rpy:454
