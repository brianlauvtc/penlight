    ks neutral "Es natural que te asuste un poco estar en una relación, Nozomi. Las cosas nuevas asustan."

# game/kyou 1.rpy:443
translate spanish Day1_Kyou_1ac39be2:

    # ks "But there's no denying how relaxed you're feeling, is there, Nozomi?"
    ks "Pero no puedes negar lo relajada que te sientes, ¿o sí, Nozomi?"

# game/kyou 1.rpy:444
translate spanish Day1_Kyou_825c58ff:

    # ncg sleeptalk "N-no..." with dissolve
    ncg sleeptalk "N-no..." with dissolve

# game/kyou 1.rpy:446
