    h surprised_side "... con esto. Espera, ¿qué mierda estoy haciendo con estos?" with dissolve

# game/Kyou 11.rpy:3105
translate spanish Day11_Con_Kyou_Nozomi_Zombie_8533605a:

    # s smirk "Giving them back before you develop some kind of sock fetish?" with dissolve
    s smirk "¿Devolviéndolos antes de que desarrolles alguna clase de fetiche por los calcetines?" with dissolve

# game/Kyou 11.rpy:3107
translate spanish Day11_Con_Kyou_Nozomi_Zombie_0c9f282c:

    # h uniform_headhold sad_side blush "Uhh... h'yeah, here you go." with dissolve
    h uniform_headhold sad_side blush "Eeh... seh, aquí tienes." with dissolve

