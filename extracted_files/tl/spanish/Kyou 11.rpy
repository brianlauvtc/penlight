translate spanish Day11_Con_Kyou_Nozomi_Trance_d406d841:

    # ks "Two, feeling your eyelids flicker open..." with dissolve
    ks "Dos, siente cómo tus párpados se abren..." with dissolve

# game/Kyou 11.rpy:1079
translate spanish Day11_Con_Kyou_Nozomi_Trance_55393d8e:

    # ks "And three, wide awake."
    ks "Y tres, despierta."

# game/Kyou 11.rpy:1080
translate spanish Day11_Con_Kyou_Nozomi_Trance_c3624eb5:

    # ncg standing drowsy "..." with dissolve
    ncg standing drowsy "..." with dissolve

# game/Kyou 11.rpy:1081
translate spanish Day11_Con_Kyou_Nozomi_Trance_6469d9a8:

    # ks "Okay so, Nozomi, given what just happened I thought I'd better-{w=0.8}{nw}"
    ks "Muy bien, pues, dado lo que pasó, pensé que sería mejor-{w=0.8}{nw}"

# game/Kyou 11.rpy:1083
translate spanish Day11_Con_Kyou_Nozomi_Trance_0f8bfcef:

    # ncg "Kyou, you..."
    ncg "Kyou, tú..."

# game/Kyou 11.rpy:1084
translate spanish Day11_Con_Kyou_Nozomi_Trance_2cf94c41:

    # ncg surprised "Y-you... oh my god..." with dissolve
    ncg surprised "T-tú... oh, por Dios..." with dissolve

# game/Kyou 11.rpy:1085
translate spanish Day11_Con_Kyou_Nozomi_Trance_fb405a72:

    # ks "Nozomi, please, I'm sorry-{w=0.8}{nw}"
    ks "Nozomi, por favor, lo siento-{w=0.8}{nw}"

# game/Kyou 11.rpy:1086
translate spanish Day11_Con_Kyou_Nozomi_Trance_a25dde79:

    # ncg "O- OH MY GOD!" with vpunch
    ncg "¡O- OH, POR DIOS!" with vpunch

# game/Kyou 11.rpy:1089
translate spanish Day11_Con_Kyou_Nozomi_Trance_e84a493d:

    # "And just like that, she bolts for the door." with dissolve
    "Y así nada más, corre hacia la puerta." with dissolve

# game/Kyou 11.rpy:1091
translate spanish Day11_Con_Kyou_Nozomi_Trance_528de73c:

    # "... I don't try to stop her."
    "... No intento detenerla."

# game/Kyou 11.rpy:1097
translate spanish Day11_Con_Kyou_Nozomi_Trance_5f5b8450:

    # "Kyou's seen enough. He knows this isn't what Nozomi wanted. He KNOWS it. Why isn't she pushing back?"
    "Kyou ya vio suficiente. Sabe que esto no es lo que Nozomi quería. Lo SABE. ¿Por qué no está oponiendo resistencia?"

# game/Kyou 11.rpy:1098
translate spanish Day11_Con_Kyou_Nozomi_Trance_e4e086e1:

    # "Why isn't she waking up and stopping this? And what does that mean for everything else they've done previously?"
    "¿Por qué no despierta y le pone un alto a esto? ¿Y eso qué significa respecto a todo lo que hicieron anteriormente?"

# game/Kyou 11.rpy:1099
translate spanish Day11_Con_Kyou_Nozomi_Trance_64c12c77:

    # "But more to the point, Nozomi trusts him. Why is he even thinking about putting her in legitimate danger?"
    "Pero, lo más importante, Nozomi confía en él. ¿Por qué está pensando en ponerla en verdadero peligro?"

# game/Kyou 11.rpy:1100
translate spanish Day11_Con_Kyou_Nozomi_Trance_7bcb6e95:

    # "It's too much; he needs to take responsibility and put a stop to this..."
    "Es demasiado; necesita hacerse responsable y ponerle un alto a esto..."

# game/Kyou 11.rpy:1102
translate spanish Day11_Con_Kyou_Nozomi_Trance_66089d8e:

    # "So he takes Nozomi back into trance, clears her mind of all his suggestions (including the ones from previous nights) and wakes her."
    "Por lo que vuelve a poner a Nozomi en trance, limpia su mente de todas las sugestiones (incluyendo las de las noches anteriores) y la despierta."

# game/Kyou 11.rpy:1103
translate spanish Day11_Con_Kyou_Nozomi_Trance_ab01db52:

    # "Cue frightened conversation between them over what just happened, Nozomi confirming that she was unaware and defenceless..."
    "Durante una aterrorizada conversación sobre lo que pasó, Nozomi confirma que estaba inconsciente e indefensa..."

# game/Kyou 11.rpy:1104
translate spanish Day11_Con_Kyou_Nozomi_Trance_f20db00f:

    # "... And that this wasn't what she wanted. This was TOO real."
    "... Y que eso no era lo que quería. Eso fue DEMASIADO real."

# game/Kyou 11.rpy:1105
translate spanish Day11_Con_Kyou_Nozomi_Trance_8325c688:

    # "((We have reached the end of the current rewritten script.))"
    "((Hemos alcanzado el final del guion reescrito que hay hasta el momento.))"

# game/Kyou 11.rpy:1106
translate spanish Day11_Con_Kyou_Nozomi_Trance_9f3739a7:

    # "((Going to cut to credits instead of continuing with the old script, which is going to basically make no sense at all now.))"
    "((Cortaré hasta los créditos en lugar de continuar con el viejo guion, el cual no tendrá básicamente ningún sentido ahora.))"

# game/Kyou 11.rpy:1107
translate spanish Day11_Con_Kyou_Nozomi_Trance_63707af8:

    # "((To be continued!))"
    "((¡Continuará!))"

# game/Kyou 11.rpy:1112
translate spanish Day11_Con_Kyou_Nozomi_Trance_91cd37ad:

    # ks neutral blush "So, err..."
    ks neutral blush "Pues, em..."

# game/Kyou 11.rpy:1113
translate spanish Day11_Con_Kyou_Nozomi_Trance_d6ed0595:

    # "I've never done anything like this before."
    "Nunca había hecho algo así."

# game/Kyou 11.rpy:1114
translate spanish Day11_Con_Kyou_Nozomi_Trance_4e91473e:

    # ks "On your knees, Nozomi."
    ks "De rodillas, Nozomi."

# game/Kyou 11.rpy:1117
translate spanish Day11_Con_Kyou_Nozomi_Trance_a68b2a8e:

    # "As she obediently drops down to the floor to sit on her heels, I reach down to pet her head."
    "Ella se arroja obedientemente al suelo, sentándose sobre sus tacones, y yo me acerco a acariciar su cabeza."

# game/Kyou 11.rpy:1118
translate spanish Day11_Con_Kyou_Nozomi_Trance_b877498e:

    # "The last thing I want to do is hurt her."
    "Lo último que quiero es hacerle daño."

# game/Kyou 11.rpy:1119
translate spanish Day11_Con_Kyou_Nozomi_Trance_294e02c9:

    # "So maybe I should ask her what she wants me to make her do? Would that be defeating the purpose?"
    "¿Tal vez deba preguntarle qué quiere que la obligue hacer? ¿Eso arruinaría el propósito?"

# game/Kyou 11.rpy:1122
translate spanish Day11_Con_Kyou_Nozomi_Trance_f519231d:

    # "And now she's looking at me expectantly again." with dissolve
    "Y nuevamente me mira con expectativa en sus ojos." with dissolve

# game/Kyou 11.rpy:1123
translate spanish Day11_Con_Kyou_Nozomi_Trance_ba019533:

    # "Well... if I assume she can now stop my influence over her at any time, maybe I shouldn't worry about this too much."
    "Bueno... si asumo que puede detener mi influencia sobre ella en cualquier momento, tal vez no deba preocuparme demasiado."

# game/Kyou 11.rpy:1124
translate spanish Day11_Con_Kyou_Nozomi_Trance_62a68ffa_1:

    # ks smile "You know, I'm still thinking about the power I have over you. About all the things I could make you do."
    ks smile "¿Sabes?, sigo pensando en el poder que tengo sobre ti. En todas las cosas que podrías obligarte a hacer."

# game/Kyou 11.rpy:1125
translate spanish Day11_Con_Kyou_Nozomi_Trance_bff579d5:

    # ks "And all you'd be able to do in return is smile and obey. Even if you knew it would risk your life. Even if my orders would strip you of your very humanity."
    ks "Y lo único que serías capaz de hacer en respuesta es sonreír y obedecer. Aunque supieras que pondría en riesgo tu vida. Aunque supieras que mis órdenes te despojarían de tu humanidad."

# game/Kyou 11.rpy:1126
translate spanish Day11_Con_Kyou_Nozomi_Trance_6adfa4a3:

    # ks "Doesn't that excite you, Nozomi?"
    ks "¿Acaso no te emociona, Nozomi?"

# game/Kyou 11.rpy:1127
translate spanish Day11_Con_Kyou_Nozomi_Trance_a5d213f1:

    # n blush "{size=16}It.. it does, Sir. It thrills me to my core to know I'm powerless before you.{/size}" with dissolve
    n blush "{size=16}S-... sí, Señor. Me emociona en lo más profundo saber lo impotente que soy ante usted.{/size}" with dissolve

# game/Kyou 11.rpy:1129
translate spanish Day11_Con_Kyou_Nozomi_Trance_da2cb5d6_1:

    # ks "So then, Nozomi. With this ultimate power at my disposal I command you to..."
    ks "Entonces, Nozomi. Con el poder absoluto que tengo a mi disposición, te ordeno que..."

# game/Kyou 11.rpy:1134
translate spanish Day11_Con_Kyou_Nozomi_Trance_3d6a8fc6:

    # "Nozomi blinks in surprise as she registers what I said, but her body responds immediately as she rises back to her feet and starts padding towards the kitchen." with dissolve
    "Nozomi parpadea sorprendida mientras analiza lo que dije, pero su cuerpo responde inmediatamente poniéndose de pie y dirigiéndose a la cocina." with dissolve

# game/Kyou 11.rpy:1140
translate spanish Day11_Con_Kyou_Nozomi_Trance_33410836:

    # "I'm sure I heard a soft chuckle from her as she disappears from view, followed shortly after by the sound of the fridge door opening."
    "Estoy seguro de que escuché una risita cuando desapareció de mi vista, seguido poco después por el sonido del refrigerador abriéndose."

# game/Kyou 11.rpy:1141
translate spanish Day11_Con_Kyou_Nozomi_Trance_a192aea5:

    # "Not wanting to miss the sight of an underwear-clad girl cooking for me, I decide to follow her."
    "Sin querer perderme la imagen de una chica en ropa interior cocinando para mí, decido seguirla."

# game/Kyou 11.rpy:1143
translate spanish Day11_Con_Kyou_Nozomi_Trance_27b0ea84:

    # "Taking a seat at the dining table, I simply watch with a grin as she works, navigating around my kitchen with relative ease to get her task done."
    "Con una sonrisa, tomo asiento en el comedor y la observo trabajar, navegando por mi cocina con relativa facilidad para terminar su tarea."

# game/Kyou 11.rpy:1145
translate spanish Day11_Con_Kyou_Nozomi_Trance_a5e47e8d_1:

    # "I can tell she's a little flustered at my staring, but she doesn't say anything as she prepares the food, sets it on a plate and serves it up to me at the table." with dissolve
    "Puedo notar que la pone un poco nerviosa que la mire, pero prepara la comida sin decir nada, la coloca en un plato y la sirve en la mesa para mí." with dissolve

# game/Kyou 11.rpy:1146
translate spanish Day11_Con_Kyou_Nozomi_Trance_655e6fd5_1:

    # n side sad "{size=16}H-Here you are, Sir.{/size}" with dissolve
    n side sad "{size=16}B-buen provecho, Señor.{/size}" with dissolve

# game/Kyou 11.rpy:1147
translate spanish Day11_Con_Kyou_Nozomi_Trance_6cde1bce_1:

    # "I take a look at the cheese omelette in front of me, then at her, still grinning."
    "Le echo un vistazo al omelet de queso que tengo delante, luego a ella, sin dejar de sonreír."

# game/Kyou 11.rpy:1148
translate spanish Day11_Con_Kyou_Nozomi_Trance_3de11c0a_1:

    # ks smirk "I never said I wanted to eat it, Nozo. Besides, I'm not hungry."
    ks smirk "Nunca dije que quería comerlo, Nozo. Además, no tengo hambre."

# game/Kyou 11.rpy:1149
translate spanish Day11_Con_Kyou_Nozomi_Trance_910b0e00:

    # n frown "{size=16}What? Geez, then why did you have me make it?{/size}" with dissolve
    n frown "{size=16}¿Qué? Caray, entonces ¿por qué me hizo prepararlo?{/size}" with dissolve

# game/Kyou 11.rpy:1150
translate spanish Day11_Con_Kyou_Nozomi_Trance_8e452eea_1:

    # ks "Sit down and eat it yourself."
    ks "Siéntate y cómetelo tú."

# game/Kyou 11.rpy:1154
translate spanish Day11_Con_Kyou_Nozomi_Trance_0a8d9a5f_1:

    # n front pout "{size=16}But I'm not hungry either...{/size}" with dissolve
    n front pout "{size=16}Pero tampoco tengo hambre...{/size}" with dissolve

# game/Kyou 11.rpy:1157
translate spanish Day11_Con_Kyou_Nozomi_Trance_f7ec5f10_1:

    # "She says, as she tears a piece off and pops it into her mouth."
    "Dice ella, cortando un trozo e introduciéndolo a su boca."

# game/Kyou 11.rpy:1158
translate spanish Day11_Con_Kyou_Nozomi_Trance_a61e1984:

    # n "{size=16}Jerk...{/size}"
    n "{size=16}Cretino...{/size}"

# game/Kyou 11.rpy:1159
translate spanish Day11_Con_Kyou_Nozomi_Trance_14fa03e8_1:

    # ks smile "Tell me how you're really feeling, Nozomi."
    ks smile "Dime cómo te sientes en realidad, Nozomi."

# game/Kyou 11.rpy:1160
translate spanish Day11_Con_Kyou_Nozomi_Trance_3de4fc13:

    # "She takes a moment to swallow her food before replying."
    "Hace una pausa para tragar su comida antes de contestar."

# game/Kyou 11.rpy:1161
translate spanish Day11_Con_Kyou_Nozomi_Trance_459cf716:

    # n pout_left "{size=16}Really good. I know it's just a simple thing, but even making me do this and knowing I can't stop myself is so euphoric you wouldn't believe.{/size}" with dissolve
    n pout_left "{size=16}Muy bien. Sé que es algo muy simple, pero incluso ser obligada a hacer esto y saber que no me puedo detener me causa más euforia de la que se imagina.{/size}" with dissolve

# game/Kyou 11.rpy:1162
translate spanish Day11_Con_Kyou_Nozomi_Trance_4d019a1e_1:

    # "She stops to take another bite of the omelette; her compulsion to obey my latest order conflicting with the previous."
    "Se detiene para darle otro mordisco al omelet; su impulso por obedecer mi más reciente orden entra en conflicto con la anterior."

# game/Kyou 11.rpy:1163
translate spanish Day11_Con_Kyou_Nozomi_Trance_806f8b6e:

    # ks neutral "Yet you still look a bit worried to me."
    ks neutral "Aunque yo aún te veo un poco preocupada."

# game/Kyou 11.rpy:1164
translate spanish Day11_Con_Kyou_Nozomi_Trance_28fecc93:

    # n sleeptalk "{size=16}I'm not worried, Sir. I'm just embarrassed to admit this to you. And to myself.{/size}" with dissolve
    n sleeptalk "{size=16}No estoy preocupada, Señor. Es que me avergüenza admitirle esto a usted. Y a mí misma.{/size}" with dissolve

# game/Kyou 11.rpy:1165
translate spanish Day11_Con_Kyou_Nozomi_Trance_8a7dd692_1:

    # ks smile blush "Nozomi, there's no reason to feel embarrassed about feeling this way. You like what you like."
    ks smile blush "Nozomi, sentirte así no es nada de qué avergonzarse. Lo que te gusta te gusta."

# game/Kyou 11.rpy:1167
translate spanish Day11_Con_Kyou_Nozomi_Trance_f485605e_1:

    # ks "Also, no one else needs to know if you don't want to say anything. We had a deal." with dissolve
    ks "Además, nadie más debe saber si no quieres decir nada. Tenemos un trato, ¿recuerdas?" with dissolve

# game/Kyou 11.rpy:1168
translate spanish Day11_Con_Kyou_Nozomi_Trance_023d553f_1:

    # ks "So don't feel ashamed about who you are. You're safe here, with someone who wants you to be happy."
    ks "Así que no sientas pena de ser quién eres. Estás a salvo aquí, con alguien que quiere que seas feliz."

# game/Kyou 11.rpy:1169
translate spanish Day11_Con_Kyou_Nozomi_Trance_43ec31f6_1:

    # ks "Let yourself enjoy this."
    ks "Disfrútalo."

# game/Kyou 11.rpy:1171
translate spanish Day11_Con_Kyou_Nozomi_Trance_fe59ddc5_1:

    # "Nozomi gives me a smile from across the table and nods, still half-chewing as she responds in her cute whispered voice." with dissolve
    "Nozomi me lanza una sonrisa desde el otro lado de la mesa y asiente, y sin dejar del todo de masticar, responde:" with dissolve

# game/Kyou 11.rpy:1172
translate spanish Day11_Con_Kyou_Nozomi_Trance_61c40fb0_1:

    # n "{size=16}Thank you, Sir. That does actually make me feel better.{/size}"
    n "{size=16}Gracias, Señor. Eso me hace sentir mejor.{/size}"

# game/Kyou 11.rpy:1173
translate spanish Day11_Con_Kyou_Nozomi_Trance_e1f740e6:

    # "I smile back at her as we share a moment of mutual bliss."
    "Le devuelvo la sonrisa y ambos compartimos este momento de dicha."

# game/Kyou 11.rpy:1174
translate spanish Day11_Con_Kyou_Nozomi_Trance_28d9f3e0_1:

    # "And then with a grin, I'm the one to break the silence for a change."
    "Luego, con malicia, soy yo quien rompe el silencio, para variar."

# game/Kyou 11.rpy:1175
translate spanish Day11_Con_Kyou_Nozomi_Trance_19b452d3_1:

    # ks smirk "Now be a good girl and finish your omelette, and wash everything up when you're done."
    ks smirk "Ahora sé una buena chica y termina tu omelet, y limpia todo cuando acabes."

# game/Kyou 11.rpy:1177
translate spanish Day11_Con_Kyou_Nozomi_Trance_fecb6bff_1:

    # "She pokes her tongue out at me, then takes another bite of her food." with dissolve
    "Me saca la lengua, para luego tomar otro bocado de su comida." with dissolve

# game/Kyou 11.rpy:1180
translate spanish Day11_Con_Kyou_Nozomi_Trance_ea0d63a2_1:

    # "Soon after she was done in the kitchen I had her get dressed and ready to leave."
    "Poco después, cuando su trabajo en la cocina hubo acabado, hice que se vistiera, lista para partir."

# game/Kyou 11.rpy:1181
translate spanish Day11_Con_Kyou_Nozomi_Trance_ee525a79_1:

    # "Not that I wanted to, but dad's going to be home soon, and I don't think either of us want to explain this to him of all people."
    "No es que quiera, pero papá volverá a casa pronto, y no creo que ninguno de los dos quiera explicarle esto a nadie, mucho menos a él."

# game/Kyou 11.rpy:1182
translate spanish Day11_Con_Kyou_Nozomi_Trance_dc146684_1:

    # ks smile "You got everything?"
    ks smile "¿Tienes todo?"

# game/Kyou 11.rpy:1183
translate spanish Day11_Con_Kyou_Nozomi_Trance_4c10b5d4_1:

    # n "{size=16}Yes, Sir. Are we doing this again tomorrow?{/size}"
    n "{size=16}Sí, Señor. ¿Volveremos a hacerlo mañana?{/size}"

# game/Kyou 11.rpy:1184
translate spanish Day11_Con_Kyou_Nozomi_Trance_6ce3cc38_1:

    # "I respond with a wink and a knowing smirk."
    "Respondo con un guiño y una sonrisa."

# game/Kyou 11.rpy:1185
translate spanish Day11_Con_Kyou_Nozomi_Trance_5c91c90b_1:

    # ks smirk "Oh, you WILL be coming back here tomorrow. Do I make myself clear?"
    ks smirk "Oh, tú VAS a regresar aquí mañana. ¿Quedó claro?"

# game/Kyou 11.rpy:1187
translate spanish Day11_Con_Kyou_Nozomi_Trance_6fcf8645_1:

    # "She replies with a muted giggle." with dissolve
    "Ella contesta con una muda risita." with dissolve

# game/Kyou 11.rpy:1188
translate spanish Day11_Con_Kyou_Nozomi_Trance_91bf6307_1:

    # n "{size=16}Yes, Sir. I must obey~{/size}"
    n "{size=16}Sí, Señor. Debo obedecer.{/size}"

# game/Kyou 11.rpy:1260
translate spanish Day11_Con_Kyou_Nozomi_Trance_7e771913:

    # "To be continued."
    "Continuará."

