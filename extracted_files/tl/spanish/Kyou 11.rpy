    # n sleeptalk_concerned "So Kyou... what I want is..." with dissolve
    n sleeptalk_concerned "Así que, Kyou... lo que quiero es..." with dissolve

# game/Kyou 11.rpy:350
translate spanish Day11_Con_Kyou_Nozomi_Trance_ada5e415:

    # n "I-is..."
    n "E-es..."

# game/Kyou 11.rpy:351
translate spanish Day11_Con_Kyou_Nozomi_Trance_30dbf961:

    # n frown "I want you to dominate my mind!" with dissolve
    n frown "¡Quiero que domines mi mente!" with dissolve

# game/Kyou 11.rpy:352
translate spanish Day11_Con_Kyou_Nozomi_Trance_01d280d9:

    # ks "I... Y-You mean like last time?"
    ks "Yo... ¿C-como la última vez?"

# game/Kyou 11.rpy:353
translate spanish Day11_Con_Kyou_Nozomi_Trance_3e3652e0:

    # "Nozomi lets out a sigh as she shakes her head firmly."
    "Nozomi suspira, negando firmemente con la cabeza."

# game/Kyou 11.rpy:354
