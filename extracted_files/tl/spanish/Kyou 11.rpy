# game/Kyou 11.rpy:861
translate spanish Day11_Con_Kyou_Nozomi_Trance_e8a49152:

    # "I mean... it's been obvious from the start, hasn't it?"
    "Pues... ha sido obvio desde el principio, ¿no?"

# game/Kyou 11.rpy:863
