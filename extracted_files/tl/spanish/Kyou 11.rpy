# game/Kyou 11.rpy:1312
translate spanish Day11_Con_Kyou_Sayori_Doll_274d5aab:

    # "I'm not feeling any better the next morning."
    "No me siento mejor a la mañana siguiente."

# game/Kyou 11.rpy:1314
translate spanish Day11_Con_Kyou_Sayori_Doll_1b8a8ad8:

    # "Walking to school with leaden feet, I can feel my stomach tense as I approach the gates."
    "Caminando a la escuela arrastrando los pies, siento que mi estómago se revuelve cuando me acerco a las puertas."

# game/Kyou 11.rpy:1321
translate spanish Day11_Con_Kyou_Sayori_Doll_c8555a05:

    # h "Mornin'."
    h "Buenos días."

# game/Kyou 11.rpy:1322
translate spanish Day11_Con_Kyou_Sayori_Doll_d690ce57:

    # n "Hiroko, hi!"
    n "¡Hiroko, hola!"

# game/Kyou 11.rpy:1323
translate spanish Day11_Con_Kyou_Sayori_Doll_9e052143:

    # "I don't know how Sayori's doing since she went home. Seems we both decided not to contact each other."
    "No sé cómo ha estado Sayori desde que se fue a casa. Parece que ambos decidimos no contactar al otro."

# game/Kyou 11.rpy:1324
translate spanish Day11_Con_Kyou_Sayori_Doll_cf2e092b:

    # n neutral_side "Um, I guess she didn't get back to you either?" with dissolve
    n neutral_side "Em, ¿supongo que tampoco fue contigo?" with dissolve

# game/Kyou 11.rpy:1325
translate spanish Day11_Con_Kyou_Sayori_Doll_06effb54:

    # h sad_side "Nah." with dissolve
    h sad_side "Nah." with dissolve

# game/Kyou 11.rpy:1326
translate spanish Day11_Con_Kyou_Sayori_Doll_bb770935:

    # "But I know she'll never miss a day of school no matter what."
    "Pero sé que nunca se perdería un día de escuela, no importa qué."

# game/Kyou 11.rpy:1327
translate spanish Day11_Con_Kyou_Sayori_Doll_7ad52708:

    # h sleeptalk "Even stopped by her place on the way home, but her folks said she popped out." with dissolve
    h sleeptalk "Hasta pasé por su casa de camino a la mía, pero sus viejos dijeron que había salido." with dissolve

# game/Kyou 11.rpy:1329
translate spanish Day11_Con_Kyou_Sayori_Doll_d71d6605:

    # "So I'm sure I'll find..."
    "Así que seguro lo..."

# game/Kyou 11.rpy:1342
translate spanish Day11_Con_Kyou_Sayori_Doll_b89db7a1:

