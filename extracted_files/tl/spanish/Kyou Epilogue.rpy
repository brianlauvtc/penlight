translate spanish Epilogue_Con_Kyou_Hiroko_9f43fc76:

    # k "And now taking another deep breath for me... That's right." with dissolve
    k "Tomen aire una vez más... Eso es." with dissolve

# game/Kyou Epilogue.rpy:2415
translate spanish Epilogue_Con_Kyou_Hiroko_f38cc8f7:

    # k "Four. Feeling all the remaining tension in your back vanish, nice and relaxed as you drop deeper and deeper."
    k "Cuatro. Sientan toda la tensión restante desvanecerse. Completamente relajados. Cayendo más y más profundo."

# game/Kyou Epilogue.rpy:2418
translate spanish Epilogue_Con_Kyou_Hiroko_e7343c1e:

    # tb "{size=14}Are they really doing it?{/size}" with dissolve
    tb "{size=14}¿Sí lo están haciendo?{/size}" with dissolve

# game/Kyou Epilogue.rpy:2421
translate spanish Epilogue_Con_Kyou_Hiroko_45124be6:

    # k "Another deep breath now... Three, exhaling, letting all the tension drain out of your shoulders. Feeling it all drop away, going deeper and deeper." with dissolve
    k "Inhalen de nuevo... Tres, exhalen, dejen que toda esa tensión abandone sus hombros. Sientan cómo se cae, yendo más y más profundo." with dissolve

# game/Kyou Epilogue.rpy:2384
translate spanish Epilogue_Con_Kyou_Hiroko_59cbfe15:

    # "There's a little whoop from the crowd as I spot someone about to fall off her chair."
    "Hay un pequeño alarido en la audiencia cuando una chica está a punto de caer de su silla."

# game/Kyou Epilogue.rpy:2424
translate spanish Epilogue_Con_Kyou_Hiroko_c632b018:

    # "I walk over and touch her shoulder gently to make sure she doesn't fall on her head." with dissolve
    "Camino hacia ella y la tomo gentilmente del hombro para asegurarme de que no se caiga de cabeza." with dissolve

# game/Kyou Epilogue.rpy:2425
translate spanish Epilogue_Con_Kyou_Hiroko_43b78718:

    # k "And to you, whose shoulder I am now touching, your butt is stuck to the seat of that chair. Understand?"
    k "Y tú, a la que le estoy tocando el hombro, tu trasero está pegado a la silla. ¿Entendido?"

# game/Kyou Epilogue.rpy:2429
translate spanish Epilogue_Con_Kyou_Hiroko_d5e627cd:

    # n "Y... yeah." with dissolve
    n "S-... seh." with dissolve

# game/Kyou Epilogue.rpy:2391
translate spanish Epilogue_Con_Kyou_Hiroko_6fe700e0:

    # ta "{size=14}Hahaha, isn't that the girl from last year?{/size}"
    ta "{size=14}Jajaja, ¿qué no es la chica del año pasado?{/size}"

# game/Kyou Epilogue.rpy:2392
translate spanish Epilogue_Con_Kyou_Hiroko_1b4fbff8:

    # r "The fake chicken lady!"
    r "¡La que fingía ser una gallina!"

# game/Kyou Epilogue.rpy:2393
translate spanish Epilogue_Con_Kyou_Hiroko_d768ec51:

    # s "Shush!"
    s "¡Chitón!"

# game/Kyou Epilogue.rpy:2434
translate spanish Epilogue_Con_Kyou_Hiroko_068650df:

    # k "That's right, feeling so loose. So limp. And now taking another deep breath with me."
    k "Eso es. Sus cuerpos están tan flojitos. Y ahora, una vez más, inhalen profundamente."

# game/Kyou Epilogue.rpy:2437
translate spanish Epilogue_Con_Kyou_Hiroko_26fe7871:

    # k "And exhale... Two, all the tension draining from your neck now. Relaxing so deep, feeling so loose." with dissolve
    k "Y exhalen... Dos, y ahora toda esa tensión abandona sus cuellos. Quedando totalmente flojos y relajados." with dissolve

# game/Kyou Epilogue.rpy:2396
translate spanish Epilogue_Con_Kyou_Hiroko_24e02cc5:

    # "There's another excited whoop as I notice the guy on the other end of the row of chairs is close to suffering the same fate as Nozomi. I better help him out too."
    "Se escucha otro exaltado alarido al ver que un chico en la última silla está a punto de sufrir el mismo destino que Nozomi. Será mejor que lo ayude."

# game/Kyou Epilogue.rpy:2441
translate spanish Epilogue_Con_Kyou_Hiroko_dbf2fe1e:

    # k "And now you, I'm touching your shoulder, your butt is also stuck solidly to that chair. Understood?" with dissolve
    k "Y ahora tú, al que le estoy tocando el hombro, tu trasero está firmemente pegado a la silla. ¿Entendido?" with dissolve

# game/Kyou Epilogue.rpy:2442
translate spanish Epilogue_Con_Kyou_Hiroko_52b6799e:

    # tc "Mm, yeah..."
    tc "Mm, seh..."

# game/Kyou Epilogue.rpy:2399
translate spanish Epilogue_Con_Kyou_Hiroko_4070d2d8:

    # r "{size=14}Faaaake.{/size}"
    r "{size=14}Faaalsoooo.{/size}"

# game/Kyou Epilogue.rpy:2445
translate spanish Epilogue_Con_Kyou_Hiroko_b8769702:

    # k "Okay and now, one more deep breath with me. So close to going all the way down, deep breath."
    k "Muy bien, y ahora, respiren profundo otra vez. Ya estamos casi en el fondo. Respiren hondo."

# game/Kyou Epilogue.rpy:2448
translate spanish Epilogue_Con_Kyou_Hiroko_57aa145e:

    # "I listen once more as those seated in front of me, and some in the crowd it seems, draw another breath." with dissolve
    "Nuevamente escucho como aquellos sentados frente a mí; y algunos en el público, al parecer; vuelven a tomar aire." with dissolve

# game/Kyou Epilogue.rpy:2451
translate spanish Epilogue_Con_Kyou_Hiroko_89faaa78:

    # "The audience seems to really be getting into this now as they react to the participants slumped over each other more and more, barely able to stay on their seats." with dissolve
    "La audiencia parece estar muy atenta al espectáculo, contemplando cómo se desploman más y más uno sobre el otro, apenas capaces de quedarse en sus asientos." with dissolve

# game/Kyou Epilogue.rpy:2452
translate spanish Epilogue_Con_Kyou_Hiroko_6bbf9cbe:

    # k "Those noises you hear from the audience only take you deeper down, boys and girls. Only take you deeper and deeper."
    k "Esos ruidos que escuchan de la audiencia solo los hacen caer más profundo, chicos y chicas. Tan solo los llevan más y más profundo."

# game/Kyou Epilogue.rpy:2455
translate spanish Epilogue_Con_Kyou_Hiroko_1e71186d:

    # k "And now on this final number, there will be nothing left. You will be dropping effortlessly into the deepest sleep; not a drop of tension anywhere in your body." with dissolve
    k "Y con este último número, ya no quedará nada. Caerán al sueño más profundo posible; no habrá ni una sola gota de tensión en todo su cuerpo." with dissolve

# game/Kyou Epilogue.rpy:2456
translate spanish Epilogue_Con_Kyou_Hiroko_c462971c:

    # k "Are you ready? Exhale slowly now..."
    k "¿Están listos? Ahora exhalen lentamente..."

# game/Kyou Epilogue.rpy:2458
translate spanish Epilogue_Con_Kyou_Hiroko_86e7a3a3:

    # k "One." with dissolve
    k "Uno." with dissolve

# game/Kyou Epilogue.rpy:2460
translate spanish Epilogue_Con_Kyou_Hiroko_41ef086b:

    # "There's another excited whoop from the audience members as the guy to my left pretty much collapses onto poor Nozomi, who nevertheless holds fast in her seat." with dissolve
    "Y suena otro alarido más de la audiencia en cuanto las personas sentadas se colapsan unas sobre las otras." with dissolve

# game/Kyou Epilogue.rpy:2463
translate spanish Epilogue_Con_Kyou_Hiroko_fc2daba1:

    # "And yeah, I can tell that guy seated at the end is faking. Whatever, so long as he plays along." with dissolve
    "Y sí, me doy cuenta de que el tipo de allá está fingiendo. Como sea, en tanto siga la corriente." with dissolve

# game/Kyou Epilogue.rpy:2466
translate spanish Epilogue_Con_Kyou_Hiroko_51c3e1f9:

    # k "That's right, so deeply relaxed, all the tension completely gone from your bodies... feeling so completely hypnotized." with dissolve
    k "Eso es, profundamente relajados. Toda la tensión ha abandonado por completo sus cuerpos... Sintiéndose completamente hipnotizados." with dissolve

# game/Kyou Epilogue.rpy:2411
translate spanish Epilogue_Con_Kyou_Hiroko_e21094bc:

    # "With an eye on the clock, I can see I need to wrap this up soon."
    "Echándole un ojo al reloj, veo que ya casi es hora de terminar."

# game/Kyou Epilogue.rpy:2412
translate spanish Epilogue_Con_Kyou_Hiroko_f2d4804e:

    # "I was a bit nervous to start, and it took a while to find more than a couple volunteers for this stuff."
    "Estaba un poco nervioso al principio, y me tomó un rato encontrar más que solo un par de voluntarios para esto."

# game/Kyou Epilogue.rpy:2413
translate spanish Epilogue_Con_Kyou_Hiroko_da61808e:

    # "But that's okay, I can still do one more trick with them, just like I rehearsed."
    "Pero está bien, aún puedo hacer un tuco más con ellos, tal como lo ensayé."

# game/Kyou Epilogue.rpy:2471
translate spanish Epilogue_Con_Kyou_Hiroko_0f9b02d8:

    # "I'll just start by reaching down and touching the shoulders of someone I know will be reliable." with dissolve
    "Comenzaré tocando el hombro de alguien con quien sé que puedo contar." with dissolve

# game/Kyou Epilogue.rpy:2472
translate spanish Epilogue_Con_Kyou_Hiroko_d9a361e0:

    # k "But now you and only you, whose shoulder I am currently touching, can sit back up in your chair."
    k "Y ahora tú, y solamente tú, a quien le estoy tocando el hombro en este momento, puedes erguirte en tu asiento."

# game/Kyou Epilogue.rpy:2476
translate spanish Epilogue_Con_Kyou_Hiroko_e354c793:

    # h "..." with dissolve
    h "..." with dissolve

# game/Kyou Epilogue.rpy:2420
translate spanish Epilogue_Con_Kyou_Hiroko_9b7bc2d4:

    # r "Ahaha, leave her alone, ball boy!"
    r "¡Jajaja, déjala en paz, recogepelotas!"

# game/Kyou Epilogue.rpy:2481
translate spanish Epilogue_Con_Kyou_Hiroko_e0b2a01f:

    # k "And as I speak to you, you will realize that you are now a cat. You will only be able to think and act like a cat. Do you understand?"
    k "Y mientras te hablo, te darás cuenta de que ahora eres una gata. Solo podrás pensar como gata. ¿Comprendes?"

# game/Kyou Epilogue.rpy:2482
translate spanish Epilogue_Con_Kyou_Hiroko_2a47964c:

    # h "Mew..."
    h "Miau..."

# game/Kyou Epilogue.rpy:2484
translate spanish Epilogue_Con_Kyou_Hiroko_c90bc400:

    # "That gets a loud chuckle from everyone on its own."
    "Tan solo eso les saca una fuerte carcajada a todos."

# game/Kyou Epilogue.rpy:2486
translate spanish Epilogue_Con_Kyou_Hiroko_01866982:

    # k "Now when I snap my fingers, Hiroko, you will be able to leave your seat and roam around the stage as a cat. Three, two, one..." with dissolve
    k "Y cuando truene los dedos, podrás dejar tu asiento y recorrer el escenario como una gata. Tres, dos, uno..." with dissolve

# game/Kyou Epilogue.rpy:2492
translate spanish Epilogue_Con_Kyou_Hiroko_62af7c55:

    # h "Mroww..."
    h "Muauu..."

# game/Kyou Epilogue.rpy:2435
translate spanish Epilogue_Con_Kyou_Hiroko_84129385:

    # "The audience erupts as she drops on all fours from her chair and crawls around the stage for a moment before crouching to lick her hand."
    "La audiencia estalla al verla caer de su silla en cuatro patas, gatear por el escenario por un momento y luego ponerse de cuclillas para lamer su mano."

# game/Kyou Epilogue.rpy:2436
translate spanish Epilogue_Con_Kyou_Hiroko_7b39a317:

    # "I look her over before moving on, just to quickly check on her, as I know she's been anxious about doing this stuff in public."
    "La observo un momento antes de continuar, solo para ver cómo está, pues sé que estaba nerviosa por hacer estas cosas en público."

# game/Kyou Epilogue.rpy:2437
translate spanish Epilogue_Con_Kyou_Hiroko_34e129dd:

    # "But I smile as she seems contented amidst the cacophany of laughter before her."
    "Pero sonrío al ver que luce contenta entre la cacofonía de risas que la rodea."

# game/Kyou Epilogue.rpy:2501
translate spanish Epilogue_Con_Kyou_Hiroko_928276d7:

    # "Now I clap my hand on the shoulder of the guy at the end of the row, the one I think is faking." with dissolve
    "Ahora coloco mi mano en el hombro del chico de la última silla, el que creo que está fingiendo." with dissolve

# game/Kyou Epilogue.rpy:2439
translate spanish Epilogue_Con_Kyou_Hiroko_8d8594d7:

    # "Let's see how good an actor he is."
    "Veamos qué tan bien actúa."

# game/Kyou Epilogue.rpy:2503
translate spanish Epilogue_Con_Kyou_Hiroko_7a8f2a3e:

    # k "And now you, whose shoulder I am touching, you can sit back up in your chair and realize you are a dog."
    k "Y ahora tú, al que le estoy tocando el hombro, puedes erguirte en tu silla y descubrir que eres un perro."

# game/Kyou Epilogue.rpy:2504
translate spanish Epilogue_Con_Kyou_Hiroko_8c27108f:

    # k "You will only be able to think and act like a dog, understand?"
    k "Solo podrás pensar como perro, ¿comprendes?"

# game/Kyou Epilogue.rpy:2442
translate spanish Epilogue_Con_Kyou_Hiroko_1d844baf:

    # tc "Uh, woof?"
    tc "Eh, ¿guau?"

# game/Kyou Epilogue.rpy:2444
translate spanish Epilogue_Con_Kyou_Hiroko_0844e61b:

    # r "Faaaake!"
    r "¡Faaalsoooo!"

# game/Kyou Epilogue.rpy:2445
translate spanish Epilogue_Con_Kyou_Hiroko_be973100:

    # s "{size=14}Risa, please.{/size}"
    s "{size=14}Risa, por favor.{/size}"

# game/Kyou Epilogue.rpy:2446
translate spanish Epilogue_Con_Kyou_Hiroko_40bc5df3:

    # r "{size=14}What?{/size}"
    r "{size=14}¿Qué?{/size}"

# game/Kyou Epilogue.rpy:2510
translate spanish Epilogue_Con_Kyou_Hiroko_c3b33ca9:

    # k "So now when I snap my fingers, you will be able to leave your seat and roam the stage as a dog. Three, two, one-"
    k "Y cuando truene los dedos, podrás dejar tu asiento y recorrer el escenario como perro. Tres, dos, uno-"

# game/Kyou Epilogue.rpy:2513
translate spanish Epilogue_Con_Kyou_Hiroko_c5c80237:

    # "And at the snap of my fingers the guy drops on all fours and starts barking somewhat unconvincingly, which Hiroko immediately seems to notice." with blink
    "En cuanto chasqueo, el chico cae en cuatro patas y empieza a ladrar de forma no muy convincente, lo cual Hiroko parece notar de inmediato." with blink

# game/Kyou Epilogue.rpy:2520
translate spanish Epilogue_Con_Kyou_Hiroko_329453e8:

    # "I watch with the audience as he crawls over to Hiroko's crouched form, barking intermittently." with dissolve
    "Tanto yo como la audiencia lo vemos gatear hacia Hiroko, ladrando intermitentemente." with dissolve

# game/Kyou Epilogue.rpy:2453
translate spanish Epilogue_Con_Kyou_Hiroko_07c66360:

    # "And in response she gets up on her hind \"legs\" and raises a hand."
    "Y en respuesta ella se para en dos \"patas\" y levanta una mano."

# game/Kyou Epilogue.rpy:2524
translate spanish Epilogue_Con_Kyou_Hiroko_3679313b:

    # h "HSSSSSSSSS!" with vpunch
    h "¡JJJJJJSSS!" with vpunch

# game/Kyou Epilogue.rpy:2458
translate spanish Epilogue_Con_Kyou_Hiroko_ef981b5f:

    # tc "O-oh shit!"
    tc "¡O-oh, mierda!"

# game/Kyou Epilogue.rpy:2461
translate spanish Epilogue_Con_Kyou_Hiroko_62c7b3bb:

    # "I can't stop myself from laughing with everyone else as Hiroko swings her paw and narrowly misses this dude's cheek..."
    "No puedo evitar reírme junto a todos los demás cuando Hiroko triza un zarpazo y por poco golpea el cuello del chico..."

# game/Kyou Epilogue.rpy:2464
translate spanish Epilogue_Con_Kyou_Hiroko_e4770fba:

    # "... before he jumps up to his feet and runs off the stage with Hiroko in hot pursuit."
    "... y entonces él se pone de pie y se va corriendo del escenario con Hiroko persiguiéndolo."

# game/Kyou Epilogue.rpy:2465
translate spanish Epilogue_Con_Kyou_Hiroko_62ce575b:

    # "Thankfully she doesn't chase him beyond the stage as he flees into the audience."
    "Afortunadamente no lo persigue más allá del escenario y él se mezcla en la audiencia."

# game/Kyou Epilogue.rpy:2466
translate spanish Epilogue_Con_Kyou_Hiroko_1dea4416:

    # "I... don't know what else I expected."
    "No... sé qué otra cosa esperaba."

# game/Kyou Epilogue.rpy:2532
translate spanish Epilogue_Con_Kyou_Hiroko_9520eebc:

    # ks smile "O-okay, Hiroko, come over here... good kitty."
    ks smile "M-muy bien, Hiroko, ven aquí... linda gatita."

# game/Kyou Epilogue.rpy:2472
translate spanish Epilogue_Con_Kyou_Hiroko_cb31e474:

    # "I smile and beckon as she smiles back and pads over to me on all fours, purring."
    "La llamo con una sonrisa. Ella sonríe también y camina hacia mí en cuatro patas, ronroneando."

# game/Kyou Epilogue.rpy:2475
translate spanish Epilogue_Con_Kyou_Hiroko_6ce765f1:

    # ks "That's a good kitty... now..."
    ks "Buena gatita... ahora..."

# game/Kyou Epilogue.rpy:2476
translate spanish Epilogue_Con_Kyou_Hiroko_0ebf763e:

    # "Taking her hand in mine, I tug it firmly across and raise my voice."
    "Tomándola de la mano, tiro firmemente de su brazo y elevo la voz."

# game/Kyou Epilogue.rpy:2478
translate spanish Epilogue_Con_Kyou_Hiroko_9cb1cf91:

    # ks "Sleep!" with dissolve
    ks "¡Duerme!" with dissolve

# game/Kyou Epilogue.rpy:2481
translate spanish Epilogue_Con_Kyou_Hiroko_e76653af:

    # "As her head droops I guide her gently to the floor."
    "Su cabeza cae y yo la guío gentilmente al suelo."

# game/Kyou Epilogue.rpy:2484
translate spanish Epilogue_Con_Kyou_Hiroko_061276a1:

    # ks "Good kitty, nice and deep."
    ks "Buena gatita, muy profundo."

# game/Kyou Epilogue.rpy:2485
translate spanish Epilogue_Con_Kyou_Hiroko_39b5154b:

    # "But as I look up I see Mr. Kobayashi pointing to his wrist. Time's up."
    "Pero cuando elevo la mirada, veo al profesor Kobayashi apuntando a su muñeca. Se acabó el tiempo."

# game/Kyou Epilogue.rpy:2554
translate spanish Epilogue_Con_Kyou_Hiroko_5061d226:

    # k "Okay, well, I hope everyone enjoyed that and, don't worry, I'll make sure they're all back to normal before I let them go." with dissolve
    k "Muy bien, espero que todos lo hayan disfrutado, y no se preocupen, me aseguraré de que todos vuelvan a la normalidad antes de dejarlos ir." with dissolve

# game/Kyou Epilogue.rpy:2556
translate spanish Epilogue_Con_Kyou_Hiroko_822bdf0a:

    # k "Enjoy the rest of the festival!" with dissolve
    k "¡Disfruten del resto del festival!" with dissolve

# game/Kyou Epilogue.rpy:2558
translate spanish Epilogue_Con_Kyou_Hiroko_d4b2df8e:

    # "I'm beaming with pride and adrenaline as I get a hearty round of applause."
    "Rebosante de orgullo y adrenalina, recibo una fuerte ronda de aplausos."

# game/Kyou Epilogue.rpy:2491
translate spanish Epilogue_Con_Kyou_Hiroko_9e909628:

    # "But I can't enjoy it too much right now. I need to tend to these volunteers before the next act is up..."
    "Pero no puedo quedarme mucho tiempo a disfrutarlo. Tengo que atender a estos voluntarios antes de que comience el próximo acto."

# game/Kyou Epilogue.rpy:2503
translate spanish Epilogue_Con_Kyou_Hiroko_c5d1dfc3:

    # ks smile "So, uh, what did you think?"
    ks smile "Y, eh, ¿qué les pareció?"

# game/Kyou Epilogue.rpy:2504
translate spanish Epilogue_Con_Kyou_Hiroko_82fdb1e3:

    # "After all was said and done, I meet up with Hiroko, Nozomi and their friends while the rest of the culture fest carried on without us."
    "Al terminar, me reúno con Hiroko, Nozomi y sus amigas mientras el resto del festival cultural continúa sin nosotros."

# game/Kyou Epilogue.rpy:2505
translate spanish Epilogue_Con_Kyou_Hiroko_f0d23c8e:

    # s uniform_folded "It was interesting how your show differed from Satoshi's last year." with dissolve
    s uniform_folded "Fue interesante cómo tu acto difirió del de Satoshi del año pasado." with dissolve

# game/Kyou Epilogue.rpy:2506
translate spanish Epilogue_Con_Kyou_Hiroko_96e5b350:

    # s smirk "Although more entertaining to me was the involvement of these two." with dissolve
    s smirk "Aunque lo que más me entretuvo fue la participación de estas dos." with dissolve

# game/Kyou Epilogue.rpy:2507
translate spanish Epilogue_Con_Kyou_Hiroko_40c31fcc:

    # r smile_side "Right? I mean, I was sorta expecting to see the fake chicken lady again." with dissolve
    r smile_side "Sí, ¿verdad? O sea, me espera ver otra vez lo de la gallina falsa." with dissolve

# game/Kyou Epilogue.rpy:2508
translate spanish Epilogue_Con_Kyou_Hiroko_b848feb8:

    # n side frown_side blush "N-Now wait just a minute-{w=1.0}{nw}" with dissolve
    n side frown_side blush "O-Oye, espera un minuto-{w=1.0}{nw}" with dissolve

# game/Kyou Epilogue.rpy:2510
translate spanish Epilogue_Con_Kyou_Hiroko_ebe16c27:

    # r uniform_armup smug_side "But you, Hiro? Putting on a show like this?" with dissolve
    r uniform_armup smug_side "Pero ¿tú, Hiro? ¿Dar un espectáculo como ese?" with dissolve

# game/Kyou Epilogue.rpy:2511
translate spanish Epilogue_Con_Kyou_Hiroko_aecc0f1c:

    # r "Didn't think you'd be up for this sort of thing."
    r "No creí que te fueras a apuntar a algo así."

# game/Kyou Epilogue.rpy:2512
translate spanish Epilogue_Con_Kyou_Hiroko_358452b0:

    # h frown_side "I was paying him back for that racket, y'know? Sides..." with dissolve
    h frown_side "Solo le estaba pagando la raqueta. Aparte..." with dissolve

# game/Kyou Epilogue.rpy:2513
translate spanish Epilogue_Con_Kyou_Hiroko_ef1d7805:

    # "She lets a moment pass in silence before shrugging."
    "Deja pasar un momento de silencio para luego encogerse de hombros."

# game/Kyou Epilogue.rpy:2514
translate spanish Epilogue_Con_Kyou_Hiroko_bb96f23f:

    # h sleep "It was pretty fun." with dissolve
    h sleep "Estuvo divertido." with dissolve

# game/Kyou Epilogue.rpy:2515
translate spanish Epilogue_Con_Kyou_Hiroko_df165d37:

    # n front concerned noblush "Yes. It was a shame you didn't have more time for your act. I did what I could, but there were a lot of people wanting to perform this year." with dissolve
    n front concerned noblush "Sí. Qué lástima que no tuviste más tiempo. Hice lo que pude, pero había mucha gente queriendo hacer algo este año." with dissolve

# game/Kyou Epilogue.rpy:2516
translate spanish Epilogue_Con_Kyou_Hiroko_0e0674ce:

    # ks "I'm just happy it went okay. And after that, I kinda want to do it again real soon."
    ks "Me alegra que saliera bien. Y después de esto, creo que me gustaría volverlo a hacer pronto."

# game/Kyou Epilogue.rpy:2517
translate spanish Epilogue_Con_Kyou_Hiroko_d23bd5ef:

    # n smile "Well, let me know when and I'll do absolutely everything I can to help~" with dissolve
    n smile "Bueno, hazme saber cuándo y haré todo lo posible por ayudar." with dissolve

# game/Kyou Epilogue.rpy:2520
translate spanish Epilogue_Con_Kyou_Hiroko_70d3e693:

    # h neutral_side "..." with dissolve
    h neutral_side "..." with dissolve

# game/Kyou Epilogue.rpy:2521
