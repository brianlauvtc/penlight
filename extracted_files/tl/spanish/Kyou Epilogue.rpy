    s alert_irritated blush "... Volverme adicta a ella... ¡solo para negármela en mi momento de necesidad!" with dissolve

# game/Kyou Epilogue.rpy:4999
translate spanish Epilogue_NonCon_Kyou_Sayori_Doll_d72f2994:

    # "She hasn't been this way since..."
    "No había estado así desde..."

# game/Kyou Epilogue.rpy:5000
translate spanish Epilogue_NonCon_Kyou_Sayori_Doll_083e1516:

    # ks frown "Sayori, come on!"
    ks frown "¡Sayori, por favor!"

# game/Kyou Epilogue.rpy:5001
translate spanish Epilogue_NonCon_Kyou_Sayori_Doll_11b12fc3:

    # "Since our last fight."
    "Desde nuestra última pelea."

# game/Kyou Epilogue.rpy:5002
translate spanish Epilogue_NonCon_Kyou_Sayori_Doll_2f8d588d:

    # s alert_annoyed_right "I can't allow it." with dissolve
    s alert_annoyed_right "No puedo permitirlo." with dissolve

# game/Kyou Epilogue.rpy:5003
translate spanish Epilogue_NonCon_Kyou_Sayori_Doll_a1e35e39:

    # ks angry "Sayori! People are looking-{w=0.5}{nw}"
    ks angry "¡Sayori! Hay gente mirando-{w=0.5}{nw}"

# game/Kyou Epilogue.rpy:5004
translate spanish Epilogue_NonCon_Kyou_Sayori_Doll_47e0e1d8:

    # s maid alert_angry_right "I WON'T allow it!" with vpunch
    s maid alert_angry_right "¡No VOY a permitirlo!" with vpunch

# game/Kyou Epilogue.rpy:5005
translate spanish Epilogue_NonCon_Kyou_Sayori_Doll_e20420b4:

    # "Shit, I gotta calm her down. Manage the situation, just as I've been managing her this past couple weeks."
    "Mierda, tengo que calmarla. Manejar esta situación, como he estado manejando por ella las últimas semanas."

# game/Kyou Epilogue.rpy:5007
translate spanish Epilogue_NonCon_Kyou_Sayori_Doll_5292bdcb:

    # ks sigh "A-alright! We'll work something out but just... stop, okay? You're making a scene."
    ks sigh "¡E-está bien! Ya nos las arreglaremos, pero... detente, ¿sí? Estás haciendo una escena."

# game/Kyou Epilogue.rpy:5010
translate spanish Epilogue_NonCon_Kyou_Sayori_Doll_83e02267:

    # "Sayori takes a sudden breath and glances around us, as if she's just remembered where we are." with dissolve
    "Sayori toma aire abruptamente y mira a nuestro alrededor, como si recién recordara dónde estamos." with dissolve

# game/Kyou Epilogue.rpy:5011
translate spanish Epilogue_NonCon_Kyou_Sayori_Doll_ba5b76f4:

    # s maid_handup alert_concerned_right "Ah... I apologize. That was unseemly of me." with dissolve
    s maid_handup alert_concerned_right "Ah... mil disculpas. Eso fue impropio de mi parte." with dissolve

# game/Kyou Epilogue.rpy:5012
translate spanish Epilogue_NonCon_Kyou_Sayori_Doll_bd8d07de:

    # s alert_sleeptalk "But don't you see? This merely reinforces my point." with dissolve
    s alert_sleeptalk "Pero ¿no lo ves? Esto meramente refuerza mi punto." with dissolve

# game/Kyou Epilogue.rpy:5013
translate spanish Epilogue_NonCon_Kyou_Sayori_Doll_cc8b55ca:

    # s maid "I remain uncentered. Unfocused. Unready." with dissolve
    s maid "Continúo descentrada. Desconcentrada. Desorientada." with dissolve

# game/Kyou Epilogue.rpy:5014
translate spanish Epilogue_NonCon_Kyou_Sayori_Doll_4ba729e5:

    # ks neutral "Sayori..."
    ks neutral "Sayori..."

# game/Kyou Epilogue.rpy:5015
translate spanish Epilogue_NonCon_Kyou_Sayori_Doll_0523a0dc:

    # s alert_concerned_right "I need to be hypnotized. And you are the only one I can turn to." with dissolve
    s alert_concerned_right "Necesito ser hipnotizada. Y tú eres el único a quien puedo acudir." with dissolve

# game/Kyou Epilogue.rpy:5017
translate spanish Epilogue_NonCon_Kyou_Sayori_Doll_0c738a88:

    # "As she speaks, Sayori steps a little closer and gently takes my hands in hers as she looks to me pleadingly." with dissolve
    "Mientras habla, Sayori da un pequeño paso hacia mí y toma mis manos con una mirada suplicante." with dissolve

# game/Kyou Epilogue.rpy:5018
translate spanish Epilogue_NonCon_Kyou_Sayori_Doll_3b14bc09:

    # s alert_drowsy "You are the only one who can make me wonderful." with dissolve
    s alert_drowsy "Eres el único que puede hacerme sentir maravillosa." with dissolve

# game/Kyou Epilogue.rpy:5019
translate spanish Epilogue_NonCon_Kyou_Sayori_Doll_8e0642d1:

    # s alert_sleeptalk "So please... make me your doll." with dissolve
    s alert_sleeptalk "Así que, por favor... hazme tu muñeca." with dissolve

# game/Kyou Epilogue.rpy:5020
translate spanish Epilogue_NonCon_Kyou_Sayori_Doll_ba7e65fd:

    # s alert_sleeptalk_concerned "Make me free again." with dissolve
    s alert_sleeptalk_concerned "Hazme libre otra vez." with dissolve

# game/Kyou Epilogue.rpy:5021
translate spanish Epilogue_NonCon_Kyou_Sayori_Doll_a3ddf0d5:

    # "Well... again, it's not like I don't want to."
    "Bueno... como dije, no es que no quiera."

# game/Kyou Epilogue.rpy:5023
translate spanish Epilogue_NonCon_Kyou_Sayori_Doll_387a5b3f:

    # ks neutral "Let's go home, Sayori."
    ks neutral "Vamos a casa, Sayori."

# game/Kyou Epilogue.rpy:5025
translate spanish Epilogue_NonCon_Kyou_Sayori_Doll_a06d3fa5:

    # "And if she truly needs it this much..."
    "Y si en serio lo necesita tanto..."

# game/Kyou Epilogue.rpy:5027
translate spanish Epilogue_NonCon_Kyou_Sayori_Doll_4ba7e6ad:

    # "... Then I'll take her to the only place she feels she can be free."
    "... La llevaré al único lugar en el que siente que puede ser libre."

# game/Kyou Epilogue.rpy:5028
translate spanish Epilogue_NonCon_Kyou_Sayori_Doll_f3feeb00:

    # "Free of stress. Free of thought. Free of any semblance of personal responsibility."
    "Libre de estrés. Libre de pensamientos. Libre de toda semblanza de responsabilidad personal."

# game/Kyou Epilogue.rpy:5030
translate spanish Epilogue_NonCon_Kyou_Sayori_Doll_9a9b7069:

    # ks neutral "It's alright now, Sayori."
    ks neutral "Descuida, Sayori."

# game/Kyou Epilogue.rpy:5031
translate spanish Epilogue_NonCon_Kyou_Sayori_Doll_54597d8b:

    # ks "I thought you only needed a reset, a little chance to center yourself, but it's clear your problems go so much deeper."
    ks "Creí que solo necesitabas un respiro, una pequeña oportunidad de centrarte, pero está claro que tus problemas van mucho más profundo."

# game/Kyou Epilogue.rpy:5032
translate spanish Epilogue_NonCon_Kyou_Sayori_Doll_97abda24:

    # ks neutral "You still need me. And I want you to know that's okay."
    ks neutral "Aún me necesitas. Y quiero que sepas que eso está bien."

# game/Kyou Epilogue.rpy:5033
translate spanish Epilogue_NonCon_Kyou_Sayori_Doll_1ed59217:

    # ks "I mean, it feels good to be needed. And besides, I sorta need you too, Sayori."
    ks "Digo, se siente bien ser necesitado. Y además, creo que yo también te necesito a ti, Sayori."

# game/Kyou Epilogue.rpy:5038
translate spanish Epilogue_NonCon_Kyou_Sayori_Doll_e1554201:

    # s "..."
    s "..."

# game/Kyou Epilogue.rpy:5039
translate spanish Epilogue_NonCon_Kyou_Sayori_Doll_9548dc60:

    # ks "So... it's fine. This is fine."
    ks "Así que... está bien. Esto está bien."

# game/Kyou Epilogue.rpy:5040
translate spanish Epilogue_NonCon_Kyou_Sayori_Doll_19e2d589:

    # ks "You can come to me any time you want and I'll be here. Here to help you manage your stress and get you working again, so don't worry."
    ks "Puedes venir a mí cuando desees y yo estaré aquí. Estaré aquí para ayudarte a manejar tu estrés y ponerte de vuelta en marcha, así que no te preocupes."

# game/Kyou Epilogue.rpy:5041
translate spanish Epilogue_NonCon_Kyou_Sayori_Doll_4c05370b:

    # ks "I'll be responsible for both of us from now on."
    ks "Seré responsable por ambos de ahora en adelante."

# game/Kyou Epilogue.rpy:5042
translate spanish Epilogue_NonCon_Kyou_Sayori_Doll_24c4f383:

    # ks "And in return... you'll be my doll."
    ks "Y a cambio... tú serás mi muñeca."

# game/Kyou Epilogue.rpy:5043
translate spanish Epilogue_NonCon_Kyou_Sayori_Doll_3a6d1a4d:

    # ks "You'll look pretty for me. Let me play with you."
    ks "Te verás bonita para mí. Me dejarás jugar contigo."

# game/Kyou Epilogue.rpy:5044
translate spanish Epilogue_NonCon_Kyou_Sayori_Doll_4edd3ede:

    # ks "Because that's what you want... isn't it, Sayori?"
    ks "Porque eso es lo que quieres... ¿no es así, Sayori?"

# game/Kyou Epilogue.rpy:5045
translate spanish Epilogue_NonCon_Kyou_Sayori_Doll_e1554201_1:

    # s "..."
    s "..."

# game/Kyou Epilogue.rpy:5046
translate spanish Epilogue_NonCon_Kyou_Sayori_Doll_30fc0c00:

    # ks "We don't need anyone else. Do we?"
    ks "No necesitamos a nadie más. ¿O sí?"

# game/Kyou Epilogue.rpy:5047
translate spanish Epilogue_NonCon_Kyou_Sayori_Doll_e1554201_2:

    # s "..."
    s "..."

# game/Kyou Epilogue.rpy:5048
translate spanish Epilogue_NonCon_Kyou_Sayori_Doll_07ddeb19:

    # "Satisfied, I smile back at my doll sitting so ornamentally on my bed. So perfectly at peace with herself."
    "Satisfecho, le sonrío a mi muñeca, sentada ornamentalmente en mi cama. Perfectamente en paz consigo misma."

# game/Kyou Epilogue.rpy:5049
translate spanish Epilogue_NonCon_Kyou_Sayori_Doll_91a62723:

    # ks smile "Yeah. That's what I thought. Then it's settled."
    ks smile "Sí. Eso pensé. Entonces está decidido."

# game/Kyou Epilogue.rpy:5051
translate spanish Epilogue_NonCon_Kyou_Sayori_Doll_cda538c4:

    # ks "I'll take care of everything..."
    ks "Yo me encargaré de todo..."
# TODO: Translation updated at 2022-08-31 22:23

# game/Kyou Epilogue.rpy:2514
translate spanish Epilogue_Reversal_Good_Nozomi_5528c03c:

    # "So that was last night..."
    "Pues eso pasó anoche..."

# game/Kyou Epilogue.rpy:2515
translate spanish Epilogue_Reversal_Good_Nozomi_fbe9188d:

    # "As I get myself ready for school this morning, I'm still not sure how to feel about everything that went down."
    "Mientras me preparo para la escuela esta mañana, aún no estoy seguro de cómo sentirme con todo lo que ocurrió."

# game/Kyou Epilogue.rpy:2517
translate spanish Epilogue_Reversal_Good_Nozomi_c86712a6:

    # "All the work I put into learning hypnosis for her, and building that penlight, and it seems all we have to show for it is a load of trouble."
    "Todo el empeño que puse en aprender hipnosis para ella, y fabricar esa linterna, y parece que lo único que nos trajo fue un montón de problemas."

# game/Kyou Epilogue.rpy:2518
translate spanish Epilogue_Reversal_Good_Nozomi_222d865f:

    # "I can't exactly blame Nozomi if she wanted to step away from everything."
    "No podría culpar a Nozomi si quisiera alejarse de todo."

# game/Kyou Epilogue.rpy:2519
translate spanish Epilogue_Reversal_Good_Nozomi_b34af990:

    # "But she said she wanted to live up to what I said? About being a good hypnotist?"
    "Pero ¿dijo que quiere estar a la altura de lo que dije? ¿Sobre ser una buena hipnotista?"

# game/Kyou Epilogue.rpy:2520
translate spanish Epilogue_Reversal_Good_Nozomi_42654748:

    # "I wonder what she really meant by that. Are things really going to be any different now, Nozomi?"
    "Me pregunto qué quiso decir con eso. ¿En serio cambiarán las cosas ahora, Nozomi?"

# game/Kyou Epilogue.rpy:2522
translate spanish Epilogue_Reversal_Good_Nozomi_3a990933:

    # "Wait, hold that thought. My phone's ringing..."
    "Espera, aguarda. Mi teléfono está sonando..."

# game/Kyou Epilogue.rpy:2523
translate spanish Epilogue_Reversal_Good_Nozomi_fbb51362:

    # "Why is my phone ringing? No one ever calls me?!"
    "¿Por qué está sonando mi teléfono? ¡Nadie nunca me llama!"

# game/Kyou Epilogue.rpy:2528
translate spanish Epilogue_Reversal_Good_Nozomi_e0e6652b:

    # n "\"Kyou! Oh good, you're up!\""
    n "\"¡Kyou! ¡Oh, qué bien, estás despierto!\""

# game/Kyou Epilogue.rpy:2529
translate spanish Epilogue_Reversal_Good_Nozomi_2081f609:

    # ks surprised "N-Nozomi? Yeah, of course I'm up; it's a school day."
    ks surprised "¿N-Nozomi? Sí, claro que estoy despierto; hoy hay escuela."

# game/Kyou Epilogue.rpy:2530
translate spanish Epilogue_Reversal_Good_Nozomi_acf3cd8f:

    # n "\"Mhmhmh~ Well, it's a little early so I thought...\""
    n "\"Jejeje. Bueno, es algo temprano, así que pensé...\""

# game/Kyou Epilogue.rpy:2531
translate spanish Epilogue_Reversal_Good_Nozomi_fd638fdc:

    # n "\"A-ahem, anyway I just wanted to talk before school. Can we meet outside? Are you ready to go?\""
    n "\"E-ejem, en fin, solo quería hablar contigo antes de la escuela. ¿Podemos vernos afuera? ¿Ya estás listo para ir?\""

# game/Kyou Epilogue.rpy:2554
translate spanish Epilogue_Reversal_Good_Nozomi_36dc5fb8:

    # ks confused "Y... y-yeah, just gimme a minute. Where are you anyway?"
    ks confused "S... s-sí, solo dame un minuto. ¿Dónde estás, por cierto?"

# game/Kyou Epilogue.rpy:2533
translate spanish Epilogue_Reversal_Good_Nozomi_4f718701:

    # n "\"Um... Just come out when you can, okay?\""
    n "\"Em... Solo sal cuando puedas, ¿sí?\""

# game/Kyou Epilogue.rpy:2539
translate spanish Epilogue_Reversal_Good_Nozomi_4f990669:

    # "She... wow, she wanted to talk to me this badly, huh?"
    "Está... guau, tan impaciente estaba por hablar conmigo, ¿eh?"

# game/Kyou Epilogue.rpy:2540
translate spanish Epilogue_Reversal_Good_Nozomi_09c4d3fc:

    # n chuckle "Good morning!" with dissolve
    n chuckle "¡Buenos días!" with dissolve

# game/Kyou Epilogue.rpy:2541
translate spanish Epilogue_Reversal_Good_Nozomi_e14ee8ba:

    # ks smile "M... morning!"
    ks smile "¡B... buenos días!"

# game/Kyou Epilogue.rpy:2543
translate spanish Epilogue_Reversal_Good_Nozomi_467b481e:

    # n "S-so, um... I wanted to ask how you're feeling after... you know?" with dissolve
    n "P-pues, em... quería preguntarte cómo te sientes después de... ¿ya sabes?" with dissolve

# game/Kyou Epilogue.rpy:2544
translate spanish Epilogue_Reversal_Good_Nozomi_fb6c80dc:

    # "She seems to examine my expression as I examine her back."
    "Parece examinar mi expresión, mientras yo examino la suya."

# game/Kyou Epilogue.rpy:2545
translate spanish Epilogue_Reversal_Good_Nozomi_b04624f7:

    # n "Still think you're clear-headed?"
    n "¿Aún crees tener la mente clara?"

# game/Kyou Epilogue.rpy:2546
translate spanish Epilogue_Reversal_Good_Nozomi_0528caf9:

    # "Damn, I don't know about that. Nozomi looks as bewitching as ever, maybe even more so when she's being like this."
    "Diablos, no estoy seguro. Nozomi luce tan cautivadora como siempre, tal vez incluso más al actuar así."

# game/Kyou Epilogue.rpy:2547
translate spanish Epilogue_Reversal_Good_Nozomi_94a8709e:

    # ks "I'm fine. Just a little surprised, that's all."
    ks "Estoy bien. Solo un tanto sorprendido."

# game/Kyou Epilogue.rpy:2548
translate spanish Epilogue_Reversal_Good_Nozomi_97cb7a79:

    # n happy blush "Yeah, I just... I really need you to be okay, that's all." with dissolve
    n happy blush "Sí, es que... en serio necesito que estés bien, es todo." with dissolve

# game/Kyou Epilogue.rpy:2549
translate spanish Epilogue_Reversal_Good_Nozomi_a506a3db:

    # n smile_side "But, um... come on, let's get going. We'll talk on the way." with dissolve
    n smile_side "Pero, em... vamos, hay que irnos. Hablaremos en el camino." with dissolve

# game/Kyou Epilogue.rpy:2559
translate spanish Epilogue_Reversal_Good_Nozomi_2b8a3a7e:

    # n "I'm still trying to make sense of it all, you know?"
    n "Aún intento asimilarlo todo, ¿sabes?"

# game/Kyou Epilogue.rpy:2560
translate spanish Epilogue_Reversal_Good_Nozomi_1fa32190:

    # n sad_side "A penlight that can literally control minds... it's just insane to think about what we had." with dissolve
    n sad_side "Una pluma linterna que literalmente puede controlar mentes... al pensar en lo que teníamos, me parece una locura." with dissolve

# game/Kyou Epilogue.rpy:2561
translate spanish Epilogue_Reversal_Good_Nozomi_b57a2d73:

    # ks neutral "A penight that I made, don't forget."
    ks neutral "Una pluma linterna que yo hice, no lo olvides."

# game/Kyou Epilogue.rpy:2562
translate spanish Epilogue_Reversal_Good_Nozomi_83a08492:

    # n surprised "Yeah! How is that even possible? I can't even imagine how you pulled that off!" with dissolve
    n surprised "¡Sí! ¿Cómo es eso posible? ¡Ni siquiera puedo imaginarme cómo lograste algo así!" with dissolve

# game/Kyou Epilogue.rpy:2563
translate spanish Epilogue_Reversal_Good_Nozomi_6197154b:

    # ks sigh "And we never will. It's gone now."
    ks sigh "Y nunca lo sabremos. Ahora se ha ido."

# game/Kyou Epilogue.rpy:2564
translate spanish Epilogue_Reversal_Good_Nozomi_75c8b5fa:

    # n sad "Yeah..." with dissolve
    n sad "Sí..." with dissolve

# game/Kyou Epilogue.rpy:2565
translate spanish Epilogue_Reversal_Good_Nozomi_7eb34aca:

    # n neutral_side "It's... it really is for the best that it's gone though, right?" with dissolve
    n neutral_side "Es... para mejor que se haya ido, ¿verdad?" with dissolve

# game/Kyou Epilogue.rpy:2566
translate spanish Epilogue_Reversal_Good_Nozomi_3beb13b6:

    # "She asks, and I think we both know the answer to that one, but I notice how she looks away from me as she says it."
    "Pregunta ella, y creo que ambos sabemos la respuesta, pero noto cómo aparta la mirada de mí al decirlo."

# game/Kyou Epilogue.rpy:2567
translate spanish Epilogue_Reversal_Good_Nozomi_76f54bc5:

    # ks neutral "Yeah... I mean, yeah of course it is."
    ks neutral "Sí... digo, claro que lo es."

# game/Kyou Epilogue.rpy:2568
translate spanish Epilogue_Reversal_Good_Nozomi_3c18062b:

    # n neutral "Right. Of course it is." with dissolve
    n neutral "Sí. Claro que lo es." with dissolve

# game/Kyou Epilogue.rpy:2569
translate spanish Epilogue_Reversal_Good_Nozomi_a7193f77:

    # n sad_side "... But is it wrong that a part of me still regrets that it's gone?" with dissolve
    n sad_side "... Pero ¿está mal que parte de mí aún lamente que se haya ido?" with dissolve

# game/Kyou Epilogue.rpy:2570
translate spanish Epilogue_Reversal_Good_Nozomi_0d4c8c36:

    # n "Even knowing what I know now, I still can't stop myself from playing it all back in my head and finding it..."
    n "Incluso sabiendo lo que ahora sé, aún no puedo evitar reproducirlo todo de nuevo en mi cabeza y me hace..."

# game/Kyou Epilogue.rpy:2571
translate spanish Epilogue_Reversal_Good_Nozomi_e9df76b3:

    # n sad_closed blush "Well... it still gets me going." with dissolve
    n sad_closed blush "Bueno... aún me pone ansiosa." with dissolve

# game/Kyou Epilogue.rpy:2572
translate spanish Epilogue_Reversal_Good_Nozomi_b3ea4fa2:

    # n sad "I've been trying not to think too deeply about it, but... is there something wrong with me, Kyou?" with dissolve
    n sad "He estado intentando no pensar mucho en ello, pero... ¿hay algo mal conmigo, Kyou?" with dissolve

# game/Kyou Epilogue.rpy:2575
translate spanish Epilogue_Reversal_Good_Nozomi_6f1bcaf3:

    # "She suddenly stops in her tracks, and I turn to her as she looks at me pensively." with dissolve
    "Sus pies frenan de repente, y yo volteo hacia ella mientras me mira pensativa." with dissolve

# game/Kyou Epilogue.rpy:2576
translate spanish Epilogue_Reversal_Good_Nozomi_c697c5f3:

    # n sleep "I know how close I came to taking over your mind with that thing. It wasn't just a fantasy that I pulled out of my imagination, or out of some weird manga." with dissolve
    n sleep "Sé lo cerca que estuve de apoderarme de tu mente con esa cosa. No fue una simple fantasía que saqué de mi imaginación, o de algún extraño manga." with dissolve

# game/Kyou Epilogue.rpy:2577
translate spanish Epilogue_Reversal_Good_Nozomi_194ecda1:

    # n sleeptalk "So why..." with dissolve
    n sleeptalk "Entonces, ¿por qué...?" with dissolve

# game/Kyou Epilogue.rpy:2578
translate spanish Epilogue_Reversal_Good_Nozomi_89212979:

    # n sleeptalk_concerned "Why am I still like this?" with dissolve
    n sleeptalk_concerned "¿Por qué aún me siento así?" with dissolve

# game/Kyou Epilogue.rpy:2520
translate spanish Epilogue_Reversal_Good_Nozomi_0df043fc:

    # "I sigh. Yeah, it's a little weird that a high school girl gets a kick out of controlling people's minds. Or even having her own mind taken over."
    "Suelto un suspiro. Sí, es un poco raro que a una chica de preparatoria le emocione así controlar la mente de alguien. O que alguien tome dominio de la suya."

# game/Kyou Epilogue.rpy:2580
translate spanish Epilogue_Reversal_Good_Nozomi_ef326274:

    # "It still surprises me that a girl as sweet as her would have such perverted thoughts."
    "Aún me sorprende que una chica tan dulce como ella pueda tener esos pensamientos pervertidos."

# game/Kyou Epilogue.rpy:2581
translate spanish Epilogue_Reversal_Good_Nozomi_cfbbfd7c:

    # ks sigh "Nozomi, there's nothing wrong with you, okay? Nothing could be further from the truth."
    ks sigh "Nozomi, no hay nada mal contigo, ¿de acuerdo? Nada puede estar más lejos de la realidad."

# game/Kyou Epilogue.rpy:2582
translate spanish Epilogue_Reversal_Good_Nozomi_87be810e:

    # "But since I've come to know that about her, I'm not sure I'd want it any other way."
    "Pero ahora que he conocido esa faceta de ella, no creo querer cambiarla por nada."

# game/Kyou Epilogue.rpy:2584
translate spanish Epilogue_Reversal_Good_Nozomi_cc97b215:

    # ks neutral "Yeah, maybe you got caught up in your fantasies or whatever, when we were doing all that stuff together. But when it got real? You did the right thing." with dissolve
    ks neutral "Sí, tal vez te dejaste llevar por tus fantasías o lo que sea cuando hicimos todo eso juntos. Pero ¿en el momento que se volvió real? Hiciste lo correcto." with dissolve

# game/Kyou Epilogue.rpy:2585
translate spanish Epilogue_Reversal_Good_Nozomi_8e437f92:

    # ks "That's what's important, Nozomi. So don't put yourself down; don't do that to yourself."
    ks "Eso es lo que importa, Nozomi. Así que no te tortures; no te hagas eso."

