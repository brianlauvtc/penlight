    # h neutral "Yeah, yeah. Stop admiring your pen and let's get it done already." with dissolve
    h neutral "Seh, seh. Deja de admirar tu pluma y terminemos de una vez." with dissolve

# game/Kyou 10.rpy:487
translate spanish Day10_Con_Kyou_Nozomi_Zombie_f99bd792:

