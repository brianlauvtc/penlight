    ks frown "No es una pluma. Es una pluma linterna."

# game/Kyou 10.rpy:490
translate spanish Day10_Con_Kyou_Nozomi_Zombie_17c880c9:

    # h frown "Oh, my bad. Don't mean to insult your lil' friend or anything." with dissolve
    h frown "Uy, perdón. No quise insultar a tu amiguita ni nada." with dissolve

# game/Kyou 10.rpy:491
