translate spanish Day10_Con_Kyou_Hiroko_Trickster_c112281e:

    # h happy_closed "H'yeah, hi. I'm [stagename]. Nice to meet ya~" with dissolve
    h happy_closed "Sí, hola. Soy [stagename]. Mucho gusto." with dissolve

# game/Kyou 10.rpy:2090
translate spanish Day10_Con_Kyou_Hiroko_Trickster_82761df8:

    # n chuckle "And I'm... HypnoTea. I might have talked to some of you in the chat before, ehehe~" with dissolve
    n chuckle "Y yo soy... HipnoTé. Puede que haya hablado con algunos de ustedes en el chat antes, ejeje." with dissolve

# game/Kyou 10.rpy:2091
translate spanish Day10_Con_Kyou_Hiroko_Trickster_5215af3c:

    # "\"HypnoTea\", huh? So that's what her chatroom name is. I'll have to remember that."
    "\"HipnoTé\", ¿eh? Conque ese es su nombre en el chat. Tendré que recordarlo."

# game/Kyou 10.rpy:2094
translate spanish Day10_Con_Kyou_Hiroko_Trickster_8cde2d47:

    # ks noblush "For our show tonight, I'm going to be hypnotizing [stagename] again. And... HypnoTea? She's here for... moral support. Mostly." with dissolve
    ks noblush "Para nuestro acto de esta noche, hipnotizaré a [stagename] una vez más. E... ¿HipnoTé? Ella está aquí... como apoyo moral. Más que nada." with dissolve

# game/Kyou 10.rpy:2095
translate spanish Day10_Con_Kyou_Hiroko_Trickster_012dbd36:

    # "I try to phrase my words carefully, so as not to antagonize Nozomi."
    "Intento elegir mis palabras con cuidado, para no antagonizar a Nozomi."

# game/Kyou 10.rpy:2096
translate spanish Day10_Con_Kyou_Hiroko_Trickster_d462bfc7:

    # n surprised "Uh... that's a lot of comments going on over there." with dissolve
    n surprised "Eh... esos son muchos comentarios." with dissolve

# game/Kyou 10.rpy:2097
translate spanish Day10_Con_Kyou_Hiroko_Trickster_943f1a52:

    # "Although I'm not even sure \"HypnoTea\" heard me just now. She seems to be watching my computer screen pretty intensely."
    "Aunque ni siquiera sé si \"HipnoTé\" me escuchó. Parece estar mirando la pantalla de mi computadora con intensidad."

# game/Kyou 10.rpy:2098
translate spanish Day10_Con_Kyou_Hiroko_Trickster_3f08a5fb:

    # "Can she even see what they're saying about her back there? She's not even wearing her glasses."
    "¿Siquiera puede ver lo que están diciendo desde ahí? Sobre todo sin sus anteojos."

# game/Kyou 10.rpy:2076
translate spanish Day10_Con_Kyou_Hiroko_Trickster_e8090e6b:

    # "Almost as if to answer my unspoken question, Nozomi jumps off the bed and patters over to my side to get a closer look at the chatroom."
    "Casi cual si en respuesta a mi no pronunciada pregunta, Nozomi salta de la cama y corre hasta donde estoy para mirar más de cerca la sala de chat."

# game/Kyou 10.rpy:2106
translate spanish Day10_Con_Kyou_Hiroko_Trickster_12390f1d:

    # n "Now let's see here..."
    n "Veamos..."

# game/Kyou 10.rpy:2078
translate spanish Day10_Con_Kyou_Hiroko_Trickster_d872ad7e:

    # ks casual confused "Uh, N-... H-HypnoTea? I was about to start."
    ks casual confused "Eh, N-... ¿Hi-hipnoTé? Estaba a punto de comenzar."

# game/Kyou 10.rpy:2108
translate spanish Day10_Con_Kyou_Hiroko_Trickster_4fe95b84:

    # n frown "Just a minute... what are you guys..." with dissolve
    n frown "Solo un minuto... ¿de qué tanto están...?" with dissolve

# game/Kyou 10.rpy:2109
translate spanish Day10_Con_Kyou_Hiroko_Trickster_5b72bad4:

    # n irritated "Ugh, well that's just typical. What kind of show do you all think this is?" with dissolve
    n irritated "Ay, típico. ¿Qué clase de espectáculo creen que es?" with dissolve

# game/Kyou 10.rpy:2110
translate spanish Day10_Con_Kyou_Hiroko_Trickster_ae302b49:

    # "I can't even tell what comment she just reacted to, as the page of chatroom comments is swiftly replaced with another flood of text as people start laughing at Nozomi's disgusted reaction."
    "Ni siquiera sé a qué comentario reaccionó, pues la página rápidamente es reemplazada por otra ola de texto de la gente riéndose de la reacción de disgusto de Nozomi."

# game/Kyou 10.rpy:2111
translate spanish Day10_Con_Kyou_Hiroko_Trickster_81c517a7:

    # n side frown "This is going to be good, clean fun. Me and [stagename] are here to have a good time, so please behave yourselves and don't ruin this for us." with dissolve
    n side frown "Será diversión limpia e inocente. [stagename] y yo vinimos a pasarla bien, así que por favor compórtense y no nos lo arruinen." with dissolve

# game/Kyou 10.rpy:2112
translate spanish Day10_Con_Kyou_Hiroko_Trickster_6a85b2fb:

    # n frown_side "... Yes, thank you, we ARE very cute, but we're not taking the masks off so you can get a better look at us." with dissolve
    n frown_side "... Sí, gracias, somos MUY lindas, pero no nos vamos a quitar la máscara para que puedan vernos mejor." with dissolve

# game/Kyou 10.rpy:2113
translate spanish Day10_Con_Kyou_Hiroko_Trickster_fa43135f:

    # n irritated "And... n-no, like Ky... I mean, MindCoder just said, I'm only here for moral support. I don't want to be hypnotized tonight, so stop asking." with dissolve
    n irritated "Y... n-no, como dijo Ky... digo, MindCoder, solo estoy aquí como apoyo moral. No quiero ser hipnotizada esta noche, así que dejen de preguntar." with dissolve

# game/Kyou 10.rpy:2086
translate spanish Day10_Con_Kyou_Hiroko_Trickster_0fc82a9a:

    # "And with that, Nozomi grumpily folds her arms and goes to sit back on the bed with Hiroko."
    "Y dicho eso, Nozomi se cruza de brazos malhumorada y vuelve a su asiento en la cama con Hiroko."

# game/Kyou 10.rpy:2087
translate spanish Day10_Con_Kyou_Hiroko_Trickster_cca4f6f0:

    # h "You okay there, bestie?"
    h "¿Estás bien, amiga?"

# game/Kyou 10.rpy:2088
translate spanish Day10_Con_Kyou_Hiroko_Trickster_38ef0500:

    # n "I suppose..."
    n "Supongo..."

# game/Kyou 10.rpy:2129
translate spanish Day10_Con_Kyou_Hiroko_Trickster_728314fb:

    # n concerned "But it's like they always say: Don't read the comments." with dissolve
    n concerned "Pero ya sabes lo que dicen: No leas los comentarios." with dissolve

# game/Kyou 10.rpy:2091
translate spanish Day10_Con_Kyou_Hiroko_Trickster_274a5c1e:

    # ks casual smile "Everyone's just excited. But anyway..."
    ks casual smile "Es que todos están muy emocionados. Pero, en fin..."

# game/Kyou 10.rpy:2133
translate spanish Day10_Con_Kyou_Hiroko_Trickster_99f31f64:

    # "I get up from my desk and step in front of Hiroko, whose eyes immediately swivel to look up at me from the bed." with dissolve
    "Me levanto de mi escritorio y me paro frente a Hiroko, cuyos ojos inmediatamente giran en mi dirección desde la cama." with dissolve

# game/Kyou 10.rpy:2134
translate spanish Day10_Con_Kyou_Hiroko_Trickster_f33241f8:

    # ks "I think it's time we got this show on the road, right, \"[stagename]\"?"
    ks "Creo que es hora de darle marcha a esto, ¿verdad, \"[stagename]\"?"

# game/Kyou 10.rpy:2136
translate spanish Day10_Con_Kyou_Hiroko_Trickster_62f869ca:

    # "I smile encouragingly at her, and Hiroko offers a shy, sleepy smile in reply." with dissolve
    "Le muestro una sonrisa alentadora, y Hiroko ofrece una tímida y soñolienta sonrisa en respuesta." with dissolve

# game/Kyou 10.rpy:2137
translate spanish Day10_Con_Kyou_Hiroko_Trickster_74fb8005:

    # h "Yeah. Let's do it."
    h "Sí. Hagámoslo."

# game/Kyou 10.rpy:2138
translate spanish Day10_Con_Kyou_Hiroko_Trickster_543e735c:

    # "She... really wants me to hypnotize her now. She's so completely convinced that this is what she needs to do."
    "En... serio quiere que la hipnotice. Está completamente convencida de que esto es lo que debe hacer."

# game/Kyou 10.rpy:2139
translate spanish Day10_Con_Kyou_Hiroko_Trickster_b1094ce6:

    # "You're so hypnotically suggestible it's unbelievable. And I'm so pumped that I get to have some more fun with you in front of all these people."
    "Eres tan hipnóticamente sugestionable que me es difícil creerlo. Y me emociona tanto poder divertirme contigo frente a toda esta gente."

# game/Kyou 10.rpy:2140
translate spanish Day10_Con_Kyou_Hiroko_Trickster_0c9a79e8:

    # ks "So, I'd like you to stand up here, nice and straight. And HypnoTea? Stand a little ways behind her, please."
    ks "Entonces, quiero que te pongas de pie, bien erguida. E, ¿HipnoTé? Párate detrás de ella, por favor."

# game/Kyou 10.rpy:2112
translate spanish Day10_Con_Kyou_Hiroko_Trickster_70ef208e:

    # "Having just read the script I gave them I'm sure they both remember this part, and they're quick to hop back to their feet and stand where I direct them."
    "Habiendo recién leído el libreto que les di, estoy seguro de que ambas recuerdan esta parte, y sin demora se levantan y posicionan donde indiqué."

# game/Kyou 10.rpy:2113
translate spanish Day10_Con_Kyou_Hiroko_Trickster_b9232eb0:

    # ks casual smile "Could you take maybe half a step forward, HypnoTea? Perfect. So now [stagename], I'd like you to plant your feet firmly on the floor and in a second, I want you to concentrate..."
    ks casual smile "¿Podrías dar medio paso adelante, HipnoTé? Perfecto. Y ahora, [stagename], me gustaría que plantes tus pies firmemente en el suelo y en un segundo, quiero que te concentres..."

# game/Kyou 10.rpy:2154
translate spanish Day10_Con_Kyou_Hiroko_Trickster_e23e9af1:

    # "It's then that I pull my penlight from out of my pocket and hold it aloft, just above Hiroko's eye level, and immediately she naturally begins to focus on it."
    "Entonces saco la linterna de mi bolsillo y la sostengo en lo alto, justo arriba de los ojos de Hiroko, y su impulso inmediato es concentrarse en ella."

# game/Kyou 10.rpy:2155
translate spanish Day10_Con_Kyou_Hiroko_Trickster_cc2e71e5:

    # n surprised "Oh, you're using one of those?" with dissolve
    n surprised "Oh, ¿vas a usar una de esas?" with dissolve

# game/Kyou 10.rpy:2156
translate spanish Day10_Con_Kyou_Hiroko_Trickster_3973afae:

    # "I spare a smile for Nozomi before I begin the induction I had planned."
    "Le arrojo una rápida sonrisa a Nozomi antes de comenzar la inducción que tenía planeada."

# game/Kyou 10.rpy:2157
translate spanish Day10_Con_Kyou_Hiroko_Trickster_bd9c51ba:

    # ks "Yeah. [stagename]'s really good at eye-fixation inductions. Aren't you, [stagename]?"
    ks "Sí. [stagename] es muy buena con las inducciones de fijación ocular. ¿No es así, [stagename]?"

# game/Kyou 10.rpy:2158
translate spanish Day10_Con_Kyou_Hiroko_Trickster_a7e901c6:

    # h "Yeah... So good..."
    h "Sí... Muy buena..."

# game/Kyou 10.rpy:2159
translate spanish Day10_Con_Kyou_Hiroko_Trickster_732a37e7:

    # "Heh. She's already spacing out. Whether it's her anticipation from seeing the penlight again or from standing this close to me, who's to say?"
    "Je. Ya se me está durmiendo. Ya sea por la anticipación de ver la linterna otra vez o estar parada tan cerca de mí, ¿quién sabe?"

# game/Kyou 10.rpy:2160
translate spanish Day10_Con_Kyou_Hiroko_Trickster_3806a32c:

    # n neutral "Okay, well... I'm ready when you two are." with dissolve
    n neutral "Muy bien, pues... estoy lista cuando ustedes lo estén." with dissolve

# game/Kyou 10.rpy:2165
translate spanish Day10_Con_Kyou_Hiroko_Trickster_54a358b7:

    # "And without further ado, I click the switch on my penlight and carefully begin passing the light gently across Hiroko's waiting eyes."
    "Y sin más dilación, enciendo mi linterna y comienzo a pasar cuidadosamente la luz por los impacientes ojos de Hiroko."

# game/Kyou 10.rpy:2169
translate spanish Day10_Con_Kyou_Hiroko_Trickster_422e51ea:

    # ks "So now, [stagename], concentrate on the light as I shine it in front of you."
    ks "Ahora, [stagename], concéntrate en la luz que resplandece ante ti."

# game/Kyou 10.rpy:2171
translate spanish Day10_Con_Kyou_Hiroko_Trickster_558c80ea:

    # ks "Taking a deep breath in..."
    ks "Inhala profundamente..."

# game/Kyou 10.rpy:2174
translate spanish Day10_Con_Kyou_Hiroko_Trickster_7c175760:

    # ks "And out... Allowing everything else to fade from your consciousness."
    ks "Y exhala... Dejando que todo lo demás desaparezca de tu consciencia..."

# game/Kyou 10.rpy:2146
translate spanish Day10_Con_Kyou_Hiroko_Trickster_6e6af353:

    # "I can already see Hiroko spacing out majorly as she watches my light attentively."
    "Ya puedo notar esa desvanecida expresión en Hiroko al observar atentamente mi luz."

# game/Kyou 10.rpy:2179
translate spanish Day10_Con_Kyou_Hiroko_Trickster_5ed0c088:

    # ks "That's right. Another breath in, and out..."
    ks "Eso es. Una vez más inhala, y exhala..."

# game/Kyou 10.rpy:2152
translate spanish Day10_Con_Kyou_Hiroko_Trickster_4707192b:

    # "I could've hypnotized her nice and deep without this penlight, but I think it's better to put on a show for these people. Draw it out a bit."
    "Pude haberla hipnotizado profundamente sin esta linterna, pero creo que así será más entretenido para esta gente. Extendiéndolo un poco."

# game/Kyou 10.rpy:2185
translate spanish Day10_Con_Kyou_Hiroko_Trickster_34b06f2f:

    # ks neutral "Your whole body now entering a deep, deep state of relaxation, but still standing up nice and straight and rigid for me, letting everything else fade away..."
    ks neutral "Todo tu cuerpo está entrando a un muy, muy profundo estado de relajación, pero seguirá rígidamente de pie, dejando que todo lo demás desaparezca..."

# game/Kyou 10.rpy:2188
translate spanish Day10_Con_Kyou_Hiroko_Trickster_e0a648e5:

    # "Not to mention Nozomi, watching us curiously from behind."
    "Sin mencionar a Nozomi, viéndonos con curiosidad desde atrás."

# game/Kyou 10.rpy:2190
translate spanish Day10_Con_Kyou_Hiroko_Trickster_acec5a1a:

    # ks "Just watching the light and following my voice, letting your eyelids become heavy, letting your consciousness fade, and..."
    ks "Solo observa la luz y sigue mi voz, dejando que tus párpados se pongan pesados, que tu consciencia se esfume, y ahora..."

# game/Kyou 10.rpy:2193
translate spanish Day10_Con_Kyou_Hiroko_Trickster_02598ad1:

    # ks "{cps=20}Closing your eyes... {/cps}{w=0.5}{nw}"
    ks "{cps=20}Cierra los ojos... {/cps}{w=0.5}{nw}"

# game/Kyou 10.rpy:2197
translate spanish Day10_Con_Kyou_Hiroko_Trickster_82428cc1:

    # extend "Sleep, [stagename]. Relax and go deep. Deeper into that wonderful, comfortable feeling of hypnosis."
    extend "Duerme, [stagename]. Relájate y cae muy profundo. Muy profundo en esta maravillosa y cómoda sensación de hipnosis."

# game/Kyou 10.rpy:2199
translate spanish Day10_Con_Kyou_Hiroko_Trickster_3983c586:

    # ks "That's right. Letting yourself sink. Hearing only my voice, becoming even more relaxed and focused the more you hear it."
    ks "Eso es. Siente cómo te hundes. Escuchando únicamente mi voz, relajándote y concentrándote más entre más la escuchas."

# game/Kyou 10.rpy:2200
translate spanish Day10_Con_Kyou_Hiroko_Trickster_3cf2c7f7:

    # "Down, down she goes. Hypnotizing Hiroko at this point feels almost as easy as flicking a light switch. So easy I'm not even sure my viewers got much satisfaction from seeing her drop."
    "Y así nada más, cayó. Hipnotizar a Hiroko a estas alturas es tan fácil como mover un interruptor. Tan fácil que no sé qué tan satisfactorio fue verla para los espectadores."

# game/Kyou 10.rpy:2201
translate spanish Day10_Con_Kyou_Hiroko_Trickster_7c9ddcb9:

    # "But that's okay. The real fun's just about to begin as I move to demonstrate just how deeply hypnotized she truly is."
    "Pero no importa. La verdadera diversión está a punto de comenzar. Voy a demostrar lo profundamente hipnotizada que está."

# game/Kyou 10.rpy:2202
translate spanish Day10_Con_Kyou_Hiroko_Trickster_4baa5e4e:

    # ks "Now, [stagename], while you keep your feet so firmly planted to the floor, rooted in place as they are, I want you to tilt your head back, as if you were looking up at the ceiling."
    ks "Ahora, [stagename], manteniendo los pies firmemente en el suelo, plantados en su posición, quiero que inclines tu cabeza hacia atrás, como si miraras al techo."

# game/Kyou 10.rpy:2203
translate spanish Day10_Con_Kyou_Hiroko_Trickster_08f8d28e:

    # "We all watch as Hiroko complies almost immediately, her head hanging loose against the back of her shoulders while the rest of her stands stiffly to attention."
    "Todos vemos cómo Hiroko obedece casi de inmediato, dejando caer su cabeza sobre la parte de atrás de sus hombros mientras el resto de ella continúa erguido."

# game/Kyou 10.rpy:2204
translate spanish Day10_Con_Kyou_Hiroko_Trickster_979d8041:

    # "She's like a funny little statue. But one who won't be stable for much longer as I move on to the true test of her suggestibility for the audience."
    "Es como una estatuilla. Pero una que no durará estable por mucho, pues es hora de la verdadera prueba de sugestionabilidad para la audiencia."

# game/Kyou 10.rpy:2205
translate spanish Day10_Con_Kyou_Hiroko_Trickster_4d87e26a:

    # ks "Very good. Now I'd like for you to imagine a magnetic force pulling you from behind. Compelling you to fall backwards."
    ks "Muy bien. Ahora, quiero que imagines una fuerza magnética jalándote desde atrás. Haciéndote caer de espaldas."

# game/Kyou 10.rpy:2206
translate spanish Day10_Con_Kyou_Hiroko_Trickster_95a92dbc:

    # ks "There's no need to worry, even as that force becomes stronger and stronger and stronger."
    ks "No tienes por qué preocuparte, por más que esa fuerza crezca y crezca."

# game/Kyou 10.rpy:2207
translate spanish Day10_Con_Kyou_Hiroko_Trickster_220718d8:

    # ks "You can simply stay as relaxed and focused as you are, and allow that force to begin pulling you back."
    ks "Puedes permanecer así de relajada y concentrada, y dejar que esa fuerza te jale hacia atrás."

# game/Kyou 10.rpy:2208
translate spanish Day10_Con_Kyou_Hiroko_Trickster_a1d03938:

    # ks "Simply accept that as that force becomes even stronger still, you feel your body becoming slowly yet irresistibly pulled towards it."
    ks "Simplemente acepta que, mientras la fuerza crece todavía más, sientes cómo tu cuerpo lenta e irresistiblemente es jalado hacia atrás."

# game/Kyou 10.rpy:2209
translate spanish Day10_Con_Kyou_Hiroko_Trickster_566ce493:

    # "I can see Nozomi visibly tense up and start to raise her hands as Hiroko clearly begins to tilt towards her."
    "Puedo notar a Nozomi tensarse y alzar las manos mientras Hiroko claramente comienza a inclinarse hacia ella."

# game/Kyou 10.rpy:2210
translate spanish Day10_Con_Kyou_Hiroko_Trickster_6bb9dcc3:

    # ks "That's right. That powerful magnetic force becoming even stronger now. Even stronger. Pulling you back more and more."
    ks "Eso es. Esa poderosa fuerza magnética crece más y más. Más intensa. Jalándote más y más."

# game/Kyou 10.rpy:2211
translate spanish Day10_Con_Kyou_Hiroko_Trickster_4b5cd387:

    # ks "{cps=15}More and more and... {w=0.5}{/cps}{nw}"
    ks "{cps=15}Más y más y... {w=0.5}{/cps}{nw}"

# game/Kyou 10.rpy:2212
translate spanish Day10_Con_Kyou_Hiroko_Trickster_792f3462:

    # n shocked "A-ah!" with vpunch
    n shocked "¡A-ah!" with vpunch

# game/Kyou 10.rpy:2213
translate spanish Day10_Con_Kyou_Hiroko_Trickster_d815971b:

    # "Just then, Hiroko can't help herself from toppling backwards."
    "En ese momento, Hiroko no puede evitar desplomarse de espaldas."

# game/Kyou 10.rpy:2214
translate spanish Day10_Con_Kyou_Hiroko_Trickster_2270f2b6:

    # "She falls back so much that Nozomi's forced to reflexively grab Hiroko's shoulders to stop her from simply crashing to the floor like a plank of wood."
    "Cae hacia atrás, y Nozomi se ve obligada a tomarla de los hombros por reflejo, para evitar que se estrelle de lleno contra el suelo como una tabla de madera."

# game/Kyou 10.rpy:2215
translate spanish Day10_Con_Kyou_Hiroko_Trickster_9a5b6015:

    # ks smile "Very good, [stagename]. You can imagine that magnetic force becoming weaker now."
    ks smile "Muy bien, [stagename]. Ahora puedes imaginar esa fuerza magnética disminuyendo."

# game/Kyou 10.rpy:2185
translate spanish Day10_Con_Kyou_Hiroko_Trickster_cc08e52b:

    # "Nozomi looks on slack-jawed at her friend, who offers no resistance to being gently pulled upright again."
    "Nozomi mira boquiabierta a su amiga, quien ofrece cero resistencia a ser empujada de vuelta hacia arriba."

# game/Kyou 10.rpy:2195
translate spanish Day10_Con_Kyou_Hiroko_Trickster_add4568b:

    # n surprised "{size=16}S-she's so out of it, my god...{/size}"
    n surprised "{size=16}E-está completamente inmersa, santo Dios...{/size}"

# game/Kyou 10.rpy:2218
translate spanish Day10_Con_Kyou_Hiroko_Trickster_45ac471d:

    # ks "That magnetic force completely gone now, and as it disappears so completely I'd like you to bring your head forward to its natural position again... very good."
    ks "Y la fuerza magnética se ha ido por completo, y ahora que desapareció, quiero que regreses tu cabeza a su posición natural... muy bien."

# game/Kyou 10.rpy:2219
translate spanish Day10_Con_Kyou_Hiroko_Trickster_6e5f540e:

    # "It was a simple suggestibility test, but I'm really enjoying how impressed Nozomi seems with it. Which is exactly what I hoped, as I now turn to address my online audience."
    "Fue una prueba simple de sugestionabilidad, pero me encanta lo impresionada que luce Nozomi, lo cual es justo lo que esperaba. Ahora vuelvo mi atención a mi audiencia."

# game/Kyou 10.rpy:2220
translate spanish Day10_Con_Kyou_Hiroko_Trickster_3090cde9:

    # ks "So you guys saw what happened, right? I simply impressed on [stagename] how she was compelled to fall backwards even if her natural inclination is to stay standing."
    ks "Vieron lo que pasó, ¿verdad? Convencí a [stagename] de que debía caer hacia atrás, a pesar de que su inclinación natural fuera permanecer de pie."

# game/Kyou 10.rpy:2221
translate spanish Day10_Con_Kyou_Hiroko_Trickster_f6b9cf15:

    # ks "Naturally you'll want to stay upright, so it's hard for a subject to simply let themselves go like this unless they're not only hypnotized but deeply trusting of their hypnotist."
    ks "Naturalmente uno quiere permanecer de pie. Es difícil que un sujeto simplemente se deje ir así a no ser que no solo esté hipnotizado, sino que confíe plenamente en su hipnotista."

# game/Kyou 10.rpy:2222
translate spanish Day10_Con_Kyou_Hiroko_Trickster_93e60a07:

    # ks "If she thought she was in any danger at all, this simply wouldn't work."
    ks "Si hubiera pensado que corría algún peligro, esto sencillamente no habría funcionado."

# game/Kyou 10.rpy:2224
translate spanish Day10_Con_Kyou_Hiroko_Trickster_ff40320b:

    # "As I explain myself to the room, I see Nozomi gently nodding along, her hands still resting gently on Hiroko's shoulders." with dissolve
    "Dando mi explicación a la sala, veo a Nozomi asintiendo suavemente, con las manos aún posadas con gentileza en los hombros de Hiroko." with dissolve

# game/Kyou 10.rpy:2226
translate spanish Day10_Con_Kyou_Hiroko_Trickster_04ae1e7a:

    # "She looks contemplative. Like she might seriously be questioning the role she wants to play tonight having seen how completely her best friend has placed her trust in me."
    "Luce contemplativa. Como si estuviera cuestionando seriamente el papel que quiere jugar esta noche, habiendo visto cómo su amiga puso toda su confianza en mí."

# game/Kyou 10.rpy:2227
translate spanish Day10_Con_Kyou_Hiroko_Trickster_910e30ad:

    # "I think it's time..."
    "Creo que es el momento..."

# game/Kyou 10.rpy:2229
translate spanish Day10_Con_Kyou_Hiroko_Trickster_1bb3ceef:

    # ks "So, \"HypnoTea\"..."
    ks "Entonces, \"HipnoTé\"..."

# game/Kyou 10.rpy:2230
translate spanish Day10_Con_Kyou_Hiroko_Trickster_d7468b81:

    # n surprised "H-huh?" with dissolve
    n surprised "¿E-eh?" with dissolve

# game/Kyou 10.rpy:2231
translate spanish Day10_Con_Kyou_Hiroko_Trickster_1d220234:

    # "It's time I made my move on Nozomi."
    "Es momento de hacer mi jugada con Nozomi."

# game/Kyou 10.rpy:2232
translate spanish Day10_Con_Kyou_Hiroko_Trickster_a60f6b91:

    # ks "I know you said you didn't want to take part in this, but it's not too late to change your mind."
    ks "Sé que dijiste que no querías ser parte de esto, pero no es muy tarde para cambiar de opinión."

# game/Kyou 10.rpy:2233
translate spanish Day10_Con_Kyou_Hiroko_Trickster_1a5f8a25:

    # n side sad_side "Yes... w-well..." with dissolve
    n side sad_side "Sí... b-bueno..." with dissolve

# game/Kyou 10.rpy:2234
translate spanish Day10_Con_Kyou_Hiroko_Trickster_06e8962b:

    # n sad_closed blush "N-no, I can't..." with dissolve
    n sad_closed blush "N-no, no puedo..." with dissolve

# game/Kyou 10.rpy:2235
translate spanish Day10_Con_Kyou_Hiroko_Trickster_bde44fe7:

    # "She's wavering. I knew she'd be tempted."
    "Está titubeando. Sabía que estaría tentada."

# game/Kyou 10.rpy:2236
translate spanish Day10_Con_Kyou_Hiroko_Trickster_07ea9fcc:

    # ks "Why not?"
    ks "¿Por qué no?"

# game/Kyou 10.rpy:2237
translate spanish Day10_Con_Kyou_Hiroko_Trickster_f12b1028:

    # n sad "I need her to be safe, you understand? If I'm hypnotized and there's no one to watch over her..." with dissolve
    n sad "Necesito que esté a salvo, ¿lo entiendes? Si yo soy hipnotizada, no habrá nadie que la cuide..." with dissolve

# game/Kyou 10.rpy:2238
translate spanish Day10_Con_Kyou_Hiroko_Trickster_3ffc0e7c:

    # ks "I'll still be here. I'll watch over you both, and you can see how much [stagename] trusts me with her safety. You know she was happy with the idea of you joining her, right?"
    ks "Yo estaré aquí. Las cuidaré a las dos, y podrás ver lo mucho que [stagename] confía en que la mantenga a salvo. Sabes que le agradaba la idea de que te le unieras, ¿no?"

# game/Kyou 10.rpy:2239
translate spanish Day10_Con_Kyou_Hiroko_Trickster_e172303c:

    # n sad_side "I... I-I..." with dissolve
    n sad_side "Este... e-eh..." with dissolve

# game/Kyou 10.rpy:2240
translate spanish Day10_Con_Kyou_Hiroko_Trickster_239b8bf1:

    # ks "And besides, look how encouraging everyone's being."
    ks "Y además, mira, todos te están animando."

# game/Kyou 10.rpy:2227
translate spanish Day10_Con_Kyou_Hiroko_Trickster_c308dd37:

    # "I point her in the direction of the chat window, which is once again bursting with activity." with dissolve
    "Apunto en dirección a la ventana de chat, la cual una vez más estalla de actividad." with dissolve

# game/Kyou 10.rpy:2242
translate spanish Day10_Con_Kyou_Hiroko_Trickster_44123e47:

    # "There's just tons of messages like \"OMG YES DO IT\" and \"GO HYPNOTEA!!!\""
    "Está repleta de mensajes como \"OH POR DIOS SI HAZLO\" y \"VAMOS HIPNOTE!!!\"."

# game/Kyou 10.rpy:2243
translate spanish Day10_Con_Kyou_Hiroko_Trickster_1e73b8fa:

    # ks "I'll make sure you have a ton of fun as well, HypnoTea, I guarantee it."
    ks "Me aseguraré de que tú también te diviertas, HipnoTé, te lo garantizo."

# game/Kyou 10.rpy:2230
translate spanish Day10_Con_Kyou_Hiroko_Trickster_260da429:

    # "I'm just glad no one looks to be writing anything lewd about her right now. Seems they all understand the need to encourage her with some positive reinforcement."
    "Solo me alegro de que al parecer nadie esté escribiendo nada sucio. Parece que entienden la necesidad de alentarla con refuerzo positivo."

# game/Kyou 10.rpy:2245
translate spanish Day10_Con_Kyou_Hiroko_Trickster_bd49bb34:

    # ks "And besides, do you really want to miss out on what [stagename]'s experiencing right now?"
    ks "Y además, ¿en serio quieres perderte de lo que [stagename] está experimentando?"

# game/Kyou 10.rpy:2233
translate spanish Day10_Con_Kyou_Hiroko_Trickster_e31c1571:

    # n "I..." with dissolve
    n "Este..." with dissolve

# game/Kyou 10.rpy:2234
translate spanish Day10_Con_Kyou_Hiroko_Trickster_e9f78837:

    # "Nozomi breathes out a shuddered sigh as I notice her hold on her stomach tightens..."
    "Nozomi suelta un abatido suspiro, y la noto apretarse más el vientre otra vez."

# game/Kyou 10.rpy:2242
translate spanish Day10_Con_Kyou_Hiroko_Trickster_4642e80c:

    # "... before she gingerly steps aside from Hiroko to stand nervously in front of me, her eyes lowered."
    "... para posteriormente separarse con cautela de Hiroko y pararse nerviosa frente a mí, con la mirada hacia abajo."

# game/Kyou 10.rpy:2254
translate spanish Day10_Con_Kyou_Hiroko_Trickster_8a44b84e:

    # n "... P-please don't make me regret this, MindCoder."
    n "... P-por favor, no hagas que me arrepienta, MindCoder."

# game/Kyou 10.rpy:2255
translate spanish Day10_Con_Kyou_Hiroko_Trickster_d692292e:

    # "I feel the excitement welling up inside me, even as I know I need to play it cool."
    "Siento la emoción brotar en mi interior, incluso sabiendo que debo mostrarme calmado."

# game/Kyou 10.rpy:2245
translate spanish Day10_Con_Kyou_Hiroko_Trickster_b8577b81:

    # ks casual smile "Just take it easy, Hypnotea. Take a deep breath and relax. This is happening."
    ks casual smile "Tranquila, HipnoTé. Respira profundo y relájate. Esto está pasando."

# game/Kyou 10.rpy:2257
translate spanish Day10_Con_Kyou_Hiroko_Trickster_b4dc39b0:

    # "First, make sure she can't back out of it now that she's committed herself..."
    "Primero, me aseguraré de que no pueda echarse para atrás ahora que se comprometió..."

# game/Kyou 10.rpy:2258
translate spanish Day10_Con_Kyou_Hiroko_Trickster_a2d364a4:

    # n concerned noblush "Ahhh..." with dissolve
    n concerned noblush "Aaah..." with dissolve

# game/Kyou 10.rpy:2259
translate spanish Day10_Con_Kyou_Hiroko_Trickster_1e466c18:

    # ks "And just remember, as I'm sure you know, no matter what I do tonight you're always in control, no matter how deeply hypnotized you might become."
    ks "Y recuerda, como has de saber, sin importar lo que haga hoy tú siempre tienes el control, sin importar lo profundamente hipnotizada que estés."

# game/Kyou 10.rpy:2260
translate spanish Day10_Con_Kyou_Hiroko_Trickster_5552fe93:

    # "Next, a little reassurance to help put her mind at ease..."
    "Luego, un poco de seguridad para calmar su mente..."

# game/Kyou 10.rpy:2261
translate spanish Day10_Con_Kyou_Hiroko_Trickster_053c7cac:

    # n "O... o-of course."
    n "P-... p-por supuesto."

# game/Kyou 10.rpy:2262
translate spanish Day10_Con_Kyou_Hiroko_Trickster_ea35dc82:

    # ks "But to get started, I want you to keep your feet planted firmly on the ground."
    ks "Pero, para empezar, quiero que plantes los pies firmemente en el suelo."

# game/Kyou 10.rpy:2263
translate spanish Day10_Con_Kyou_Hiroko_Trickster_e9c732ae:

    # "Project easy confidence. Make it clear to her that I know what I'm doing, as if it wasn't obvious to her before."
    "Proyectar confianza. Dejarle en claro que sé lo que estoy haciendo, como si no fuera ya evidente."

# game/Kyou 10.rpy:2264
translate spanish Day10_Con_Kyou_Hiroko_Trickster_48e4e544:

    # n surprised "O... o-okay..." with dissolve
    n surprised "D-... d-de acuerdo..." with dissolve

# game/Kyou 10.rpy:2254
translate spanish Day10_Con_Kyou_Hiroko_Trickster_2f0c4322:

    # ks "Stand up nice and straight and imagine a rigid steel bar running through your body, running from the base of your feet all the way up to the top of your head."
    ks "Párate derecha e imagina una rígida barra de acero que va de las plantas de tus pies hasta tu cabeza."

# game/Kyou 10.rpy:2268
translate spanish Day10_Con_Kyou_Hiroko_Trickster_cd2f5efe:

    # "As I instruct her, I raise my penlight up again, just like I did with Hiroko just now."
    "Mientras le doy instrucciones, elevo mi linterna una vez más, tal como hice con Hiroko."

# game/Kyou 10.rpy:2269
translate spanish Day10_Con_Kyou_Hiroko_Trickster_aa4b4a27:

    # ks "So now HypnoTea, concentrate on the light as I shine it in front of you."
    ks "Ahora, HipnoTé, concéntrate en la luz que resplandece ante ti."

# game/Kyou 10.rpy:2271
translate spanish Day10_Con_Kyou_Hiroko_Trickster_f79f40b6:

    # "This... this is going to work, right?"
    "Esto... va a funcionar, ¿cierto? "

# game/Kyou 10.rpy:2274
translate spanish Day10_Con_Kyou_Hiroko_Trickster_fed37968:

    # n "{size=16}K-Kyou, I... wait...{/size}"
    n "{size=16}K-Kyou, eh... espera...{/size}"

# game/Kyou 10.rpy:2275
translate spanish Day10_Con_Kyou_Hiroko_Trickster_1615ae52:

    # "I've never done this with anyone besides Hiroko and... shit did she just whisper my real name?"
    "Nunca he hecho esto con nadie aparte de Hiroko y... mierda, ¿acaba de susurrar mi nombre real?"

# game/Kyou 10.rpy:2276
translate spanish Day10_Con_Kyou_Hiroko_Trickster_4401af76:

    # ks neutral "Just... take a deep breath in..."
    ks neutral "Solo... inhala profundamente..."

# game/Kyou 10.rpy:2277
translate spanish Day10_Con_Kyou_Hiroko_Trickster_38fdbd3b:

    # "Well, nevermind."
    "Bueno, qué importa."

# game/Kyou 10.rpy:2281
translate spanish Day10_Con_Kyou_Hiroko_Trickster_b70bf22c:

    # n "{size=16}Ahhh... t-that light...{/size}"
    n "{size=16}Aaah... e-esa luz...{/size}"

# game/Kyou 10.rpy:2282
translate spanish Day10_Con_Kyou_Hiroko_Trickster_7f8ebb93:

    # ks "And out. Letting the tension release from your body as you watch the light, HypnoTea."
    ks "Y exhala. Dejando que la tensión escape de tu cuerpo al ver la luz, HipnoTé."

# game/Kyou 10.rpy:2283
translate spanish Day10_Con_Kyou_Hiroko_Trickster_b5abb583:

    # "It was probably too quiet for the camera to pick up anyway..."
    "Seguro fue muy bajo para que la cámara lo escuche..."

# game/Kyou 10.rpy:2285
translate spanish Day10_Con_Kyou_Hiroko_Trickster_a39217d9:

    # ks "Just focusing on the light. Watching the pattern forming on your eyes and letting everything else slip away..."
    ks "Solo concéntrate en la luz. Observa el patrón que se forma ante tus ojos y deja que todo lo demás se esfume..."

# game/Kyou 10.rpy:2287
translate spanish Day10_Con_Kyou_Hiroko_Trickster_62570c9c:

    # n "Mmmn..."
    n "Mmmn..."

# game/Kyou 10.rpy:2288
translate spanish Day10_Con_Kyou_Hiroko_Trickster_7e45d342:

    # "And I have to say, this seems to be going a lot better than I expected. I can tell she's already responding well to this."
    "Y he de decir que esto parece estar yendo mucho mejor de lo que esperaba. Puedo ver que ya está respondiendo muy bien."

# game/Kyou 10.rpy:2290
translate spanish Day10_Con_Kyou_Hiroko_Trickster_f1888378:

    # ks "That's right. Focusing all of your attention on the light and my voice. Allowing all other distractions to fade."
    ks "Eso es. Concentra tu atención en la luz y en mi voz. Dejando que todas las demás distracciones se desvanezcan."

# game/Kyou 10.rpy:2291
translate spanish Day10_Con_Kyou_Hiroko_Trickster_dacbfab1:

    # "Well, she does know how to be hypnotized after all. Maybe not by me, but she's been hypnotized before, so maybe that's why..."
    "Bueno, ya sabe cómo ser hipnotizada, después de todo. Tal vez no por mí, pero ha sido hipnotizada antes. Tal vez sea por eso..."

# game/Kyou 10.rpy:2293
translate spanish Day10_Con_Kyou_Hiroko_Trickster_25296343:

    # ks "Still standing nice and upright, still feeling that steel rod through your body."
    ks "Pero aún firmemente de pie, sintiendo esa barra de acero a través de tu cuerpo."

# game/Kyou 10.rpy:2294
translate spanish Day10_Con_Kyou_Hiroko_Trickster_d2dd03c0:

    # "That's why she's finding my process so natural. I'll bet some of those guys on the chatroom have hypnotized her online, not to mention that time at the culture fest..."
    "Por eso mi proceso le es tan natural. Apuesto a que algunos de esos sujetos en la sala de chat la han hipnotizado en línea, sin mencionar esa vez en el festival cultural..."

# game/Kyou 10.rpy:2296
translate spanish Day10_Con_Kyou_Hiroko_Trickster_8d68d8d2:

    # ks "So you can let go of your consciousness now as you watch the light. You can let it all melt into a pleasant feeling of relaxation."
    ks "Y así puedes dejar ir tu consciencia, observando la luz. Dejando solo una placentera sensación de relajación."

# game/Kyou 10.rpy:2300
translate spanish Day10_Con_Kyou_Hiroko_Trickster_061048b2:

    # "It's really not surprising that she'd be almost as good at dropping for me as Hiroko."
    "No es de sorprenderse que sea casi tan buena cayendo en trance para mí como Hiroko."

# game/Kyou 10.rpy:2301
translate spanish Day10_Con_Kyou_Hiroko_Trickster_96158486:

    # ks "Feeling so good and comfortable, feeling so relaxed as all your conscious thought seems to disappear."
    ks "Te sientes muy bien, muy cómoda, muy relajada dejando que todos tus pensamientos conscientes desaparezcan."

# game/Kyou 10.rpy:2303
translate spanish Day10_Con_Kyou_Hiroko_Trickster_15ba5162:

    # "And yet... why am I getting a feeling that something's not quite right about this?"
    "Sin embargo... ¿por qué tengo la sensación de que algo no anda bien?"

# game/Kyou 10.rpy:2304
translate spanish Day10_Con_Kyou_Hiroko_Trickster_457afa6a:

    # ks "Letting those sleepy eyelids close, HypnoTea. Letting them close as you... sleep."
    ks "Deja que esos adormecidos párpados se cierren, HipnoTé. Deja que se cierren y... duerme."

# game/Kyou 10.rpy:2282
translate spanish Day10_Con_Kyou_Hiroko_Trickster_b1afef9d:

    # ks "That's right, HypnoTea. Sleep and drop deeper into this relaxing, comfortable state of hypnosis."
    ks "Eso es, HipnoTé. Duerme y cae más profundo en este relajante y cómodo estado de hipnosis."

# game/Kyou 10.rpy:2307
translate spanish Day10_Con_Kyou_Hiroko_Trickster_c85c042a:

    # "What are the odds that I have two extremely easy to hypnotize people as my very first subjects?"
    "¿Cuál es la probabilidad de encontrar a dos personas extremadamente fáciles de hipnotizar como mis primeros sujetos?"

# game/Kyou 10.rpy:2308
translate spanish Day10_Con_Kyou_Hiroko_Trickster_fec1ff83:

    # ks "Now... uhh..."
    ks "Ahora... eeh..."

# game/Kyou 10.rpy:2309
translate spanish Day10_Con_Kyou_Hiroko_Trickster_d45fde39:

    # "Not to mention how nervous Nozomi has been about the idea of being hypnotized by me..."
    "Sin mencionar lo nerviosa que estaba Nozomi respecto a ser hipnotizada por mí."

# game/Kyou 10.rpy:2310
translate spanish Day10_Con_Kyou_Hiroko_Trickster_e4f38802:

    # "Throughout all of this she's been anxious and panicky about going under in such a public way. Her thoughts must have been all over the place."
    "Ha estado ansiosa desde el comienzo, y le asustaba ser hipnotizada de manera tan pública. ¿Cómo podría silenciar sus pensamientos así como así?"

# game/Kyou 10.rpy:2311
translate spanish Day10_Con_Kyou_Hiroko_Trickster_570d52f3:

    # "So... so how is it that she was still able to focus her mind for me and drop as deeply as this in spite of all of that?"
    "¿Cómo... cómo es que pudo concentrar su mente y caer así de profundo a pesar de todo eso?"

# game/Kyou 10.rpy:2312
translate spanish Day10_Con_Kyou_Hiroko_Trickster_86fbbadc:

    # "It doesn't make any sense. Unless..."
    "No tiene sentido. A no ser..."

# game/Kyou 10.rpy:2315
translate spanish Day10_Con_Kyou_Hiroko_Trickster_8b80d2c5:

    # "... Unless I really AM making her do this somehow. With just a few flashes of my self-made penlight."
    "... A no ser que SÍ la esté obligando de alguna forma. Con tan solo un par de destellos de la linterna hecha con mis propias manos."

# game/Kyou 10.rpy:2316
translate spanish Day10_Con_Kyou_Hiroko_Trickster_bdbd3459:

    # "And now I can't stop my mind from racing as I turn my attention from my light and Nozomi's sleeping form to my assistant, still completely entranced at her side."
    "Y ahora mi mente se acelera, pasando mi atención de mi linterna y la durmiente Nozomi a mi asistente, aún completamente hipnotizada a su lado"

# game/Kyou 10.rpy:2317
translate spanish Day10_Con_Kyou_Hiroko_Trickster_e9cb1fe1:

    # "Hiroko told me, over and over, about how she couldn't resist me and this light."
    "Hiroko me dijo, una y otra vez, que no podía resistirse a mí y mi luz."

# game/Kyou 10.rpy:2318
translate spanish Day10_Con_Kyou_Hiroko_Trickster_72d8295b:

    # "And I just thought she was gullible as all hell for buying into the idea that I have so much power over her."
    "Y yo simplemente pensé que era sumamente crédula por creer que tengo tanto poder sobre ella."

# game/Kyou 10.rpy:2319
translate spanish Day10_Con_Kyou_Hiroko_Trickster_71a1c634:

    # "She was so easy to manipulate into doing so many ridiculous things. Why couldn't she stop me at all? Even a little bit?"
    "Fue tan fácil de manipular para hacer tantas cosas ridículas. ¿Por qué no podía detenerme? ¿Ni siquiera un poco?"

# game/Kyou 10.rpy:2320
translate spanish Day10_Con_Kyou_Hiroko_Trickster_11e2f37e:

    # "Don't tell me she was right. That's... that's impossible."
    "No me digas que tenía razón. Es... es imposible."

# game/Kyou 10.rpy:2301
translate spanish Day10_Con_Kyou_Hiroko_Trickster_4df02a99:

    # "As impossible as thinking Hiroko is so impressionable she'd believe her hands were massively ticklish no matter what? Or that she had to yawn in class all day long for her sworn enemy?"
    "¿Tan imposible como pensar que Hiroko es tan impresionable como para creer que sus manos son supercosquilludas sin importar qué?"
    "¿O que debía bostezar en clase por su enemigo jurado?"

# game/Kyou 10.rpy:2322
translate spanish Day10_Con_Kyou_Hiroko_Trickster_b809a446:

    # "That she'd abandon all her friends just because she bought into the idea that she couldn't resist my hypnosis at all?"
    "¿Que abandonaría a todas sus amigas solo porque se tragó la idea de que no podía resistir mi hipnosis?"

# game/Kyou 10.rpy:2323
translate spanish Day10_Con_Kyou_Hiroko_Trickster_a3ac3bfe:

    # "Much as I don't want to admit it, I have to believe there's something else going on here."
    "Por mucho que no quiera admitirlo, he de creer que algo más está ocurriendo."

# game/Kyou 10.rpy:2324
translate spanish Day10_Con_Kyou_Hiroko_Trickster_da626dbc:

    # "I made this penlight to help induce a trance state, and it's clearly worked wonders on these girls."
    "Hice esta pluma linterna para ayudarme a inducir el trance, y claramente ha funcionado de maravilla en estas chicas."

# game/Kyou 10.rpy:2325
translate spanish Day10_Con_Kyou_Hiroko_Trickster_4bc55ed8:

    # "But what if it was somehow doing more than that?"
    "Pero ¿qué tal si de algún modo hace más que eso?"

# game/Kyou 10.rpy:2326
translate spanish Day10_Con_Kyou_Hiroko_Trickster_bd06d82e:

    # "What if I can truly override their free will with this thing?"
    "¿Qué tal si realmente puedo sobrescribir su libre albedrío con esta cosa?"

# game/Kyou 10.rpy:2327
translate spanish Day10_Con_Kyou_Hiroko_Trickster_a5a7506b:

    # ks "O-okay, so..."
    ks "M-muy bien, pues..."

# game/Kyou 10.rpy:2328
translate spanish Day10_Con_Kyou_Hiroko_Trickster_59e5d0f9:

    # "Meanwhile I can see the chat window buzzing again. The crowds are impatiently telling me to get on with it."
    "Mientras tanto, puedo ver que la ventana de chat una vez más está vuelta loca. Las masas me piden impacientes que continúe."

# game/Kyou 10.rpy:2329
translate spanish Day10_Con_Kyou_Hiroko_Trickster_cc0098b5:

    # "Right... In spite of all of this, I still have a show to do."
    "Cierto... A pesar de todo, aún tengo un espectáculo que dar."

# game/Kyou 10.rpy:2310
translate spanish Day10_Con_Kyou_Hiroko_Trickster_e1b291af:

    # "So, putting my penlight back in my pocket, I then clear my throat before gently addressing the pair of them."
    "Así que, guardando la linterna en mi bolsillo, pongo con delicadeza mis manos en los hombros de las chicas para dirigirme a ellas."

# game/Kyou 10.rpy:2332
translate spanish Day10_Con_Kyou_Hiroko_Trickster_dc308610:

    # ks "HypnoTea. [stagename]. From now until the rest of the evening, whenever I say the word \"sleep\" to you..."
    ks "HipnoTé. [stagename]. Desde ahora y por el resto de la noche, cada vez que les diga la palabra \"duerman\"..."

# game/Kyou 10.rpy:2333
translate spanish Day10_Con_Kyou_Hiroko_Trickster_afcd9e75:

    # ks "... you will find yourselves immediately and automatically returning to this deep state of hypnosis."
    ks "... inmediata y automáticamente regresarán a este profundo estado de hipnosis."

# game/Kyou 10.rpy:2334
translate spanish Day10_Con_Kyou_Hiroko_Trickster_7f70146f:

    # ks "Every time I say the word \"sleep\" you will immediately fall back into this state of hypnotic trance, remaining rigidly upright and hearing only my voice, understand?"
    ks "Cada vez que diga la palabra \"duerman\" caerán de inmediato en este profundo estado de trance hipnótico, escuchando solo mi voz, ¿comprenden?"

# game/Kyou 10.rpy:2338
translate spanish Day10_Con_Kyou_Hiroko_Trickster_94eb954e:

    # multi "Yes..." with dissolve
    multi "Sí..." with dissolve

# game/Kyou 10.rpy:2341
translate spanish Day10_Con_Kyou_Hiroko_Trickster_b9976459:

    # "They both reply in unison, and somehow I don't have a doubt in my mind that they'll drop at my word now no matter what." with dissolve
    "Ambas responden al unísono, y no tengo duda en mi mente de que caerán a mi señal no importa qué." with dissolve

# game/Kyou 10.rpy:2342
translate spanish Day10_Con_Kyou_Hiroko_Trickster_ab145976:

    # ks "Wonderful. Now when I count to three and snap my fingers you will awaken from this deep state of hypnosis. Ready to drop back into trance again at the word \"sleep\"."
    ks "Maravilloso. Ahora, cuando cuente hasta tres y chasquee mis dedos, despertarán de este profundo estado de hipnosis. Listas para caer de nuevo cuando diga \"duerman\"."

# game/Kyou 10.rpy:2343
translate spanish Day10_Con_Kyou_Hiroko_Trickster_7c9ae4cd:

    # "It unerves me, but I have to admit... it also excites me."
    "Me pone de los nervios, pero tengo que admitir que... también me emociona."

# game/Kyou 10.rpy:2344
translate spanish Day10_Con_Kyou_Hiroko_Trickster_f5a48d26:

    # ks "{cps=15}Counting up now. One, two three and... {/cps}{w=0.5}{nw}"
    ks "{cps=15}A la cuenta de uno, dos, tres y... {/cps}{w=0.5}{nw}"

# game/Kyou 10.rpy:2349
translate spanish Day10_Con_Kyou_Hiroko_Trickster_b9e01ae9:

    # extend "*snap*"
    extend "*clic*"

# game/Kyou 10.rpy:2350
translate spanish Day10_Con_Kyou_Hiroko_Trickster_cd953774:

    # "What I'm imagining is ridiculous... but there's a way to be sure, isn't there?"
    "Lo que estoy imaginando es ridículo... pero hay una forma de estar seguro, ¿no?"

# game/Kyou 10.rpy:2352
translate spanish Day10_Con_Kyou_Hiroko_Trickster_4b2e6cd5:

    # ks smile "Welcome back, girls. We're going to move on to the next part of the show, just like I planned, ¿de acuerdo?"
    ks smile "Bienvenidas de vuelta, chicas. Pasaremos a la siguiente parte del espectáculo, tal como planeé, ¿de acuerdo?"

# game/Kyou 10.rpy:2354
translate spanish Day10_Con_Kyou_Hiroko_Trickster_2010aef7:

    # n surprised "O... o-okay?" with dissolve
    n surprised "¿D-... d-de acuerdo?" with dissolve

# game/Kyou 10.rpy:2355
translate spanish Day10_Con_Kyou_Hiroko_Trickster_850db8bb:

    # "All I'd need to do to test my theory is make a suggestion Nozomi would absolutely, positively refuse."
    "Solo tengo que poner a prueba mi teoría y darle a Nozomi una sugestión que con toda certeza rechazaría."

# game/Kyou 10.rpy:2357
translate spanish Day10_Con_Kyou_Hiroko_Trickster_9454ec09:

    # h dungaree_headhold2 nervous "Uh, y-yeah, what do we... do again?" with dissolve
    h dungaree_headhold2 nervous "Eh, s-sí, ¿qué era... lo que seguía?" with dissolve

# game/Kyou 10.rpy:2358
translate spanish Day10_Con_Kyou_Hiroko_Trickster_d0354acc:

    # ks "Just sit back down on the bed, please, so you're facing the camera."
    ks "Solo siéntense en mi cama, por favor, mirando a la cámara."

# game/Kyou 10.rpy:2363
translate spanish Day10_Con_Kyou_Hiroko_Trickster_2b8bfcff:

    # "And this could be my only chance to do this. I'm not sure I could persuade Nozomi to let me hypnotize her again, not with how much she distrusts me."
    "Y esta podría ser mi única oportunidad de hacerlo. No sé si podré persuadir a Nozomi de dejarme hipnotizarla otra vez, no con lo mucho que desconfía de mí."

# game/Kyou 10.rpy:2345
translate spanish Day10_Con_Kyou_Hiroko_Trickster_dff935b7:

    # n "Oh... sure."
    n "Oh... claro."

# game/Kyou 10.rpy:2371
translate spanish Day10_Con_Kyou_Hiroko_Trickster_73ad1392:

    # "No, if I'm going to do this, it has to be now."
    "No, si voy a hacerlo, debe ser ahora."

# game/Kyou 10.rpy:2372
translate spanish Day10_Con_Kyou_Hiroko_Trickster_74955535:

    # ks "That's perfect. Now sleep."
    ks "Perfecto. Ahora duerman."

# game/Kyou 10.rpy:2375
translate spanish Day10_Con_Kyou_Hiroko_Trickster_146228e9:

    # "Both pairs of eyes immediately fall closed. Both of them stay sat up rigidly on the bed." with dissolve
    "Ambos pares de párpados caen al instante. Ambas permanecen erguidas en su asiento sobre la cama." with dissolve

# game/Kyou 10.rpy:2376
translate spanish Day10_Con_Kyou_Hiroko_Trickster_b4e42b69:

    # "They have no idea what I'm thinking right now."
    "No tienen idea de lo que estoy pensando."

# game/Kyou 10.rpy:2377
translate spanish Day10_Con_Kyou_Hiroko_Trickster_4c4a9108:

    # "But it's time I decided..."
    "Pero he decidido..."

# game/Kyou 10.rpy:2407
translate spanish Day10_Con_Kyou_Hiroko_Trickster_af3c3994:

    # "I'm going to do it. I have to know. I HAVE to!"
    "Voy a hacerlo. Tengo que hacerlo. ¡TENGO que!"

# game/Kyou 10.rpy:2409
translate spanish Day10_Con_Kyou_Hiroko_Trickster_a8a3ef61:

    # "So while \"HypnoTea\" and \"[stagename]\" sit obediently in trance, I turn back to my computer and the ever active chat window, where everyone is speculating on my next move."
    "Así que con \"[stagename]\" e \"HipnoTé\" sentadas obedientemente en trance, regreso a la incesante ventana de chat, donde todos están especulando mi siguiente movimiento."

# game/Kyou 10.rpy:2410
translate spanish Day10_Con_Kyou_Hiroko_Trickster_8d168f2a:

    # "And I know just what I'm going to do. It's risky, but... this is the way to be sure one way or another."
    "Y sé exactamente qué es lo que haré. Es arriesgado, pero... de esta manera estaré seguro de una forma u otra."

# game/Kyou 10.rpy:2411
translate spanish Day10_Con_Kyou_Hiroko_Trickster_93b79b3f:

    # "Rather than talk to the camera, I simply type my intentions into the chatroom so that the girls don't overhear."
    "En vez de hablar a la cámara, simplemente escribo mis intenciones en el chat para que las chicas no me escuchen."

# game/Kyou 10.rpy:2401
translate spanish Day10_Con_Kyou_Hiroko_Trickster_cbf378b8:

    # "{color=#FFFFFF}\"You guys wanted to see them lose the masks, right?\"{/color}"
    "{color=#FFFFFF}\"Querían verlas sin las máscaras, ¿verdad?\"{/color}"

# game/Kyou 10.rpy:2413
translate spanish Day10_Con_Kyou_Hiroko_Trickster_426af0cc:

    # "... The replies are near instantaneous, and resoundingly in the affirmative."
    "... Las respuestas son casi instantáneas, y rotundamente afirmativas."

# game/Kyou 10.rpy:2414
translate spanish Day10_Con_Kyou_Hiroko_Trickster_062ab8ab:

    # "A few people also start to complain about the voice changing software I'm using, saying it's detracting from the experience."
    "Un par de personas también comienzan a quejarse del filtro de voz que estoy usando, diciendo que los distrae de la experiencia."

# game/Kyou 10.rpy:2415
translate spanish Day10_Con_Kyou_Hiroko_Trickster_030079b8:

    # "But some others are annoyed about me getting their hopes up. \"HypnoTea\" just told us there was no way she was going to let them see her face, after all."
    "Pero a algunos otros les molesta que les esté dando esperanzas. \"HipnoTé\" acaba de decirles que no iban a ver su cara, después de todo."

# game/Kyou 10.rpy:2416
translate spanish Day10_Con_Kyou_Hiroko_Trickster_9fb0aa23:

    # "That's right, but as I deactivate the voice changer and continue to type I'm quick to allay their fears with... well, a little lie."
    "Es cierto, pero mientras desactivo el modificador de voz y continúo escribiendo, me apresuro a calmar sus miedos con... pues, una mentirilla."

# game/Kyou 10.rpy:2406
translate spanish Day10_Con_Kyou_Hiroko_Trickster_5c95bbb0:

    # "{color=#FFFFFF}\"Yes, well, here's the thing. Me and the girls were talking before and they have a little surprise for you. Just watch.\"{/color}"
    "{color=#FFFFFF}\"Sí, bueno, la cosa es que las chicas y yo hablamos hace rato y tienen una sorpresita para ustedes. Solo observen.\"{/color}"

# game/Kyou 10.rpy:2418
translate spanish Day10_Con_Kyou_Hiroko_Trickster_c21fa5ab:

    # "And with that, I leave them to return to the two stars of the show as I set my new plan into motion."
    "Y con eso, los dejo para regresar a nuestras dos estrellas, poniendo mi nuevo plan en marcha."

# game/Kyou 10.rpy:2395
translate spanish Day10_Con_Kyou_Hiroko_Trickster_eff9fea9:

    # ks casual "Now, HypnoTea, I want to address you and only you."
    ks casual "Ahora, HipnoTé, quiero hablarte a ti y solo a ti."

# game/Kyou 10.rpy:2420
translate spanish Day10_Con_Kyou_Hiroko_Trickster_8d56a32f:

    # ks "And before I go any further... you wouldn't do anything for me that you weren't comfortable with, would you?"
    ks "Y antes que nada... tú no harías nada con lo que no estuvieras cómoda, ¿o sí?"

# game/Kyou 10.rpy:2421
translate spanish Day10_Con_Kyou_Hiroko_Trickster_fd63c360:

    # n sleeptalk "No... I wouldn't." with dissolve
    n sleeptalk "No... nada." with dissolve

# game/Kyou 10.rpy:2423
translate spanish Day10_Con_Kyou_Hiroko_Trickster_a022427d:

    # ks "That's right. So with that in mind, I want to talk to you about taking off your mask..." with dissolve
    ks "Es correcto. Así que, con eso en mente, quiero hablarte sobre quitarte la máscara..." with dissolve

# game/Kyou 10.rpy:2424
translate spanish Day10_Con_Kyou_Hiroko_Trickster_b0da68d4:

    # n irritated "..." with dissolve
    n irritated "..." with dissolve

# game/Kyou 10.rpy:2425
translate spanish Day10_Con_Kyou_Hiroko_Trickster_3bbc10d0:

    # "Yeah, I know how she really feels about removing it."
    "Sí, sé lo que piensa realmente sobre removerla."

# game/Kyou 10.rpy:2426
translate spanish Day10_Con_Kyou_Hiroko_Trickster_1ce1cc25:

    # ks "You know how much everyone wants you to uncover your face. How everyone wants you to reveal your beauty to the world..."
    ks "Sabes lo mucho que todos quieren que desveles tu rostro. Lo mucho que todos quieren que reveles tu belleza al mundo..."

# game/Kyou 10.rpy:2427
translate spanish Day10_Con_Kyou_Hiroko_Trickster_0461aa85:

    # "I know how she feels about the attention of a bunch of unknowable strangers..."
    "Sé cómo se siente con la atención de un montón de extraños..."

# game/Kyou 10.rpy:2428
translate spanish Day10_Con_Kyou_Hiroko_Trickster_d82a6cdf:

    # ks "And you ARE beautiful, HypnoTea. It's very empowering, to know how beautiful you are, to know how desired you are..."
    ks "Y SÍ que eres bella, HipnoTé. Es muy empoderante saber lo hermosa que eres, lo mucho que te desean..."

# game/Kyou 10.rpy:2429
translate spanish Day10_Con_Kyou_Hiroko_Trickster_79c5be7e:

    # n sleeptalk_concerned "... Desired? What..." with dissolve
    n sleeptalk_concerned "... ¿Desean? ¿Qué...?" with dissolve

# game/Kyou 10.rpy:2430
translate spanish Day10_Con_Kyou_Hiroko_Trickster_6dbb06c8:

    # "But if I can be direct in my suggestions, perhaps I could steer her into thinking very differently."
    "Pero si puedo ser directo con mis sugestiones, quizás pueda hacerla pensar muy diferente."

# game/Kyou 10.rpy:2432
translate spanish Day10_Con_Kyou_Hiroko_Trickster_9c7e6ea7:

    # ks "Yes, HypnoTea. You must feel very empowered by how desired you are. It makes you confident. So very confident about yourself." with dissolve
    ks "Sí, HipnoTé. Debes sentirte muy empoderada sabiendo cuánto te desean. Te da confianza. Tanta confianza en ti misma." with dissolve

# game/Kyou 10.rpy:2433
translate spanish Day10_Con_Kyou_Hiroko_Trickster_29f99fa6:

    # "And if I succeed? It'd be all the proof I need that she truly is helpless to resist the effects of my penlight-induced hypnosis on her."
    "¿Y si tengo éxito? Será toda la prueba que necesito de que en verdad no puede resistir los efectos de la hipnosis de mi linterna."

# game/Kyou 10.rpy:2434
translate spanish Day10_Con_Kyou_Hiroko_Trickster_947c5b8a:

    # ks "It makes you want to remove your mask and show everyone just how beautiful you truly are."
    ks "Te hace querer remover tu máscara y mostrarles a todos los hermosa que realmente eres."

# game/Kyou 10.rpy:2435
translate spanish Day10_Con_Kyou_Hiroko_Trickster_3370d03f:

    # "... Just like Hiroko."
    "... Al igual que Hiroko."

# game/Kyou 10.rpy:2436
translate spanish Day10_Con_Kyou_Hiroko_Trickster_8ff0cf31:

    # ks "There's no need to worry. There's no need to be shy. Simply enjoy this feeling of being desired and accept it into your heart."
    ks "No hay por qué preocuparte. No hay por qué ser tímida. Simplemente disfruta la sensación de ser deseada y acéptala en tu corazón."

# game/Kyou 10.rpy:2437
translate spanish Day10_Con_Kyou_Hiroko_Trickster_37a25326:

    # ks "Feeling more confident about yourself. Feeling more attractive and desirable. Allowing yourself to enjoy that feeling of being desired."
    ks "Sintiendo más confianza en ti misma. Sintiéndote más atractiva y deseable. Permítete disfrutar esa sensación de ser deseada."

# game/Kyou 10.rpy:2440
translate spanish Day10_Con_Kyou_Hiroko_Trickster_1af06adc:

    # n "M... mmmn..."
    n "M... mmmn..."

# game/Kyou 10.rpy:2441
translate spanish Day10_Con_Kyou_Hiroko_Trickster_ab802c09:

    # "The gentle smile that starts to spread across her lips is all the confirmation I need."
    "La gentil sonrisa que comienza a dibujarse en sus labios es toda la confirmación que necesito."

# game/Kyou 10.rpy:2442
translate spanish Day10_Con_Kyou_Hiroko_Trickster_0e2227d3:

    # ks "So let me ask you, HypnoTea... Do you want to take the mask off?"
    ks "Así que déjame preguntarte, HipnoTé... ¿Quieres quitarte la máscara?"

# game/Kyou 10.rpy:2443
translate spanish Day10_Con_Kyou_Hiroko_Trickster_c6c85ded:

    # n sleeptalk "I... y-yes..." with dissolve
    n sleeptalk "S-... s-sí..." with dissolve

# game/Kyou 10.rpy:2444
translate spanish Day10_Con_Kyou_Hiroko_Trickster_4cd5ac5d:

    # "She... she really is convinced. I really was able to talk her around."
    "En... en verdad está convencida. En serio fui capaz de convencerla."

# game/Kyou 10.rpy:2446
translate spanish Day10_Con_Kyou_Hiroko_Trickster_8edc8ed6:

    # ks "That's... right, HypnoTea. It's what you really want, after all." with dissolve
    ks "Es... correcto, HipnoTé. Eso es lo que realmente quieres, después de todo." with dissolve

# game/Kyou 10.rpy:2447
translate spanish Day10_Con_Kyou_Hiroko_Trickster_0cd609e8:

    # "It was so easy... so trivially easy that I could surely press her even further."
    "Fue tan fácil... tan trivialmente fácil que seguro podría empujarla aún más lejos."

# game/Kyou 10.rpy:2448
translate spanish Day10_Con_Kyou_Hiroko_Trickster_37c36b7e:

    # ks "So in a moment I'm going to snap my fingers and you're going to wake up feeling happy and refreshed and feeling so good about being a part of my hypnosis show."
    ks "Así que, en un momento voy a chasquear mis dedos y despertarás fresca y contenta, y sintiéndote muy bien de ser parte de mi espectáculo de hipnosis."

# game/Kyou 10.rpy:2449
translate spanish Day10_Con_Kyou_Hiroko_Trickster_bdc5a388:

    # "I want to know. I want to know how far I can push her."
    "Quiero saber. Quiero saber qué tan lejos la puedo llevar."

# game/Kyou 10.rpy:2450
translate spanish Day10_Con_Kyou_Hiroko_Trickster_4cecfe40:

    # ks "And as soon as you wake, you'll want to take off your mask, drop it on the floor and give your best smile for the camera so everyone can see how beautiful you are."
    ks "Y en cuanto despiertes, querrás quitarte la máscara, tirarla al suelo y mostrarle tu mejor sonrisa a la cámara para que todos vean lo bella que eres."

# game/Kyou 10.rpy:2451
translate spanish Day10_Con_Kyou_Hiroko_Trickster_04d671b0:

    # "And she'll show me. She will."
    "Y me lo mostrará. Yo sé que sí."

# game/Kyou 10.rpy:2452
translate spanish Day10_Con_Kyou_Hiroko_Trickster_3b4cf906:

    # ks "I'll ask you to introduce yourself again, and as soon as you're asked you'll introduce yourself to the camera with your real name, not your chatroom name."
    ks "Volveré a pedir que te presentes, y en cuanto lo haga, te presentarás con tu nombre real, no tu nombre de usuario."

# game/Kyou 10.rpy:2453
translate spanish Day10_Con_Kyou_Hiroko_Trickster_5d64415b:

    # "Whether she wanted to or not."
    "Así lo quiera o no."

# game/Kyou 10.rpy:2454
translate spanish Day10_Con_Kyou_Hiroko_Trickster_f6f3c995:

    # ks "Then you'll tell everyone how happy you are to be a part of MindCoder's hypnosis show. Do you understand, HypnoTea?"
    ks "Luego le dirás a todos lo feliz que estás de ser parte del espectáculo de hipnosis de MindCoder. ¿Comprendes, HipnoTé?"

# game/Kyou 10.rpy:2455
translate spanish Day10_Con_Kyou_Hiroko_Trickster_602bebda:

    # n sleeptalk "Yes..." with dissolve
    n sleeptalk "Sí..." with dissolve

# game/Kyou 10.rpy:2457
translate spanish Day10_Con_Kyou_Hiroko_Trickster_434e4fea:

    # ks "And you're completely comfortable with what you've been asked to do?" with dissolve
    ks "¿Y estás completamente cómoda con lo que te acabo de pedir?" with dissolve

# game/Kyou 10.rpy:2458
translate spanish Day10_Con_Kyou_Hiroko_Trickster_602bebda_1:

    # n sleeptalk "Yes..." with dissolve
    n sleeptalk "Sí..." with dissolve

# game/Kyou 10.rpy:2460
translate spanish Day10_Con_Kyou_Hiroko_Trickster_70d31aff:

    # ks "Good. Now..." with dissolve
    ks "Bien. Ahora..." with dissolve

# game/Kyou 10.rpy:2461
translate spanish Day10_Con_Kyou_Hiroko_Trickster_19ea9519:

    # "Leaving her dormantly smiling in trance, I next turn to my trusted assistant."
    "Dejándola en su soñoliento y sonriente trance, me dirijo ahora a mi confiable asistente."

# game/Kyou 10.rpy:2462
translate spanish Day10_Con_Kyou_Hiroko_Trickster_4d868d14:

    # ks "[stagename], I'm addressing you and only you."
    ks "[stagename], te estoy hablando a ti y solo a ti."

# game/Kyou 10.rpy:2463
translate spanish Day10_Con_Kyou_Hiroko_Trickster_83838853:

    # "If convincing Nozomi to go along was that easy, getting Hiroko to do the same will be no trouble at all."
    "Si convencer a Nozomi de seguirme el juego fue tan fácil, lograr que Hiroko haga lo mismo no será ningún problema."

# game/Kyou 10.rpy:2464
translate spanish Day10_Con_Kyou_Hiroko_Trickster_4bc90b68:

    # ks "The next time I snap my fingers you will also wake up feeling happy and refreshed and feeling so good about being part of my hypnosis show."
    ks "La próxima vez que chasquee mis dedos, también despertarás fresca y contenta, y sintiéndote muy bien de ser parte de mi espectáculo de hipnosis."

# game/Kyou 10.rpy:2465
translate spanish Day10_Con_Kyou_Hiroko_Trickster_a28e0bf3:

    # ks "As soon as you wake, you will take off your mask, drop it on the floor and smile sweetly for the camera so everyone can get a good look at your pretty face."
    ks "En cuanto despiertes, te quitarás la máscara, la tirarás al suelo y sonreirás dulcemente para la cámara para que todos vean tu linda cara."

# game/Kyou 10.rpy:2466
translate spanish Day10_Con_Kyou_Hiroko_Trickster_0b049c46:

    # ks "When I ask you to introduce yourself again, you'll introduce yourself with your real name, not your stage name."
    ks "Cuando te pida que vuelvas a presentarte, lo harás con tu nombre real, no tu nombre artístico."

# game/Kyou 10.rpy:2467
translate spanish Day10_Con_Kyou_Hiroko_Trickster_03cf0bcf:

    # ks "Then you'll say how happy you are to be a part of MindCoder's hypnosis show. Do you understand, [stagename]?"
    ks "Luego dirás lo feliz que estás de ser parte del espectáculo de hipnosis de MindCoder. ¿Comprendes, [stagename]?"

# game/Kyou 10.rpy:2468
translate spanish Day10_Con_Kyou_Hiroko_Trickster_38a74bff:

    # h sleeptalk "Yeah... understand..." with dissolve
    h sleeptalk "Sí... comprendo..." with dissolve

# game/Kyou 10.rpy:2470
translate spanish Day10_Con_Kyou_Hiroko_Trickster_3d0cb8b3:

    # "Just as I thought. I didn't even need to convince her, she just straight up accepted it without a conflicting thought in her head." with dissolve
    "Tal como pensé. Ni siquiera tuve que convencerla. Aceptó directamente y sin conflicto alguno en su cabeza." with dissolve

# game/Kyou 10.rpy:2471
translate spanish Day10_Con_Kyou_Hiroko_Trickster_55494e2d:

    # "And now the moment of truth. The moment I get the answer I'm so desperately wanting..."
    "Y ahora el momento de la verdad. El momento de obtener la respuesta que quiero desesperadamente..."

# game/Kyou 10.rpy:2472
translate spanish Day10_Con_Kyou_Hiroko_Trickster_bc41e4c9:

    # ks "{cps=15}Now one, two three... {/cps}{w=0.5}{nw}"
    ks "{cps=15}Ahora uno, dos, tres... {/cps}{w=0.5}{nw}"

# game/Kyou 10.rpy:2477
translate spanish Day10_Con_Kyou_Hiroko_Trickster_b9e01ae9_1:

    # extend "*snap*"
    extend "*clic*"

# game/Kyou 10.rpy:2478
translate spanish Day10_Con_Kyou_Hiroko_Trickster_f56e5314:

    # "My fingers snap together, and my trained subjects sleepily blink themselves slowly back to life."
    "Mis dedos truenan, y mis sujetos parpadean con sueño, volviendo lentamente a la vida."

# game/Kyou 10.rpy:2479
translate spanish Day10_Con_Kyou_Hiroko_Trickster_4484bd1d:

    # "And I watch..."
    "Y yo observo..."

# game/Kyou 10.rpy:2465
translate spanish Day10_Con_Kyou_Hiroko_Trickster_ffb0f2f0:

    # "... as the pair of them reach around their heads and pull the masks clean off their faces, drop them to the floor around their feet and look straight at the camera."
    "... cómo ambas se llevan las manos a la cabeza y se desprenden de sus máscaras, las tiran al suelo junto a sus pies y miran directo a la cámara."

# game/Kyou 10.rpy:2483
translate spanish Day10_Con_Kyou_Hiroko_Trickster_10ed4ff4:

    # "Those smiles... they're so pure. They look so happy to be here."
    "Esas sonrisas... tan puras. Lucen tan felices de estar aquí."

# game/Kyou 10.rpy:2467
translate spanish Day10_Con_Kyou_Hiroko_Trickster_d1e6b173:

    # ks smile "So, HypnoTea, please introduce yourself to the audience one more time."
    ks smile "Entonces, HipnoTé, por favor preséntate a la audiencia una vez más."

# game/Kyou 10.rpy:2485
translate spanish Day10_Con_Kyou_Hiroko_Trickster_5ac46d40:

    # "Nozomi's eyes flash towards me momentarily, and she answers without missing a beat."
    "Los ojos de Nozomi voltean hacia mí momentáneamente, y responde sin perder ni un segundo."

# game/Kyou 10.rpy:2486
translate spanish Day10_Con_Kyou_Hiroko_Trickster_90f9da9b:

    # n chuckle "Oh, of course~" with dissolve
