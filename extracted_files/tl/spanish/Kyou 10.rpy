    # ks "Aww, don't be shy. You can tell us."
    ks "Ooh, no seas tímida. Puedes decirnos."

# game/Kyou 10.rpy:722
translate spanish Day10_Con_Kyou_Nozomi_Zombie_761efc02:

    # "All of a sudden, Hiroko stands up from her chair and eyeballs me furiously, waving her hands while her lips impotently flap up and down."
