    # a sad_side blush "... Bad joke, sorry." with dissolve
    a sad_side blush "... Mal chiste, lo siento." with dissolve

# game/Kyou 6.rpy:6238
translate spanish Day6_Redemption_d448c712:

    # ks sigh "But yeah, that's when you can give their subconscious suggestions to follow."
    ks sigh "Pero sí, ahí es cuando le das sugestiones a su subconsciente."

# game/Kyou 6.rpy:6239
translate spanish Day6_Redemption_f490a769:

    # a neutral noblush "Like making them cluck like chickens, or..." with dissolve
    a neutral noblush "Como hacer que cacaree como gallina, o..." with dissolve

