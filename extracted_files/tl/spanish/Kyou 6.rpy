    # nm "Sayori, hun, you need to take a break. A *real* one this time."
    nm "Sayori, querida, necesitas un descanso. Uno de *verdad*."

# game/Kyou 6.rpy:9446
translate spanish Day6_Con_Kyou_Sayori_Alter_Switch_f14d533d:

    # "I look to Sayori, her textbooks cradled in her arms as she regards Nozomi's mother with a stunned expression."
    "Volteo a ver a Sayori, quien con sus libros acunados en brazos mira a la madre de Nozomi con una atónita expresión."

# game/Kyou 6.rpy:9447
translate spanish Day6_Con_Kyou_Sayori_Alter_Switch_70899a2a:

    # nm surprised_side "I mean, that's what you've been telling us isn't it? All that talk of playing games and goofing off earlier?" with dissolve
    nm surprised_side "Quiero decir, eso es lo que nos has estado diciendo, ¿no? ¿Toda esa charla sobre jugar y holgazanear hace rato?" with dissolve

# game/Kyou 6.rpy:9450
translate spanish Day6_Con_Kyou_Sayori_Alter_Switch_d28b8b70:

    # "Her head droops slightly, her eyelids fluttering as if she could just drop to the floor in an exhausted heap." with dissolve
    "Su cabeza baja ligeramente, sus ojos revolotean como si pudiera caer exhausta al suelo en cualquier instante." with dissolve

# game/Kyou 6.rpy:9452
translate spanish Day6_Con_Kyou_Sayori_Alter_Switch_babb8a0f:

    # "But a moment later she seems to collect herself as she shakes her head; her arms tensing tightly around those textbooks." with dissolve
    "Pero un momento después parece recomponerse y sacude la cabeza; sus brazos aprietan esos libros con fuerza." with dissolve

# game/Kyou 6.rpy:9453
translate spanish Day6_Con_Kyou_Sayori_Alter_Switch_095ea063:

    # s "I... A-Atsuko, I should not have said such frivolous things, and I am sorry to have worried you."
    s "Yo... A-Atsuko, no debí decir tales frivolidades, y lamento haberla preocupado."

# game/Kyou 6.rpy:9454
translate spanish Day6_Con_Kyou_Sayori_Alter_Switch_fc12de4a:

    # s irritated "But I have obligations and they must be fulfilled. Please understand." with dissolve
    s irritated "Pero tengo obligaciones que deben cumplirse." with dissolve

# game/Kyou 6.rpy:9456
translate spanish Day6_Con_Kyou_Sayori_Alter_Switch_207d58cd:

    # "Atsuko puts a hand to her cheek and sighs."
    "Atsuko se lleva una mano a la mejilla y suspira."

# game/Kyou 6.rpy:9457
translate spanish Day6_Con_Kyou_Sayori_Alter_Switch_f8abece4:

    # nm sleep "Oh my, you must be talking about your father." with dissolve
    nm sleep "Oh, cielos, debes estar hablando de tu padre." with dissolve

# game/Kyou 6.rpy:9458
translate spanish Day6_Con_Kyou_Sayori_Alter_Switch_e3e9358d:

    # s sleepy "B-besides, this... th-this reckless side of me has gotten me into enough trouble. I simply must..." with dissolve
    s sleepy "A-demás, este... e-este lado imprudente mío ya me ha causado suficientes problemas." with dissolve

# game/Kyou 6.rpy:9459
translate spanish Day6_Con_Kyou_Sayori_Alter_Switch_b5731942:

    # nm neutral_side "Dragging yourself to work while unfit sounds rather reckless to me, Sayori." with dissolve
    nm neutral_side "Ir a rastras a trabajar mientras no te encuentras apta a mí me parece bastante imprudente, Sayori." with dissolve

# game/Kyou 6.rpy:9460
translate spanish Day6_Con_Kyou_Sayori_Alter_Switch_16e60863:

    # s panicked "Ahhh, b-but this is... different." with dissolve
    s panicked "Aaah, p-pero esto es... diferente." with dissolve

# game/Kyou 6.rpy:9461
translate spanish Day6_Con_Kyou_Sayori_Alter_Switch_93f92064:

    # s scared "M-Mrs. Akemi, I cannot... y-you don't understand, I can't simply abandon my... my obligations, I..." with dissolve
    s scared "S-Sra. Akemi, no puedo... n-no comprende, no puedo abandonar mis... mis obligaciones, tengo..." with dissolve

# game/Kyou 6.rpy:9467
translate spanish Day6_Con_Kyou_Sayori_Alter_Switch_6dddcf03:

    # "As Sayori babbles desperately to convince her, we can only stand by as Atsuko places a hand on Sayori's shoulder and smiles gently."
    "Sayori murmulla desesperadamente para convencerla, y solo observamos cómo Atsuko pone sus manos en los hombros de Sayori, sonriendo con gentileza."

# game/Kyou 6.rpy:9470
translate spanish Day6_Con_Kyou_Sayori_Alter_Switch_86feb6ff:

    # nm smile_side "Let me talk to him, Sayori. Let me talk to your father, from one parent to another." with dissolve
    nm smile_side "Déjame hablar con él, Sayori. Déjame hablar con tu papá, de un padre a otro." with dissolve

# game/Kyou 6.rpy:9471
translate spanish Day6_Con_Kyou_Sayori_Alter_Switch_133f2249:

    # s sleeptalk_concerned "But if I... th-that is..." with dissolve
    s sleeptalk_concerned "Pero si yo... e-eso..." with dissolve

# game/Kyou 6.rpy:9473
translate spanish Day6_Con_Kyou_Sayori_Alter_Switch_a10ce57c:

    # s sleepy "... Mrrn, do you think it would help?" with dissolve
    s sleepy "... Mmnn, ¿cree que eso ayudaría?" with dissolve

# game/Kyou 6.rpy:9474
translate spanish Day6_Con_Kyou_Sayori_Alter_Switch_1567f9fa:

    # nm happy "I'm sure he wants what's best for you. And right now, that involves turning that hard work ethic of yours inward." with dissolve
    nm happy "Estoy segura de que quiere lo mejor para ti. Y ahora mismo, eso involucra repensar esa ética de trabajo en pro de tu bien." with dissolve

# game/Kyou 6.rpy:9475
translate spanish Day6_Con_Kyou_Sayori_Alter_Switch_e6e09886:

    # nm neutral_side "Which starts by getting some gosh-darned rest, young lady!" with dissolve
    nm neutral_side "¡Y el primer paso es tomar un condenado descanso, jovencita!" with dissolve

# game/Kyou 6.rpy:9477
translate spanish Day6_Con_Kyou_Sayori_Alter_Switch_917c4783:

    # "Sayori lets out a groan as she lets her arms drop; her treasured textbooks scattering to the floor as if to signal her defeat." with dissolve
    "Sayori dejar caer sus brazos con un gruñido; sus preciados libros se esparcen por el suelo cual seña de su derrota." with dissolve

# game/Kyou 6.rpy:9478
translate spanish Day6_Con_Kyou_Sayori_Alter_Switch_dcbd63f6:

    # s "I... suppose I can disappoint him a... a little longer..."
    s "Supongo... que puedo decepcionarlo un... un poco más..."

# game/Kyou 6.rpy:9480
translate spanish Day6_Con_Kyou_Sayori_Alter_Switch_bd7f8095:

    # "Atsuko tuts a little to herself and shakes her head at the shattered girl." with dissolve
    "Atsuko hace un ruido de desaprobación y le sacude la cabeza a la agotada chica." with dissolve

# game/Kyou 6.rpy:9481
translate spanish Day6_Con_Kyou_Sayori_Alter_Switch_ac51105f:

    # nm "You're not disappointing anyone, dear. Just take care of yourself, okay?"
    nm "No estás decepcionando a nadie, cariño. Solo cuida de ti, ¿sí?"

# game/Kyou 6.rpy:9485
translate spanish Day6_Con_Kyou_Sayori_Alter_Switch_81481e5d:

    # "To that, Sayori doesn't have an answer. Instead, she takes a step back before unceremoniously flopping down onto Nozomi's bedsheets."
    "Ante eso, Sayori no tiene una respuesta. En cambio, da un paso atrás para luego desplomarse sin contemplaciones sobre las sábanas de Nozomi."

# game/Kyou 6.rpy:9486
translate spanish Day6_Con_Kyou_Sayori_Alter_Switch_8c02448f:

    # s "{size=16}Nozomi....{/size}"
    s "{size=16}Nozomi....{/size}"

# game/Kyou 6.rpy:9490
translate spanish Day6_Con_Kyou_Sayori_Alter_Switch_7cde24ae:

    # n "Um, yes?" with dissolve
    n "Em, ¿sí?" with dissolve

# game/Kyou 6.rpy:9491
translate spanish Day6_Con_Kyou_Sayori_Alter_Switch_0dfece50:

    # s "{size=16}... I need to borrow your bed againnn...... mmrn...{/size}"
    s "{size=16}... Debo tomar prestada tu cama otra vez...... mmnn...{/size}"

# game/Kyou 6.rpy:9493
translate spanish Day6_Con_Kyou_Sayori_Alter_Switch_529246f3:

    # n happy "Ehehe... sweet dreams, Sayori..." with dissolve
    n happy "Jejeje... dulces sueños, Sayori..." with dissolve

# game/Kyou 6.rpy:9520
translate spanish Day6_Con_Kyou_Sayori_Alter_Switch_951a1c6b:

    # "With Sayori seemingly at peace (and fast asleep), there wasn't really much more to do but head back home."
    "Con Sayori aparentemente tranquila (y habiéndose quedado dormida rápidamente), no había mucho más que hacer que volver a casa."

# game/Kyou 6.rpy:9258
translate spanish Day6_Con_Kyou_Sayori_Alter_Switch_e280c570:

    # "So here I am, laying on my own bed as I think back on that wild journey I had with Sayori, and with hypnosis."
    "Así que heme aquí, recostado en mi cama y pensando en el loco viaje que tuve con Sayori y la hipnosis."

# game/Kyou 6.rpy:9523
translate spanish Day6_Con_Kyou_Sayori_Alter_Switch_856170cf:

    # "Hypnosis and... and mind control. Thinking about it now it's over just makes it feel like some weird fever dream I had."
    "Hipnosis y... control mental. Pensar en eso ahora que terminó me hace sentir que fue un mal sueño."

# game/Kyou 6.rpy:9524
translate spanish Day6_Con_Kyou_Sayori_Alter_Switch_4916a0dc:

    # "That I somehow managed to make a penlight that could do all that to Sayori... Even experiencing it myself, it still doesn't seem real. But it really did happen."
    "Que de alguna forma haya logrado hacer una linterna que podía hacerle todo eso a Sayori... E incluso la haya experimentado yo mismo. No parece real. Pero sí pasó."

# game/Kyou 6.rpy:9525
translate spanish Day6_Con_Kyou_Sayori_Alter_Switch_b053ad1e:

    # "I put her through all that confusion and pain because I didn't know what I was dealing with. I literally reshaped part of her mind to think she hated everything about her real self."
    "La hice pasar por toda esa confusión y dolor por no saber con qué lidiaba. Literalmente reformé partes de su mente para que pensara que odiaba todo de su verdadero ser."

# game/Kyou 6.rpy:9526
translate spanish Day6_Con_Kyou_Sayori_Alter_Switch_9d10e312:

    # "I even made her think she had a crush on me... goddamn, why did I think that was a good idea?"
    "Incluso la hice pensar que estaba enamorada de mí... maldita sea, ¿cómo se me pudo ocurrir que eso era una buena idea?"

# game/Kyou 6.rpy:9527
translate spanish Day6_Con_Kyou_Sayori_Alter_Switch_c866409a:

    # "What's she going to think of me when she's had the chance to think about what I've done?"
    "¿Qué va a pensar de mí cuando tenga tiempo para pensar en lo que he hecho?"

# game/Kyou 6.rpy:9528
translate spanish Day6_Con_Kyou_Sayori_Alter_Switch_9017a81d:

    # "Maybe it would've been better if I never studied hypnosis in the first place."
    "Tal vez habría sido mejor si nunca hubiera estudiado hipnosis en primer lugar."

# game/Kyou 6.rpy:9529
translate spanish Day6_Con_Kyou_Sayori_Alter_Switch_6b63ecf0:

    # "If I never forced my way into Sayori's life at all..."
    "Si nunca hubiera irrumpido en la vida de Sayori..."

# game/Kyou 6.rpy:9534
translate spanish Day6_Con_Kyou_Sayori_Alter_Switch_84a84771:

    # ks casual confused "Uhh, what?"
    ks casual confused "Eeh, ¿qué?"

# game/Kyou 6.rpy:9535
translate spanish Day6_Con_Kyou_Sayori_Alter_Switch_1580d5d9:

    # "That vibrating sound..."
    "Escucho una vibración..."

# game/Kyou 6.rpy:9538
translate spanish Day6_Con_Kyou_Sayori_Alter_Switch_7330c460:

    # "Wait, that's my phone! Who on earth is calling me? No one calls me!"
    "¡Espera, es mi teléfono! ¿Quién rayos me está llamando? ¡Nadie me llama!"

# game/Kyou 6.rpy:9540
translate spanish Day6_Con_Kyou_Sayori_Alter_Switch_060239e3:

    # ks "... H-hello?"
    ks "... ¿Ho-hola?"

# game/Kyou 6.rpy:9543
translate spanish Day6_Con_Kyou_Sayori_Alter_Switch_2d717939:

    # s "\"Hello, Kyou. I suppose I have [alt_name] to thank for acquiring your phone number.\""
    s "\"Hola, Kyou. Supongo que debo agradecerle a [alt_name] por adquirir tu número de teléfono.\""

# game/Kyou 6.rpy:9544
translate spanish Day6_Con_Kyou_Sayori_Alter_Switch_8a9c5e8d:

    # ks surprised "Sayori!?"
    ks surprised "¿¡Sayori!?"

# game/Kyou 6.rpy:9545
translate spanish Day6_Con_Kyou_Sayori_Alter_Switch_f3fc0884:

    # "After a moment's silence, an amused chuckle floats into my ear."
    "Después de un momento de silencio, una risa llega a mi oído."

# game/Kyou 6.rpy:9547
translate spanish Day6_Con_Kyou_Sayori_Alter_Switch_767260d1:

    # s "\"The one and only. I wanted to speak with you again now that my head is... somewhat clearer than before.\""
    s "\"La única e inigualable. Quería hablar contigo otra vez ahora que mi mente está... un poco más clara que antes.\""

# game/Kyou 6.rpy:9549
translate spanish Day6_Con_Kyou_Sayori_Alter_Switch_2f7f266c:

    # ks confused "Yeah... y-yeah, how are you doing, anyway?"
    ks confused "Sí... s-sí, ¿cómo estás, por cierto?"

# game/Kyou 6.rpy:9550
translate spanish Day6_Con_Kyou_Sayori_Alter_Switch_695b1de5:

    # s "\"Hmm, well, I am safely back at home. And my parents and I had a lengthy talk about my... recent conduct.\""
    s "\"Mmm, bueno, volví a casa sana y salva. Y mis padres y yo tuvimos una larga charla sobre mi... reciente conducta.\""

# game/Kyou 6.rpy:9551
translate spanish Day6_Con_Kyou_Sayori_Alter_Switch_b50ab51c:

    # "I wince inwardly, as if I needed another reminder of all the bullshit I put her through."
    "Hago una mueca, como si necesitara otro recordatorio de toda la mierda por la que la hice pasar."

# game/Kyou 6.rpy:9552
translate spanish Day6_Con_Kyou_Sayori_Alter_Switch_966976ed:

    # ks sigh "Ouch."
    ks sigh "Auch."

# game/Kyou 6.rpy:9553
translate spanish Day6_Con_Kyou_Sayori_Alter_Switch_f399c2a1:

    # s "\"Oh, it was not as terrible as I feared. As a matter of fact, my dad has proven to be refreshingly understanding about my situation.\""
    s "\"Oh, no fue tan terrible como temí. De hecho, mi padre probó ser refrescantemente comprensivo respecto a mi situación.\""

# game/Kyou 6.rpy:9554
translate spanish Day6_Con_Kyou_Sayori_Alter_Switch_742425f9:

    # s "\"So moving forward we are going to reassess my work schedule to ensure I do not have another \"burnout episode\", as he put it. Heh.\""
    s "\"Así que, de ahora en adelante, reevaluaremos mi horario de trabajo para evitar otro \"episodio de agotamiento\", como él lo llamó. Je.\""

# game/Kyou 6.rpy:9556
translate spanish Day6_Con_Kyou_Sayori_Alter_Switch_eaa956de:

    # "I smile as I listen to her go on. Seems she's going to be okay at least."
    "Sonrío, escuchando el relato. Parece que estará bien, al menos."

# game/Kyou 6.rpy:9557
translate spanish Day6_Con_Kyou_Sayori_Alter_Switch_8f05e5d2:

    # ks smile "That's great, Sayori. "
    ks smile "Eso es grandioso, Sayori."

# game/Kyou 6.rpy:9558
translate spanish Day6_Con_Kyou_Sayori_Alter_Switch_5244aaa5:

    # "No thanks to me, though."
    "Aunque no gracias a mí."

# game/Kyou 6.rpy:9559
translate spanish Day6_Con_Kyou_Sayori_Alter_Switch_d6123049:

    # ks sigh "Listen, Sayori, about what happened... it's not going to happen again, I promise."
    ks sigh "Escucha, Sayori, sobre lo que pasó... no volverá a pasar, lo prometo."

# game/Kyou 6.rpy:9295
translate spanish Day6_Con_Kyou_Sayori_Alter_Switch_e1554201_2:

    # s "..."
    s "..."

# game/Kyou 6.rpy:9562
translate spanish Day6_Con_Kyou_Sayori_Alter_Switch_9c9f3067:

    # ks sad "This hypnosis stuff is way more dangerous than I thought it'd be. I figured it'd be fun to show people what I could do."
    ks sad "Esto de la hipnosis es mucho más peligroso de lo que pensé que sería. Creí que sería divertido mostrarle a la gente lo que puedo hacer."

# game/Kyou 6.rpy:9563
translate spanish Day6_Con_Kyou_Sayori_Alter_Switch_05a61b54:

    # ks "Yeah I didn't know what that penlight could do, but even so I never should've given someone a dangerous suggestion when I didn't know what I was doing."
    ks "Sí, no sabía lo que esa linterna podía hacer, pero aun así nunca debí darle a alguien una sugestión tan peligrosa cuando no sabía lo que estaba haciendo."

# game/Kyou 6.rpy:9564
translate spanish Day6_Con_Kyou_Sayori_Alter_Switch_8cfd9ba2:

    # ks "And seeing what it did to you... w-well, I guess I'm not cut out to be a hypnotist, huh."
    ks "Y viendo lo que te hizo a ti... b-bueno, supongo que no sirvo para ser hipnotista, ¿eh?"

# game/Kyou 6.rpy:9565
translate spanish Day6_Con_Kyou_Sayori_Alter_Switch_b7496430:

    # "I hear nothing but silence on the other end for a while. But eventually, I hear Sayori clicking her tongue."
    "No escucho más que silencio del otro lado por unos momentos, pero eventualmente, oigo a Sayori tronarse la lengua."

# game/Kyou 6.rpy:9566
translate spanish Day6_Con_Kyou_Sayori_Alter_Switch_89a1f08d:

    # s "\"Kyou. What compelled you to study hypnosis in the first place?\""
    s "\"Kyou. ¿Qué te inspiró a estudiar hipnosis en primer lugar?\""

# game/Kyou 6.rpy:9567
translate spanish Day6_Con_Kyou_Sayori_Alter_Switch_2670a5f9:

    # ks confused "Huh?"
    ks confused "¿Eh?"

# game/Kyou 6.rpy:9568
translate spanish Day6_Con_Kyou_Sayori_Alter_Switch_a12ab51d:

    # s "\"It was to be seen, was it not?\""
    s "\"Querías ser visto, ¿no es así?\""

# game/Kyou 6.rpy:9570
translate spanish Day6_Con_Kyou_Sayori_Alter_Switch_61ce327e:

    # ks "U-uhhhh..."
    ks "E-eeeeh..."

# game/Kyou 6.rpy:9578
translate spanish Day6_Con_Kyou_Sayori_Alter_Switch_8f1e949e:

    # s "\"Perhaps things did not go the way you imagined, in more ways than one, but you *were* seen.\""
    s "\"Tal vez las cosas no salieron como imaginaste, de más de una forma, pero *sí* fuiste visto.\""

# game/Kyou 6.rpy:9579
translate spanish Day6_Con_Kyou_Sayori_Alter_Switch_a7fac96e:

    # s "\"Thank you, for allowing me to see you at last.\""
    s "\"Gracias, por permitirme verte al fin.\""

# game/Kyou 6.rpy:9580
translate spanish Day6_Con_Kyou_Sayori_Alter_Switch_25d6a39f:

    # ks "I-I..."
    ks "E-este..."

# game/Kyou 6.rpy:9581
translate spanish Day6_Con_Kyou_Sayori_Alter_Switch_0522d923:

    # "Oh, fuck, I have no idea how to respond to that."
    "Oh, mierda, no tengo idea de cómo responder a eso."

# game/Kyou 6.rpy:9582
translate spanish Day6_Con_Kyou_Sayori_Alter_Switch_6507f4f4:

    # s "\"So Kyou, I am free tomorrow evening and I was wondering...\""
    s "\"Así que, Kyou, estoy libre mañana por la tarde y me preguntaba...\""

# game/Kyou 6.rpy:9583
translate spanish Day6_Con_Kyou_Sayori_Alter_Switch_914f40f8:

    # s "\"... Could I see you again?\""
    s "\"... ¿Podría verte otra vez?\""
# TODO: Translation updated at 2023-10-19 09:38

# game/Kyou 6.rpy:4211
translate spanish Day6_Con_Kyou_Nozomi_Trance_863302d7:

    # "It's almost noon, what is she talking about?"
    "Casi es mediodía, ¿de qué está hablando?"

# game/Kyou 6.rpy:4288
translate spanish Day6_Con_Kyou_Nozomi_Trance_54cf13ab:

    # "And... now that I think about it..."
    "Y... ahora que lo pienso..."

# game/Kyou 6.rpy:4295
translate spanish Day6_Con_Kyou_Nozomi_Trance_2f315478:

    # ks smile "It doesn't matter how awake you seem in the future, this truth will always be in effect. Understand, Nozomi?"
    ks smile "Sin importar lo despierta que parezcas estar en el futuro, esta verdad siempre te afectará. ¿Comprendes, Nozomi?"

# game/Kyou 6.rpy:4296
translate spanish Day6_Con_Kyou_Nozomi_Trance_92736ffa:

    # ncg sleeptalk "I understand..." with dissolve
    ncg sleeptalk "Comprendo..." with dissolve

# game/Kyou 6.rpy:4301
translate spanish Day6_Con_Kyou_Nozomi_Trance_ac339595:

    # "... Yeah. I never told her it only applied to my house."
    "... Sí. Nunca le dije que solo aplicara en mi casa."

# game/Kyou 6.rpy:4622
translate spanish Day6_Con_Kyou_Nozomi_Trance_fb47d6a7:

    # "I honestly don't know either, and knowing it from my expression seems to satisfy her." with dissolve
    "Honestamente, yo tampoco lo sé, y leerlo en mi expresión parece satisfacerla." with dissolve

# game/Kyou 6.rpy:5333
translate spanish Day6_Con_Kyou_Nozomi_Trance_75fe44fb:

    # "And nothing makes me more certain of that than knowing she keeps letting me get away with this." with dissolve
    "Y nada me hace estar más seguro de eso que saber que sigue permitiéndome hacer esto y salirme con la mía." with dissolve
# TODO: Translation updated at 2023-12-02 19:32

# game/Kyou 6.rpy:4183
translate spanish Day6_Con_Kyou_Nozomi_Trance_9be02778:

    # "No prizes for guessing that this is Nozomi's mother."
    "Creo que no hay que ser un genio para deducir que esta es la madre de Nozomi."

# game/Kyou 6.rpy:4299
translate spanish Day6_Con_Kyou_Nozomi_Trance_8da0c3f9:

    # "And I sure didn't remove the suggestion after we were done with it the other day. We were so rushed for time that I forgot all about it."
    "Y definitivamente no removí la sugestión cuando terminamos de jugar con ella el otro día. Con toda la emoción, me olvidé por completo."

# game/Kyou 6.rpy:4304
translate spanish Day6_Con_Kyou_Nozomi_Trance_05ddd07d:

    # "But then, when I consider what she was telling me yesterday, about wanting to feel like I'm really controlling her mind..."
    "Sin embargo, cuando considero lo que me dijo ayer, sobre querer sentir que de verdad estoy controlando su mente..."
# TODO: Translation updated at 2024-02-01 09:35

# game/Kyou 6.rpy:7259
translate spanish Day6_Con_Kyou_Sayori_Alter_Switch_b49a7791:

    # nm happy "Oh, but where are my manners? I'm Atsuko; nice to meet another classmate of Nozomi's!" with dissolve
    nm happy "Oh, pero ¿dónde están mis modales? ¡Soy Atsuko; un gusto conocer a otro compañero de clase de Nozomi!" with dissolve

# game/Kyou 6.rpy:7309
translate spanish Day6_Con_Kyou_Sayori_Alter_Switch_3418edb1:

    # ks sigh "Yeah. Yeah, I know."
    ks sigh "Sí. Sí, lo sé."

# game/Kyou 6.rpy:7350
translate spanish Day6_Con_Kyou_Sayori_Alter_Switch_b3d5a16b:

    # s neutral_right "But that changed with my second session with you. When an entire twenty-four hours of my life had passed, and yet I did not live to see it." with dissolve
    s neutral_right "Pero eso cambió en mi segunda sesión contigo. Cuando veinticuatro horas de mi vida en su totalidad transcurrieron, y sin embargo, no estuve ahí para verlo." with dissolve

# game/Kyou 6.rpy:7351
translate spanish Day6_Con_Kyou_Sayori_Alter_Switch_f6332a11:

    # s casual surprised_right "So to discover that someone else had lived in my place? Interacted with everyone I know as though she were me?" with dissolve
    s casual surprised_right "¿Y descubrir que alguien más vivió en mi lugar? ¿Que interactuó con todos mis conocidos cual si fuera yo?" with dissolve

# game/Kyou 6.rpy:7352
translate spanish Day6_Con_Kyou_Sayori_Alter_Switch_dd94f8bf:

    # s sleeptalk "And all because I accommodated your careless want for a moment's frivolity?" with dissolve
    s sleeptalk "¿Y todo para satisfacer tu descuidado deseo de un momento de frivolidad?" with dissolve

# game/Kyou 6.rpy:7360
translate spanish Day6_Con_Kyou_Sayori_Alter_Switch_a632c36b:

    # s casual_folded sleep "Kyou, I do believe that your intentions that day were harmless." with dissolve
    s casual_folded sleep "Kyou, considero que tus intenciones no eran las de hacer daño." with dissolve

# game/Kyou 6.rpy:7361
translate spanish Day6_Con_Kyou_Sayori_Alter_Switch_51b6fc55:

    # s sleeptalk "Surely my reaction came as a surprise to you. I imagine it must have delighted you at first, that I would take to your hypnosis so swimmingly." with dissolve
    s sleeptalk "Seguramente mi reacción fue una sorpresa para ti. Imagino que te habrá deleitado al principio que haya reaccionado tan efectivamente a tu hipnosis." with dissolve

# game/Kyou 6.rpy:7362
translate spanish Day6_Con_Kyou_Sayori_Alter_Switch_d34306b8:

    # s neutral_right "Even so, you must have realized how unconscionable it would be to allow such a state to reside within me beyond the safety of your home." with dissolve
    s neutral_right "No obstante, debiste darte cuenta de lo desmesurado que fue permitir que tal estado residiera dentro de mí fuera de la seguridad de tu morada." with dissolve

# game/Kyou 6.rpy:7363
translate spanish Day6_Con_Kyou_Sayori_Alter_Switch_5aa4c15f:

    # "The air begins to feel cold around me as Sayori falls silent for a moment. It feels like she wants me to agree."
    "El aire comienza a enfriarse a mi alrededor mientras Sayori se queda momentáneamente en silencio. Parece que quiere que le conceda la razón."

# game/Kyou 6.rpy:7364
translate spanish Day6_Con_Kyou_Sayori_Alter_Switch_04310382:

    # "But as I struggle to respond, she begins to speak once more."
    "Pero cuando estoy a punto de intentar responder, ella comienza a hablar una vez más."

# game/Kyou 6.rpy:7366
translate spanish Day6_Con_Kyou_Sayori_Alter_Switch_8c2a71e5:

    # s casual_handup "Nozomi informed me that you and I spoke alone during the lunchbreak." with dissolve
    s casual_handup "Nozomi me informó que tú y yo hablamos a solas durante el almuerzo." with dissolve

# game/Kyou 6.rpy:7367
translate spanish Day6_Con_Kyou_Sayori_Alter_Switch_c662486d:

    # ks surprised "Huh? W-well..."
    ks surprised "¿Eh? P-pues..."

# game/Kyou 6.rpy:7368
translate spanish Day6_Con_Kyou_Sayori_Alter_Switch_5a7e8c83:

    # s sleep "I have no idea of what we discussed, of course. Only that you had the opportunity to put a halt to this madness there and then." with dissolve
    s sleep "No tengo idea de qué discutimos, por supuesto. Solo sé que tuviste la oportunidad de ponerle fin a esta locura ahí y entonces." with dissolve

# game/Kyou 6.rpy:7369
translate spanish Day6_Con_Kyou_Sayori_Alter_Switch_6e2ed8b4:

    # s concerned_right "You were the only one who could help me, and yet..." with dissolve
    s concerned_right "Tú eras el único que podía ayudarme, y sin embargo..." with dissolve

# game/Kyou 6.rpy:7370
translate spanish Day6_Con_Kyou_Sayori_Alter_Switch_a19fcf7f:

    # "There's a sadness in her eyes as Sayori searches my expression for an explanation."
    "Puedo ver la tristeza en los ojos de Sayori que observan mi expresión en busca de una explicación."

# game/Kyou 6.rpy:7371
translate spanish Day6_Con_Kyou_Sayori_Alter_Switch_34054248:

    # ks "I... w-well, you see..."
    ks "Pues... e-este, verás..."

# game/Kyou 6.rpy:7372
translate spanish Day6_Con_Kyou_Sayori_Alter_Switch_e945186b:

    # "I can feel my throat closing as I struggle to find the words to respond to a face like that."
    "Siento que la garganta se me cierra al luchar por encontrar las palabras para responderle a una cara así."

# game/Kyou 6.rpy:7373
translate spanish Day6_Con_Kyou_Sayori_Alter_Switch_aa3ef919:

    # ks "L-look, you have to understand! There were people all around us, I couldn't just..."
    ks "¡M-mira, tienes que entender! Había mucha gente alrededor, no podía simplemente..."

# game/Kyou 6.rpy:7375
translate spanish Day6_Con_Kyou_Sayori_Alter_Switch_9c3a7453:

    # n side frown "What did you say her, Kyou?" with dissolve
    n side frown "¿Qué le dijiste, Kyou?" with dissolve

# game/Kyou 6.rpy:7376
translate spanish Day6_Con_Kyou_Sayori_Alter_Switch_fbb5975e:

    # n furious "What did you say to your \"school project\"?" with dissolve
    n furious "¿Qué le dijiste a tu \"proyecto escolar\"?" with dissolve

# game/Kyou 6.rpy:7378
translate spanish Day6_Con_Kyou_Sayori_Alter_Switch_9721d8c6:

    # ks confused "I-I didn't know what to do, okay? You seemed happy to go along with it, and I wanted that for you. I thought you wanted to be happy for a while."
    ks confused "N-no sabía qué hacer, ¿de acuerdo? Parecías feliz de seguir así, y yo quería eso para ti. Creí que querías ser feliz por un rato."

# game/Kyou 6.rpy:7379
translate spanish Day6_Con_Kyou_Sayori_Alter_Switch_75d0182e:

    # ks "And even if you didn't, what do you think would've happened if I woke you up in the middle of class? Don't you think you would've freaked out in front of all those people?"
    ks "E incluso si no, ¿qué crees que habría pasado si te hubiera despertado en plena clase? ¿No crees que habrías entrado en pánico delante de toda esa gente?"

# game/Kyou 6.rpy:7380
translate spanish Day6_Con_Kyou_Sayori_Alter_Switch_38a8ae8c:

    # ks "So... yeah, maybe I wussed out. And yeah, maybe I should've brought you back to yourself, but I really thought it'd be better to just play along until you were out of there."
    ks "Así que... sí, tal vez me acobardé. Y sí, tal vez debí haberte traído devuelta yo mismo, pero de verdad creí que sería mejor seguir la corriente hasta que estuvieras fuera de ahí."

# game/Kyou 6.rpy:7381
translate spanish Day6_Con_Kyou_Sayori_Alter_Switch_2f7669c2:

    # n irritated "Unbelievable..." with dissolve
    n irritated "No puedo creer esto..." with dissolve

# game/Kyou 6.rpy:7383
translate spanish Day6_Con_Kyou_Sayori_Alter_Switch_2fc8b83d:

    # "(( AUTHOR'S NOTE: Regrettably, I'm going to have to leave it here for now as I'm out of time, but I'll outline how the rest of this sub path is intended to play out. ))" with dissolve
    "(( NOTA DE LA AUTORA: Desafortunadamente, voy a tener que dejarlo aquí por ahora, pues ya no tengo tiempo, pero bosquejaré cómo el resto de esta sub-ruta se supone que vaya. )) " with dissolve

# game/Kyou 6.rpy:7384
translate spanish Day6_Con_Kyou_Sayori_Alter_Switch_839a6d98:

    # "(( So feel free to read on if you like, or come back next time where I should have this scripted properly. ))"
    "(( Así que siéntanse libres de leer si quieren, o regresen a la próxima cuando debería estar completa. ))"

# game/Kyou 6.rpy:7682
translate spanish Day6_Con_Kyou_Sayori_Alter_Switch_0dcec31d:

    # "More... awkward... by the second..."
    "Más... incómodo... con cada segundo..."
# TODO: Translation updated at 2024-02-02 16:13

# game/Kyou 6.rpy:7385
translate spanish Day6_Con_Kyou_Sayori_Alter_Switch_97f4463a:

    # "So, after chewing out Kyou some more for his reckless stupidity, Nozomi expresses her disbelief that this incompetant hypnotist was able to do so much damage to Sayori."
    "Pues bien, después de sermonear un poco más a Kyou por su estupidez, Nozomi expresa lo difícil que es creer que un hipnotista incompetente pudo hacerle tanto daño a Sayori."

# game/Kyou 6.rpy:7386
translate spanish Day6_Con_Kyou_Sayori_Alter_Switch_07fb95eb:

    # "She then expresses a wish that he never dabbles in hypnosis again as delving into someone's mind is a weighty responsibility that he has proven himself unworthy of carrying."
    "Luego expresa su deseo de que nunca se vuelva a involucrar con la hipnosis, pues ahondar en la mente de alguien es una responsabilidad para la que claramente no está equipado."

# game/Kyou 6.rpy:7387
translate spanish Day6_Con_Kyou_Sayori_Alter_Switch_132d3a1a:

    # "While Kyou is reeling from guilt, Nozomi starts talking about getting Sayori some professional help to undo the damage he's done. But Sayori has other ideas..."
    "Mientras Kyou se retuerce por la culpa, Nozomi comienza a hablar de conseguirle a Sayori ayuda profesional para deshacer el daño que provocó. Pero Sayori tiene otra idea..."

# game/Kyou 6.rpy:7388
translate spanish Day6_Con_Kyou_Sayori_Alter_Switch_18c34814:

    # "She pleads with Kyou to hypnotize her one last time, under Nozomi's supervision, and thoroughly remove every suggestion he planted in her head."
    "Ella aboga por que Kyou la hipnotice una última vez, bajo la supervisión de Nozomi, y remueva exhaustivamente todas las sugestiones que puso en su cabeza."

# game/Kyou 6.rpy:7389
translate spanish Day6_Con_Kyou_Sayori_Alter_Switch_4dd60d5d:

    # "Nozomi objects, but Sayori desperately doesn't want to involve a hypnotherapist."
    "Nozomi objeta, pero Sayori desesperadamente no quiere involucrar a un hipnoterapeuta."

# game/Kyou 6.rpy:7390
translate spanish Day6_Con_Kyou_Sayori_Alter_Switch_887833e2:

    # "For one, she fears what having this mental health episode on record will do to her aspirations of entering the medical profession, to say nothing of losing even more time for her studies."
    "Para empezar, teme lo que un registro de este episodio de salud mental pueda hacerles a sus aspiraciones en la profesión médica, sin mencionar de perder más tiempo de estudio."

# game/Kyou 6.rpy:7391
translate spanish Day6_Con_Kyou_Sayori_Alter_Switch_68db8dda:

    # "But more than that, she just wants to never have to think about hypnosis again."
    "Pero lo que es más, simplemente no quiere tener que volver a pensar en hipnosis nunca más."

# game/Kyou 6.rpy:7392
translate spanish Day6_Con_Kyou_Sayori_Alter_Switch_bc875a51:

    # "For her, hypnosis has been a terrifying nightmare that threatens to uproot her mental stability. She wants nothing more than to close this horrific chapter of her life immediately."
    "Para ella, la hipnosis ha sido una espantosa pesadilla que amenaza con desarraigar su estabilidad mental. No quiere nada más que cerrar este horrible capítulo de su vida de inmediato."

# game/Kyou 6.rpy:7393
translate spanish Day6_Con_Kyou_Sayori_Alter_Switch_4b862427:

    # "So once again, she begs Kyou to right what he wronged. After what she has experienced, she's positive that he can do it."
    "Así que, una vez más, le pide a Kyou que arregle lo que rompió. Luego de lo que ha experimentado, no le caben dudas de que puede hacerlo."

# game/Kyou 6.rpy:7394
translate spanish Day6_Con_Kyou_Sayori_Alter_Switch_a944e0dd:

    # "And Kyou, upset at what he's reduced her to after she was the only one who even vaguely believed in him, agrees..."
    "Y Kyou, dolido por haberla reducido a esto después de que fue la única que creyó aunque fuera vagamente en él, acepta..."

# game/Kyou 6.rpy:7399
translate spanish Day6_Con_Kyou_Sayori_Alter_Switch_7705b980:

    # "We then jump forward to a couple of days later."
    "Luego damos un salto a un par de días más tarde."

# game/Kyou 6.rpy:7400
translate spanish Day6_Con_Kyou_Sayori_Alter_Switch_a9d2b620:

    # "Things seem to be almost back to the status quo as Kyou thinks back on his mistakes."
    "Las cosas parecen haber vuelto casi por completo al statu quo mientras Kyou reflexiona sobre sus errores."

# game/Kyou 6.rpy:7401
translate spanish Day6_Con_Kyou_Sayori_Alter_Switch_28f65084:

    # "He's given up on hypnosis and doesn't even want to look at the penlight again after that disaster. Instead he's trying to stay focused on his studies to distract from the numbness in his heart."
    "Renunció a la hipnosis y ni siquiera quiere volver a ver la linterna después de ese desastre."
    "En vez de eso, intenta concentrarse en sus propios estudios para distraerse del pesar en su corazón."


# game/Kyou 6.rpy:7403
translate spanish Day6_Con_Kyou_Sayori_Alter_Switch_0a1a1799:

    # "At this point there'll probably be a brief exhange of words between himself and Sayori, who clearly has trouble talking to him but is trying to remain impartial to his presence nevertheless." with dissolve
    "En este momento probablemente haya un breve intercambio de palabras entré él y Sayori, quien claramente no está cómoda hablando con él, pero intenta mantenerse imparcial ante su presencia." with dissolve

# game/Kyou 6.rpy:7404
translate spanish Day6_Con_Kyou_Sayori_Alter_Switch_cb14f8ab:

    # "They wish each other luck for the exams tomorrow and, with a little hesitation, Sayori tells him that she hopes he can channel his boundless potential towards achieving some good in the world."
    "Se desean buena suerte en los exámenes de mañana y, con algo de indecisión, Sayori le dice que espera que pueda canalizar su ilimitado potencial para lograr algo bueno."

# game/Kyou 6.rpy:7406
translate spanish Day6_Con_Kyou_Sayori_Alter_Switch_ac231f78:

    # "Sayori leaves him with that little moment of kindness, and Kyou returns to his thoughts and regrets about things turned out between him and Sayori..." with dissolve
    "Sayori lo deja con ese pequeño momento de amabilidad, y Kyou vuelve a su reflexión, lamentando cómo resultaron las cosas entre él y Sayori." with dissolve

# game/Kyou 6.rpy:7407
translate spanish Day6_Con_Kyou_Sayori_Alter_Switch_1aadcc88:

    # "Yeah, so that's it. I don't think this particular sub path needs to be a full-blown storyline like the others."
    "Sí, creo es eso es todo. No creo que esta sub-ruta en particular necesite toda una historia larga como las otras."

# game/Kyou 6.rpy:7408
translate spanish Day6_Con_Kyou_Sayori_Alter_Switch_dada27c2:

    # "It just needs to leave Kyou in a worse place than when he switches Sayori back earlier in the story, and in a better place when he never switches her at all until the very end."
    "Solo necesita dejar a Kyou en un peor lugar que cuando regresa a Sayori a la normalidad más pronto en la historia, y mejor que cuando nunca lo hace salvo al final."

# game/Kyou 6.rpy:7409
translate spanish Day6_Con_Kyou_Sayori_Alter_Switch_5ca6be82:

    # "But what do you think? Please share your thoughts in the usual places while I work on wrapping this path up in the next update~"
    "Pero ¿ustedes que opinan? Por favor, compartan sus opiniones en los lugares de siempre mientras trabajo en darle cierre a este sendero para la próxima actualización."
# TODO: Translation updated at 2024-02-27 17:26

# game/Kyou 6.rpy:7346
translate spanish Day6_Con_Kyou_Sayori_Alter_Switch_0ab27fe2:

    # s concerned "Ever since my first hypnosis session I have been left with an unsettling feeling that something was not right. That my mind was being influenced in ways I couldn't fathom." with dissolve
    s concerned "Desde mi primera sesión de hipnosis, he tenido la inquietante sensación de que algo no anda bien, y mi mente era influenciada de formas fuera de mi comprensión." with dissolve

# game/Kyou 6.rpy:7360
translate spanish Day6_Con_Kyou_Sayori_Alter_Switch_aedb233f:

    # s casual_folded sleep "Kyou, I am certain your intentions that day were harmless." with dissolve
    s casual_folded sleep "Kyou, tengo la certeza de que tus intenciones ese día no eran las de causar perjuicio." with dissolve

# game/Kyou 6.rpy:7368
translate spanish Day6_Con_Kyou_Sayori_Alter_Switch_c190f3cb:

    # s sleep "I have no memory of what we discussed, of course. Only that you had the opportunity to put a halt to this madness there and then." with dissolve
    s sleep "No tengo recuerdos de lo que discutimos, claro. Solo sé que tuviste la oportunidad de ponerle un cese a esta locura ahí y entonces." with dissolve

# game/Kyou 6.rpy:7373
translate spanish Day6_Con_Kyou_Sayori_Alter_Switch_4307e911:

    # ks "L-Look, you have to understand! There were people all around us, I couldn't just..."
    ks "¡M-mira, tienes que entender! Había mucha gente alrededor, no podía simplemente..."

# game/Kyou 6.rpy:7375
translate spanish Day6_Con_Kyou_Sayori_Alter_Switch_4fdafd87:

    # n side frown "What did you say to her, Kyou?" with dissolve
    n side frown "¿Qué le dijiste, Kyou?" with dissolve

# game/Kyou 6.rpy:7377
translate spanish Day6_Con_Kyou_Sayori_Alter_Switch_43286731:

    # "It's not like I didn't have my reasons, Nozomi..."
    "No es como si no tuviera mis razones, Nozomi..."

# game/Kyou 6.rpy:7379
translate spanish Day6_Con_Kyou_Sayori_Alter_Switch_cfe3803d:

    # ks confused "I-I didn't know what to do, okay? She seemed happy to go along with it, and I wanted that for her. I thought she wanted to be happy for a while."
    ks confused "No sabía qué hacer, ¿de acuerdo? Parecía feliz de seguir el juego, y yo quería eso para ella. Creí que quería ser feliz por un rato."

# game/Kyou 6.rpy:7380
translate spanish Day6_Con_Kyou_Sayori_Alter_Switch_353131aa:

    # ks "And even if she didn't, what do you think would've happened if I woke her up in the middle of class? Don't you think she would've freaked out in front of all those people?"
    ks "Y aunque no fuera eso lo que quería, ¿qué crees que habría pasado si la despertaba en plena clase? ¿No crees que habría entrado en pánico frente a todos?"

# game/Kyou 6.rpy:7381
translate spanish Day6_Con_Kyou_Sayori_Alter_Switch_4c17fcb9:

    # ks "So... yeah, maybe I wussed out. And yeah, maybe I should've brought Sayori back to herself, but I really thought it'd be better to just play along until she was out of there."
    ks "Así que... sí, tal vez me acobardé. Y sí, tal vez debí haber devuelto a Sayori a la normalidad, pero de verdad pené sería mejor seguir la corriente hasta que saliera de ahí."

# game/Kyou 6.rpy:7382
translate spanish Day6_Con_Kyou_Sayori_Alter_Switch_75b5327c:

    # "But nothing I say will change how you feel about me, will it?"
    "Pero nada de lo que diga cambiará lo que piensas de mí, ¿o sí?"

# game/Kyou 6.rpy:7385
translate spanish Day6_Con_Kyou_Sayori_Alter_Switch_3c411b27:

    # ks frown "C-come on, can you blame me, Nozomi? I just wanted to keep her safe through all of this!" with dissolve
    ks frown "P-por favor, ¿puedes culparme, Nozomi? ¡Solo quería mantenerla a salvo hasta el final!" with dissolve

# game/Kyou 6.rpy:7387
translate spanish Day6_Con_Kyou_Sayori_Alter_Switch_8886fc33:

    # n frown "Don't give me that crap. Like you were ever thinking about her safety before this all blew up in your face." with dissolve
    n frown "No me vengas con esa mierda. No finjas que pensaste una sola vez en su seguridad antes de que todo esto te estallara en la cara." with dissolve

# game/Kyou 6.rpy:7388
translate spanish Day6_Con_Kyou_Sayori_Alter_Switch_2a8e6d35:

    # n irritated "Sure, I doubt Sayori would've taken it well if you brought her out of it in front of our classmates. But you only chose not to because you didn't want to deal with that." with dissolve
    n irritated "Claro, dudo que Sayori hubiera reaccionado bien si la hubieras despertado frente a nuestros compañeros. Pero solo elegiste no hacerlo porque no querías lidiar con eso." with dissolve

# game/Kyou 6.rpy:7390
translate spanish Day6_Con_Kyou_Sayori_Alter_Switch_b2870e62:

    # n front2 angry "This was only ever about YOUR comfort! About YOUR safety!" with dissolve
    n front2 angry "¡Todo esto fue solo para TU confort! ¡Para TU seguridad!" with dissolve

# game/Kyou 6.rpy:7391
translate spanish Day6_Con_Kyou_Sayori_Alter_Switch_ec420237:

    # ks confused "Nozomi, I..."
    ks confused "Nozomi, yo..."

# game/Kyou 6.rpy:7392
translate spanish Day6_Con_Kyou_Sayori_Alter_Switch_e77b9a71:

    # n determined "You weren't thinking about her at all!" with dissolve
    n determined "¡Nunca pensaste en ella ni por un segundo!" with dissolve

# game/Kyou 6.rpy:7393
translate spanish Day6_Con_Kyou_Sayori_Alter_Switch_a71f7e2a:

    # "And what does Sayori feel about this? As I look to her for answers, all I can see is that same forlorn expression in her eyes."
    "¿Y qué es lo que siente Sayori? Al voltear a mirarla en busca de respuestas, lo único que veo es la misma expresión desamparada en sus ojos."

# game/Kyou 6.rpy:7394
translate spanish Day6_Con_Kyou_Sayori_Alter_Switch_7daf3242:

    # "It's unsettling to see her this withdrawn. To see someone like her allow anyone else to speak in her place."
    "Es desconcertante verla tan retraída. Ver a alguien como ella permitir que otra persona hable en su lugar."

# game/Kyou 6.rpy:7396
translate spanish Day6_Con_Kyou_Sayori_Alter_Switch_332a5163:

    # n side irritated "Rrrrgh... I don't know how the hell an incompetant like you managed to worm your way into Sayori's mind like this, but it ends today." with dissolve
    n side irritated "Grrr... No sé cómo diablos un incompetente como tú logró meterse así en la mente de Sayori, pero eso termina hoy." with dissolve

# game/Kyou 6.rpy:7397
translate spanish Day6_Con_Kyou_Sayori_Alter_Switch_cf605be3:

    # n furious "I mean, CLEARLY you can't handle the responsibility that comes with being a hypnotist. So here's what's going to happen." with dissolve
    n furious "Digo, CLARAMENTE no puedes manejar la responsabilidad de ser un hipnotista. Así que esto es lo que va a pasar." with dissolve

# game/Kyou 6.rpy:7399
translate spanish Day6_Con_Kyou_Sayori_Alter_Switch_10329f67:

    # n frown_side "Sayori, I'm going to get you some professional help, okay? We'll see a real hypnotherapist; try and heal the damage he did to you." with dissolve
    n frown_side "Sayori, te conseguiré ayuda profesional, ¿de acuerdo? Veremos a un hipnoterapeuta de verdad; trataremos de sanar el daño que te hizo." with dissolve

# game/Kyou 6.rpy:7400
translate spanish Day6_Con_Kyou_Sayori_Alter_Switch_7a13c946:

    # s casual_handup "H-hmm?" with dissolve
    s casual_handup "¿M-mmm?" with dissolve

# game/Kyou 6.rpy:7401
translate spanish Day6_Con_Kyou_Sayori_Alter_Switch_a0a98f59:

    # n front2 frown "And as for you, I think we'll all breathe a little easier if you never hypnotize anyone again!" with dissolve
    n front2 frown "¡Y en cuanto a ti, creo que todos estaremos más tranquilos si no hipnotizas a nadie nunca más!" with dissolve

# game/Kyou 6.rpy:7403
translate spanish Day6_Con_Kyou_Sayori_Alter_Switch_9d7a90cf:

    # ks "What?!"
    ks "¡¿Qué?!"

# game/Kyou 6.rpy:7404
translate spanish Day6_Con_Kyou_Sayori_Alter_Switch_9675e025:

    # n irritated "As far as I'm concerned you're done here. We don't need your reckless brand of hypnosis making things worse for my friend." with dissolve
    n irritated "En lo que a mí concierne, tú ya terminaste. No necesitamos que tu imprudente hipnosis le siga empeorando las cosas a mi amiga." with dissolve

# game/Kyou 6.rpy:7406
translate spanish Day6_Con_Kyou_Sayori_Alter_Switch_5837dc62:

    # n determined "Now get out of my house!" with dissolve
    n determined "¡Ahora largo de mi casa!" with dissolve

# game/Kyou 6.rpy:7407
translate spanish Day6_Con_Kyou_Sayori_Alter_Switch_0d4b3309:

    # "I can feel the hairs stand at the back of my neck as I hear her declaration ringing in my ears."
    "Puedo sentir los vellos en la parte de atrás de mi cuello erizarse al escuchar sus declaraciones, que zumban en mis oídos."

# game/Kyou 6.rpy:7408
translate spanish Day6_Con_Kyou_Sayori_Alter_Switch_8be5372c:

    # s surprised "Nozomi... no!" with dissolve
    s surprised "¡Nozomi... no!" with dissolve

# game/Kyou 6.rpy:7409
translate spanish Day6_Con_Kyou_Sayori_Alter_Switch_e9dbef9f:

    # "And I had unconsciously taken a step towards the door before Sayori breaks her silence with a sudden urgency."
    "Y ya había dado inconscientemente un paso hacia la puerta para cuando Sayori rompe el silencio con repentina urgencia."

# game/Kyou 6.rpy:7410
translate spanish Day6_Con_Kyou_Sayori_Alter_Switch_b547b27c:

    # n side frown_side "\"No\"? What do you mean \"no\"?" with dissolve
    n side frown_side "¿\"No\"? ¿Cómo que \"no\"?" with dissolve

# game/Kyou 6.rpy:7411
