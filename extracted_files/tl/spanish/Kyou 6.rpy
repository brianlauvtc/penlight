    # h angry "That time you were rolling on the floor laughing yourself half to death? {w=0.7}That was 'cuz of {nw}" with dissolve
    h angry "¿Esa vez estuviste rodando en el suelo muriéndote de la risa? {w=0.7}¿Fue por culpa de {nw}" with dissolve

# game/Kyou 6.rpy:3221
translate spanish Day6_Con_Kyou_Nozomi_9b2edede_1:

    # extend "HIM?" with vpunch
    extend "ÉL?" with vpunch

