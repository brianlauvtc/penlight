translate spanish Day6_Con_Kyou_Hiroko_Penlight_a65185de:

    # "Maybe just for a few days, if she doesn't manage to snap out of it by then."
    "Tal vez solo por un par de días, si no es que termina quitándosele para entonces."

# game/Kyou 6.rpy:9687
translate spanish Day6_Con_Kyou_Hiroko_Penlight_58f780a9:

    # ks "Polite and courteous... understand, Hiroko?"
    ks "Educada y cortés... entiendes, ¿Hiroko?"

# game/Kyou 6.rpy:9688
translate spanish Day6_Con_Kyou_Hiroko_Penlight_2fc0011a:

    # "Who knows, maybe she'll have learned something by the time this is over."
    "Quién sabe, tal vez haya aprendido algo para cuando esto termine."

# game/Kyou 6.rpy:9689
translate spanish Day6_Con_Kyou_Hiroko_Penlight_46c324b7:

    # h sleeptalk "Yeah..." with dissolve
    h sleeptalk "Sí..." with dissolve

# TODO: Translation updated at 2024-03-31 19:21

# game/Kyou 6.rpy:9695
