    # n "I still have to tidy my room of course. There's still a lot to do around here..." with dissolve
    n "Claro que aún tengo que limpiar mi habitación. Aún queda mucho que hacer por aquí." with dissolve

# game/Kyou 6.rpy:4372
translate spanish Day6_Con_Kyou_Nozomi_Trance_73c72248:

    # n "But we could have a quick game when I'm done. What do you think?" with dissolve
    n "Pero podemos jugar una partida rápida cuando termine. ¿Qué opinas?" with dissolve

# game/Kyou 6.rpy:4390
