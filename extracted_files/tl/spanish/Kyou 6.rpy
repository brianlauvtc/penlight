# game/Kyou 6.rpy:612
translate spanish Day6_NonCon_Kyou_9f907c06_1:

    # n sad "But you can't do this to us anymore, Kyou. You understand?" with dissolve
    n sad "Pero no puedes seguir haciéndonos esto, Kyou. ¿Lo entiendes?" with dissolve

