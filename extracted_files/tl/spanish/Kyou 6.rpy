    # k "No, you heard right. I hoped she would listen and obey. Just like how you both are listening to me right now." with dissolve
    k "No, escucharon bien. Esperaba que viniera a escuchar y obedecer. Así como ustedes me están escuchando ahora." with dissolve

# game/Kyou 6.rpy:2411
translate spanish Day6_Villain_Kyou_d0b62937:

    # s "There's something... f-familiar about this..."
    s "Algo me es… familiar…"

# game/Kyou 6.rpy:3245
translate spanish Day6_Villain_Kyou_b127ec7f:

    # k "And... yes, there's a comforting familiarity to my words I think you'll find. A comfort for you both to listen and obey."
    k "Y… sí, notarán que hay una cierta familiaridad en mis palabras. Es muy cómodo para ambas escuchar y obedecer."

# game/Kyou 6.rpy:3247
translate spanish Day6_Villain_Kyou_a9bba294:

    # h "Shut up with that creepy shit, or I'll... I-I'll..." with dissolve
    h "Para con esa mierda tan espeluznante, o voy a... voy a..." with dissolve

# game/Kyou 6.rpy:3248
translate spanish Day6_Villain_Kyou_52dc0006:

    # k "You'll continue to listen, Hiroko. It feels so correct, so natural, to listen and obey."
    k "Vas a escuchar, Hiroko. Se siente tan correcto y tan natural escuchar y obedecer."

# game/Kyou 6.rpy:3249
