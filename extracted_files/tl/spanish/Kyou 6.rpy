    # game/Kyou 6.rpy:8573
    old "Agree to let Sayori hypnotize me"
    new "Dejar que Sayori me hipnotice"

    # game/Kyou 6.rpy:8573
    old "Find a way out of this"
    new "Hallar la forma de salir de esta"

    # game/Kyou 6.rpy:8635
