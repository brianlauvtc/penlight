translate spanish Day6_Con_Kyou_Nozomi_6cc400f2:

    # n surprised "{size=16}Ah, they're already here...{/size}"
    n surprised "{size=16}Ah, a llegaron...{/size}"

# game/Kyou 6.rpy:3181
translate spanish Day6_Con_Kyou_Nozomi_ddbccdd1:

    # n "{size=16}Set me free.{/size}"
    n "{size=16}Libérame.{/size}"

# game/Kyou 6.rpy:3182
translate spanish Day6_Con_Kyou_Nozomi_6dffe5c4:

    # ks surprised "Huh?"
    ks surprised "¿Eh?"

# game/Kyou 6.rpy:3183
translate spanish Day6_Con_Kyou_Nozomi_c260c7ff:

    # n smile "Eheh, sorry Kyou, but I need to be in my right mind for this~" with dissolve
    n smile "Jeje, perdón, Kyou, pero tengo que estar en mi sano juicio para esto." with dissolve

# game/Kyou 6.rpy:3184
translate spanish Day6_Con_Kyou_Nozomi_81c8da7f:

    # ks smirk "Eh, I specifically made sure my suggestions wouldn't work while we had company."
    ks smirk "Eh, me aseguré específicamente de que mis sugestiones no funcionaran cuando tenemos compañía."

# game/Kyou 6.rpy:3185
translate spanish Day6_Con_Kyou_Nozomi_e4f73c57:

    # n front concerned "Maybe not, but still, I just realized I have no idea what other influences you might have exerted on me without either of us realizing." with dissolve
    n front concerned "Tal vez no, pero, aun así, me acabo de dar cuenta de que no tengo idea de qué otras influencias puedas ejercer en mi sin que ninguno de los dos lo notemos." with dissolve

# game/Kyou 6.rpy:3186
translate spanish Day6_Con_Kyou_Nozomi_db3be945:

    # n "I can't have any of that effect me right now."
    n "No puedo permitir que nada de eso me afecte ahora."

# game/Kyou 6.rpy:3188
translate spanish Day6_Con_Kyou_Nozomi_796ff908:

    # n pout_left "... You should probably get that." with dissolve
    n pout_left "... Creo que será mejor que atiendas." with dissolve

# game/Kyou 6.rpy:3376
translate spanish Day6_Con_Kyou_Nozomi_4f15d096:

    # n surprised "Ah, they're here already?!"
    n surprised "¡Ah, ¿ya llegaron?!"

# game/Kyou 6.rpy:3191
translate spanish Day6_Con_Kyou_Nozomi_1377a40b:

    # n sad_closed "W-well... let's get this over with, then." with dissolve
    n sad_closed "P-pues... comencemos." with dissolve

# game/Kyou 6.rpy:3199
translate spanish Day6_Con_Kyou_Nozomi_61eafc02:

    # s "So. Here we are."
    s "Bueno. Henos aquí."

# game/Kyou 6.rpy:3200
translate spanish Day6_Con_Kyou_Nozomi_13528b5e:

    # h dress_arm frown_side "C'mon, let's get this over with. What's going on with you two?" with dissolve
    h dress_arm frown_side "Vamos, terminemos con esto. ¿Qué está pasando entre ustedes dos?" with dissolve

# game/Kyou 6.rpy:3201
translate spanish Day6_Con_Kyou_Nozomi_35589700:

    # n side casual sad_side "Alright, so..." with dissolve
    n side casual sad_side "Muy bien, pues..." with dissolve

# game/Kyou 6.rpy:3202
translate spanish Day6_Con_Kyou_Nozomi_a766e13d:

    # n "While I was cleaning the classroom with Kyou this week, he told me something interesting."
    n "Cuando estaba limpiando el salón con Kyou esta semana, me contó algo interesante."

# game/Kyou 6.rpy:3203
translate spanish Day6_Con_Kyou_Nozomi_0466afa4:

    # n "He told me he was studying hypnosis."
    n "Me contó que estaba estudiando hipnosis."

# game/Kyou 6.rpy:3204
translate spanish Day6_Con_Kyou_Nozomi_6f3953a1:

    # h "Hypnosis?"
    h "¿Hipnosis?"

# game/Kyou 6.rpy:3205
translate spanish Day6_Con_Kyou_Nozomi_e34c58c2:

    # s neutral "And that is interesting to you?" with dissolve
    s neutral "¿Y eso te parece interesante?" with dissolve

