    a smile "{size=28}{font=DejaVuSans.ttf}♪{/font} Por favor no digas que me he de rendir {font=DejaVuSans.ttf}♫{/font}{/size}" with dissolve

# game/Kyou 6.rpy:4878
translate spanish Day6_Villain2_Kyou_68fc8a39:

    # k "{size=28}Please, I beg you, don't go with another man, I just want you to look at me.{/size}" with dissolve
    k "{size=28}Por favor nunca te vayas con alguien más; siempre mírame solo a mí.{/size}" with dissolve

# game/Kyou 6.rpy:4865
translate spanish Day6_Villain2_Kyou_256a00ca:

    # a shy "{size=28}{font=DejaVuSans.ttf}♪{/font} Please just look in my direction {font=DejaVuSans.ttf}♫{/font}{/size}" with dissolve
    a shy "{size=28}{font=DejaVuSans.ttf}♪{/font} Quiero que te des la vuelta {font=DejaVuSans.ttf}♫{/font}{/size}" with dissolve

# game/Kyou 6.rpy:4882
translate spanish Day6_Villain2_Kyou_1532ff12:

    # k "{size=28}Please acknowledge my affection.{/size}" with dissolve
    k "{size=28}Que me mires; date cuenta.{/size}" with dissolve

# game/Kyou 6.rpy:4885
translate spanish Day6_Villain2_Kyou_8f60d8e3:

    # t "{size=28}{font=DejaVuSans.ttf}♪{/font} I know that this sounds greedy; please promise that you won't leave me {font=DejaVuSans.ttf}♫{/font}{/size}" with dissolve
    t "{size=28}{font=DejaVuSans.ttf}♪{/font} Estaré varado{w=0.8} si te vas de mi lado {font=DejaVuSans.ttf}♫{/font}{/size}" with dissolve

# game/Kyou 6.rpy:4869
translate spanish Day6_Villain2_Kyou_a27ab114:

    # t "{size=28}{font=DejaVuSans.ttf}♪{/font} Don't change a thing about you, just think of what we could be {font=DejaVuSans.ttf}♫{/font}{/size}"
    t "{size=28}{font=DejaVuSans.ttf}♪{/font} Tú no necesitas cambiar; {w=0.8}es tu verdadero ser a quien pienso amar {font=DejaVuSans.ttf}♫{/font}{/size}"

# game/Kyou 6.rpy:4888
translate spanish Day6_Villain2_Kyou_fde25a65:

    # t "{size=28}{font=DejaVuSans.ttf}♪{/font} Maybe we could tomorrow, live that simulation {font=DejaVuSans.ttf}♫{/font}{/size}" with dissolve
    t "{size=28}{font=DejaVuSans.ttf}♪{/font} Tal vez mañana todo pueda confesarte {font=DejaVuSans.ttf}♫{/font}{/size}" with dissolve

# game/Kyou 6.rpy:4871
translate spanish Day6_Villain2_Kyou_d0efc2e0:

    # t "{size=28}{font=DejaVuSans.ttf}♪{/font} I know my love for you will push me to become my best version {font=DejaVuSans.ttf}♫{/font}{/size}"
    t "{size=28}{font=DejaVuSans.ttf}♪{/font} Juro volverme en la mejor versión de mí para darte {font=DejaVuSans.ttf}♫{/font}{/size}"

# game/Kyou 6.rpy:4892
translate spanish Day6_Villain2_Kyou_23601ff2:

    # "The two of us take a long breath as the song winds down and the final lyric line fades away." with dissolve
    "Los dos tomamos una gran bocanada de aire una vez la canción se serena y los últimos versos se desvanecen de la pantalla." with dissolve

# game/Kyou 6.rpy:4874
translate spanish Day6_Villain2_Kyou_766fcbe5:

    # "And as the final notes play out over the speaker, our eyes meet..."
    "Y envueltos en el sonido de la última nota siendo reproducida por la bocina, nuestras miradas se cruzan..."

# game/Kyou 6.rpy:4899
translate spanish Day6_Villain2_Kyou_f8d2c709:

    # a "... You know, everyone who saw us today think we're a couple."
    a "... Sabes, todos los que nos han viso hoy creen que somos pareja."

# game/Kyou 6.rpy:4900
translate spanish Day6_Villain2_Kyou_857c3f5c:

    # ks casual confused "Hm?"
    ks casual confused "¿Mm?"

# game/Kyou 6.rpy:4879
translate spanish Day6_Villain2_Kyou_fe6f30b4:

    # a shy_side "The people at the clothing store, the shoe store, the restaurant... I-I mean, of course they would, wouldn't they?" with dissolve
    a shy_side "La gente en la tienda de ropa, la zapatería, el restaurante... D-digo, no es de extrañarse que lo piensen, ¿verdad?" with dissolve

# game/Kyou 6.rpy:4880
translate spanish Day6_Villain2_Kyou_100d9c74:

    # ks smile "Eheh... yeah, we really have been like a couple on a perfect date, haven't we?"
    ks smile "Jeje... sí, hoy de verdad fuimos como una pareja en una cita perfecta, ¿no?"

# game/Kyou 6.rpy:4881
translate spanish Day6_Villain2_Kyou_fd0914ec:

    # a happy "Yeah... Yeah, we really have been like that." with dissolve
    a happy "Sí... Sí, es cierto." with dissolve

# game/Kyou 6.rpy:4882
translate spanish Day6_Villain2_Kyou_0aad86f1:

    # a smile "So are we?" with dissolve
    a smile "Y, ¿lo somos?" with dissolve

# game/Kyou 6.rpy:4883
translate spanish Day6_Villain2_Kyou_6e7cab30:

    # "I knew this was coming. Everything I've done with her today has been leading to this moment, and yet her question still leaves me breathless."
    "Sabía que esto venía. Todo lo que he hecho con ella hoy nos conducía a este momento, y sin embargo, la pregunta me deja sin aliento."

# game/Kyou 6.rpy:4885
translate spanish Day6_Villain2_Kyou_554b802f:

    # a happy "Kyou... You said I'm the only person you can talk to? I feel the same way with you." with dissolve
    a happy "Kyou... ¿Dijiste que yo era la única persona con la que puedes hablar? Yo siento lo mismo por ti." with dissolve

# game/Kyou 6.rpy:4886
translate spanish Day6_Villain2_Kyou_6fed4c2f:

    # "To witness this girl, our plain student council president mere days ago, blossom into the epitome of grace and beauty was one thing."
    "Presenciar a esta chica, hace solo días nuestra insulsa presidenta del consejo estudiantil, germinar y volverse el epítome de la gracia y la belleza fue una cosa."

# game/Kyou 6.rpy:4910
translate spanish Day6_Villain2_Kyou_c3f730b5:

    # a smile "Right now, it feels like you're the only person in the whole world who truly understands me. The only one who believes in me." with dissolve
    a smile "Ahora mismo, siento que eres la única persona en el mundo que realmente me entiende. El único que cree en mí." with dissolve

# game/Kyou 6.rpy:4888
translate spanish Day6_Villain2_Kyou_26528fc2:

    # "She might be an imitation of the real thing, but in a moment such as this, I don't know how that could matter."
    "Puede que sea una imitación de la verdadera, pero en un momento así, no sé cómo eso podría importar."

# game/Kyou 6.rpy:4916
translate spanish Day6_Villain2_Kyou_c1639a90:

    # a "And I believe in you, Kyou. I believe in us. So..."
    a "Y yo creo en ti, Kyou. Creo en nosotros. Así que..."

# game/Kyou 6.rpy:4891
translate spanish Day6_Villain2_Kyou_68206bb5:

    # "I don't see Akiko standing here, performing a perfect impression of the girl I love."
    "No es Akiko a quien veo aquí de pie, haciendo una emulación perfecta de la chica que amo."

# game/Kyou 6.rpy:4892
translate spanish Day6_Villain2_Kyou_b93d353f:

    # a shy "Let's be the best that we can be. Together {font=DejaVuSans.ttf}♥{/font}" with dissolve
    a shy "Seamos los mejores que podamos ser. Juntos. {font=DejaVuSans.ttf}♥{/font}" with dissolve

# game/Kyou 6.rpy:4893
translate spanish Day6_Villain2_Kyou_9752be6a:

    # "I just see Nozomi; the most attractive girl in our school bar none."
    "Solo veo a Nozomi; de lejos la chica más atractiva en nuestra escuela."

# game/Kyou 6.rpy:4921
translate spanish Day6_Villain2_Kyou_a615fd91:

    # k "Yeah. We will, Nozomi. I promise."
    k "Sí. Lo seremos, Nozomi. Lo prometo."

# game/Kyou 6.rpy:4924
translate spanish Day6_Villain2_Kyou_fe620224:

    # "And she's my girlfriend. My heroine." with dissolve
    "Y es mi novia. Mi heroína." with dissolve

# game/Kyou 6.rpy:4927
translate spanish Day6_Villain2_Kyou_dadbe207:

    # "My choice."
    "Mi elección."

# game/Kyou 6.rpy:4897
translate spanish Day6_Villain2_Kyou_a5ed6454:

    # "(( AUTHOR'S NOTE: And that's all she wrote~ ))"
    "(( NOTA DE LA AUTORA: Y eso es todo lo que escribí. ))"

# game/Kyou 6.rpy:4898
translate spanish Day6_Villain2_Kyou_cff585ed:

    # "(( Please look forward to the next update, where we'll see ongoing storyline head ever closer towards its conclusion! ))"
    "(( ¡Por favor esperen con ansias la próxima actualización, donde nuestra historia en curso se aproximará a su conclusión! ))"

