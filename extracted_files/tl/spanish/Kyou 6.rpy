    "¡NO voy a mandar esto a la mierda!"

# game/Kyou 6.rpy:8097
translate spanish Day6_Redemption_b990cd7f:

    # ks "Wide awake on the count of five. One, two, three..."
    ks "Despertarás a la cuenta de cinco. Uno, dos, tres..."

# game/Kyou 6.rpy:8098
translate spanish Day6_Redemption_c6bf8f63:

    # ks "Four and... {w=1.0}{nw}"
    ks "Cuatro y... {w=1.0}{nw}"

# game/Kyou 6.rpy:8103
