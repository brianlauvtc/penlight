    n side sad_closed "*suspiro* Dios. Ya dejen de llamarme." with dissolve

# game/Kyou 6.rpy:1268
translate spanish Day6_Villain_Kyou_bb2cf764_1:

    # n "..."
    n "…"

# game/Kyou 6.rpy:1270
translate spanish Day6_Villain_Kyou_c3351ad7:

