# game/Kyou 6.rpy:6223
translate spanish Day6_Redemption_72cea688:

    # a smile "Okay. Let's back up a bit." with dissolve
    a smile "Muy bien. Demos un paso atrás." with dissolve

# game/Kyou 6.rpy:6224
translate spanish Day6_Redemption_ac6adbc1:

    # ks neutral "Hm?"
    ks neutral "¿Mm?"

