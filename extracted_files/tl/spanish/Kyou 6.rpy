translate spanish Day6_Con_Kyou_Nozomi_c211186e:

    # ks sigh "Do you really think that will happen?"
    ks sigh "¿De verdad crees que eso pasará?"

# game/Kyou 6.rpy:3175
translate spanish Day6_Con_Kyou_Nozomi_73c48220:

    # n side sad_side "{size=16}I... I don't know, Sir. I really don't know.{/size}" with dissolve
    n side sad_side "{size=16}N-... No lo sé, Señor. En serio no lo sé.{/size}" with dissolve

# game/Kyou 6.rpy:3177
translate spanish Day6_Con_Kyou_Nozomi_5c0abb9a:

    # n side sad_side "I... I don't know, Kyou. I really don't know." with dissolve
    n side sad_side "N-... No lo sé, Kyou. De verdad no lo sé." with dissolve

