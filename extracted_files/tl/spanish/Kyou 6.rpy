    ks "¿No es cierto, Hiroko?"

# game/Kyou 6.rpy:9647
translate spanish Day6_Con_Kyou_Hiroko_Penlight_ac98becb:

    # h sleeptalk "... Right." with dissolve
    h sleeptalk "... Cierto." with dissolve

