    # a "What sort of suggestions?" with dissolve
    a "¿Qué clase de sugestiones?" with dissolve

# game/Kyou 6.rpy:6175
translate spanish Day6_Redemption_1f4ab4d0:

    # ks "Uh..."
    ks "Eh..."

# game/Kyou 6.rpy:6176
translate spanish Day6_Redemption_a257aef7:

    # "I really don't want to talk to her about Hiroko, but I don't think I should lie. So..."
