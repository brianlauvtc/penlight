translate spanish Day6_Con_Kyou_Nozomi_d138990c:

    # n blush "It's like... a hobby of mine? Kinda? So..." with dissolve
    n blush "Es como... ¿un pasatiempo? ¿Algo así? Y..." with dissolve

# game/Kyou 6.rpy:3209
translate spanish Day6_Con_Kyou_Nozomi_188ff706:

    # "Nozomi went on to try and explain everything that happened between us over the last few days."
    "Nozomi intentó explicar todo lo que pasó entre nosotros los últimos días."

# game/Kyou 6.rpy:3210
translate spanish Day6_Con_Kyou_Nozomi_884a7457:

    # "The arranged hypnosis sessions, the kinds of things we'd do in those sessions..."
    "Las sesiones de hipnosis, la clase de cosas que hemos hecho en esas sesiones..."

# game/Kyou 6.rpy:3212
translate spanish Day6_Con_Kyou_Nozomi_06111be4:

    # "And the real reason why she injured herself and broke her glasses."
    "Y la verdadera razón por la que se lastimó y rompió sus anteojos."

# game/Kyou 6.rpy:3214
translate spanish Day6_Con_Kyou_Nozomi_40c64286:

    # s casual_folded concerned "Alright... I need a minute to process this." with dissolve
    s casual_folded concerned "Muy bien... necesito un minuto para procesar esto." with dissolve

# game/Kyou 6.rpy:3215
translate spanish Day6_Con_Kyou_Nozomi_740418fc:

    # h casual no_arm concerned "So like, Kyou's seriously been controlling your mind?" with dissolve
    h casual no_arm concerned "Entonces, o sea, ¿Kyou te ha estado controlando la mente?" with dissolve

# game/Kyou 6.rpy:3217
translate spanish Day6_Con_Kyou_Nozomi_c27e08a9:

    # h angry "That time you looked like you were about to come for no damn reason? That was {w=0.7}{nw}" with dissolve
    h angry "¿Esa vez que parecía que estabas a punto de venirte sin razón? ¿Fue por culpa de {w=0.7}{nw}" with dissolve

# game/Kyou 6.rpy:3218
