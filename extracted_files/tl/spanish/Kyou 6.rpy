translate spanish Day6_Villain2_Kyou_8dec68bd:

    # a shy_side "I actually thought about dyeing my hair the other day, right after restyling it? But I've never done it before and I didn't want to mess up." with dissolve
    a shy_side "De hecho pensé en teñirme el cabello el otro día, justo después del cambio de estilo. Pero nunca lo he hecho antes y no quería hacer un desastre." with dissolve

# game/Kyou 6.rpy:4377
translate spanish Day6_Villain2_Kyou_eebcc67f:

    # a embarrassed "O-oh no, ehehehe~" with dissolve
    a embarrassed "O-oh, no, ejejeje." with dissolve

# game/Kyou 6.rpy:4378
translate spanish Day6_Villain2_Kyou_2827e90f:

    # a shy "I, um... wanted you to be here for this." with dissolve
    a shy "Yo, em... quería que estuvieras aquí para esto." with dissolve

# game/Kyou 6.rpy:4387
translate spanish Day6_Villain2_Kyou_4a448c6a:

    # a laugh blush "Yeah! They have a same day service; I actually stopped by here on my way to the hairdressers." with dissolve
    a laugh blush "¡Sí! Tienen servicio para el mismo día; de hecho, pasé por aquí de camino a la peluquería." with dissolve

# game/Kyou 6.rpy:4401
translate spanish Day6_Villain2_Kyou_3aae2334:

    # ks casual surprised "How... how on earth?"
    ks casual surprised "¿Cómo... cómo es que...?"

# game/Kyou 6.rpy:4405
