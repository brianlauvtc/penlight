translate spanish Day6_Con_Kyou_Sayori_Alter_Switch_c92b5f42:

    # s sleeptalk_concerned "I will manage. I always do." with dissolve
    s sleeptalk_concerned "Puedo manejarlo. Siempre lo hago." with dissolve

