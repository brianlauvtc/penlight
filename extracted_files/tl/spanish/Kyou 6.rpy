    # a neutral noblush "But I have to say this isn't a good look for you, Koyama." with dissolve
    a neutral noblush "Pero he de decir que esto no te da muy buena imagen, Koyama." with dissolve

# game/Kyou 6.rpy:6204
translate spanish Day6_Redemption_0ebe0cff:

