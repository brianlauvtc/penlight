translate spanish Day6_Redemption_42a1e5d8:

    # a smile_side "You said you hypnotize people with a light. How does that work?" with dissolve
    a smile_side "Dijiste que hipnotizas gente con una linterna. ¿Eso cómo funciona?" with dissolve

