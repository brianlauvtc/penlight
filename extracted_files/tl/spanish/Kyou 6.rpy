    n irritated "Deberías destruirla." with dissolve

# game/Kyou 6.rpy:1182
translate spanish Day6_Villain_Kyou_fc5b2db5:

    # ks frown "I... Why would I do that?"
    ks frown "Des-… ¿Por qué haría eso?"

# game/Kyou 6.rpy:1183
translate spanish Day6_Villain_Kyou_d079a0b3:

    # n frown "Because you have a shred of common decency? Is that too much to expect of you?" with dissolve
    n frown "¿Porque tienes un ápice de decencia? ¿Es acaso mucho esperar de ti?" with dissolve

# game/Kyou 6.rpy:1184
translate spanish Day6_Villain_Kyou_e6ad7324:

    # ks "Nozomi, I've stumbled on something incredible. I can't just... destroy an invention like that."
    ks "Nozomi, he descubierto algo increíble. No puedo solo… destruir una invención así."

# game/Kyou 6.rpy:1185
