    # ks casual neutral "Hey, Nozomi. How are you holding up?"
    ks casual neutral "Hola, Nozomi. ¿Cómo has estado?"

# game/Kyou 6.rpy:3168
translate spanish Day6_Con_Kyou_Nozomi_a5411599:

    # n sigh "{size=16}As well as can be expected, I guess. I'm so nervous.{/size}" with dissolve
    n sigh "{size=16}Tan bien como puede esperarse, supongo. Estoy muy nerviosa.{/size}" with dissolve

# game/Kyou 6.rpy:3169
translate spanish Day6_Con_Kyou_Nozomi_e0c98f62:

    # n "{size=16}What if they never want to speak to me again?{/size}"
    n "{size=16}¿Qué tal si ya nunca me quieren volver a hablar?{/size}"

# game/Kyou 6.rpy:3171
translate spanish Day6_Con_Kyou_Nozomi_3441dfc0:

    # n sigh "As well as can be expected, I guess. I'm so nervous." with dissolve
    n sigh "Tan bien como puede esperarse, supongo. Estoy tan nerviosa." with dissolve

# game/Kyou 6.rpy:3172
translate spanish Day6_Con_Kyou_Nozomi_6db54d43:

    # n "What if they never want to speak to me again?"
