translate spanish Day6_Con_Kyou_Nozomi_f45ab7c8:

    # h casual "It's coming home with me, then I'm getting a hammer and smashing this fucker to bits!" with dissolve
    h casual "¡Se irá a casa conmigo, luego tomaré un martillo y hare está mierda pedacitos!" with dissolve

# game/Kyou 6.rpy:3397
