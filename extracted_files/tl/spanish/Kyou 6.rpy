translate spanish Day6_Con_Kyou_Nozomi_Trance_47e4b2ab:

    # n sigh "I want you in my life. I want us to be friends." with dissolve
    n sigh "Te quiero en mi vida. Quiero que seamos amigos." with dissolve

# game/Kyou 6.rpy:4459
translate spanish Day6_Con_Kyou_Nozomi_Trance_edaf3307:

    # "I want us to be more than friends."
    "Quiero que seamos más que amigos."

# game/Kyou 6.rpy:4460
translate spanish Day6_Con_Kyou_Nozomi_Trance_8a8ce13e:

    # "Like, shit, is what we did even something \"friends\" do?"
    "O sea, mierda, ¿lo que hicimos fue algo que hacen los \"amigos\"?"

# game/Kyou 6.rpy:4461
translate spanish Day6_Con_Kyou_Nozomi_Trance_641dceb5:

    # n side frown_side "And I don't want to be ashamed of us." with dissolve
    n side frown_side "Y no quiero avergonzarme por nosotros." with dissolve

# game/Kyou 6.rpy:4462
translate spanish Day6_Con_Kyou_Nozomi_Trance_74aa19fe:

    # n sad "I just wish I knew this about you sooner instead of you... W-well..." with dissolve
    n sad "Solo desearía haber sabido esto de ti antes en lugar de que tú… p-pues…" with dissolve

# game/Kyou 6.rpy:4463
translate spanish Day6_Con_Kyou_Nozomi_Trance_32bcf3a0:

    # n sad_closed "Never mind." with dissolve
    n sad_closed "Olvídalo." with dissolve

# game/Kyou 6.rpy:4798
translate spanish Day6_Con_Kyou_Nozomi_Trance_edb8fd81:

    # ks casual smile "Yeah... Well, we can make up for lost time, can't we? There's still tomorrow."
    ks casual smile "Sí… Bueno, podemos recuperar el tiempo perdido, ¿no? Aún tenemos mañana."

# game/Kyou 6.rpy:4465
translate spanish Day6_Con_Kyou_Nozomi_Trance_a5d840ff:

    # n sad_side "Tomorrow..." with dissolve
    n sad_side "Mañana..." with dissolve

# game/Kyou 6.rpy:4466
translate spanish Day6_Con_Kyou_Nozomi_Trance_d4a1f798:

    # "Yeah. Even if she's sticking to the \"friends\" talk she has to be rethinking it."
    "Sí. Aunque se aferre a lo de \"amigos\", tiene que estarlo repensando."

# game/Kyou 6.rpy:4467
translate spanish Day6_Con_Kyou_Nozomi_Trance_da35b190:

    # "She's stubborn, but she has to be coming round the more I show her of me. Bit by bit."
    "Es obstinada, pero tendrá que ceder entre más le muestre de mí. Poco a poco."

# game/Kyou 6.rpy:4469
translate spanish Day6_Con_Kyou_Nozomi_Trance_1139438e:

    # n front concerned "Actually, Kyou, tomorrow is- {w=1.0}{nw}" with dissolve
    n front concerned "De hecho, Kyou, mañana es-{w=1.0}{nw}" with dissolve

# game/Kyou 6.rpy:4472
translate spanish Day6_Con_Kyou_Nozomi_Trance_5f2a75c0:

    # ks "You want to visit me tomorrow morning." with dissolve
    ks "Quieres visitarme mañana en la mañana." with dissolve

# game/Kyou 6.rpy:4838
translate spanish Day6_Con_Kyou_Nozomi_Trance_97acc578:

    # "And nothing makes me more certain of that then knowing she keeps letting me do this." with dissolve
    "Y nada me hace estar más seguro de eso que saber que sigue permitiéndome hacerle esto." with dissolve

# game/Kyou 6.rpy:4840
translate spanish Day6_Con_Kyou_Nozomi_Trance_ffe14603:

    # n "{size=16}I want to visit you tomorrow morning.{/size}"
    n "{size=16}Quiero visitarte mañana en la mañana.{/size}"

# game/Kyou 6.rpy:4476
translate spanish Day6_Con_Kyou_Nozomi_Trance_dfc44b41:

    # n smile "Tomorrow is good. I'll swing by yours again in the morning, okay?" with dissolve
    n smile "Mañana está bien. Pasaré por tu casa en la mañana, ¿de acuerdo?" with dissolve

# game/Kyou 6.rpy:4479
translate spanish Day6_Con_Kyou_Nozomi_Trance_22c9d32b:

    # "So we say our goodbyes for now and I head back home full of hope."
    "Así que nos despedimos por ahora y yo vuelvo a casa lleno de esperanza."

# game/Kyou 6.rpy:4482
translate spanish Day6_Con_Kyou_Nozomi_Trance_c66665ae:

    # "Nozomi Akemi. Maybe you're not the picture of feminine perfection I imagined you were."
    "Nozomi Akemi. Tal vez no seas la imagen de perfección femenina que imaginé que serías."

# game/Kyou 6.rpy:4483
translate spanish Day6_Con_Kyou_Nozomi_Trance_adee12db:

    # "You're as beautiful as you ever were but also..."
    "Eres tan hermosa como siempre lo has sido, pero además..."

# game/Kyou 6.rpy:4484
translate spanish Day6_Con_Kyou_Nozomi_Trance_a89bf7dd:

    # "The fact is that you really are weird, and nerdy and at least a little bit perverted..."
    "El hecho de que seas rara, y nerd y al menos un poquitín pervertida..."

# game/Kyou 6.rpy:4485
translate spanish Day6_Con_Kyou_Nozomi_Trance_1cdce17b:

    # "I never knew girls like you existed. But..."
    "Nunca pensé que existieran chicas como tú. Pero..."

# game/Kyou 6.rpy:4486
translate spanish Day6_Con_Kyou_Nozomi_Trance_7607388c:

    # "It feels like I'm falling in love with you all over again."
    "Siento que me estoy enamorando de ti una vez más."

# game/Kyou 6.rpy:4495
translate spanish Day6_Con_Kyou_Sayori_a70c7bc5:

    # "I wake up the following morning with a sinking feeling."
    "Despierto a la mañana siguiente con desazón."

# game/Kyou 6.rpy:4496
translate spanish Day6_Con_Kyou_Sayori_9148f6e8:

    # "Sayori's coming here and I know she wants me to deprogram her. I can understand that."
    "Sayori está por venir y sé que quiere que la desprograme. Eso puedo entenderlo."

# game/Kyou 6.rpy:4497
translate spanish Day6_Con_Kyou_Sayori_ee1f39fd:

    # "But what about after? Are we still gonna hang out?"
    "Pero ¿y luego qué? ¿Seguiremos viéndonos?"

# game/Kyou 6.rpy:4499
translate spanish Day6_Con_Kyou_Sayori_3f11da2e:

    # "Ugh, the doorbell already?! I've barely gotten out of bed." with vpunch
    "¡Ay, ¿el timbre?! ¡¿Tan pronto?! Apenas salí de la cama." with vpunch

# game/Kyou 6.rpy:4500
translate spanish Day6_Con_Kyou_Sayori_13df9cc3:

    # "She must really want to get this done if she's this early."
    "Debe estar muy impaciente por hacer esto para llegar tan temprano."

# game/Kyou 6.rpy:4502
translate spanish Day6_Con_Kyou_Sayori_182584fe:

    # "As I hear the doorbell again, I scrabble to look decent and rush downstairs."
    "Tras volver a escuchar el timbre, me pongo rápido algo decente y corro por las escaleras."

# game/Kyou 6.rpy:4507
translate spanish Day6_Con_Kyou_Sayori_ebcc5657:

    # s "Did I come at a bad time?"
    s "¿Vine en un mal momento?"

# game/Kyou 6.rpy:4508
translate spanish Day6_Con_Kyou_Sayori_1b3f355b:

    # ks casual frown "You're early. It's barely past nine."
    ks casual frown "Llegas temprano. Son poco más de las nueve."

# game/Kyou 6.rpy:4509
translate spanish Day6_Con_Kyou_Sayori_e4a71bec:

    # s alert_pout "We agreed on meeting in the morning. Nine o'clock is well into the morning." with dissolve
    s alert_pout "Acordamos vernos en la mañana. Las nueve en punto es tarde por la mañana." with dissolve

# game/Kyou 6.rpy:4511
translate spanish Day6_Con_Kyou_Sayori_e4fa1bb4:

    # "She looks me up and down and crinkles her nose at me." with dissolve
    "Me mira de arriba abajo y me arruga la nariz." with dissolve

# game/Kyou 6.rpy:5881
translate spanish Day6_Con_Kyou_Sayori_e24b9d76:

    # s alert_smirk_right casual_handup "But if I knew you would smell so unwashed, I would have come later." with dissolve
    s alert_smirk_right casual_handup "Pero de haber sabido que estarías tan maloliente, habría venido más tarde." with dissolve

# game/Kyou 6.rpy:5882
translate spanish Day6_Con_Kyou_Sayori_d212e0c1:

    # s alert_happy "Penlight or no, I may not be able to fall into trance with such a distraction." with dissolve
    s alert_happy "Linterna o no, puede que no sea capaz de caer en trance con tal distracción." with dissolve

# game/Kyou 6.rpy:4514
translate spanish Day6_Con_Kyou_Sayori_02975a8f:

    # ks sigh "Uggh, whatever."
    ks sigh "Ajj, muy graciosa."

# game/Kyou 6.rpy:6790
translate spanish Day6_Con_Kyou_Sayori_aed9f6fe:

    # s alert_rolleyes "Huh, and now I am thinking... Is it possible to hypnotize a person using scent?" with dissolve
    s alert_rolleyes "Mmm, eso me pone a pensar... ¿Es posible hipnotizar a una persona utilizando aromas?" with dissolve

# game/Kyou 6.rpy:4516
translate spanish Day6_Con_Kyou_Sayori_de9fe0af:

    # ks frown "Uh... I think so? You can use pretty much anything as a hypnotic fixation, depending on the subject."
    ks frown "Eh... ¿creo? Puedes usar básicamente lo que sea como fijación hipnótica, dependiendo del sujeto."

# game/Kyou 6.rpy:4517
translate spanish Day6_Con_Kyou_Sayori_488a59fb:

    # ks "... Why?"
    ks "... ¿Por qué?"

# game/Kyou 6.rpy:5887
translate spanish Day6_Con_Kyou_Sayori_623b5101:

    # s casual_folded alert_smile "Oh, I just had the thought that you could use this for your stage hypnotist routine." with dissolve
    s casual_folded alert_smile "Oh, es que se me ocurrió que podrías usarlo para tu rutina de hipnosis escénica." with dissolve

# game/Kyou 6.rpy:4519
translate spanish Day6_Con_Kyou_Sayori_c33ffb57:

    # s alert_smirk_right "You could be like a mesmerist Pepé Le Pew." with dissolve
    s alert_smirk_right "Serías como un Pepé Le Pew mesmerizante." with dissolve

# game/Kyou 6.rpy:4520
translate spanish Day6_Con_Kyou_Sayori_1d34f5ee:

    # ks angry "F-fuck off! So what if I've got a little morning musk, it can't be that bad."
    ks angry "¡A-ay, ya no jodas! ¿Y qué si tengo un poco de hedor mañanero? No puede estar tan mal."

# game/Kyou 6.rpy:6797
translate spanish Day6_Con_Kyou_Sayori_4e287c52:

    # "Sayori simply chuckles at my discomfort." with dissolve
    "Sayori simplemente se ríe de mi descontento." with dissolve

# game/Kyou 6.rpy:4523
translate spanish Day6_Con_Kyou_Sayori_36604946:

    # s "Well, if you are not going to freshen up, then I suppose we should just get to it."
    s "Bueno, si no te vas a refrescar, supongo que será mejor que empecemos de una vez."

# game/Kyou 6.rpy:4526
translate spanish Day6_Con_Kyou_Sayori_ad89981d:

    # "As Sayori goes to sit down on the living room couch, I have to wonder about her."
    "Sayori se sienta en el sofá de la sala, y no puedo evitar sentir incertidumbre con ella."

# game/Kyou 6.rpy:4527
translate spanish Day6_Con_Kyou_Sayori_0063a975:

    # "I mean, I guess she's in a good mood? And she's still okay with me deprogramming her."
    "Digo, supongo que está ¿de buen humor? Y sigue estando cómoda con que yo la desprograme."

# game/Kyou 6.rpy:4528
translate spanish Day6_Con_Kyou_Sayori_cd53a894:

    # "Maybe she was just messing with me to put herself at ease?"
    "¿Tal vez solo me estaba molestando para tranquilizarse?"

# game/Kyou 6.rpy:4531
translate spanish Day6_Con_Kyou_Sayori_938d6d46:

    # s alert_neutral_right "Just so we are clear, I want you to bring me under one more time and make sure to undo all your alterations. Both the personality AND the sleep conditioning." with dissolve
    s alert_neutral_right "Solo para que quede claro, quiero que me pongas en trance una vez más y te asegures de deshacer todas las alteraciones: La personalidad Y TAMBIÉN el sueño." with dissolve

# game/Kyou 6.rpy:4532
translate spanish Day6_Con_Kyou_Sayori_c3a64c83:

    # "All of it? But..."
    "¿Todo? Pero..."

# game/Kyou 6.rpy:6808
translate spanish Day6_Con_Kyou_Sayori_2d69ff35:

    # ks casual confused "So everything we did was for nothing?"
    ks casual confused "¿Entonces todo lo que hicimos fue para nada?"

# game/Kyou 6.rpy:6810
translate spanish Day6_Con_Kyou_Sayori_b9264e35:

    # s alert_concerned_right "I am sorry, Kyou. I know your intentions were good, but I foresee only trouble if we kept them lurking in my mind." with dissolve
    s alert_concerned_right "Lo lamento, Kyou. Sé que tus intenciones fueron buenas, pero no puedo ver más que problemas si seguimos hurgando en mi mente." with dissolve

# game/Kyou 6.rpy:4535
translate spanish Day6_Con_Kyou_Sayori_9881555f:

    # "She then averts her gaze and pauses a moment before continuing."
    "Luego desvía la mirada y hace una pausa entes de continuar."

# game/Kyou 6.rpy:4536
translate spanish Day6_Con_Kyou_Sayori_47afc700:

    # s alert_concerned "There is also one more thing I would ask: That you destroy that penlight once you're finished, and..." with dissolve
    s alert_concerned "Y hay una cosa más que quisiera pedirte: Que destruyas esa linterna una vez hayas terminado, y..." with dissolve

# game/Kyou 6.rpy:4537
translate spanish Day6_Con_Kyou_Sayori_9368d9ed:

    # s alert_concerned_right "... And that you remove any plans you may have drawn up so it cannot be remade." with dissolve
    s alert_concerned_right "... Y que borres todos los planos que tengas de ella para que no pueda ser replicada." with dissolve

# game/Kyou 6.rpy:4538
translate spanish Day6_Con_Kyou_Sayori_bcca08b4:

    # "She... really wants me to lose everything I worked for?"
    "¿De verdad... de verdad quiere que pierda todo por lo que he trabajado?"

# game/Kyou 6.rpy:4539
translate spanish Day6_Con_Kyou_Sayori_b0a676b2:

    # "Fuck, I know the penlight is dangerous, but..."
    "Mierda, sé que la linterna es peligrosa, pero..."

# game/Kyou 6.rpy:4540
translate spanish Day6_Con_Kyou_Sayori_e62d5ab0:

    # s casual "You know this is the right thing to do, Kyou." with dissolve
    s casual "Sabes que esto es lo correcto, Kyou." with dissolve

# game/Kyou 6.rpy:4543
translate spanish Day6_Con_Kyou_Sayori_64d29a7c:

    # "With a sigh, I find myself nodding my head."
    "Con un suspiro, asiento con la cabeza."

# game/Kyou 6.rpy:4544
translate spanish Day6_Con_Kyou_Sayori_405c9359:

    # ks sigh "You're right, Sayori. I know you're right. I mean..."
    ks sigh "Tienes razón, Sayori. Sé que tienes razón. Es decir..."

# game/Kyou 6.rpy:4547
translate spanish Day6_Con_Kyou_Sayori_33051eac:

    # ks "Without even meaning to, I've put you in a lot of danger by using this."
    ks "Sin quererlo, te he puesto en mucho peligro usando esto."

# game/Kyou 6.rpy:6815
translate spanish Day6_Con_Kyou_Sayori_804f16f2:

    # ks "Maybe I could try to be more careful in future, but I guess you can't always tell how a suggestion will affect someone."
    ks "Tal vez pueda intentar ser más cuidadoso en el futuro, pero supongo que nunca se sabe cómo una sugestión afectará a alguien."

# game/Kyou 6.rpy:4549
translate spanish Day6_Con_Kyou_Sayori_f5aa9071:

    # ks "Not to mention what would happen if this got in the wrong hands..."
    ks "Sin mencionar lo que pasaría si esto acabara en las manos equivocadas..."

# game/Kyou 6.rpy:4551
translate spanish Day6_Con_Kyou_Sayori_53289dd3:

    # s alert_annoyed_right "It does not bear thinking about, does it?" with dissolve
    s alert_annoyed_right "El solo pensarlo es insoportable, ¿no es cierto?" with dissolve

# game/Kyou 6.rpy:4552
translate spanish Day6_Con_Kyou_Sayori_32a450a8:

    # ks neutral "Yeah... alright, so are you ready?"
    ks neutral "Sí... muy bien, ¿estás lista?"

# game/Kyou 6.rpy:4554
translate spanish Day6_Con_Kyou_Sayori_400b7242:

    # "I raise the penlight above her head and she nods as I pass the light across her eyes once more." with dissolve
    "Alzo la linterna por encima de su cabeza y ella asiente mientras paso la luz por sus ojos una vez más." with dissolve

# game/Kyou 6.rpy:4560
translate spanish Day6_Con_Kyou_Sayori_4ca1aa9f:

    # ks "Alright. Then you should find it so very easy to relax in your seat once more, just looking up as you let the light dance across your eyes."
    ks "Muy bien. Pues seguramente ya te diste cuenta de lo fácil que es relajarte nuevamente en tu asiento, con la vista aquí arriba mientras la luz danza ante tus ojos."

# game/Kyou 6.rpy:4562
translate spanish Day6_Con_Kyou_Sayori_9caca8d9:

    # "And sure enough, any anxiety she may have had about being hypnotized by this thing seems to dissipate after just a couple of exposures to the beam."
    "Y, sin duda, cualquier ansiedad que pudiera haber tenido en cuanto a ser hipnotizada por esta cosa parece desaparecer tras ser expuesta solo un par de veces al haz."

# game/Kyou 6.rpy:4563
translate spanish Day6_Con_Kyou_Sayori_f8d2f40c:

    # ks "That's right. Let me and the light do all the work. All you need to do is stare up at the light and let yourself feel nice and comfortable."
    ks "Eso es. Deja que mi linterna y yo hagamos todo el trabajo. Lo único que tienes que hacer es observar la luz y ponerte muy, muy cómoda."

# game/Kyou 6.rpy:4565
translate spanish Day6_Con_Kyou_Sayori_fee491ad:

    # ks "Stare and let yourself tire. Let yourself sink into the couch. Let the light take you down as you take a deep breath in."
    ks "Observa y nota cómo empiezas a sentirte cansada. Tan solo húndete en el sofá. Deja que la luz te lleve mientras inhalas profundo."

# game/Kyou 6.rpy:4568
translate spanish Day6_Con_Kyou_Sayori_d904f4fc:

    # ks "And out. Watching the light. Letting those eyelids droop. Breathing in..."
    ks "Y exhalas. Mirando la luz. Deja que tus párpados caigan. Inhala..."

# game/Kyou 6.rpy:4571
translate spanish Day6_Con_Kyou_Sayori_74b60ca7:

    # ks "And out. Deeper. Breathing in." with dissolve
    ks "Y exhala. Más profundo. Inhala." with dissolve

# game/Kyou 6.rpy:4573
translate spanish Day6_Con_Kyou_Sayori_88455c8d:

    # ks "Breathing out. Feeling so drowsy. So comfortable and relaxed for the light. That's good, Sayori."
    ks "Exhala. Sintiendo mucho sueño. Sintiéndote muy cómoda y relajada por la luz. Muy bien, Sayori."

# game/Kyou 6.rpy:5745
translate spanish Day6_Con_Kyou_Sayori_1803ce8a:

    # ks "Let's try to stay awake just a little longer. Take a deep, full breath now. Filling your lungs with relaxation."
    ks "Trata de quedarte despierta solo un poco más. Ahora respira a fondo. Llenando tus pulmones de relajación."

# game/Kyou 6.rpy:4578
translate spanish Day6_Con_Kyou_Sayori_aa8ecf4a:

    # ks "That's good. Keep that relaxation and let it fill you completely."
    ks "Eso es. Conserva esa relajación y deja que te llene por completo."

# game/Kyou 6.rpy:4580
translate spanish Day6_Con_Kyou_Sayori_1c022c73:

    # ks "And now breathe out fully, letting all the remaining tension leave your body."
    ks "Y ahora exhálalo todo, dejando que toda la tensión restante abandone tu cuerpo."

# game/Kyou 6.rpy:4582
translate spanish Day6_Con_Kyou_Sayori_e60ed2d3:

    # ks "So relaxed. So comfortable... sleep, Sayori."
    ks "Muy relajada. Muy cómoda... duerme, Sayori."

# game/Kyou 6.rpy:4586
translate spanish Day6_Con_Kyou_Sayori_2b25a923:

    # "Her straining eyelids flutter closed as she once more slumps on my couch." with dissolve
    "Sus exhaustos párpados se cierran y una vez más se desploma en mi sofá." with dissolve

# game/Kyou 6.rpy:4587
translate spanish Day6_Con_Kyou_Sayori_fa18bace:

    # ks "Very good. Letting yourself drop for me, going deep into that familiar, wonderful state of trance."
    ks "Muy bien. Caes muy profundo en ese familiar y maravilloso estado de trance."

# game/Kyou 6.rpy:4588
translate spanish Day6_Con_Kyou_Sayori_a611a002:

    # s alert_sleep "..."
    s alert_sleep "..."

# game/Kyou 6.rpy:4589
translate spanish Day6_Con_Kyou_Sayori_60a4ea0b:

    # ks "And as you drop, you will realize that there is no longer another person within you."
    ks "Y al caer, te darás cuenta de que ya no hay ninguna otra persona dentro de ti."

# game/Kyou 6.rpy:4590
translate spanish Day6_Con_Kyou_Sayori_9ac4ed39:

    # ks "[alt_name] is no more, and the words \"become [alt_name]\" will no longer have any special effect on you if you hear me or anyone else say it."
    ks "[alt_name] ya no existe, y las palabras \"Conviértete en [alt_name]\" ya no tienen ningún efecto especial en ti al escucharme a mí o a quien sea decirlas."

# game/Kyou 6.rpy:4591
translate spanish Day6_Con_Kyou_Sayori_ae3b8afe:

    # ks "Also... you will no longer be compelled to blank your mind completely when you try to sleep at night. What you do when you try to sleep is entirely up to you again."
    ks "Además... ya no estarás obligada a vaciar por completo tu mente al intentar dormir por las noches. Lo que hagas al intentar dormir, una vez más, depende enteramente de ti."

# game/Kyou 6.rpy:4592
translate spanish Day6_Con_Kyou_Sayori_f931dd29:

    # ks "Anything I may have suggested to you in trance will immediately and effortlessly fade from your mind."
    ks "Cualquier sugestión que pudiera haberte dado mientras estabas en trance se desvanecerá al instante de tu mente."

# game/Kyou 6.rpy:4593
translate spanish Day6_Con_Kyou_Sayori_121b7032:

    # ks "None of those suggestions will influence your behaviour or thinking in any way."
    ks "Ninguna de esas sugestiones influenciará de ninguna mantera tu comportamiento o tus pensamientos."

# game/Kyou 6.rpy:4594
translate spanish Day6_Con_Kyou_Sayori_6cbdd3cd:

    # ks "Do you understand, Sayori?"
    ks "Comprendes, ¿Sayori?"

# game/Kyou 6.rpy:4595
translate spanish Day6_Con_Kyou_Sayori_2c76e08e:

    # s alert_sleeptalk "Yes..." with dissolve
    s alert_sleeptalk "Sí..." with dissolve

# game/Kyou 6.rpy:4597
translate spanish Day6_Con_Kyou_Sayori_ae15a34d:

    # "I sigh quietly. I still think she could've kept the sleep trigger." with dissolve
    "Suspiro silenciosamente. Sigo pensando que podría haber conservado el ancla de sueño." with dissolve

# game/Kyou 6.rpy:4598
translate spanish Day6_Con_Kyou_Sayori_ed2667ed:

    # "It really did seem to be helping her. But this is what she wants."
    "De verdad parecía ayudarle. Pero esto es lo que quiere."

# game/Kyou 6.rpy:4599
translate spanish Day6_Con_Kyou_Sayori_b3bd3ef2:

    # ks "Very good, Sayori. Now we will wake you up on a count of three. I will count up, and on three you will become comfortably awake."
    ks "Muy bien Sayori. Ahora despertarás a las tres. Voy a contar y a la cuenta de tres estarás completamente despierta."

# game/Kyou 6.rpy:4601
translate spanish Day6_Con_Kyou_Sayori_eeb91ac6:

    # ks "Counting up now... one, feeling the energy start to return to your limbs."
    ks "Ahora, comenzaré a contar... uno, siente la energía regresar a tus brazos y piernas."

# game/Kyou 6.rpy:4602
translate spanish Day6_Con_Kyou_Sayori_bf6924f5:

    # ks "Two, beginning to test your eyelids, letting the tiredness fade from them."
    ks "Dos, el cansancio desaparece de tus párpados y comienzan a moverse."

# game/Kyou 6.rpy:4603
translate spanish Day6_Con_Kyou_Sayori_6053d30c:

    # ks "And three, comfortably awake, Sayori."
