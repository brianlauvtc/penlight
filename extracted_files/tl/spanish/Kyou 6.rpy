# game/Kyou 6.rpy:6177
translate spanish Day6_Redemption_ef47c61b:

    # ks "I... asked one of them how she felt about being my girlfriend."
    ks "Le... pregunté a una de ellas qué le parecería ser mi novia."

# game/Kyou 6.rpy:6178
translate spanish Day6_Redemption_92fdf646:

    # a surprised "Really?" with dissolve
    a surprised "¿En serio?" with dissolve

# game/Kyou 6.rpy:6179
translate spanish Day6_Redemption_d27740c2:

    # a "That's... bold."
    a "Eso... es muy atrevido."

# game/Kyou 6.rpy:6180
translate spanish Day6_Redemption_36559417:

    # "She prods her pancakes with a fork as she thinks for a moment."
    "Pincha sus panqueques por un momento mientras piensa."

# game/Kyou 6.rpy:6181
translate spanish Day6_Redemption_c5406aaf:

    # a sigh "I guess the rumours about you are making a little more sense now." with dissolve
    a sigh "Supongo que ahora los rumores sobre ti tienen un poco más de sentido." with dissolve

# game/Kyou 6.rpy:6182
translate spanish Day6_Redemption_e01eb4d4:

    # ks "Yeah... I mean, I thought it would be okay. I wanted to impress her."
    ks "Seh... bueno, pensé que estaría bien. Quería impresionarla."

# game/Kyou 6.rpy:6183
translate spanish Day6_Redemption_73d2471e:

    # a neutral "Hmm... and what scared her about that situation, do you think?" with dissolve
    a neutral "Mmm... ¿y qué dirías tú que le causó miedo de esa situación?" with dissolve

# game/Kyou 6.rpy:11473
translate spanish Day6_Redemption_118ad601:

    # ks confused "Scared?"
    ks confused "¿Miedo?"

# game/Kyou 6.rpy:6185
translate spanish Day6_Redemption_2f5fbdc1:

    # a sleep "You told me your classmates freaked out when you hypnotized them." with dissolve
    a sleep "Me dijiste que tus compañeras se asustaron cuando las hipnotizaste." with dissolve

# game/Kyou 6.rpy:6186
translate spanish Day6_Redemption_dbf76c69:

    # a neutral_side "Was it that you put her on the spot by asking something so provocative?" with dissolve
    a neutral_side "¿Será porque la pusiste en el punto de mira preguntándole algo provocativo?" with dissolve

# game/Kyou 6.rpy:6187
