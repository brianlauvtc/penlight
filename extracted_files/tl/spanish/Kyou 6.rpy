# game/Kyou 6.rpy:3615
translate spanish Day6_Con_Kyou_Nozomi_Trance_8f29f42f:

    # n front annoyed "How dare you!" with dissolve
    n front annoyed "¡¿Cómo te atreves?!" with dissolve

# game/Kyou 6.rpy:3616
translate spanish Day6_Con_Kyou_Nozomi_Trance_fcb60e4d:

    # ks smirk "I just think you're making excuses for your own messiness. Do you need some encouragement?"
    ks smirk "Creo que solo estás inventando excusas para justificar tu propio desorden. ¿Necesitas algo de motivación?"

# game/Kyou 6.rpy:3618
translate spanish Day6_Con_Kyou_Nozomi_Trance_5a496dc9:

    # "Nozomi pouts, and I indignantly wave my hand in front of her eyes, referencing our time together the other day."
    "Nozomi me pone una mala cara y yo muevo indignado mi mano frente a sus ojos, haciendo referencia a nuestro tiempo juntos del otro día."

# game/Kyou 6.rpy:3620
translate spanish Day6_Con_Kyou_Nozomi_Trance_c1c3c993:

    # "Nozomi pouts, and I indignantly poke her forehead between her eyes, referencing our time together the other day."
    "Nozomi me pone una mala cara y yo coloco indignado mi dedo en su frente, haciendo referencia a nuestro tiempo juntos del otro día."

# game/Kyou 6.rpy:3623
translate spanish Day6_Con_Kyou_Nozomi_Trance_5ff3800e:

    # ks "You will tidy your room." with dissolve
    ks "Limpiarás tu habitación." with dissolve

# game/Kyou 6.rpy:3863
translate spanish Day6_Con_Kyou_Nozomi_Trance_ab191a0b:

    # n "{size=16}I... I will tidy my room.{/size}"
    n "{size=16}L-... Limpiaré mi habitación.{/size}"

# game/Kyou 6.rpy:3627
translate spanish Day6_Con_Kyou_Nozomi_Trance_2e0e08fe:

    # "As soon as I finish speaking I just look at her stunned, recognizing the blank expression on her face immediately." with dissolve
    "En cuanto termino de hablar la miro atónito, reconociendo inmediatamente esa vacía expresión en su rostro." with dissolve

# game/Kyou 6.rpy:3629
translate spanish Day6_Con_Kyou_Nozomi_Trance_edec0ac9:

    # "As soon as I finish speaking I just look at her stunned, recognizing the blank expression on her face immediately."
    "En cuanto termino de hablar y la miro atónito, reconociendo inmediatamente esa vacía expresión en su rostro."

# game/Kyou 6.rpy:3631
translate spanish Day6_Con_Kyou_Nozomi_Trance_3ba19154:

    # n side sad_closed "*sigh* No, you're right. I'm just making excuses." with dissolve
    n side sad_closed "*suspiro* No, tienes razón. Solo estoy inventando excusas." with dissolve

# game/Kyou 6.rpy:3632
translate spanish Day6_Con_Kyou_Nozomi_Trance_2810ffee:

    # "I meant it as a joke, but she seriously processed that as a post-hypnotic suggestion? Outside of my house?"
    "Lo hice de broma, pero ¿en serio lo procesó como una sugestión posthipnótica? ¿Fuera de mi casa?"

# game/Kyou 6.rpy:3633
translate spanish Day6_Con_Kyou_Nozomi_Trance_b1e1aac5:

    # n sad "So I'm going to carry on tidying if you don't mind." with dissolve
    n sad "Mejor me pongo a limpiar, si no te molesta." with dissolve

# game/Kyou 6.rpy:3634
translate spanish Day6_Con_Kyou_Nozomi_Trance_4bc9b1ca:

    # "I mean... when I think about it, I don't remember telling her it only applied to my house."
    "Bueno... ahora que lo pienso, no recuerdo haberle dicho que solo aplicaba en mi casa."

# game/Kyou 6.rpy:3635
translate spanish Day6_Con_Kyou_Nozomi_Trance_df0399be:

    # "And I sure didn't remove the suggestion after we were done with it the other day."
    "Y definitivamente no removí la sugestión cuando terminamos el otro día."

# game/Kyou 6.rpy:3637
translate spanish Day6_Con_Kyou_Nozomi_Trance_1d592ac6:

    # "But with what we talked about before it seemed implied that it'd only work under the same conditions as all the other suggestions I gave her." with dissolve
    "Pero, después de lo que hablamos, parecía estar implícito que solo funcionaría bajo las mismas condiciones que todas las otras sugestiones que le di." with dissolve

# game/Kyou 6.rpy:3640
translate spanish Day6_Con_Kyou_Nozomi_Trance_92a8e16d:

    # "But then, after what she was telling me yesterday, about wanting to feel like I'm really controlling her mind..."
    "Sin embargo, tras lo que me dijo ayer sobre querer sentir que de verdad estoy controlando su mente..."

# game/Kyou 6.rpy:3641
translate spanish Day6_Con_Kyou_Nozomi_Trance_231e5e19:

    # "Maybe she's seriously trying to immerse herself in her own fantasy as fully as possible?"
    "¿Tal vez intenta sumergirse lo más posible en su fantasía?"

# game/Kyou 6.rpy:3642
translate spanish Day6_Con_Kyou_Nozomi_Trance_5d1fbce2:

    # n frown "So, Kyou." with dissolve
    n frown "Y, Kyou." with dissolve

# game/Kyou 6.rpy:4310
translate spanish Day6_Con_Kyou_Nozomi_Trance_69327d0d:

    # ks casual surprised "H-huh?"
    ks casual surprised "¿E-eh?"

# game/Kyou 6.rpy:3644
translate spanish Day6_Con_Kyou_Nozomi_Trance_3a70196a:

    # "In any case, Nozomi's voice catches my attention."
    "Sea como sea, la voz de Nozomi atrapa mi atención."

# game/Kyou 6.rpy:3645
translate spanish Day6_Con_Kyou_Nozomi_Trance_4c955508:

    # n "I might be a little occupied here, but we can still talk."
    n "Puede que esté un poco ocupada, pero aún podemos hablar."

# game/Kyou 6.rpy:3646
translate spanish Day6_Con_Kyou_Nozomi_Trance_c2eb7e17:

    # n smile "Believe it or not, I didn't invite you over here to help me clean." with dissolve
    n smile "Créelo o no, no te invité para que me ayudaras a limpiar." with dissolve

# game/Kyou 6.rpy:3647
translate spanish Day6_Con_Kyou_Nozomi_Trance_f4534ac5:

    # "So she says, but watching her pick up the littered cards and playing pieces off the floor is making me a little self-conscious of my idleness."
    "Eso dice, pero verla recoger las castas tiradas y piezas de juego del suelo me está haciendo sentir autoconsciente de mi ociosidad."

# game/Kyou 6.rpy:4315
translate spanish Day6_Con_Kyou_Nozomi_Trance_0f6ee120:

    # ks confused "O-okay, sure. What do you want to talk about?"
    ks confused "C-claro, muy bien. ¿De qué quieres hablar?"

# game/Kyou 6.rpy:3649
translate spanish Day6_Con_Kyou_Nozomi_Trance_5a11062c:

    # "I reply, as I bend down to pick up a box while Nozomi gingerly steps around some rather sharp-looking figurines to re-shelve a boxed set of some card game."
    "Contesto agachándome para levantar una caja, mientras Nozomi camina con cuidado, entre unas figuras que lucen algo filosas, para guardar una caja de cartas."

# game/Kyou 6.rpy:3650
translate spanish Day6_Con_Kyou_Nozomi_Trance_d5cd0554:

    # n frown_side "Well... We could talk about what you like?" with dissolve
    n frown_side "Pues... ¿Podríamos hablar de lo que te gusta?" with dissolve

# game/Kyou 6.rpy:3651
translate spanish Day6_Con_Kyou_Nozomi_Trance_e0846f3e:

    # ks neutral "What I like?"
    ks neutral "¿Lo que me gusta?"

# game/Kyou 6.rpy:3654
translate spanish Day6_Con_Kyou_Nozomi_Trance_2a1cb2f7:

    # "She nods as she follows my gaze to those figurines and crouches down to collect them in her hands."
    "Asiente, luego dirige su mirada hacia las figuras, y se agacha para recogerlas."

# game/Kyou 6.rpy:3657
translate spanish Day6_Con_Kyou_Nozomi_Trance_a5ee16ea:

    # n "Mhm. I'm thrilled we're both into hypnosis, but that's only a recent thing for you."
    n "Mjm. Me emociona que a ambos nos guste la hipnosis, pero es solo algo reciente para ti."

# game/Kyou 6.rpy:3658
translate spanish Day6_Con_Kyou_Nozomi_Trance_8da1f42a:

    # n smile "So tell me what you're passionate about. What gets you out of bed in the morning?" with dissolve
    n smile "Dime qué te apasiona. ¿Qué te levanta de la cama por las mañanas?" with dissolve

# game/Kyou 6.rpy:3659
translate spanish Day6_Con_Kyou_Nozomi_Trance_aadb85ba:

    # ks frown "Uh, school?"
    ks frown "Eh, ¿la escuela?"

# game/Kyou 6.rpy:3663
translate spanish Day6_Con_Kyou_Nozomi_Trance_4bebf6fb:

    # n "Don't be dense! I'm obviously talking about your hobbies." with dissolve
    n "¡Qué graciosito! Obviamente refiero a tus pasatiempos." with dissolve

# game/Kyou 6.rpy:3664
translate spanish Day6_Con_Kyou_Nozomi_Trance_19c5729f:

    # "Honestly this question makes me anxious. I know what I like, but is she really going to appreciate it and not blow me off as some sort of lonely nerd?"
    "Honestamente esa pregunta me pone nervioso. Sé lo que me gusta, pero ¿acaso lo apreciará en vez de tacharme de nerd sin amigos?"

# game/Kyou 6.rpy:3665
translate spanish Day6_Con_Kyou_Nozomi_Trance_ec0e0f06:

    # ks "Well... yeah, of course I have hobbies."
    ks "Pues... sí, claro que tengo pasatiempos."

# game/Kyou 6.rpy:3666
translate spanish Day6_Con_Kyou_Nozomi_Trance_5157ce6c:

    # n frown "Yes, and I'm asking you to tell me about them!" with dissolve
    n frown "Sí, ¡y te estoy pidiendo que me hables de ellos!" with dissolve

# game/Kyou 6.rpy:3667
translate spanish Day6_Con_Kyou_Nozomi_Trance_1b2f1b0f:

    # ks sigh "Okay, well... I'm pretty into computers and gadgets and stuff."
    ks sigh "Muy bien, pues... Me gustan mucho las computadoras y artilugios y esas cosas."

# game/Kyou 6.rpy:3672
translate spanish Day6_Con_Kyou_Nozomi_Trance_b5287963:

    # "I pause a moment to gauge Nozomi's response, but she simply stands up and places her figurines back in their box while keeping a neutral expression." with dissolve
    "Hago una pausa para medir la respuesta de Nozomi, pero simplemente se pone de pie y vuelve a poner sus dedos en la caja, con una expresión neutral." with dissolve

# game/Kyou 6.rpy:3675
translate spanish Day6_Con_Kyou_Nozomi_Trance_769efa1e:

    # ks "So, uh... I'm always reading about new things coming out in the tech world. I always loved that kinda stuff."
    ks "Y, eh... siempre estoy leyendo de las novedades del mundo de la tecnología. Siempre me encantó esa clase de cosas."

# game/Kyou 6.rpy:3676
translate spanish Day6_Con_Kyou_Nozomi_Trance_0ebdf8cf:

    # n "Uh-huh?"
    n "¿Ajá?"

# game/Kyou 6.rpy:3677
translate spanish Day6_Con_Kyou_Nozomi_Trance_14efce74:

    # "I nod, although I think she's too distracted arranging the figurines to notice."
    "Asiento con la cabeza, aunque creo que está muy distraída organizando las figuras para notarlo."

# game/Kyou 6.rpy:3678
translate spanish Day6_Con_Kyou_Nozomi_Trance_8f52e0ca:

    # ks "Uh, yeah. And if I'm not doing that I'm sometimes tinkering."
    ks "Eh, sí. Y cuando no estoy haciendo eso, a veces retoco cosas."

# game/Kyou 6.rpy:3679
translate spanish Day6_Con_Kyou_Nozomi_Trance_7a196eca:

    # ks "L-like... taking things apart and putting them back together."
    ks "O-o sea...  desmantelo cosas y las reensamblo."

# game/Kyou 6.rpy:3680
translate spanish Day6_Con_Kyou_Nozomi_Trance_2b9ac37a:

    # n smile "Oh, like with that penlight?" with dissolve
    n smile "Oh, ¿como con la linterna?" with dissolve

# game/Kyou 6.rpy:3681
translate spanish Day6_Con_Kyou_Nozomi_Trance_874d11c4:

    # ks smile "Yeah, exactly! But I've done loads of things besides that."
    ks smile "¡Sí, exacto! Pero he hecho montones de cosas más."

# game/Kyou 6.rpy:3683
translate spanish Day6_Con_Kyou_Nozomi_Trance_b2ba11d0:

    # ks "Like... you know those little circuit board computers? I have a bunch of those." with dissolve
    ks "Como... ¿has visto esas pequeñas placas de circuitos de las computadoras? Tengo un montón de esas." with dissolve

# game/Kyou 6.rpy:4348
translate spanish Day6_Con_Kyou_Nozomi_Trance_f3b39ae3:

    # n sad_side "Um... \"Those little circuit board computers\"?" with dissolve
    n sad_side "Em... ¿\"placas de circuitos de computadoras\"?" with dissolve

# game/Kyou 6.rpy:3685
translate spanish Day6_Con_Kyou_Nozomi_Trance_f3138a2a:

    # ks "Y-yeah... I've programmed a few and uh..."
    ks "S-sí... He programado unas cuantas y eh..."

# game/Kyou 6.rpy:3686
translate spanish Day6_Con_Kyou_Nozomi_Trance_682189f1:

    # "Shit. I can't explain this stuff very well. And Nozomi's gone back to tidying while seemingly half-listening."
    "Mierda. No soy bueno explicando estas cosas. Y Nozomi ya regresó a la limpieza y parece escuchar a medias."

# game/Kyou 6.rpy:3687
translate spanish Day6_Con_Kyou_Nozomi_Trance_a370c9da:

    # "I'll talk about something else."
    "Hablaré de otra cosa."

# game/Kyou 6.rpy:3688
translate spanish Day6_Con_Kyou_Nozomi_Trance_df3d3ab4:

    # ks "U-uh... and I write apps for my phone sometimes."
    ks "E-eh... y a veces escribo aplicaciones de teléfono."

# game/Kyou 6.rpy:3691
translate spanish Day6_Con_Kyou_Nozomi_Trance_d6207d48:

    # "Yeah, I'll pull out my phone and show her that."
    "Sí, sacaré mi teléfono y se lo mostraré."

# game/Kyou 6.rpy:3695
translate spanish Day6_Con_Kyou_Nozomi_Trance_8cbe5737:

    # "It's enough to distract her momentarily as she looks at it with a quizzical expression." with dissolve
    "Eso logra distraerla por un momento y lo mira con curiosidad." with dissolve

# game/Kyou 6.rpy:3696
translate spanish Day6_Con_Kyou_Nozomi_Trance_0b7fc75d:

    # n "Oh, you mean like games?"
    n "Oh, ¿como juegos? "

# game/Kyou 6.rpy:3697
translate spanish Day6_Con_Kyou_Nozomi_Trance_e56cf746:

    # "Only to realize..."
    "Y entonces me doy cuenta..."

# game/Kyou 6.rpy:3913
translate spanish Day6_Con_Kyou_Nozomi_Trance_8ffa0a00:

    # ks sigh "Games sometimes, yeah. I just remembered, though..."
    ks sigh "A veces juegos, sí. Pero me acabo de acordar..."

# game/Kyou 6.rpy:3699
translate spanish Day6_Con_Kyou_Nozomi_Trance_b9d4d99b:

    # n neutral "Remembered what?" with dissolve
    n neutral "¿De qué te acordaste?" with dissolve

# game/Kyou 6.rpy:3700
translate spanish Day6_Con_Kyou_Nozomi_Trance_c2468e09:

    # ks "I only just got this phone, so there's nothing I wrote on it yet."
    ks "Apenas acabo de conseguir este teléfono y no he escrito nada en él."

# game/Kyou 6.rpy:3701
translate spanish Day6_Con_Kyou_Nozomi_Trance_3413d577:

    # n concerned "Oh... well, that's too bad." with dissolve
    n concerned "Oh... pues, qué lástima." with dissolve

# game/Kyou 6.rpy:3702
translate spanish Day6_Con_Kyou_Nozomi_Trance_00af7257:

    # ks "Yeah..."
    ks "Sí..."

# game/Kyou 6.rpy:3703
translate spanish Day6_Con_Kyou_Nozomi_Trance_55fd46eb:

    # "This is why I didn't want to talk about this sort of thing. I'm just no good at it."
    "Por esto no quería hablar de esta clase de cosas. No soy bueno en ello."

# game/Kyou 6.rpy:3704
translate spanish Day6_Con_Kyou_Nozomi_Trance_335b5b03:

    # "It always turns out like this somehow."
    "De una forma u otra siempre termina así."

# game/Kyou 6.rpy:3705
translate spanish Day6_Con_Kyou_Nozomi_Trance_cb47cbd9:

    # n side sad_side "Well... it's a nice phone anyway." with dissolve
    n side sad_side "Pues... aun así es un lindo teléfono." with dissolve

# game/Kyou 6.rpy:3707
translate spanish Day6_Con_Kyou_Nozomi_Trance_2f362fc2:

    # "Still, at least Nozomi is trying to keep our conversation going while she sorts her things."
    "Al menos Nozomi sigue intentando mantener la conversación mientras ordena sus cosas."

# game/Kyou 6.rpy:3708
translate spanish Day6_Con_Kyou_Nozomi_Trance_b42a3a59:

    # ks smile "Oh yeah, thanks. It's the latest model."
    ks smile "Oh, sí, gracias. Es el modelo más reciente. "

# game/Kyou 6.rpy:3709
translate spanish Day6_Con_Kyou_Nozomi_Trance_d8c61654:

    # n sad "It is? Aren't those really expensive?" with dissolve
    n sad "¿En serio? ¿No son muy costosos?" with dissolve

# game/Kyou 6.rpy:3711
translate spanish Day6_Con_Kyou_Nozomi_Trance_db950835:

    # ks "It... set me back a bit, yeah. But it's got everything you could ever want."
    ks "Me... costó un poco, sí. Pero tiene todo lo que podrías desear."

# game/Kyou 6.rpy:3712
translate spanish Day6_Con_Kyou_Nozomi_Trance_feca549d:

    # n side smile "Hm, if you say so. But mine's a budget model and I don't need anything else." with dissolve
    n side smile "Mm, si tú lo dices. Pero el mío en uno económico y no necesito mucho más." with dissolve

# game/Kyou 6.rpy:3713
translate spanish Day6_Con_Kyou_Nozomi_Trance_4647bf0b:

    # n smile_side "No offense, but I kinda think getting the latest tech is a waste of money." with dissolve
    n smile_side "Sin ofender, pero me parece que comprar lo último en tecnología es un desperdicio de dinero." with dissolve

# game/Kyou 6.rpy:3714
translate spanish Day6_Con_Kyou_Nozomi_Trance_3dcf54f4:

    # "I'm wounded."
    "Estoy herido."

# game/Kyou 6.rpy:3715
translate spanish Day6_Con_Kyou_Nozomi_Trance_af9f7f36:

    # ks frown "You do?"
    ks frown "¿Eso crees?"

# game/Kyou 6.rpy:4383
translate spanish Day6_Con_Kyou_Nozomi_Trance_2f39e6ea:

    # n rolleyes "I mean, I look at them? But they barely seem any better and you pay such a premium for features you won't even use." with dissolve
    n rolleyes "Es que los miro, pero apenas logro ver ninguna mejora y pagas una fortuna por características que apenas usarás." with dissolve

# game/Kyou 6.rpy:3717
translate spanish Day6_Con_Kyou_Nozomi_Trance_561e1bfb:

    # n sad_side "... W-well if it makes you happy and you can afford it then I guess it's fine." with dissolve
    n sad_side "... B-bueno, si te hace feliz y puedes permitírtelo, supongo que está bien." with dissolve

# game/Kyou 6.rpy:3718
translate spanish Day6_Con_Kyou_Nozomi_Trance_4c98632a:

    # n smile "But I'll stick to the budget options, heh~" with dissolve
    n smile "Pero yo me quedo con las opciones más económicas, je." with dissolve

# game/Kyou 6.rpy:3720
translate spanish Day6_Con_Kyou_Nozomi_Trance_aecab05f:

    # "I nod and sigh, as I pass her the box I was clearing up. Although she opens it up to examine and immediately frowns, tapping a finger over a trio of metal tokens." with dissolve
    "Asiento y suspiro, pasándole la caja que estaba limpiando. Aunque al abrirla para examinarla, de inmediato frunce el ceño, golpeteando con su dedo un trío de fichas metálicas." with dissolve

# game/Kyou 6.rpy:3721
translate spanish Day6_Con_Kyou_Nozomi_Trance_c2a773c9:

    # n front frown "Ah, there's supposed to be four of these." with dissolve
    n front frown "Ah, se supone que haya cuatro de estas." with dissolve

# game/Kyou 6.rpy:3722
translate spanish Day6_Con_Kyou_Nozomi_Trance_8bfc1605:

    # ks neutral "Oh..."
    ks neutral "Oh..."

# game/Kyou 6.rpy:3723
translate spanish Day6_Con_Kyou_Nozomi_Trance_700cda6c:

    # "We both start to scan the floor with our eyes as the thought occurs to me..."
    "Ambos comenzamos a escanear el suelo y entonces se me ocurre..."

# game/Kyou 6.rpy:3724
translate spanish Day6_Con_Kyou_Nozomi_Trance_4923122d:

    # ks frown "And how much are you paying for all these games?"
    ks frown "¿Y cuánto pagas por estos juegos?"

# game/Kyou 6.rpy:3726
translate spanish Day6_Con_Kyou_Nozomi_Trance_818e7ad3:

    # "Nozomi frowns at the question. I think she immediately picked up where I'm going with this." with dissolve
    "Nozomi frunce el sueño ante la pregunta. Creo que se dio cuenta de inmediato adónde voy con esto." with dissolve

# game/Kyou 6.rpy:3727
translate spanish Day6_Con_Kyou_Nozomi_Trance_411c10f0:

    # n side frown "Excuse you?"
    n side frown "¿Disculpa?"

# game/Kyou 6.rpy:3728
translate spanish Day6_Con_Kyou_Nozomi_Trance_8d813fa4:

    # ks "All this stuff's gotta set you back."
    ks "Todo esto te debe costar un ojo de la cara."

# game/Kyou 6.rpy:3729
translate spanish Day6_Con_Kyou_Nozomi_Trance_24892c02:

    # n frown_side "That's different." with dissolve
    n frown_side "Es diferente." with dissolve

# game/Kyou 6.rpy:3730
translate spanish Day6_Con_Kyou_Nozomi_Trance_34db75a7:

    # ks "Different how?"
    ks "¿Diferente cómo?"

# game/Kyou 6.rpy:3731
translate spanish Day6_Con_Kyou_Nozomi_Trance_b160f3eb:

    # "Nozomi simply smiles as she cradles the box she's currently holding."
    "Nozomi simplemente sonríe meciendo la caja en sus brazos."

# game/Kyou 6.rpy:3732
translate spanish Day6_Con_Kyou_Nozomi_Trance_5ce60ab8:

    # n front chuckle "Each and every one of these games represents a unique and treasured experience for me." with dissolve
    n front chuckle "Todos y cada uno de estos juegos representan una experiencia única y atesorada para mí." with dissolve

# game/Kyou 6.rpy:3733
translate spanish Day6_Con_Kyou_Nozomi_Trance_cd8b8206:

    # ks smirk "Is that why you leave them on the floor?"
    ks smirk "¿Por eso los dejas en el piso?"

# game/Kyou 6.rpy:3734
translate spanish Day6_Con_Kyou_Nozomi_Trance_bee2afe9:

    # n determined "Oh, get bent." with dissolve
    n determined "Ay, cállate." with dissolve

# game/Kyou 6.rpy:3736
translate spanish Day6_Con_Kyou_Nozomi_Trance_5b2b5040:

    # "Nozomi turns her back to me and rises up on her toes to slot her treasured box up on the top shelf of her display." with dissolve
    "Nozomi me da la espalda y se pone de puntillas para poner su atesorada caja en la repisa de arriba." with dissolve

# game/Kyou 6.rpy:3737
translate spanish Day6_Con_Kyou_Nozomi_Trance_21bb3da8:

    # n "So what if I don't always put them away afterwards? It doesn't change how I feel about them."
    n "¿Y qué si no los guardo después? Eso no cambia lo que pienso por ellos."

# game/Kyou 6.rpy:3738
translate spanish Day6_Con_Kyou_Nozomi_Trance_0c86bfbd:

    # n smile_side "Just seeing people's faces light up when a game gets going..." with dissolve
    n smile_side "Tan solo ver los rostros de la gente cuando un juego se pone en marcha..." with dissolve

# game/Kyou 6.rpy:3739
translate spanish Day6_Con_Kyou_Nozomi_Trance_2f6f347c:

    # n smile "To share in their understanding and joy when all the pieces come together..." with dissolve
    n smile "Compartir su entendimiento y alegría cuando todas las piezas se reúnen..." with dissolve

# game/Kyou 6.rpy:3743
translate spanish Day6_Con_Kyou_Nozomi_Trance_60e1fb6f:

    # n "It really can be the most magical thing~" with dissolve
    n "Es simplemente mágico." with dissolve

# game/Kyou 6.rpy:3744
translate spanish Day6_Con_Kyou_Nozomi_Trance_5b698183:

    # n side frown noblush "But can you get that sort of experience from your overpriced smartphone? I very much doubt it, Kyou." with dissolve
    n side frown noblush "Pero ¿puede tu teléfono inteligente a sobre precio darte esa clase de experiencia? Lo dudo mucho, Kyou." with dissolve

# game/Kyou 6.rpy:3745
translate spanish Day6_Con_Kyou_Nozomi_Trance_c06e7c0a:

    # ks frown "Hey, you leave my phone out of this."
    ks frown "Oye, no metas a mi teléfono en esto."

# game/Kyou 6.rpy:3747
translate spanish Day6_Con_Kyou_Nozomi_Trance_aa1036d8:

    # ks "But man, I think it might actually be true that you're a bigger nerd than me, hearing you go on like this."
    ks "Pero cielos, tal vez sí seas más nerd que yo, después de escucharte hablar así."

# game/Kyou 6.rpy:3749
translate spanish Day6_Con_Kyou_Nozomi_Trance_a9c1a605:

    # "Nozomi rolls her eyes as she sighs at me." with dissolve
    "Nozomi me voltea los ojos y suspira." with dissolve

# game/Kyou 6.rpy:3750
translate spanish Day6_Con_Kyou_Nozomi_Trance_99d87d3c:

    # n "Maybe I am, if that means I get to enjoy what I do while you get to sulk and take cheap shots."
    n "Tal vez lo soy, si eso significa que disfruto lo que hago mientras que tú te enojas y das golpes bajos."

# game/Kyou 6.rpy:3752
translate spanish Day6_Con_Kyou_Nozomi_Trance_d859fbe2:

    # ks "But man, I never knew a girl like you could be into this kinda stuff."
    ks "Pero cielos, nunca pensé que a una chica como tú pudiera gustarle esta clase de cosas."

# game/Kyou 6.rpy:3753
translate spanish Day6_Con_Kyou_Nozomi_Trance_466fcb6a:

    # n front frown "... Why, Kyou? How many girls do you know?" with dissolve
    n front frown "... ¿Por qué, Kyou? ¿Cuántas chicas conoces?" with dissolve

# game/Kyou 6.rpy:3754
translate spanish Day6_Con_Kyou_Nozomi_Trance_1f4ab4d0:

    # ks "Uh..."
    ks "Eh..."

# game/Kyou 6.rpy:3756
translate spanish Day6_Con_Kyou_Nozomi_Trance_6bb559ed:

    # n "That's what I thought~" with dissolve
    n "Eso pensé." with dissolve

# game/Kyou 6.rpy:3757
translate spanish Day6_Con_Kyou_Nozomi_Trance_1eed8306:

    # n smirk "But do you know what I think?" with dissolve
    n smirk "¿Pero sabes lo que pienso?" with dissolve

# game/Kyou 6.rpy:3759
translate spanish Day6_Con_Kyou_Nozomi_Trance_51cef414:

    # "I'm... seeing a glint in her eye, as instead of picking up another box from the floor she reaches to the middle shelf of her display..."
    "Veo... un destello en su ojo cuando, en lugar de levantar otra caja del suelo, se acerca a la repisa del centro..."

# game/Kyou 6.rpy:3760
translate spanish Day6_Con_Kyou_Nozomi_Trance_ec83a0eb:

    # "... And pulls out a well-worn game box to put in front of me."
    "... Y saca una muy desgastada caja, la cual coloca frente a mí."

# game/Kyou 6.rpy:3761
translate spanish Day6_Con_Kyou_Nozomi_Trance_0bb2ddb4:

    # n happy "I think you need to experience my passion for yourself~" with dissolve
    n happy "Creo que necesitas experimentar mi pasión por ti mismo." with dissolve

# game/Kyou 6.rpy:3763
translate spanish Day6_Con_Kyou_Nozomi_Trance_3fa447e1:

    # "I eye the box in her hands. I think I've seen that game before; it's pretty popular if I recall."
    "Observo la caja que lleva en las manos. Creo que he visto ese juego antes; es muy popular, si no mal recuerdo."

# game/Kyou 6.rpy:3764
translate spanish Day6_Con_Kyou_Nozomi_Trance_f180e24e:

    # ks "Hmmm..."
    ks "Mmmm..."

# game/Kyou 6.rpy:3765
translate spanish Day6_Con_Kyou_Nozomi_Trance_40460a7d:

    # "I don't know if I'm all that keen, but it'd probably beat cleaning her room."
    "No sé si estoy tan interesado, pero no me molestaría dejar de limpiar."

# game/Kyou 6.rpy:3766
translate spanish Day6_Con_Kyou_Nozomi_Trance_320afdb2:

    # n smile "What do you think? I'll finish tidying this place and we can have a quick game." with dissolve
    n smile "¿Qué opinas? Terminaré de limpiar este lugar y tendremos un juego rápido." with dissolve

# game/Kyou 6.rpy:3767
translate spanish Day6_Con_Kyou_Nozomi_Trance_6c7e4db4:

    # "Yeah, I think I'm done with tidying up, or watching her do it."
    "Sí, creo que ya me cansé de limpiar, o de verla hacerlo."

# game/Kyou 6.rpy:3769
translate spanish Day6_Con_Kyou_Nozomi_Trance_08076f62:

    # "So I signal my intentions by waving my hand across her face again."
    "Por lo que muestro mis intenciones moviendo mi mano frente a su rostro una vez más."

# game/Kyou 6.rpy:3771
translate spanish Day6_Con_Kyou_Nozomi_Trance_0215783f:

    # "So I signal my intentions by quickly reaching over and poking her forehead again."
    "Por lo que muestro mis intenciones acercándome y tocando rápidamente su frente una vez más."

# game/Kyou 6.rpy:3774
translate spanish Day6_Con_Kyou_Nozomi_Trance_17ba4220:

    # "I don't know if Nozomi anticipated me doing it, but it's still pretty remarkable to watch her expression fall blank so quickly." with dissolve
    "No sé si Nozomi se esperaba que lo hiciera, pero es muy notable cómo su expresión se pone en blanco en un santiamén." with dissolve

# game/Kyou 6.rpy:3775
translate spanish Day6_Con_Kyou_Nozomi_Trance_ab18d7a3:

    # ks smile "You're done tidying. We'll play now."
    ks smile "Ya terminaste de limpiar. Vamos a jugar."

# game/Kyou 6.rpy:4020
translate spanish Day6_Con_Kyou_Nozomi_Trance_004a6c9b:

    # n "{size=16}I'm done tidying. We'll play now...{/size}"
    n "{size=16}Ya terminé de limpiar. Vamos a jugar...{/size}"

# game/Kyou 6.rpy:3779
translate spanish Day6_Con_Kyou_Nozomi_Trance_62e98d40:

    # n laugh "Actually, forget the tidying. Let's just play!" with dissolve
    n laugh "¿Sabes qué?, olvida la limpieza. ¡Hay que jugar!" with dissolve

# game/Kyou 6.rpy:3781
translate spanish Day6_Con_Kyou_Nozomi_Trance_a42a5b41:

    # "So we settle down on the floor, which is looking a lot more spacious now, and she gets straight to it."
    "Entonces nos acomodamos en el suelo, el cual ya se ve mucho más espacioso, y comenzamos de inmediato."

# game/Kyou 6.rpy:3782
translate spanish Day6_Con_Kyou_Nozomi_Trance_58f3988c:

    # "Nozomi explains the rules to me quickly as she sets things up..."
    "Nozomi me explica rápidamente las reglas y le prepara todo..."

# game/Kyou 6.rpy:3783
translate spanish Day6_Con_Kyou_Nozomi_Trance_6a903a1d:

    # "It looks easy enough to follow, without seeming like a game for little kids and their parents."
    "Parece bastante simple, sin parecer un juego para niños pequeños y sus padres."

# game/Kyou 6.rpy:3784
translate spanish Day6_Con_Kyou_Nozomi_Trance_9fb96573:

    # "This might actually turn out to be fun..."
    "Puede que sí sea divertido..."

# game/Kyou 6.rpy:4406
translate spanish Day6_Con_Kyou_Nozomi_Trance_ff9fccc4:

    # "Although nearly half an hour later I'm starting to rethink that." with dissolve
    "Aunque casi una hora después empiezo a reconsiderarlo." with dissolve

# game/Kyou 6.rpy:3790
translate spanish Day6_Con_Kyou_Nozomi_Trance_81a03369:

    # "As Nozomi giggles and steals a card from me, it's dawning on me that Nozomi is a lot more competitive than she led me to think."
    "La risa de Nozomi al robarme una carta me hace darme cuenta de que es mucho más competitiva de lo que pensé."

# game/Kyou 6.rpy:4035
translate spanish Day6_Con_Kyou_Nozomi_Trance_6ce265f7:

    # ks casual sigh "Goddamn, Nozo. What happened to seeing people's faces light up when a game gets going?"
    ks casual sigh "Demonios, Nozo. ¿Qué le pasó a lo de ver los rostros de la gente iluminarse cuando el juego se pone en marcha?"

# game/Kyou 6.rpy:3792
translate spanish Day6_Con_Kyou_Nozomi_Trance_048ffda7:

    # n side smile "Aww, you poor baby. Did you really think I'd go easy on you?" with dissolve
    n side smile "Ayy, pobre bebé. ¿Creíste que te lo pondría fácil?" with dissolve

# game/Kyou 6.rpy:4473
translate spanish Day6_Con_Kyou_Nozomi_Trance_cd2a0697:

    # n front laugh "Ahaha, that's no fun at all!" with dissolve
    n front laugh "Jajaja, así no tiene chiste!" with dissolve

# game/Kyou 6.rpy:3794
translate spanish Day6_Con_Kyou_Nozomi_Trance_1d5c951b:

    # "Although it's my first time playing this, it's clear there's a little strategy involved in playing well. It's not just down to the luck of the dice roll."
    "Aunque sea mi primera vez jugando esto, está claro que hay un poco de estrategia involucrada. No todo depende de la suerte y los dados."

# game/Kyou 6.rpy:3795
translate spanish Day6_Con_Kyou_Nozomi_Trance_4a9febae:

    # "Nozomi did give me a crash course to start, but her experience is clearly telling here. I'm getting pasted."
    "Nozomi me dio un curso intensivo para empezar, pero su experiencia habla por sí sola. Me está sobrepasando."

# game/Kyou 6.rpy:4480
translate spanish Day6_Con_Kyou_Nozomi_Trance_d3f2026b:

    # "She's built up her settlements in a prime position, and maybe taken advantage of my naivety a little bit." with dissolve
    "Hizo sus construcciones en una posición privilegiada, y puede que se haya aprovechado un poco de mi inosencia." with dissolve

# game/Kyou 6.rpy:3799
translate spanish Day6_Con_Kyou_Nozomi_Trance_bbe0edc8:

    # "Like, some of the resource trades she made with me are feeling like they were a lot more beneficial to her than to myself."
    "Por ejemplo, siento que algunos de los de los intercambios que hicimos fueron mucho más beneficiosos para ella que para mí."

# game/Kyou 6.rpy:3801
translate spanish Day6_Con_Kyou_Nozomi_Trance_d5ce4e83:

    # "But she definitely IS lucky, too, as the seven she just rolled lets her move the bandit back over to my territory..."
    "Y para colmo SÍ tiene suerte, pues el siete que acaba de salirle en los dados le permite mover al bandido de regreso a mi territorio..."

# game/Kyou 6.rpy:3802
translate spanish Day6_Con_Kyou_Nozomi_Trance_76d09455:

    # "... Right when the card she just picked randomly from me is most certainly one she'd need to upgrade another of her settlements."
    "... Y tengo la certeza de que la carta que me quitó al azar es justo la que necesitaba para mejorar otra de sus contrucciones."

# game/Kyou 6.rpy:3803
translate spanish Day6_Con_Kyou_Nozomi_Trance_dc348dcb:

    # n side smile "I think at a time like this, it's important to remember it's more about having fun than winning, Kyou~" with dissolve
    n side smile "Creo que en momentos como este es importante recordar que es más importante divertirse que ganar." with dissolve

# game/Kyou 6.rpy:3804
translate spanish Day6_Con_Kyou_Nozomi_Trance_57a3cff1:

    # ks sigh "Yeah, say that again when you're not winning so hard. Ugh."
    ks sigh "Sí, dilo otra vez cuando no estés ganando por tanto. Ay."

# game/Kyou 6.rpy:3805
translate spanish Day6_Con_Kyou_Nozomi_Trance_f2d55d1d:

    # "She's gotten seven points by my reckoning, to my four. Although I bet she's hiding another point in her hand of advancement cards, so..."
    "Tiene siete puntos, según mis cálculos, contra cuatro míos. Aunque creo que oculta otro punto en su mano de cartas de progreso, así que..."

# game/Kyou 6.rpy:3806
translate spanish Day6_Con_Kyou_Nozomi_Trance_04062e27:

    # "A couple of lucky dice rolls is probably all she needs to get two more points and win this."
    "Unos cuantos tiros son posiblemente lo único que necesita para obtener dos puntos más y ganar."

# game/Kyou 6.rpy:3807
translate spanish Day6_Con_Kyou_Nozomi_Trance_86a8839d:

    # n front teasing "Stop stalling and roll. This'll be over soon enough." with dissolve
    n front teasing "Deja de buscar evasivas y tira. Esto acabará pronto." with dissolve

# game/Kyou 6.rpy:3809
translate spanish Day6_Con_Kyou_Nozomi_Trance_f42be086:

    # "So I take the dice and roll for my turn..."
    "Pues tomo los dados y comienzo mi turno..."

# game/Kyou 6.rpy:3811
translate spanish Day6_Con_Kyou_Nozomi_Trance_fd7928a2:

    # "It's a five. That's no good to me, but it lets Nozomi pick up an ore card from the pile, to go with the wheat she just stole from me." with dissolve
    "Un cinco. Eso no me viene bien, pero a Nozomi le permite tomar una carta de piedra de mi mano, además del trigo que ya me había robado." with dissolve

# game/Kyou 6.rpy:3812
translate spanish Day6_Con_Kyou_Nozomi_Trance_6444c3e0:

    # ks frown "Sooo... you host a lot of board game nights, right? Are they all like this?"
    ks frown "Entonceees… tú organizas muchas noches de juegos, ¿verdad? ¿Todas son así?"

# game/Kyou 6.rpy:3814
translate spanish Day6_Con_Kyou_Nozomi_Trance_88d6c84c:

    # "Nozomi perks an eyebrow as she adds the card to her deck." with dissolve
    "Nozomi alza una ceja añadiendo la carta a su baraja." with dissolve

# game/Kyou 6.rpy:3815
translate spanish Day6_Con_Kyou_Nozomi_Trance_6b3250d7:

    # n "I'm surprised you know about those."
    n "Me sorprende que sepas de ellas."

# game/Kyou 6.rpy:3816
translate spanish Day6_Con_Kyou_Nozomi_Trance_63edbe79:

    # "I only know because I overhear her talking about them at lunch sometimes... Maybe I shouldn't tell her that."
    "Solo lo sé porque a veces la espío hablando de ellas durante el almuerzo... Tal vez no debí decirle eso."

# game/Kyou 6.rpy:3817
translate spanish Day6_Con_Kyou_Nozomi_Trance_a85bdc33:

    # ks smile "Oh, well... I figure you're not playing all these games by yourself, right?"
    ks smile "Oh, pues... me imagino que no juegas todo esto sola, ¿verdad? "

# game/Kyou 6.rpy:3818
translate spanish Day6_Con_Kyou_Nozomi_Trance_f09b9670:

    # n side smile_side "That's true. And as a matter of fact I hosted last weekend." with dissolve
    n side smile_side "Es cierto. Y, de hecho, organicé uno el pasado fin de semana." with dissolve

# game/Kyou 6.rpy:3820
translate spanish Day6_Con_Kyou_Nozomi_Trance_c670bf16:

    # "As it's clear I can't do anything on my turn, Nozomi takes the dice and scatters them between us..."
    "Estando claro que no puedo hacer nada en mi turno, Nozomi toma los dados y los arroja entre nosotros..."

# game/Kyou 6.rpy:3822
translate spanish Day6_Con_Kyou_Nozomi_Trance_355a035c:

    # "It's a six this time. Fuck, again?" with dissolve
    "Esta vez es un seis. Mierda, ¿otra vez?" with dissolve

# game/Kyou 6.rpy:3823
translate spanish Day6_Con_Kyou_Nozomi_Trance_6b826dda:

    # n "Ehehe, this'll be over sooner than I thought~"
    n "Jejeje, esto acabará más pronto de lo que pensé."

# game/Kyou 6.rpy:3826
translate spanish Day6_Con_Kyou_Nozomi_Trance_016d3719:

    # "As Nozomi gleefully reaches for the resource cards she just won, I frustratedly wave my hand over her eyes again."
    "En lo que Nozomi estira alegremente el brazo para tomar la carta de recurso que se acaba de ganar, frustrado, vuelvo a mover mi mano frente a sus ojos."

# game/Kyou 6.rpy:3828
translate spanish Day6_Con_Kyou_Nozomi_Trance_b077db0d:

    # "As Nozomi gleefully reaches for the resource cards she just won, I frustratedly reach out and press on her forehead."
    "En lo que Nozomi estira alegremente el brazo para tomar la carta de recurso que se acaba de ganar, frustrado, vuelvo tocar su frente."

# game/Kyou 6.rpy:3830
translate spanish Day6_Con_Kyou_Nozomi_Trance_0080ef54:

    # ks frown "You rolled a four." with dissolve
    ks frown "Te salió un cuatro." with dissolve

# game/Kyou 6.rpy:4462
translate spanish Day6_Con_Kyou_Nozomi_Trance_0ac8d4b7:

    # n "{size=16}I rolled a four...{/size}" with dissolve
    n "{size=16}Me salió un cuatro...{/size}" with dissolve

# game/Kyou 6.rpy:3835
translate spanish Day6_Con_Kyou_Nozomi_Trance_a533acd8:

    # "Just then, Nozomi's outstretched hand freezes as her cheeks flush with embarrassment." with dissolve
    "Y entonces, la mano extendida de Noozmi se congela y sus mejillas se ruborizan de la pena." with dissolve

# game/Kyou 6.rpy:3836
translate spanish Day6_Con_Kyou_Nozomi_Trance_b4872529:

    # n "W-wait, what am I doing?"
    n "E-espera, ¿qué estoy haciendo?"

# game/Kyou 6.rpy:3837
translate spanish Day6_Con_Kyou_Nozomi_Trance_def5507d:

    # ks smirk "Giving me my cards?"
    ks smirk "¿Me estás dando mis cartas?"

# game/Kyou 6.rpy:3839
translate spanish Day6_Con_Kyou_Nozomi_Trance_cedc442c:

    # "Nozomi awkwardly clears her throat and flicks a couple lumber cards my way, since she totally rolled a four after all..." with dissolve
    "Nozomi se aclara avergonzada la garganta y desliza un par de cartas de madera hacia mí, porque por supuesto que le salió un cuatro." with dissolve

# game/Kyou 6.rpy:3841
translate spanish Day6_Con_Kyou_Nozomi_Trance_d51af507:

    # ks "I didn't think that number was still giving you trouble, Nozo."
    ks "Creí que ese número ya no te daba problemas, Nozo."

# game/Kyou 6.rpy:3842
translate spanish Day6_Con_Kyou_Nozomi_Trance_59ff9b25:

    # n irritated "Hah..." with dissolve
    n irritated "Ja..." with dissolve

# game/Kyou 6.rpy:3843
translate spanish Day6_Con_Kyou_Nozomi_Trance_66215895:

    # n smile noblush "But yes, you're right. I have people over every other week for a game or two." with dissolve
    n smile noblush "Pero sí, tienes razón. Invito a gente una que otra semana para un juego o dos." with dissolve

# game/Kyou 6.rpy:3844
translate spanish Day6_Con_Kyou_Nozomi_Trance_f921fe01:

    # ks smile "Do you get a lot of people at these things?"
    ks smile "¿Traes a mucha gente a estas cosas?"

# game/Kyou 6.rpy:3845
translate spanish Day6_Con_Kyou_Nozomi_Trance_000e7141:

    # n side smile_side "Hmm... I don't know about \"a lot\". It's usually me and a few girls from the literature club." with dissolve
    n side smile_side "Mmm... no sé si \"mucha\". Por lo general somos unas cuantas chicas del club de literatura y yo." with dissolve

# game/Kyou 6.rpy:4546
translate spanish Day6_Con_Kyou_Nozomi_Trance_3089c0f4:

    # ks confused "Just the literature club? I thought, er..."
    ks confused "¿Solo del club de literatura? Creí que, em..."

# game/Kyou 6.rpy:3847
translate spanish Day6_Con_Kyou_Nozomi_Trance_b871be16:

    # n front neutral "You thought Hiroko and Sayori would be part of this? I wish." with dissolve
    n front neutral "¿Creíste que Hiroko y Sayori serían parte de esto? Ojalá." with dissolve

# game/Kyou 6.rpy:3848
translate spanish Day6_Con_Kyou_Nozomi_Trance_6d19d0b3:

    # "Nozomi shrugs, then hands me the dice for my turn."
    "Nozomi se encoje de hombros, luego me entrega los dados para jugar mi turno."

# game/Kyou 6.rpy:3849
translate spanish Day6_Con_Kyou_Nozomi_Trance_559b44fc:

    # n pout "Sayori's always too busy, and I know this isn't Hiroko's kind of thing." with dissolve
    n pout "Sayori siempre está ocupada, y sé que estas cosas no son el estilo de Hiroko." with dissolve

# game/Kyou 6.rpy:3850
translate spanish Day6_Con_Kyou_Nozomi_Trance_9c043875:

    # ks neutral "Huh."
    ks neutral "Vaya."

# game/Kyou 6.rpy:3851
translate spanish Day6_Con_Kyou_Nozomi_Trance_f0742d4e:

    # n neutral "Does that surprise you?" with dissolve
    n neutral "¿Te sorpende?" with dissolve

# game/Kyou 6.rpy:3852
translate spanish Day6_Con_Kyou_Nozomi_Trance_f74118d2:

    # ks "Well, I mean... they're always hanging around you so I thought..."
    ks "Pues, bueno... siempre están a tu alrededor, así que pensé..."

# game/Kyou 6.rpy:3853
translate spanish Day6_Con_Kyou_Nozomi_Trance_e9258f16:

    # n surprised "Hanging around me?" with dissolve
    n surprised "¿A mi alrededor?" with dissolve

# game/Kyou 6.rpy:3854
translate spanish Day6_Con_Kyou_Nozomi_Trance_3ad1351a:

    # n side sad_side "Well, that's one way of looking at it, I suppose." with dissolve
    n side sad_side "Pues, es una forma de verlo, supongo." with dissolve

# game/Kyou 6.rpy:4090
translate spanish Day6_Con_Kyou_Nozomi_Trance_d5e40759:

    # n sad "You don't think I might be the one hanging around them?" with dissolve
    n sad "¿No crees que tal vez yo sea la que está a su alrededor?" with dissolve

# game/Kyou 6.rpy:4562
translate spanish Day6_Con_Kyou_Nozomi_Trance_7b213521:

    # ks confused "Huh, what do you mean?"
    ks confused "Eh, ¿a qué te refieres?"

# game/Kyou 6.rpy:3857
translate spanish Day6_Con_Kyou_Nozomi_Trance_2d2fe6e8:

    # n "It's just..."
    n "Es que..."

# game/Kyou 6.rpy:3858
translate spanish Day6_Con_Kyou_Nozomi_Trance_8b34f39a:

    # "There's a silence as I wait for her to finish that thought, but it never comes."
    "Hay un silencio en lo espero a que termine de pensar, pero nada sale."

# game/Kyou 6.rpy:3859
translate spanish Day6_Con_Kyou_Nozomi_Trance_5b1ba954:

    # "Instead she looks at my clenched hand and frowns."
    "En vez de eso mira mi mano cerrada y frunce el ceño."

# game/Kyou 6.rpy:3860
translate spanish Day6_Con_Kyou_Nozomi_Trance_43b83c4a:

    # n front frown "You've had those dice in your hands a while, Kyou." with dissolve
    n front frown "Ya llevas un rato con los dados en las manos, Kyou." with dissolve

# game/Kyou 6.rpy:3861
translate spanish Day6_Con_Kyou_Nozomi_Trance_fdfa71b1:

    # ks "Uh... oh, yeah."
    ks "Eh... ah, sí."

# game/Kyou 6.rpy:3863
translate spanish Day6_Con_Kyou_Nozomi_Trance_eaeac709:

    # "Weird. And as I rattle the dice in my hand I try to think of something else to talk about."
    "Qué extraño. Sacudiendo los dados en mi mano, intento pensar en algo más de lo que hablar."

# game/Kyou 6.rpy:3864
translate spanish Day6_Con_Kyou_Nozomi_Trance_6e08fb92:

    # "If she won't say anything about her friends, then..."
    "Si no dirá nada de sus amigas, entonces..."

# game/Kyou 6.rpy:3865
translate spanish Day6_Con_Kyou_Nozomi_Trance_1bba6926:

    # "... What was her mom telling me earlier?"
    "... ¿Qué fue lo que me dijo su mamá hace rato?"

# game/Kyou 6.rpy:3866
translate spanish Day6_Con_Kyou_Nozomi_Trance_d4a2cec9:

    # "\"It's about time Nozomi invited a boy over.\""
    "\"Ya era hora de que Nozomi trajera a un chico a la casa.\""

# game/Kyou 6.rpy:3867
translate spanish Day6_Con_Kyou_Nozomi_Trance_eb52faa9:

    # ks smile "So anyway, your board game nights... Is it like a girls only thing?"
    ks smile "Y dime, tus noches de juegos… ¿son cosa de chicas solamente?"

# game/Kyou 6.rpy:3868
translate spanish Day6_Con_Kyou_Nozomi_Trance_ab008abd:

    # n surprised "Huh? Oh..." with dissolve
    n surprised "¿Eh? Oh..." with dissolve

# game/Kyou 6.rpy:3870
translate spanish Day6_Con_Kyou_Nozomi_Trance_91e9ea11:

    # "Nozomi chuckles." with dissolve
    "Nozomi se ríe." with dissolve

# game/Kyou 6.rpy:4579
translate spanish Day6_Con_Kyou_Nozomi_Trance_73759421:

    # n "I hadn't meant for it to be, but almost everyone at literature club is a girl, so that's how it worked out."
    n "No era mi intención que lo fuera, pero en el club de literatura casi solo hay chicas, así que así terminó siendo."

# game/Kyou 6.rpy:3872
translate spanish Day6_Con_Kyou_Nozomi_Trance_21e1a0ac:

    # n teasing "Why? Don't tell me you're thinking of coming along to one of these." with dissolve
    n teasing "¿Por qué? No me digas que estás pensando en asistir a una." with dissolve

# game/Kyou 6.rpy:3873
translate spanish Day6_Con_Kyou_Nozomi_Trance_6da85613:

    # ks frown "Wh- what would you say if I was?"
    ks frown "¿Qu- qué dirías si eso pensara?"

# game/Kyou 6.rpy:3874
translate spanish Day6_Con_Kyou_Nozomi_Trance_bee50beb:

    # n chuckle "I'd say you're full of it. Now roll the dice, please~" with dissolve
    n chuckle "Diría que estás mintiendo. Ahora tira los dados, por favor." with dissolve

# game/Kyou 6.rpy:3875
translate spanish Day6_Con_Kyou_Nozomi_Trance_0d5af498:

    # "I guess she's got me there. I can't look like I'm enjoying myself playing this little game with her."
    "Supongo que eso no lo puedo discutir. De seguro no parece que yo esté disfrutando este jueguito con ella."

# game/Kyou 6.rpy:3877
translate spanish Day6_Con_Kyou_Nozomi_Trance_bea8c486:

    # "But as I toss the dice to the floor again I think I might be coming around. I mean, maybe more for the company than the game itself."
    "Pero al volver lanzar los dados al suelo, pienso que podría adaptarme. Digo, tal vez más por la compañía que por el juego en sí."

# game/Kyou 6.rpy:3878
translate spanish Day6_Con_Kyou_Nozomi_Trance_1fe7fa33:

    # "... I guess I can see a little into why she plays these things, even as I pick up another sheep card from the deck."
    "... Supongo que más o menos puedo ver por qué juega estas cosas, por más que ahora esté sacando otra oveja del mazo."

# game/Kyou 6.rpy:3879
translate spanish Day6_Con_Kyou_Nozomi_Trance_0c3cd590:

    # ks "Man, I got a ton of these damn things."
    ks "Caray, ya tengo un montón de estas malditas cosas."

# game/Kyou 6.rpy:3880
translate spanish Day6_Con_Kyou_Nozomi_Trance_dfb527a4:

    # n happy "Ahahaha. At least your people will eat well~" with dissolve
    n happy "Jajajaja. Al menos tu gente comerá bien." with dissolve

# game/Kyou 6.rpy:3881
translate spanish Day6_Con_Kyou_Nozomi_Trance_03af257b:

    # "Nozomi grins, as she scoops the dice in her hands."
    "Nozomi sonríe tomando los dados en sus manos."

# game/Kyou 6.rpy:3882
translate spanish Day6_Con_Kyou_Nozomi_Trance_dd8733e0:

    # n side smile "You know, playing with you is making me think of how I nearly started a board game club in school. Back when we were first years." with dissolve
    n side smile "¿Sabes?, jugar contigo me hace pensar en cómo casi inicio un club de juegos de mesa en la escuela en primer año." with dissolve

# game/Kyou 6.rpy:3883
translate spanish Day6_Con_Kyou_Nozomi_Trance_c0254510:

    # ks smile "Yeah? Why didn't you?"
    ks smile "¿Ah, sí? ¿Por qué no lo hiciste?"

# game/Kyou 6.rpy:3884
translate spanish Day6_Con_Kyou_Nozomi_Trance_89152306:

    # "Nozomi shrugs as it's her turn to dwell on the dice."
    "Nozomi se encoje de hombros, siendo ahora su turno de tirar los dados."

# game/Kyou 6.rpy:3885
translate spanish Day6_Con_Kyou_Nozomi_Trance_f4e10591:

    # n frown_side "I was thinking of becoming a writer of some kind, so I figured I should tailor my after-school activities with that in mind." with dissolve
    n frown_side "Estaba pensando en convertirme en alguna clase de escritora, así que supuse que debía elegir mis actividades extracurriculares con eso en mente." with dissolve

# game/Kyou 6.rpy:3886
translate spanish Day6_Con_Kyou_Nozomi_Trance_dc2a3308:

    # n front sleep "So I joined the literature club and that was that." with dissolve
    n front sleep "Por lo que entré al club de literatura y el resto es historia." with dissolve

# game/Kyou 6.rpy:4601
translate spanish Day6_Con_Kyou_Nozomi_Trance_0aa50a68:

    # ks confused "Only thinking? Don't you write a lot?"
    ks confused "¿Solo pensando? ¿Qué no escribes mucho?"

# game/Kyou 6.rpy:3889
translate spanish Day6_Con_Kyou_Nozomi_Trance_987ae34e:

    # "Nozomi shrugs again as she lets the dice fall out of her hand and scatter on the floor."
    "Nozomi vuelve a encogerse de hombros dejando los dados caer de su mano y rodar por el suelo."

# game/Kyou 6.rpy:4540
translate spanish Day6_Con_Kyou_Nozomi_Trance_6685afb8:

    # n neutral "I write a bit."
    n neutral "Escribo un poco."

# game/Kyou 6.rpy:3891
translate spanish Day6_Con_Kyou_Nozomi_Trance_6b1308f6:

    # "She passes the dice back to me as she talks, their faces having amounted to eight."
    "Vuelve a pasarme los dados mientras habla, habiendo sus caras sumado ocho."

# game/Kyou 6.rpy:3892
translate spanish Day6_Con_Kyou_Nozomi_Trance_9c0b9a47:

    # "With the bandit still camped on the number eight spot, there's nothing to do this turn."
    "Con el bandido aún acampando en la casilla número ocho, no hay nada que hacer en este turno."

# game/Kyou 6.rpy:4608
translate spanish Day6_Con_Kyou_Nozomi_Trance_cec93ccb:

    # n side sad_side "I just do short stories when I feel like it. I don't know if I can progress that into a career somehow..." with dissolve
    n side sad_side "Solo hago pequeñas historias cuando me entran ganas. No sé si puedo hacer una carrera de eso..." with dissolve

# game/Kyou 6.rpy:3894
translate spanish Day6_Con_Kyou_Nozomi_Trance_60c99ae2:

    # n sad "I'm not really sure what I'll do when I graduate, actually." with dissolve
    n sad "De hecho no estoy muy segura de qué haré cuando me gredúe." with dissolve

# game/Kyou 6.rpy:3895
translate spanish Day6_Con_Kyou_Nozomi_Trance_6a6d3b88:

    # ks surprised "You're not? But we've got our entrance exams coming up."
    ks surprised "¿No lo estás? Pero nuestros exámenes de admisión son dentro de nada."

# game/Kyou 6.rpy:3896
translate spanish Day6_Con_Kyou_Nozomi_Trance_16a24f60:

    # ks "We're... we're graduating in a few months and you really don't know?"
    ks "¿Nos... nos graduaremos en unos cuantos meses y en serio no lo sabes?"

# game/Kyou 6.rpy:3897
translate spanish Day6_Con_Kyou_Nozomi_Trance_9b737792:

    # n front angry "You don't think I know that?" with dissolve
    n front angry "¿Crees que no estoy consciente?" with dissolve

# game/Kyou 6.rpy:3898
translate spanish Day6_Con_Kyou_Nozomi_Trance_bcf0b660:

    # "... Did I actually strike a nerve that time? Over this?"
    "... ¿Toqué una fibra sensible con esto?"

# game/Kyou 6.rpy:3900
translate spanish Day6_Con_Kyou_Nozomi_Trance_45404b84:

    # "Nozomi might have seemed annoyed with me today over this or that, but I think this is the first time she's seemed genuinely upset." with dissolve
    "A Nozomi pareció molestarle una que otra cosa que hice hoy, pero creo que esta es la primera vez que de verdad luce enojada." with dissolve

# game/Kyou 6.rpy:3902
translate spanish Day6_Con_Kyou_Nozomi_Trance_77ae7e8e:

    # n determined "And what about you? What are YOU doing when you get out of high school?" with dissolve
    n determined "¿Y qué hay de ti? ¿Qué harás TÚ cuando salgas de la preparatoria?" with dissolve

# game/Kyou 6.rpy:3903
translate spanish Day6_Con_Kyou_Nozomi_Trance_64128425:

    # ks "Uhh... w-well..."
    ks "Eeeh... p-pues..."

# game/Kyou 6.rpy:3904
translate spanish Day6_Con_Kyou_Nozomi_Trance_56f00c4d:

    # "Honestly, I don't know either, and knowing it from my expression seems to satisfy her."
    "Honestamente, yo tampoco lo sé, y leerlo en mi expresión parece satisfacerla."

# game/Kyou 6.rpy:3905
translate spanish Day6_Con_Kyou_Nozomi_Trance_cdd41cff:

    # n side smile_side "See? It's pretty normal isn't it?" with dissolve
    n side smile_side "¿Lo ves? Es bastante normal, ¿no?" with dissolve

# game/Kyou 6.rpy:3906
translate spanish Day6_Con_Kyou_Nozomi_Trance_f0117254:

    # n frown_side "As if we can just plot out our whole lives when we're still in our teens." with dissolve
    n frown_side "Como si pudiéramos trazar nuestras vidas enteras y ya siendo tan solo adolescentes." with dissolve

# game/Kyou 6.rpy:3907
translate spanish Day6_Con_Kyou_Nozomi_Trance_08deed81:

    # n front frown "It's a completely unfair expectation!" with dissolve
    n front frown "¡Es una expectativa completamente injusta!" with dissolve

# game/Kyou 6.rpy:3909
translate spanish Day6_Con_Kyou_Nozomi_Trance_37a68db3:

    # "I don't have anything to say to that, but it seems like she's just saying it out loud to reassure herself as I roll the dice."
    "No tengo nada que decir al respecto, pero parece que solo lo dice en voz alta para tranquilizarse en lo que tiro los dados."

# game/Kyou 6.rpy:3911
translate spanish Day6_Con_Kyou_Nozomi_Trance_d72ae65b:

    # "We share a chuckle as I follow her eight with one of my own." with dissolve
    "Compartimos una carcajada al ver que, justo después del suyo, yo obtengo otro ocho." with dissolve

# game/Kyou 6.rpy:3912
translate spanish Day6_Con_Kyou_Nozomi_Trance_37e52d0a:

    # n smirk "Well, at least it turns out we do have something else in common, huh." with dissolve
    n smirk "Bueno, al menos resulta que tenemos algo más en común, ¿eh?" with dissolve

# game/Kyou 6.rpy:3915
translate spanish Day6_Con_Kyou_Nozomi_Trance_224bd559:

    # "Nozomi then quickly throws the dice again, and gets to pick up an ore card." with dissolve
    "Nozomi rápidamente vuelve a arrojar los dados, y consigue otra carta piedra." with dissolve

# game/Kyou 6.rpy:3916
translate spanish Day6_Con_Kyou_Nozomi_Trance_f74ea510:

    # "... Wait, doesn't that mean she's almost gotten enough to upgrade her settlement? I need to stop her."
    "... Espera, ¿qué eso no significa que ya tiene suficiente para mejorar su construcción? Debo detenerla."

# game/Kyou 6.rpy:3917
translate spanish Day6_Con_Kyou_Nozomi_Trance_67f6d6a1:

    # ks frown "Uh, how about a trade, Nozomi?"
    ks frown "Eh, ¿qué tal un intercambio, Nozomi?"

# game/Kyou 6.rpy:3918
translate spanish Day6_Con_Kyou_Nozomi_Trance_cb965161:

    # n frown "If you're thinking of palming off your sheep on me, you can forget it." with dissolve
    n frown "Si piensas que puedes echarme encima todas tus ovejas, olvídalo." with dissolve

# game/Kyou 6.rpy:3919
translate spanish Day6_Con_Kyou_Nozomi_Trance_244594ba:

    # ks smirk "Aww, come on. They're the finest sheep in the land. And you can have one for the bargain price of... one ore?"
    ks smirk "Ayy, vamos. Son las ovejas más finas en toda esta tierra. Y puedes tener una por el módico precio de... ¿una piedra?"

# game/Kyou 6.rpy:3920
translate spanish Day6_Con_Kyou_Nozomi_Trance_6839f7a5:

    # n pout "Pfft, don't waste my time." with dissolve
    n pout "Pff, no me hagas perder mi tiempo." with dissolve

# game/Kyou 6.rpy:3922
translate spanish Day6_Con_Kyou_Nozomi_Trance_ebcd731b:

    # "She says that, but I'm feeling bullish as I quickly pass my hand in front of her nose."
    "Eso dice, pero me siento optimista y rápidamente paso mi mano frente a su nariz."

# game/Kyou 6.rpy:3924
translate spanish Day6_Con_Kyou_Nozomi_Trance_366ec30d:

    # "She says that, but I'm feeling bullish as I quickly reach across and press her forehead."
    "Eso dice, pero me siento optimista y rápidamente me inclino para presionar su frente."

# game/Kyou 6.rpy:3927
translate spanish Day6_Con_Kyou_Nozomi_Trance_3c1db5a6:

    # ks "You will agree to the deal." with dissolve
    ks "Aceptarás el trato." with dissolve

# game/Kyou 6.rpy:4596
translate spanish Day6_Con_Kyou_Nozomi_Trance_3dbbceba:

    # n "{size=16}I will agree to the deal...{/size}" with dissolve
    n "{size=16}Aceptaré el trato...{/size}" with dissolve

# game/Kyou 6.rpy:3932
translate spanish Day6_Con_Kyou_Nozomi_Trance_7c8dad29:

    # "Nozomi sighs as she takes her newly-acquired card between her fingers and offers it to me." with dissolve
    "Nozomi suspira tomando su nueva adquisición entre sus dedos y ofreciéndomela." with dissolve

# game/Kyou 6.rpy:3933
translate spanish Day6_Con_Kyou_Nozomi_Trance_34ccbc5e:

    # n pout "Oh, fine then. I suppose I can use one of those." with dissolve
    n pout "Oh, está bien. Supongo que me vendría bien una de esas." with dissolve

# game/Kyou 6.rpy:3934
translate spanish Day6_Con_Kyou_Nozomi_Trance_0cc8c45b:

    # "I grin as I pass her one of my useless sheep in return."
    "Sonrío dándole a cambio una de mis inútiles ovejas."

# game/Kyou 6.rpy:3935
translate spanish Day6_Con_Kyou_Nozomi_Trance_53d001de:

    # n laugh "Ehehehe..." with dissolve
    n laugh "Jejejeje..." with dissolve

# game/Kyou 6.rpy:3936
translate spanish Day6_Con_Kyou_Nozomi_Trance_707f773e:

    # ks frown "What's so funny?"
    ks frown "¿Qué es tan gracioso?"

# game/Kyou 6.rpy:3937
translate spanish Day6_Con_Kyou_Nozomi_Trance_09fadbbe:

    # "Nozomi's grin spreads as quickly as mine fades."
    "La sonrisa de Nozomi crece, mientras que la mía se desvanece rápidamente."

# game/Kyou 6.rpy:3938
translate spanish Day6_Con_Kyou_Nozomi_Trance_00fd8a0d:

    # n side smile "Well I mean, I was thinking to drag this game out a little bit, before I changed my mind just now." with dissolve
    n side smile "Pues, bueno, tenía pensado alargar el juego un poco más, pero cambié de opinión." with dissolve

# game/Kyou 6.rpy:3939
translate spanish Day6_Con_Kyou_Nozomi_Trance_6dffe5c4:

    # ks surprised "Huh?"
    ks surprised "¿Eh?"

# game/Kyou 6.rpy:3940
translate spanish Day6_Con_Kyou_Nozomi_Trance_87b2ba44:

    # n front smirk "Kyou, you really haven't been paying attention." with dissolve
    n front smirk "Kyou, en serio que no has estado prestando atención." with dissolve

# game/Kyou 6.rpy:4615
translate spanish Day6_Con_Kyou_Nozomi_Trance_e2beb38b:

    # "Nozomi chuckles as she lays down all of her resource cards to reveal a full set of items." with dissolve
    "Nozomi se ríe poniendo en el suelo todas sus cartas de recursos revelando juego completo de artículos." with dissolve

# game/Kyou 6.rpy:3942
translate spanish Day6_Con_Kyou_Nozomi_Trance_9a417252:

    # "The sheep was the only one she was missing until now."
    "La oveja era la única que le faltaba."

# game/Kyou 6.rpy:3943
translate spanish Day6_Con_Kyou_Nozomi_Trance_619508e8:

    # n happy "I was going to wait until I got one by myself, maybe give you a chance to put some points on the board..." with dissolve
    n happy "Iba a esperar a conseguir una por mi cuenta y tal vez darte una oportunidad de poner algunos puntos en el tablero..." with dissolve

# game/Kyou 6.rpy:3944
translate spanish Day6_Con_Kyou_Nozomi_Trance_39b4deea:

    # n laugh "But if you're just going to let me have one then I guess I'll build this here settlement~" with dissolve
    n laugh "Pero si vas a dármela, supongo que hare está construcción aquí." with dissolve

# game/Kyou 6.rpy:3945
translate spanish Day6_Con_Kyou_Nozomi_Trance_0513bd35:

    # ks frown "Ugh, come on!"
    ks frown "¡Ay, vamos!"

# game/Kyou 6.rpy:3946
translate spanish Day6_Con_Kyou_Nozomi_Trance_55a2a7e1:

    # "Nozomi giggles as she places another settlement on the board and puts all the cards in her hand away."
    "Nozomi se ríe colocando otra construcción en el tablero y deshaciéndose de todas las cartas de su mano."

# game/Kyou 6.rpy:3947
translate spanish Day6_Con_Kyou_Nozomi_Trance_3e507934:

    # ks "So is that it?"
    ks "Y ¿eso es todo?"

# game/Kyou 6.rpy:3949
translate spanish Day6_Con_Kyou_Nozomi_Trance_ee81743e:

    # "She smiles and wags a finger at me." with dissolve
    "Sonríe meneándome un dedo." with dissolve

# game/Kyou 6.rpy:3950
translate spanish Day6_Con_Kyou_Nozomi_Trance_7ff5c81b:

    # n "Almost~"
    n "Casi."

# game/Kyou 6.rpy:3951
translate spanish Day6_Con_Kyou_Nozomi_Trance_4dfa614b:

    # "It's as I suspected. She needs one more to win, and even my hypnotic cheating isn't stopping her."
    "Tal como lo sospeché. Necesita uno más para ganar, y ni mis trampas hipnóticas pueden detenerla."

# game/Kyou 6.rpy:3952
translate spanish Day6_Con_Kyou_Nozomi_Trance_3637a987:

    # "I'll need to step it up as I pick up the dice and..."
    "Tengo que acelerar el paso, tomar los da dos y..."

# game/Kyou 6.rpy:3954
translate spanish Day6_Con_Kyou_Nozomi_Trance_08e8b899:

    # n side sad_side "Huh?" with dissolve
    n side sad_side "¿Eh?" with dissolve

# game/Kyou 6.rpy:3955
translate spanish Day6_Con_Kyou_Nozomi_Trance_c8ff96c9:

    # nm "Nozomi? Kyou? Is it safe to come in?"
    nm "¿Nozomi? ¿Kyou? ¿Es seguro entrar?"

# game/Kyou 6.rpy:3956
translate spanish Day6_Con_Kyou_Nozomi_Trance_4bf96893:

    # "Nozomi scoffs at the door exasperatedly."
    "Nozomi se mofa exasperadamente mirando la puerta."

# game/Kyou 6.rpy:3957
translate spanish Day6_Con_Kyou_Nozomi_Trance_fca2e3dc:

    # n frown_side "O- of COURSE it's safe!" with dissolve
    n frown_side "¡P- por SUPUESTO que es seguro!" with dissolve

# game/Kyou 6.rpy:3963
translate spanish Day6_Con_Kyou_Nozomi_Trance_0ef0bb34:

    # "And with that the door swings open and Nozomi's mom is all smiles as she joins us inside."
    "Y con eso dicho, la puerta se abre y la mamá de Nozomi entra sonriendo."

# game/Kyou 6.rpy:3966
translate spanish Day6_Con_Kyou_Nozomi_Trance_d190f6d8:

    # nm laugh "Well you can't be too careful now~" with dissolve
    nm laugh "Bueno, nunca se es demasiado cuidadoso." with dissolve

# game/Kyou 6.rpy:3968
translate spanish Day6_Con_Kyou_Nozomi_Trance_f2dca7b3:

    # "Atsuko then looks over us, sat on the floor over this old game, and chuckles." with dissolve
    "Atsuko luego nos mira sentados en el suelo con este viejo juego y se ríe." with dissolve

# game/Kyou 6.rpy:3969
translate spanish Day6_Con_Kyou_Nozomi_Trance_7b83dd91:

    # "I have a feeling she's not really surprised to find us like this."
    "Algo me dice que no la sorprende vernos así."

# game/Kyou 6.rpy:3970
translate spanish Day6_Con_Kyou_Nozomi_Trance_6c3a99c7:

    # nm neutral_side "Anyway, I was about to do a little grocery shopping. Did you two want anything?" with dissolve
    nm neutral_side "Como sea, estaba por ir de compras. ¿Quieren algo?" with dissolve

# game/Kyou 6.rpy:3971
translate spanish Day6_Con_Kyou_Nozomi_Trance_7f05e1df:

    # n smile_side "Thanks, mom, but I'm good." with dissolve
    n smile_side "Gracias, mamá, pero así estoy bien." with dissolve

# game/Kyou 6.rpy:4652
translate spanish Day6_Con_Kyou_Nozomi_Trance_ad0cd71e:

    # ks casual smile "Uh, yeah, I'm fine too."
    ks casual smile "Eh, sí, yo también estoy bien."

# game/Kyou 6.rpy:3973
translate spanish Day6_Con_Kyou_Nozomi_Trance_13ace36f:

    # nm laugh "Suit yourselves~ Now behave while I'm gone, you two." with dissolve
    nm laugh "Como gusten. Ahora, pórtense bien mientras no estoy." with dissolve

# game/Kyou 6.rpy:3977
translate spanish Day6_Con_Kyou_Nozomi_Trance_00a373db:

    # "And with that Atsuko leaves us be, and Nozomi sighs after her." with dissolve
    "Y con eso, Atsuko se retira, y Nozomi suelta un suspiro." with dissolve

# game/Kyou 6.rpy:3978
translate spanish Day6_Con_Kyou_Nozomi_Trance_66674c7b:

    # n "I was afraid she'd be like this."
    n "Me temía que se pusiera así."

# game/Kyou 6.rpy:4724
translate spanish Day6_Con_Kyou_Nozomi_Trance_c1dbe8a9:

    # ks casual confused "... Is she normally like this?"
    ks casual confused "... ¿Suele actuar de ese modo?"

# game/Kyou 6.rpy:3980
translate spanish Day6_Con_Kyou_Nozomi_Trance_b3ef729b:

    # "Nozomi glances back at the door with irritation."
    "Nozomi vuelve a mirar la puerta irritada."

# game/Kyou 6.rpy:3981
translate spanish Day6_Con_Kyou_Nozomi_Trance_e4a2e5c9:

    # n annoyed_left "Not normally, but... mom was pretty excited when I said you'd be coming over." with dissolve
    n annoyed_left "Usualmente no, pero... mamá estaba muy emocionada cando dije que vendrías." with dissolve

# game/Kyou 6.rpy:3982
translate spanish Day6_Con_Kyou_Nozomi_Trance_72aa69bf:

    # n frown "I love her and all, but I really wish she'd step off about wanting to be a grandmother, you know?" with dissolve
    n frown "La quiero y todo, pero desearía que se calmara un poco con eso de querer ser abuela, ¿sabes?" with dissolve

# game/Kyou 6.rpy:3983
translate spanish Day6_Con_Kyou_Nozomi_Trance_8aa017eb:

    # ks frown "Right... yeah."
    ks frown "Claro... sí."

# game/Kyou 6.rpy:3984
translate spanish Day6_Con_Kyou_Nozomi_Trance_36d98e18:

    # n front irritated "Well, at least she'll be out of our hair for a while." with dissolve
    n front irritated "Bueno, al menos nos dejará en paz por un rato." with dissolve

# game/Kyou 6.rpy:3985
translate spanish Day6_Con_Kyou_Nozomi_Trance_fde5c481:

    # "I let out an awkward chuckle as I reach for the dice."
    "Dejo salir una risita incómoda mientras recojo los dados."

# game/Kyou 6.rpy:3986
translate spanish Day6_Con_Kyou_Nozomi_Trance_21911f8c:

    # ks smile "Well, at least she cares about you, right?"
    ks smile "Bueno, al menos se preocupa por ti, ¿cierto?"

# game/Kyou 6.rpy:3987
translate spanish Day6_Con_Kyou_Nozomi_Trance_65af85f5:

    # n side smile_side "Of course. I don't want to complain about her too much." with dissolve
    n side smile_side "Por supuesto. No me quiero quejar de ella demasiado." with dissolve

# game/Kyou 6.rpy:4737
translate spanish Day6_Con_Kyou_Nozomi_Trance_431f33b1:

    # n smile "My family's pretty great for the most part."
    n smile "Mi familia es bastante grandiosa en general."

# game/Kyou 6.rpy:3989
translate spanish Day6_Con_Kyou_Nozomi_Trance_201e2b87:

    # ks "Yeah... must be nice."
    ks "Sí... debe ser lindo."

# game/Kyou 6.rpy:3990
translate spanish Day6_Con_Kyou_Nozomi_Trance_dcb84ecd:

    # n sad "Oh... sorry." with dissolve
    n sad "Oh... lo siento." with dissolve

# game/Kyou 6.rpy:3992
translate spanish Day6_Con_Kyou_Nozomi_Trance_656f3ccc:

    # "I give her a shrug as I rattle the dice in my hand."
    "Me encojo de hombros sacudiendo los dados."

# game/Kyou 6.rpy:4624
translate spanish Day6_Con_Kyou_Nozomi_Trance_ff855202:

    # ks neutral "So what about the others? I haven't heard them around."
    ks neutral "¿Y qué hay de los demás? No he escuchado nada de ellos."

# game/Kyou 6.rpy:3994
translate spanish Day6_Con_Kyou_Nozomi_Trance_f10b3521:

    # n smile "Oh, dad's at work and my brother's out somewhere with his friends." with dissolve
    n smile "Oh, mi papá está en el trabajo y mi hermano salió a alguna parte con sus amigos." with dissolve

# game/Kyou 6.rpy:3995
translate spanish Day6_Con_Kyou_Nozomi_Trance_5685a7ae:

    # "Huh. So it's really just us in the house, then. At least for a little while."
    "Vaya. Conque tenemos la casa para nosotros solos. Al menos por un rato."

# game/Kyou 6.rpy:3997
translate spanish Day6_Con_Kyou_Nozomi_Trance_c88bf79f:

    # "That sets my mind racing a little as I let the dice out of my hand and watch as they clatter on the floor."
    "Eso me cause un poco de emoción mientras dejo los dados escapar de mi mano y los veo rodar por el suelo."

# game/Kyou 6.rpy:3998
translate spanish Day6_Con_Kyou_Nozomi_Trance_cd980c8e:

    # n surprised "Huh, a seven. We haven't had one of those in a while." with dissolve
    n surprised "Oh, un siete. Hace tiempo que no sale uno de esos." with dissolve

# game/Kyou 6.rpy:3999
translate spanish Day6_Con_Kyou_Nozomi_Trance_5cba3c42:

    # ks smile "Heh, yeah."
    ks smile "Je, sí."

# game/Kyou 6.rpy:4001
translate spanish Day6_Con_Kyou_Nozomi_Trance_1bff5fe9:

    # "That lets me finally move the bandit out of my territory and plant it smack dab into Nozomi's." with dissolve
    "Eso finalmente me permite sacar al bandido de mi territorio y plantarlo justo en el de Nozomi." with dissolve

# game/Kyou 6.rpy:4002
translate spanish Day6_Con_Kyou_Nozomi_Trance_80a8bc6f:

    # "We've been moving that guy back and forth between these two spots all game."
    "Hemos estado moviendo a ese tipo da acá para allá entre esos dos puntos todo el juego."

# game/Kyou 6.rpy:4003
translate spanish Day6_Con_Kyou_Nozomi_Trance_ac1f3b92:

    # ks "So you owe me a card."
    ks "Pues me debes una carta."

# game/Kyou 6.rpy:4004
translate spanish Day6_Con_Kyou_Nozomi_Trance_58f183c2:

    # n front teasing "Aw, too bad~ I used all of mine just now, remember?" with dissolve
    n front teasing "Oh, qué lástima. Acabo de gastármelas todas, ¿recuerdas?" with dissolve

# game/Kyou 6.rpy:4005
translate spanish Day6_Con_Kyou_Nozomi_Trance_51ce9ee9:

    # "I remember all too well, but as soon as I moved the bandit my mind continued to work."
    "Lo recuerdo muy bien, pero tan pronto como muevo al bandido, mi mente continúa trabajando."

# game/Kyou 6.rpy:4006
translate spanish Day6_Con_Kyou_Nozomi_Trance_0d65d2e5:

    # "And... well, after Nozomi told me more about what she's into, and the fact we're home alone..."
    "Y... bueno, ahora que Nozomi me contó más de sus intereses, y con el hecho de que estamos a solas..."

# game/Kyou 6.rpy:4007
translate spanish Day6_Con_Kyou_Nozomi_Trance_28c172b7:

    # "... I think it'd be okay to try something on her."
    "... Creo que estará bien intentar algo en ella."

# game/Kyou 6.rpy:4008
translate spanish Day6_Con_Kyou_Nozomi_Trance_94c30a2f:

    # "But if I'm going to do anything, it needs to be now."
    "Pero si voy a hacer algo, tiene que ser ahora."

# game/Kyou 6.rpy:4009
translate spanish Day6_Con_Kyou_Nozomi_Trance_963d4e2c:

    # ks frown "But... but Nozomi, you don't really think the bandit's going to leave empty-handed do you?"
    ks frown "Pero... pero Nozomi, no creerás de verdad que el bandido se irá con las manos vacías, ¿o sí?"

# game/Kyou 6.rpy:4010
translate spanish Day6_Con_Kyou_Nozomi_Trance_0c159bb9:

    # n neutral "What do you mean? There's nothing to steal." with dissolve
    n neutral "¿De qué hablas? No hay nada que robar." with dissolve

# game/Kyou 6.rpy:4011
translate spanish Day6_Con_Kyou_Nozomi_Trance_0693b5ed:

    # ks neutral "That's not true. But sure, you're out of all the good stuff, and I bet the bandit's pissed about that."
    ks neutral "Eso no es verdad. Pero no cabe duda de que sí se te acabaron las cosas buenas, y apuesto a que eso pone furioso al bandido."

# game/Kyou 6.rpy:4012
translate spanish Day6_Con_Kyou_Nozomi_Trance_7beffe09:

    # n pout "Well, that's too bad." with dissolve
    n pout "Pues, qué lástima." with dissolve

# game/Kyou 6.rpy:4014
translate spanish Day6_Con_Kyou_Nozomi_Trance_99eefe20:

    # ks smirk "I agree. It's too bad for YOU!"
    ks smirk "Concuerdo. ¡Qué lástima por TI!"

# game/Kyou 6.rpy:4015
translate spanish Day6_Con_Kyou_Nozomi_Trance_edcd64cb:

    # n frown "What are you talking about?" with dissolve
    n frown "¿De qué estás hablando?" with dissolve

# game/Kyou 6.rpy:4016
translate spanish Day6_Con_Kyou_Nozomi_Trance_127e542c:

    # "Okay, here we go."
    "Muy bien, aquí voy."

# game/Kyou 6.rpy:4018
translate spanish Day6_Con_Kyou_Nozomi_Trance_7657d859:

    # ks smile blush "S-so he's pissed that he came all this way for nothing, but he gets an idea."
    ks smile blush "P-pues está enojado por haber venido hasta aquí para nada, pero tiene una idea."

# game/Kyou 6.rpy:4019
translate spanish Day6_Con_Kyou_Nozomi_Trance_c78e5f6f:

    # ks "If he can't steal resources, then he'll steal people instead."
    ks "Si no puede robar recursos, en su lugar robará gente."

# game/Kyou 6.rpy:4020
translate spanish Day6_Con_Kyou_Nozomi_Trance_e5089006:

    # n irritated "Again... what are you talking about?" with dissolve
    n irritated "De nuevo... ¿de qué estás hablando?" with dissolve

# game/Kyou 6.rpy:4021
translate spanish Day6_Con_Kyou_Nozomi_Trance_623edc7c:

    # ks smirk "And... a-and who better to steal than the leader of the settlers?"
    ks smirk "¿Y… y qu-quién mejor para robar que la líder de los colonos?"

# game/Kyou 6.rpy:4022
translate spanish Day6_Con_Kyou_Nozomi_Trance_bb2cf764:

    # n "..."
    n "..."

# game/Kyou 6.rpy:4023
translate spanish Day6_Con_Kyou_Nozomi_Trance_30d06430:

    # n surprised "Huh?!" with dissolve
    n surprised "¡¿Eh?!" with dissolve

# game/Kyou 6.rpy:4024
translate spanish Day6_Con_Kyou_Nozomi_Trance_3fd53d5d:

    # "Her momentary confusion makes me a little less sure of myself, but it's too late to stop now."
    "Su momentánea confusión me hace estar un poco menos seguro de mí mismo, pero ya es muy tarde para detenerme."

# game/Kyou 6.rpy:4027
translate spanish Day6_Con_Kyou_Nozomi_Trance_70fefb15:

    # "And I think if I show her my penlight, it'd at least make my intentions a lot more clear."
    "Y creo que, si le muestro la linterna, por lo menos mis intenciones serán más claras."

# game/Kyou 6.rpy:4028
translate spanish Day6_Con_Kyou_Nozomi_Trance_93d0d5ba:

    # ks "Yeah, so he'd sneak into her encampment at night and kidnap her."
    ks "Sí, así que se escabullirá en su campamento por la noche y la secuestrará."

# game/Kyou 6.rpy:4029
translate spanish Day6_Con_Kyou_Nozomi_Trance_20c6d680:

    # ks "Probably tie her up real good before carting her off somewhere until he can get a ransom."
    ks "Probablemente la ate muy bien antes de llevársela en carreta a algún lado hasta que le paguen el rescate."

# game/Kyou 6.rpy:4032
translate spanish Day6_Con_Kyou_Nozomi_Trance_907eeac6:

    # "Nozomi starts to blush as she begins to realize where I'm going with this." with dissolve
    "Nozomi empieza a sonrojarse. Ya se está dando cuenta de adónde voy con esto." with dissolve

# game/Kyou 6.rpy:4033
translate spanish Day6_Con_Kyou_Nozomi_Trance_c7ca7b95:

    # n "He'd tie her up, huh?"
    n "Piensa atarla, ¿eh?"

# game/Kyou 6.rpy:4034
translate spanish Day6_Con_Kyou_Nozomi_Trance_f3a3cfe8:

    # ks "Can't have her getting away now, can he?"
    ks "No puede dejar que se escape, ¿o sí?"

# game/Kyou 6.rpy:4035
translate spanish Day6_Con_Kyou_Nozomi_Trance_f7b1fb9b:

    # n frown "W-well... it's not like she'd let herself get taken by any gruff highwayman, you know?" with dissolve
    n frown "P-pues... no se dejará atrapar por un brusco bandolero cualquiera, ¿sabes?" with dissolve

# game/Kyou 6.rpy:4036
translate spanish Day6_Con_Kyou_Nozomi_Trance_39929157:

    # n front frown "Any bandit who succeeds in kidnapping her would know to treat his captives with respect!" with dissolve
    n front frown "¡Cualquier bandido que logre secuestrarla debe saber tratar a sus cautivos con respeto!" with dissolve

# game/Kyou 6.rpy:4734
translate spanish Day6_Con_Kyou_Nozomi_Trance_5b92e143:

    # ks smile "O-of course! He'd know better than to hurt her in any way. It'd be strictly business with this guy." with dissolve
    ks smile "¡P-por supuesto! Sabría muy bien que no debe lastimarla. Será estrictamente por negocios." with dissolve

# game/Kyou 6.rpy:4038
translate spanish Day6_Con_Kyou_Nozomi_Trance_ab832194:

    # n concerned "Right... Y-yes, strictly business." with dissolve
    n concerned "Claro... S-sí, estrictamente por negocios." with dissolve

# game/Kyou 6.rpy:4039
translate spanish Day6_Con_Kyou_Nozomi_Trance_0f80ef67:

    # "We hold each other's gazes for a moment, as if daring each other to back out of what's being negotiated here..."
    "Nos miramos a los ojos por un momento, como si retáramos al otro a echarse para atrás con lo que se está negociando..."

# game/Kyou 6.rpy:4738
translate spanish Day6_Con_Kyou_Nozomi_Trance_84cec118:

    # "... Only for Nozomi to bite her lip anxiously as she comes to a decision."
    "... Pero entonces Nozomi se muerde el labio ansiosamente habiendo tomado una decisión."

# game/Kyou 6.rpy:4042
translate spanish Day6_Con_Kyou_Nozomi_Trance_a5618f4d:

    # n "W-well, he should hurry up and kidnap her, then. Before her soldiers have time to discover him."
    n "P-pues, debería darse prisa y secuestrarla. Antes de que sus soldados tengan tiempo de descubrirlo."

# game/Kyou 6.rpy:4043
translate spanish Day6_Con_Kyou_Nozomi_Trance_8313b809:

    # "Taking my cue, I hold my penlight aloft and switch it on with an audible click."
    "Siendo esa mi señal, sostengo mi linterna en lo alto y la enciendo con un audible clic."

# game/Kyou 6.rpy:4741
translate spanish Day6_Con_Kyou_Nozomi_Trance_507f451a:

    # "The noise alone is enough to trigger Nozomi's immediate attention as her eyes open and swivel upwards in anticipation."
    "El sonido por sí solo es suficiente para atrapar de inmediato la atención de Nozomi. Sus ojos se abren y se vuelven hacia arriba con anticipación."

# game/Kyou 6.rpy:4046
translate spanish Day6_Con_Kyou_Nozomi_Trance_a29e8d8c:

    # "And I'm only too happy to oblige her, as I start to sweep the familiar beam of light over her waiting eyes."
    "Y yo estoy muy feliz de complacerla deslizando el familiar haz de luz por sus impacientes ojos."

# game/Kyou 6.rpy:4049
translate spanish Day6_Con_Kyou_Nozomi_Trance_82f3fe61:

    # ks smile noblush "Yeah, he should. And while he's doing just that, you should be following the light right now."
    ks smile noblush "Sí, debería. Y mientras lo hace, tú deberías seguir la luz."

# game/Kyou 6.rpy:4750
translate spanish Day6_Con_Kyou_Nozomi_Trance_dd819693:

    # ks "Just following the light, Nozomi. Giving it all your focus for me. Letting yourself relax as you see those comforting patterns in your eyes again." with dissolve
    ks "Tan solo sigue la luz, Nozomi. Dale toda tu atención. Relájate mientras observas esos reconfortantes patrones nuevamente ante tus ojos." with dissolve

# game/Kyou 6.rpy:4054
translate spanish Day6_Con_Kyou_Nozomi_Trance_fd7bb638:

    # ks "That's right. It's very comforting and natural to stare into the light. You don't even have to think about it anymore." with dissolve
    ks "Eso es. Es muy reconfortante y natural observar la luz. Ya ni siquiera tienes que pensarlo." with dissolve

# game/Kyou 6.rpy:4056
translate spanish Day6_Con_Kyou_Nozomi_Trance_ae06a821:

    # ks "You just know instinctively how right this is."
    ks "Simplemente sabes instintivamente lo correcto que es."

# game/Kyou 6.rpy:4761
translate spanish Day6_Con_Kyou_Nozomi_Trance_e21ad371:

    # ks "So automatically finding your eyelids becoming heavy. So naturally feeling all the tension seep out of your relaxed body."
    ks "Tus párpados se ponen pesados automáticamente. Es tan natural sentir cómo toda la tensión se va de tu relajado cuerpo."

# game/Kyou 6.rpy:4062
translate spanish Day6_Con_Kyou_Nozomi_Trance_76d003e9:

    # "As I pass the light over her eyes again, I stop for a moment so I can shuffle up close to her before resuming."
    "Pasando una vez más la luz por sus ojos, me detengo un momento para poder acercarme antes de continuar."

# game/Kyou 6.rpy:4064
translate spanish Day6_Con_Kyou_Nozomi_Trance_bd302515:

    # ks "Now Nozomi, while you're so naturally relaxed and focused under the light, I just need to tell you something."
    ks "Y ahora, Nozomi, ya que estás tan naturalmente relajada y enfocada en la luz, solo necesito decirte una cosa."

# game/Kyou 6.rpy:4065
translate spanish Day6_Con_Kyou_Nozomi_Trance_60aea523:

    # "Yeah, so I ended up reading a lot about the kind of stuff Nozomi might be into."
    "Pues bien, terminé leyendo mucho acerca de la clase de cosas que podrían gustarle a Nozomi."

# game/Kyou 6.rpy:4066
translate spanish Day6_Con_Kyou_Nozomi_Trance_fed8a7c4:

    # "And one of the things that came up frequently was how it's important to make sure your partner trusts you."
    "Y algo que aparecía con mucha frecuencia es lo importante que es asegurarse de que tu compañero confíe en ti."

# game/Kyou 6.rpy:4068
translate spanish Day6_Con_Kyou_Nozomi_Trance_2af6f83c:

    # ks "Soon I'm going to be touching you in a few places."
    ks "Dentro de poco voy a tocarte en unos cuantos lugares."

# game/Kyou 6.rpy:4069
translate spanish Day6_Con_Kyou_Nozomi_Trance_3b2642af:

    # "I hasten to add:"
    "Me apresuro a añadir:"

# game/Kyou 6.rpy:4070
translate spanish Day6_Con_Kyou_Nozomi_Trance_65f991af:

    # ks surprised "N-nowhere bad, just so you know. Like, only your limbs and stuff."
    ks surprised "N-nada malo, para que los sepas. Solo extremidades y eso."

# game/Kyou 6.rpy:4072
translate spanish Day6_Con_Kyou_Nozomi_Trance_41a9c65f:

    # "I hope telling her my intentions didn't kill the mood as I sweep the light across her face again. Although she doesn't appear to be fussed."
    "Y esperando que mis intenciones no hayan matado el ambiente, deslizo nuevamente la luz por su rostro. Aunque no parece estar alarmada."

# game/Kyou 6.rpy:4073
translate spanish Day6_Con_Kyou_Nozomi_Trance_d5631c34:

    # ks neutral "Is... is that okay? Just nod if it is."
    ks neutral "¿Te... te parece bien? Asiente si te parece bien."

# game/Kyou 6.rpy:4074
translate spanish Day6_Con_Kyou_Nozomi_Trance_117e5a1d:

    # "Nozomi's quiet nod of her head is enough to calm my nerves, and I flash her eyes with the penlight again as if to reward her response."
    "El silencioso movimiento de la cabeza de Nozomi es suficiente para calmar mis nervios, e ilumino de nuevo sus ojos con la linterna como recompensándola."

# game/Kyou 6.rpy:4077
translate spanish Day6_Con_Kyou_Nozomi_Trance_0c066e8d:

    # ks smile "Good girl. Relaxing deeper. Letting yourself drop so deep for me."
    ks smile "Buena chica. Relájate más profundo. Déjate caer muy profundo."

# game/Kyou 6.rpy:4786
translate spanish Day6_Con_Kyou_Nozomi_Trance_3d246aa7:

    # ks "Dropping so deep, letting those drowsy, sleepy eyelids close as you know they should."
    ks "Tan profundo. Deja que esos adormecidos ojitos se cierren como deberían."

# game/Kyou 6.rpy:4789
translate spanish Day6_Con_Kyou_Nozomi_Trance_339b45e7:

    # ks "That's right, very good. Going deeper."
    ks "Eso es, muy bien. Ve más profundo."

# game/Kyou 6.rpy:4085
translate spanish Day6_Con_Kyou_Nozomi_Trance_6ae10289:

    # "And with that, I wrap an arm gently around her shoulders as I can feel my heart pound."
    "Y con eso, envuelvo sus hombros en mi brazo con gentileza y puedo sentir su corazón retumbar."

# game/Kyou 6.rpy:4086
translate spanish Day6_Con_Kyou_Nozomi_Trance_e4783aea:

    # "I may have held her yesterday, but when she fell into my arms back then it was so sudden. I had no time to think about it when it happened."
    "Puede que la haya sostenido ayer, pero cuando cayó en mis brazos entonces, fue tan repentino. No tuve tiempo de pensar en ello cuando pasó."

# game/Kyou 6.rpy:4087
translate spanish Day6_Con_Kyou_Nozomi_Trance_4306992c:

    # "This, I'm realizing, feels way more intimate."
    "Esto, me doy cuenta, se siente mucho más íntimo."

# game/Kyou 6.rpy:4796
translate spanish Day6_Con_Kyou_Nozomi_Trance_e858746a:

    # ks casual frown blush "Now sleep, Nozomi. Deep asleep."
    ks casual frown blush "Ahora duerme, Nozomi. Duerme profundamente."

# game/Kyou 6.rpy:4091
translate spanish Day6_Con_Kyou_Nozomi_Trance_787bf9e6:

    # "As I speak, I gently tug on Nozomi's shoulder, encouraging her to lean into me as I guide her to lay on the floor, setting her down on her side."
    "Mientras hablo, tiro gentilmente del hombro de Nozomi invitándola a apoyarse en mí y la guío para recostarla en el suelo, colocándola de costado."

# game/Kyou 6.rpy:4799
translate spanish Day6_Con_Kyou_Nozomi_Trance_56f34955:

    # ks casual frown blush "So deep asleep. So fully relaxed and so completely hypnotized."
    ks casual frown blush "Muy profundamente dormida. Totalmente relajada y completamente hipnotizada."

# game/Kyou 6.rpy:4095
translate spanish Day6_Con_Kyou_Nozomi_Trance_95031461:

    # "Oh man, I had a good feeling that she'd be game for this, and I've never been happier for her to prove me right."
    "Oh, cielos, tenía el presentimiento de que esto le agradaría, y nunca había estado tan feliz de que me diera la razón."

# game/Kyou 6.rpy:4096
translate spanish Day6_Con_Kyou_Nozomi_Trance_bb3b9ed9:

    # "So okay, I'll just take her hands, gently pull her arms behind her back and hold her wrists together like this..."
    "Muy bien, solo tengo que tomar sus manos con delicadeza, poner sus brazos detrás de su espalda y juntar sus muñecas así..."

# game/Kyou 6.rpy:4097
translate spanish Day6_Con_Kyou_Nozomi_Trance_9a8b11bf:

    # ks "And while you're this completely hypnotized, Nozomi, I want you to imagine how it must feel to be tied up in rope."
    ks "Y ahora que estás completamente hipnotizada, Nozomi, quiero que imagines cómo se debe sentir estar atada con una soga."

# game/Kyou 6.rpy:4098
translate spanish Day6_Con_Kyou_Nozomi_Trance_305480bb:

    # "I give her wrists a gentle squeeze as I continue."
    "Les doy a sus muñecas un leve apretón y continúo."

# game/Kyou 6.rpy:4099
translate spanish Day6_Con_Kyou_Nozomi_Trance_495d6e92:

    # ks "Feeling your wrists completely bound together like so."
    ks "Sentir tus muñecas completamente unidas."

# game/Kyou 6.rpy:4100
translate spanish Day6_Con_Kyou_Nozomi_Trance_d17c9766:

    # ks "You might try to pull your wrists apart when you wake, but the more you struggle to pull them, the more it feels that they're tied tightly together, unable to part."
    ks "Podrás intentar separar tus muñecas cuando estés despierta, pero entre más luchas por dividirlas, más apretadas se sienten, imposible separarlas."

# game/Kyou 6.rpy:4101
translate spanish Day6_Con_Kyou_Nozomi_Trance_38365a01:

    # ks "So of course, it doesn't matter when I let go of your wrists, Nozomi. Your hands and wrists will still stay together because of all that thick heavy rope."
    ks "Y, por supuesto, no importa cuándo suelte tus muñecas Nozomi. Tus manos y muñecas se quedarán unidas por esa gruesa cuerda."

# game/Kyou 6.rpy:4102
translate spanish Day6_Con_Kyou_Nozomi_Trance_a170c15a:

    # "I can feel her arms tense as I pull my hands away, and rather than fall limply apart, Nozomi keeps her wrists touching just as I told her."
    "Puedo sentir sus brazos tensarse mientras retiro mis manos, y en lugar de caer separadas, Nozomi mantiene sus muñecas en contacto tal como le dije."

# game/Kyou 6.rpy:4103
translate spanish Day6_Con_Kyou_Nozomi_Trance_302a6a79:

    # ks smile "That's... that's right, Nozomi. Your wrists and arms completely bound in rope now, and we're gonna do the same to your legs."
    ks smile "E-... eso es, Nozomi. Tus muñecas y brazos están completamente atados ahora, y haremos lo mismo con tus piernas."

# game/Kyou 6.rpy:4105
translate spanish Day6_Con_Kyou_Nozomi_Trance_984435eb:

    # "Holding her hands felt nice, but touching her legs is definitely giving me another feeling."
    "Sostener sus manos se sintió bien, pero tocar sus piernas definitivamente me causa otra sensación."

# game/Kyou 6.rpy:4106
translate spanish Day6_Con_Kyou_Nozomi_Trance_6aee3a2c:

    # "... Especially as I can't help but catch a glimpse under her skirt while I'm doing it."
    "... Sobre todo porque no puedo evitar echar un pequeño vistazo bajo su falda mientras lo hago."

# game/Kyou 6.rpy:4107
translate spanish Day6_Con_Kyou_Nozomi_Trance_5644e0d7:

    # "Fuck. Come on, I gotta behave myself."
    "Carajo. Vamos, tengo que comportarme."

# game/Kyou 6.rpy:4111
translate spanish Day6_Con_Kyou_Nozomi_Trance_6612becb:

    # "So after giving myself a moment, I manage to arrange her limp legs so that they're curled up comfortably for her, with her feet collected side by side."
    "Luego de tomarme un momento, logro juntar sus flojas piernas de modo que estén acurrucadas cómodamente, con sus pies puestos lado a lado."

# game/Kyou 6.rpy:4112
translate spanish Day6_Con_Kyou_Nozomi_Trance_343df7bc:

    # "Drawing a shuddered breath, I look her over once more before putting my hands over her bare ankles, wrapping my fingers around them both as I speak again."
    "Soltando aire estremecido, la observo una vez más antes de poner mis manos en sus tobillos desnudos, y continúo mi discurso con ambos envueltos entre mis dedos."

# game/Kyou 6.rpy:4113
translate spanish Day6_Con_Kyou_Nozomi_Trance_79edf6c6:

    # ks casual frown blush "S-so now Nozomi, I want you to imagine those same ropes coiled around your ankles like this."
    ks casual frown blush "Y a-ahora, Nozomi, quiero que imagines que esa misma cuerda está enrollada en tus tobillos así."

# game/Kyou 6.rpy:4114
translate spanish Day6_Con_Kyou_Nozomi_Trance_e6474da6:

    # "I give them a little squeeze for emphasis."
    "Les doy una pequeña sacudida como énfasis."

# game/Kyou 6.rpy:4115
translate spanish Day6_Con_Kyou_Nozomi_Trance_509695bc:

    # ks "Nice and tight. Completely bound together just like your wrists."
    ks "Muy bien apretada. Completamente unidos al igual que tus muñecas."

# game/Kyou 6.rpy:4116
translate spanish Day6_Con_Kyou_Nozomi_Trance_48fdffa8:

    # ks "And when you wake, you can struggle and pull all you like, but your legs and feet, so completely bound in this rope, cannot be parted."
    ks "Y cuando despiertes, podrás luchar y jalar todo lo que quieras, pero tus pies y piernas estarán completamente atados por esta soga; no se pueden separar."

# game/Kyou 6.rpy:4117
translate spanish Day6_Con_Kyou_Nozomi_Trance_6951ab87:

    # "I can once again feel the tension in her body. And I already know she's going to keep those legs together no matter what as I release them from my grasp."
    "Una vez más puedo sentir la tensión en su cuerpo. Y ya sé que mantendrá esas piernas unidas, sin importar qué, en cuanto las libere de mi agarre."

# game/Kyou 6.rpy:4118
translate spanish Day6_Con_Kyou_Nozomi_Trance_6169d782:

    # ks smile "Very... very good, Nozomi. Feeling so completely bound up in the rope now."
    ks smile "Muy... muy bien, Nozomi. Siente lo apretadas que están ahora por la cuerda."

# game/Kyou 6.rpy:4119
translate spanish Day6_Con_Kyou_Nozomi_Trance_4e5cabab:

    # ks "Feeling all that rope coiled around your body. The more you try to pull yourself free, the more the rope keeps you in place."
    ks "Siente esa cuerda enrollada por todo tu cuerpo. Entre más intentas liberarte, más inmóvil te mantiene la cuerda."

# game/Kyou 6.rpy:4120
translate spanish Day6_Con_Kyou_Nozomi_Trance_c2a71679:

    # "My heart's still pounding hard in my chest as I swallow dryly."
    "Mi corazón sigue retumbando en mi pecho y trago saliva."

# game/Kyou 6.rpy:4121
translate spanish Day6_Con_Kyou_Nozomi_Trance_12ef6505:

    # "The anticipation of watching her come out of trance and accept this reality, just as readily as she's accepted everything else I've given her..."
    "La anticipación de verla salir del trance y aceptar esta realidad, tan de buena gana como ha aceptado todo lo que le he dado..."

# game/Kyou 6.rpy:4122
translate spanish Day6_Con_Kyou_Nozomi_Trance_d3fbd6ff:

    # "I can hardly contain myself as I take a deep breath and begin the process of helping Nozomi wake."
    "Apenas me puedo contener. Respiro hondo y doy comienzo al proceso de ayudar a Nozomi a despertar."

# game/Kyou 6.rpy:4123
translate spanish Day6_Con_Kyou_Nozomi_Trance_cf99aa55:

    # ks "And very soon it'll be time for you to come back from this deep hypnotic trance and realize what has happened to you."
    ks "Y pronto será hora de que regreses de este profundo trance hipnótico y te des cuenta de lo que te pasó."

# game/Kyou 6.rpy:4124
translate spanish Day6_Con_Kyou_Nozomi_Trance_92b946b0:

    # ks "So I'm going to count up to five, Nozomi, and just like before you're going to become more and more awake and aware and refreshed."
    ks "Contaré hasta cinco, Nozomi, y al igual que antes, estarás poco a poco más despierta y consciente y fresca."

# game/Kyou 6.rpy:4125
translate spanish Day6_Con_Kyou_Nozomi_Trance_1a985515:

    # ks "Fully waking and accepting your reality on five. Do you understand?"
    ks "Despertarás por completo y aceptarás tu realidad cuando llegue a cinco. ¿Comprendes?"

# game/Kyou 6.rpy:4126
translate spanish Day6_Con_Kyou_Nozomi_Trance_d0d73830:

    # n "Y-Yes... I understand..."
    n "S-sí… comprendo..."

# game/Kyou 6.rpy:4127
translate spanish Day6_Con_Kyou_Nozomi_Trance_2bf5ea23:

    # ks "I knew you would, Nozomi. I'm counting up now..."
    ks "Sabía que comprenderías, Nozomi. Ahora empezaré a contar..."

# game/Kyou 6.rpy:4128
translate spanish Day6_Con_Kyou_Nozomi_Trance_9e00ad56:

    # ks "One, taking a deep breath, feeling those tight ropes all over your body."
    ks "Uno, respira profundo, sintiendo esa apretada soga por todo tu cuerpo."

# game/Kyou 6.rpy:4129
translate spanish Day6_Con_Kyou_Nozomi_Trance_2b78284f:

    # ks "That's it... two, still very relaxed as you gently find yourself stirring back to life."
    ks "Eso es... dos, aún muy relajada y poco a poco volviendo a la vida."

# game/Kyou 6.rpy:4130
translate spanish Day6_Con_Kyou_Nozomi_Trance_2723bd67:

    # ks "Three, taking another breath, becoming more and more aware, feeling your eyelids lighten."
    ks "Tres, respira hondo una vez más, estando más y más consciente, tus párpados cada vez más ligeros."

# game/Kyou 6.rpy:4131
translate spanish Day6_Con_Kyou_Nozomi_Trance_43894b31:

    # ks "Four, Letting those eyelids open up now, feeling so good. Feeling so right."
    ks "Cuatro, deja que tus ojos se abran, se siente tan bien. Se siente tan correcto."

# game/Kyou 6.rpy:4132
translate spanish Day6_Con_Kyou_Nozomi_Trance_62570c9c:

    # n "Mmmn..."
    n "Mmmn..."

# game/Kyou 6.rpy:4133
translate spanish Day6_Con_Kyou_Nozomi_Trance_a3f04c80:

    # "I smile as I watch her face, then finally let her have it."
    "Miro su rostro con una sonrisa, y finalmente…"

# game/Kyou 6.rpy:4134
translate spanish Day6_Con_Kyou_Nozomi_Trance_cdd4c8c9:

    # ks "And five, wide awake Nozomi!"
    ks "¡Y cinco, despierta, Nozomi!"

# game/Kyou 6.rpy:4136
translate spanish Day6_Con_Kyou_Nozomi_Trance_c28531c0:

    # n "Uhhh..."
    n "Eeeh..."

# game/Kyou 6.rpy:4138
translate spanish Day6_Con_Kyou_Nozomi_Trance_abfdbd44:

    # n "H-huh?!" with dissolve
    n "¡¿Eh?!" with dissolve

# game/Kyou 6.rpy:4139
translate spanish Day6_Con_Kyou_Nozomi_Trance_01260317:

    # "Even as I was expecting it, Nozomi's reaction still startles me when she comes to."
    "Aunque me la esperaba, la rección de Nozomi al volver en sí me pega un susto."

# game/Kyou 6.rpy:4142
translate spanish Day6_Con_Kyou_Nozomi_Trance_74f31181:

    # "She tenses and strains, but she keeps her limbs firmly joined to each other while she struggles on the floor." with dissolve
    "Se tensa y forcejea, pero mantiene sus extremidades firmemente unidas, luchando en el suelo." with dissolve

# game/Kyou 6.rpy:4143
translate spanish Day6_Con_Kyou_Nozomi_Trance_1cdea0c2:

    # ks smirk "W-well, what did you expect?"
    ks smirk "Y b-bien, ¿qué esperabas?"

# game/Kyou 6.rpy:4145
translate spanish Day6_Con_Kyou_Nozomi_Trance_33ae68e0:

    # n "Ahh, I don't know, I just... I-I-I didn't think you'd actually tie me up like this?!" with dissolve
    n "Aah, No sé, es que... ¡¿N-n-no pensé que me atarías de verdad?!" with dissolve

# game/Kyou 6.rpy:4146
translate spanish Day6_Con_Kyou_Nozomi_Trance_c7f91a3d:

    # "I shoot her a look, and I'm about to point out the obvious when I stop myself."
    "Le arrojo una mirada, y estoy a punto de señalar lo obvio, pero me detengo."

# game/Kyou 6.rpy:4147
translate spanish Day6_Con_Kyou_Nozomi_Trance_349a8dda:

    # "Like, of course. I'm sure Nozomi knows deep down the restraints she feels over her body aren't actually there..."
    "Digo, claro, estoy seguro de que Nozomi sabe en el fondo que las restricciones que siente en su cuerpo no están ahí de verdad..."

# game/Kyou 6.rpy:4149
translate spanish Day6_Con_Kyou_Nozomi_Trance_b7cfdfe3:

    # "But as far as her active imagination is concerned, those ropes in her mind are extremely, physically real." with dissolve
    "Pero en cuanto a su activa imaginación concierne, esas cuerdas que hay en su mente son extremada y físicamente reales." with dissolve

# game/Kyou 6.rpy:4150
translate spanish Day6_Con_Kyou_Nozomi_Trance_7e5f999d:

    # ks smirk "What do you mean? That's the bandit's handiwork."
    ks smirk "¿De qué hablas? Esto es obra del bandido."

# game/Kyou 6.rpy:4152
translate spanish Day6_Con_Kyou_Nozomi_Trance_56ab517c:

    # n "Agh..." with dissolve
    n "Ayy..." with dissolve

# game/Kyou 6.rpy:4153
translate spanish Day6_Con_Kyou_Nozomi_Trance_7c829230:

    # ks "Man, he did a number on you, huh?"
    ks "Caray, mira cómo te dejó"

# game/Kyou 6.rpy:4155
translate spanish Day6_Con_Kyou_Nozomi_Trance_ecaf7aa5:

    # n "S-s-so tight..." with dissolve
    n "C-c-cómo aprieta..." with dissolve

# game/Kyou 6.rpy:4156
translate spanish Day6_Con_Kyou_Nozomi_Trance_c6401575:

    # "I can't disguise from her how much I'm enjoying this."
    "No puedo ocultarle lo mucho que estoy disfrutando esto."

# game/Kyou 6.rpy:4372
translate spanish Day6_Con_Kyou_Nozomi_Trance_8565451f:

    # "Her valiant struggles against her imagined bondage look little more than cute flapping of her hands and feet as she shuffles about on the floor."
    "Su lucha contra sus cuerdas imaginarías parece poco más que un lindo aleteo de sus manos y con el que se arrastra por el suelo."

# game/Kyou 6.rpy:4158
translate spanish Day6_Con_Kyou_Nozomi_Trance_3b50ade1:

    # "And all the while her cheeks darken under my gaze as I stand over her."
    "Y por si fuera poco, sus mejillas se enrojecen bajo mi mirada."

# game/Kyou 6.rpy:4160
translate spanish Day6_Con_Kyou_Nozomi_Trance_e39d2dc4:

    # n "An- a-a-and you can stop looking at me like that, you pervert!" with dissolve
    n "¡¿Y-y-y p-puedes dejar de mirarme así, pervertido?!" with dissolve

# game/Kyou 6.rpy:4161
translate spanish Day6_Con_Kyou_Nozomi_Trance_9b2d25e4:

    # "She's fucking adorable like this."
    "Mierda. Estando así se ve tan adorable."

# game/Kyou 6.rpy:4162
translate spanish Day6_Con_Kyou_Nozomi_Trance_5e485156:

    # ks "I'm not here to look at you, Nozomi. You're in the hands of the bandit now and he's taking you away."
    ks "No vine a mirarte, Nozomi. Ahora estás en manos del bandido y te va a llevar consigo."

# game/Kyou 6.rpy:4164
translate spanish Day6_Con_Kyou_Nozomi_Trance_358856f7:

    # n "Ugh, come on Kyou, you've had your fun. Now untie me!" with dissolve
    n "Aj, vamos Kyou, ya te divertiste. ¡Ahora desátame!" with dissolve

# game/Kyou 6.rpy:4165
translate spanish Day6_Con_Kyou_Nozomi_Trance_51f681df:

    # ks "Not until the bandit figures out what to do with his captive."
    ks "No hasta que el bandido averigüe qué hacer con su cautiva."

# game/Kyou 6.rpy:4166
translate spanish Day6_Con_Kyou_Nozomi_Trance_3b49e123:

    # ks "I mean... he'll probably want to offload you quickly, since you're hot goods."
    ks "Es decir... probablemente quiera venderte rápido; eres un producto de primera."

# game/Kyou 6.rpy:4168
translate spanish Day6_Con_Kyou_Nozomi_Trance_5a5a2982:

    # n "Ugh, oh my GOD don't talk about me like that!" with dissolve
    n "¡Ay, por DIOS, no me hables así!" with dissolve

# game/Kyou 6.rpy:4169
translate spanish Day6_Con_Kyou_Nozomi_Trance_dd3dbc6d:

    # ks "So surely the only person he can think of who'd want you is... your settler rival!"
    ks "Apuesto a que única persona que se le viene a la mente que te podría quererte es... ¡tu colón rival!"

# game/Kyou 6.rpy:4171
translate spanish Day6_Con_Kyou_Nozomi_Trance_527177d7:

    # "Nozomi snorts in disgust, as she slumps back down on the floor for a breather." with dissolve
    "Nozomi resopla disgustada, volviendo a desplomarse en el suelo para tomarse un respiro." with dissolve

# game/Kyou 6.rpy:4172
translate spanish Day6_Con_Kyou_Nozomi_Trance_67295299:

    # "Clearly all that frantic struggling to free herself is taking its toll."
    "Está claro que todo ese forcejeo por liberarse está pasando factura."

# game/Kyou 6.rpy:4173
translate spanish Day6_Con_Kyou_Nozomi_Trance_a7f70400:

    # n "Haaah... d-don't be ridiculous."
    n "Haaah... n-no seas ridículo."

# game/Kyou 6.rpy:4174
translate spanish Day6_Con_Kyou_Nozomi_Trance_3416a4a8:

    # ks "It's the most logical thing for the bandit to do! So he takes you to me and we agree a price."
    ks "¡Es la opción más lógica para el bandido! Así que te trae ante mí y acoramos un precio."

# game/Kyou 6.rpy:4175
translate spanish Day6_Con_Kyou_Nozomi_Trance_9581af0e:

    # ks "And he sells you to me for the perfectly reasonable sum of..."
    ks "Y me permite comprarte por la perfectamente razonable suma de..."

# game/Kyou 6.rpy:4176
translate spanish Day6_Con_Kyou_Nozomi_Trance_5e1e97dc:

    # "I laugh as I pick up one of my resource cards and mischievously toss it towards her face."
    "Me río tomando una de mis cartas de recurso y la pongo maliciosamente frente a su rostro."

# game/Kyou 6.rpy:4177
translate spanish Day6_Con_Kyou_Nozomi_Trance_ee1d3e00:

    # ks "A single sheep!"
    ks "¡Una sola oveja!"

# game/Kyou 6.rpy:4179
translate spanish Day6_Con_Kyou_Nozomi_Trance_00d451a6:

    # n "O-OH MY GOD HOW DARE YOU!" with vpunch
    n "¡O-OH, POR DIOS, ¿CÓMO TE ATREVES?!" with vpunch

# game/Kyou 6.rpy:4180
translate spanish Day6_Con_Kyou_Nozomi_Trance_52f82676:

    # "Nozomi shrieks as she tenses back into life, but even with her renewed fury the ropes of her mind hold her in place as tightly as ever."
    "Nozomi chilla y vuelve a tensarse, pero aun con su furia renovada, las cuerdas de su mente la mantuvieron inmóvil con tanta fuerza como siempre."

# game/Kyou 6.rpy:4181
translate spanish Day6_Con_Kyou_Nozomi_Trance_03140b0f:

    # ks "And now that I have you, I think it's time you told your people to stand down and declare me the winner in our little settler war."
    ks "Y ahora que te tengo, creo que es tiempo de que le digas a tu gente que se retire y me declare el ganador de nuestra guerra de colonización."

# game/Kyou 6.rpy:4182
translate spanish Day6_Con_Kyou_Nozomi_Trance_982cce59:

    # "She glares up at me and growls in righteous indignation."
    "Me observa y gruñe con gran indignación."

# game/Kyou 6.rpy:4184
translate spanish Day6_Con_Kyou_Nozomi_Trance_b3f928bd:

    # n "Ugh, no way. You're not even close to beating me!" with dissolve
    n "Aj, para nada. ¡No estás ni cerca de vencerme!" with dissolve

# game/Kyou 6.rpy:4185
translate spanish Day6_Con_Kyou_Nozomi_Trance_e47196a6:

    # ks frown "Nozomi, you're in no position to negotiate with me, are you? You lost."
    ks frown "Nozomi, no estás en posición de negociar conmigo, ¿o sí? Perdiste."

# game/Kyou 6.rpy:4186
translate spanish Day6_Con_Kyou_Nozomi_Trance_c48f3780:

    # ks "You just need to admit it, then I'll let you go."
    ks "Solo tienes que admitirlo y te dejaré ir."

# game/Kyou 6.rpy:4188
translate spanish Day6_Con_Kyou_Nozomi_Trance_5206e1ef:

    # n "Never! I'm not losing a game to a filthy cheater!" with dissolve
    n "¡Nunca! ¡No pienso perder contra un sucio tramposo!" with dissolve

# game/Kyou 6.rpy:4189
translate spanish Day6_Con_Kyou_Nozomi_Trance_527b89bb:

    # "I don't say anything for a few moments as I consider my options."
    "Paso algunos momentos sin decir nada mientras considero mis opciones."

# game/Kyou 6.rpy:4190
translate spanish Day6_Con_Kyou_Nozomi_Trance_f25f9486:

    # "She's outraged, but is she really angry? Or scared?"
    "Está escandalizada, pero ¿de verdad estará molesta? ¿O asustada?"

# game/Kyou 6.rpy:4192
translate spanish Day6_Con_Kyou_Nozomi_Trance_41c3fd0e:

    # "Could I push things just a little further?" with dissolve
    "¿Podría llevar esto un poco más allá?" with dissolve

# game/Kyou 6.rpy:4193
translate spanish Day6_Con_Kyou_Nozomi_Trance_bbe9fcdf:

    # ks smirk "If you won't face facts, little lady, then I'm afraid we're gonna need to do something about that."
    ks smirk "Si no enfrentará los hechos, señorita, me temo que habrá que hacer algo al respecto."

# game/Kyou 6.rpy:4195
translate spanish Day6_Con_Kyou_Nozomi_Trance_119dc342:

    # n "Agh, w-what do you mean?" with dissolve
    n "Aj, ¿a qu-qué te refieres?" with dissolve

# game/Kyou 6.rpy:4196
translate spanish Day6_Con_Kyou_Nozomi_Trance_33b2b27d:

    # ks "I'm talking about... punishment. Until you're singing me a different tune."
    ks "Hablo de un... castigo. Hasta que me cantes en un tono diferente."

# game/Kyou 6.rpy:4197
translate spanish Day6_Con_Kyou_Nozomi_Trance_38ee788c:

    # n "WHAT?! NO!" with vpunch
    n "¡¿QUÉ?! ¡NO!" with vpunch

# game/Kyou 6.rpy:4198
translate spanish Day6_Con_Kyou_Nozomi_Trance_2c93e0a7:

    # ks "Then accept my victory."
    ks "Entonces acepta mi victoria."

# game/Kyou 6.rpy:4200
translate spanish Day6_Con_Kyou_Nozomi_Trance_f532a2fe:

    # n "I will {nw}"
    n "¡Yo {nw}"

# game/Kyou 6.rpy:4201
translate spanish Day6_Con_Kyou_Nozomi_Trance_601f42f5:

    # extend "NEVER accept this injustice!" with vpunch
    extend "JAMÁS aceptaré esta injusticia!" with vpunch

# game/Kyou 6.rpy:4202
translate spanish Day6_Con_Kyou_Nozomi_Trance_10036f34:

    # ks "Then you leave me no choice, Nozomi. I'm afraid you're gonna need to be..."
    ks "En ese caso, no me dejas opción, Nozomi. Me temo que tendré que..."

# game/Kyou 6.rpy:4205
translate spanish Day6_Con_Kyou_Nozomi_Trance_0911d305:

    # ks "Given a right and proper spanking, until you accept your defeat and admit I won fair and square."
    ks "Darte unas buenas nalgadas hasta que aceptes tu derrota y admitas que gané justamente."

# game/Kyou 6.rpy:4209
translate spanish Day6_Con_Kyou_Nozomi_Trance_bd5f29b4:

    # ks "Given a right and proper tickling, until you accept your defeat and admit I won fair and square."
    ks "Hacerte cosquillas hasta que aceptes tu derrota y admitas que gané justamente."

# game/Kyou 6.rpy:4212
translate spanish Day6_Con_Kyou_Nozomi_Trance_ce6eea90:

    # "Nozomi's struggles cease momentarily, and she lets out a panicked squeak as I announce my intentions." with dissolve
    "El forcejeo de Nozomi cesa momentáneamente, y suelta un chirrido de pánico en cuanto anuncio mis intenciones." with dissolve

# game/Kyou 6.rpy:4213
translate spanish Day6_Con_Kyou_Nozomi_Trance_97fa925d:

    # n "Y-y-you wouldn't DARE!"
    n "¡N-n-no te ATREVERÍAS!"

# game/Kyou 6.rpy:4214
translate spanish Day6_Con_Kyou_Nozomi_Trance_5218d487:

    # "Honestly, I'm surprising myself with all this, but her confession from last night is still ringing true in my head."
    "Honestamente hasta yo estoy sorprendido por esto, pero su confesión de anoche sigue resonando en mi cabeza."

# game/Kyou 6.rpy:4215
translate spanish Day6_Con_Kyou_Nozomi_Trance_52ebe856:

    # "She WANTS to be controlled. She WANTS me to have the upper hand."
    "Ella QUIERE ser controlada. Ella QUIERE que yo tenga la ventaja."

# game/Kyou 6.rpy:4216
translate spanish Day6_Con_Kyou_Nozomi_Trance_9e30b16f:

    # "Like, even now she's still holding herself rigidly to the boundaries I've set in her mind."
    "O sea, incluso ahora sigue rígidamente aferrada a la las cuerdas que puse en su mente."

# game/Kyou 6.rpy:4217
translate spanish Day6_Con_Kyou_Nozomi_Trance_b9bad567:

    # "She wouldn't allow that to happen if she was truly uncomfortable with this situation; I know that. But still..."
    "No permitiría que eso pasara si estuviera verdaderamente incómoda con esta situación; eso lo sé. Pero, aun así..."

# game/Kyou 6.rpy:4218
translate spanish Day6_Con_Kyou_Nozomi_Trance_a9cf675b:

    # "Just in case, and still thinking back to my late night research, I'll give her a little chance to put a stop to this."
    "Solo por si acaso, y recordando de nuevo mi investigación de anoche, voy a darle una pequeña oportunidad de ponerle un alto a esto."

# game/Kyou 6.rpy:4219
translate spanish Day6_Con_Kyou_Nozomi_Trance_0ae97107:

    # "Allow her one clear opportunity to take back control of her situation despite the helpless state she's in."
    "Concederle una clara oportunidad de retomar el control de su situación a pesar del indefenso estado en el que se encuentra."

# game/Kyou 6.rpy:4220
translate spanish Day6_Con_Kyou_Nozomi_Trance_251fbcee:

    # ks neutral "N-now Nozomi, I wanna be real with you for a sec."
    ks neutral "A-ahora, Nozomi, quiero ser real contigo por un segundo."

# game/Kyou 6.rpy:4221
translate spanish Day6_Con_Kyou_Nozomi_Trance_662f4f4e:

    # ks "If you really, really don't want to go on, you need to tell me now, okay?"
    ks "Si tú de verdad, de verdad no quieres continuar, debes decírmelo ahora, ¿de acuerdo?"

# game/Kyou 6.rpy:4222
translate spanish Day6_Con_Kyou_Nozomi_Trance_9e7d7ffa:

    # "Nozomi gives me the slightest of nods as her cheeks redden once more while I crouch down beside her and place a hand over her bare calves."
    "Nozomi asiente muy ligeramente y sus mejillas enrojecen una vez más mientras me agacho junto a ella y coloco una mano en sus pantorrillas descubiertas."

# game/Kyou 6.rpy:4223
translate spanish Day6_Con_Kyou_Nozomi_Trance_ed783a4d:

    # "Our gazes meet, but Nozomi remains silent as she looks to me with trepidation."
    "Nuestras miradas se cruzan, pero Nozomi permanece en silencio, mirándome con azoramiento."

# game/Kyou 6.rpy:4224
translate spanish Day6_Con_Kyou_Nozomi_Trance_8c523f88:

    # "She's... she's really not gonna say anything, huh?"
    "De... de verdad no va a decir nada, ¿eh?"

# game/Kyou 6.rpy:4226
translate spanish Day6_Con_Kyou_Nozomi_Trance_9fe32794:

    # "So then, steeling myself, I lean in towards her as I keep one hand on her legs..."
    "Entonces, armándome de valor, me inclino hacia ella, sin quitar mi mano de sus piernas..."

# game/Kyou 6.rpy:4228
translate spanish Day6_Con_Kyou_Nozomi_Trance_11b20df3:

    # "... And without further warning, I run the fingertips of my free hand skittishly down the soles of her feet."
    "... Y sin advertencia, paso un poco temeroso las yemas los dedos de mi otra mano por las plantas de sus pies."

# game/Kyou 6.rpy:4230
translate spanish Day6_Con_Kyou_Nozomi_Trance_524e2db7:

    # "... And without further warning, I swipe my free hand down to swat her backside over her skirt."
    "... Y sin advertencia, le doy una palmada con mi otra mano a su retaguarda por encima de su falda."

# game/Kyou 6.rpy:4235
translate spanish Day6_Con_Kyou_Nozomi_Trance_dba02b7f:

    # n laugh blush "Ahahah!" with vpunch
    n laugh blush "¡Jajajaja!" with vpunch

# game/Kyou 6.rpy:4236
translate spanish Day6_Con_Kyou_Nozomi_Trance_5951a156:

    # ks casual smirk "Aw, look at that. Seems my rival's the ticklish type."
    ks casual smirk "Oh, mira nada más. Parece que mi rival es cosquilluda."

# game/Kyou 6.rpy:4237
translate spanish Day6_Con_Kyou_Nozomi_Trance_2f3412c5:

    # "Heh, that's cute. I barely touched her and she's already letting out a hearty giggle."
    "Je, qué ternura. Apenas la toqué y ya soltó una fuerte carcajada."

# game/Kyou 6.rpy:4239
translate spanish Day6_Con_Kyou_Nozomi_Trance_5a30a2fd:

    # "Although my taunt buoys her a little, as her moment of weakness gives way to a determined glare while her body tenses." with dissolve
    "Aunque mi burla la mantiene un poco a flote, pues su pequeño momento de debilidad da lugar a una mirada determinada mientras tensa su cuerpo." with dissolve

# game/Kyou 6.rpy:4240
translate spanish Day6_Con_Kyou_Nozomi_Trance_5ae3016e:

    # "That determination, I note, still doesn't extend to her actually kicking her feet away from my hand."
    "Esa determinación, puedo notar, aún no es suficiente para hacerla alejar sus pies de mi mano."

# game/Kyou 6.rpy:4241
translate spanish Day6_Con_Kyou_Nozomi_Trance_14a54316:

    # "And hell, there's something else she could do if she wasn't holding onto her hypnotic conditioning so tightly."
    "Y, diablos, sé de otra cosa que podría hacer si no estuviera tan arraigada a su acondicionamiento hipnótico. "

# game/Kyou 6.rpy:4242
translate spanish Day6_Con_Kyou_Nozomi_Trance_eefe63ea:

    # ks "You're not gonna try and slap me?"
    ks "¿No vas a intentar darme una bofetada?"

# game/Kyou 6.rpy:5034
translate spanish Day6_Con_Kyou_Nozomi_Trance_7219f42f:

    # n irritated "U-urrrgh... I AM trying, you jerk!" with dissolve
    n irritated "Aajjj... eso INTENTO, cretino!" with dissolve

# game/Kyou 6.rpy:4244
translate spanish Day6_Con_Kyou_Nozomi_Trance_c243ef59:

    # ks "Aw man, that doesn't sound like someone who's ready to give up. We need to do something about that, don't we?"
    ks "Oh, vaya, esas no son las palabras de alguien que esté lista para rendirse. Hay que hacer algo al respecto, ¿no? {w=0.8}¡Cuchi, chichi cu!"

# game/Kyou 6.rpy:4245
translate spanish Day6_Con_Kyou_Nozomi_Trance_707cb739:

    # n angry "No you don't! I- {w=1.0}{nw}" with dissolve
    n angry "¡No, no hay que ha-{w=1.0}{nw}" with dissolve

# game/Kyou 6.rpy:4246
translate spanish Day6_Con_Kyou_Nozomi_Trance_9d74b707:

    # extend laugh "Bwahahahahaha!" with dissolve
    extend laugh "¡Bajajajajaja!" with dissolve

# game/Kyou 6.rpy:4247
translate spanish Day6_Con_Kyou_Nozomi_Trance_eea008ef:

    # "I purposefully wait for her protesting reply before I skitter my fingertips down the length of her soles again."
    "Espero apropósito a que proteste antes de deslizar las puntas de mis dedos por sus suelas una vez más."

# game/Kyou 6.rpy:4248
translate spanish Day6_Con_Kyou_Nozomi_Trance_f261ad0e:

    # ks "Has anyone told you you have the cutest laugh? I could listen to you all day."
    ks "¿Alguna vez te han dicho que tienes una risa adorable? Podría escucharte todo el día."

# game/Kyou 6.rpy:4249
translate spanish Day6_Con_Kyou_Nozomi_Trance_8882c444:

    # n "Heeh... h-heeeeh~"
    n "Jee... j-jeee..."

# game/Kyou 6.rpy:4250
translate spanish Day6_Con_Kyou_Nozomi_Trance_45aeece4:

    # "I can't help but laugh a little with her as her breath catches, while she fights to control the giggles bubbling up inside her."
    "No puedo evitar reírme un poco con ella mientras recupera el aliento, luchando por controlar las carcajadas que burbujean desde su interior."

# game/Kyou 6.rpy:4251
translate spanish Day6_Con_Kyou_Nozomi_Trance_3345c344:

    # "But she's only able to fight at all because I slowed my pace down to a teasing crawl around the pads of her toes."
    "Pero es capaz de luchar solo gracias a que bajé el ritmo para tentarla en las almohadillas de sus dedos."

# game/Kyou 6.rpy:4252
translate spanish Day6_Con_Kyou_Nozomi_Trance_8eedb994:

    # "The moment I ramp up again..."
    "Y en cuanto vuelvo a frotar..."

# game/Kyou 6.rpy:4253
translate spanish Day6_Con_Kyou_Nozomi_Trance_86019cf0:

    # n cry_laugh "N-NOAHAHAHAHA!" with vpunch
    n cry_laugh "¡N-NOAJAJAJAJA!" with vpunch

# game/Kyou 6.rpy:4254
translate spanish Day6_Con_Kyou_Nozomi_Trance_643b9edc:

    # "It's like she comes with a volume control."
    "Es como si tuviera control de volumen."

# game/Kyou 6.rpy:4255
translate spanish Day6_Con_Kyou_Nozomi_Trance_930c18b3:

    # n "St-stohohohohop!"
    n "¡Ya bajajajajasta!"

# game/Kyou 6.rpy:4256
translate spanish Day6_Con_Kyou_Nozomi_Trance_855211e4:

    # "Gotta admit, I'm a little curious to find out where else she's ticklish."
    "He de admitir que me da curiosidad averiguar dónde más es cosquilluda."

# game/Kyou 6.rpy:4257
translate spanish Day6_Con_Kyou_Nozomi_Trance_d54ca51e:

    # "But I don't want to go too hard on her here. Like, what if I wind up touching somewhere I shouldn't?"
    "Pero no quiero ser muy duro con ella. O sea, ¿qué tal si termino tocando donde no debería?"

# game/Kyou 6.rpy:4258
translate spanish Day6_Con_Kyou_Nozomi_Trance_3ccaab78:

    # ks "If you're asking me to stop then does that mean you accept your defeat?"
    ks "¿Si me estas pidiendo que pare, significa que estás lista para aceptar tu derrota?"

# game/Kyou 6.rpy:4259
translate spanish Day6_Con_Kyou_Nozomi_Trance_971771d4:

    # n irritated "N-n-n..." with dissolve
    n irritated "N-n-n..." with dissolve

# game/Kyou 6.rpy:4260
translate spanish Day6_Con_Kyou_Nozomi_Trance_0411a7cc:

    # "I can tell what she's struggling to say, while trying to control her pained laughter, and I have no intention of allowing it."
    "Puedo darme cuenta de qué es lo que intenta decir mientras que intenta controlar su dolorosa risa, y no tengo intenciones de permitirlo."

# game/Kyou 6.rpy:4262
translate spanish Day6_Con_Kyou_Nozomi_Trance_63c92203:

    # "So I punish her with a sudden direction change across the ball of her foot." with dissolve
    "Así que la castigo con un repentino cambio de dirección hacia la bola del pie." with dissolve

# game/Kyou 6.rpy:4263
translate spanish Day6_Con_Kyou_Nozomi_Trance_7044cdc3:

    # "And her defiant reply is lost in a girlish squeal that's loud enough to make me stop a moment."
    "Y su desafiante respuesta se pierde en un sonriente chillido que es lo suficientemente fuerte para hacerme parar por un momento."

# game/Kyou 6.rpy:4264
translate spanish Day6_Con_Kyou_Nozomi_Trance_cc33ec40:

    # ks smile blush "Then I guess I'm gonna hear your cute laugh some more, huh."
    ks smile blush "Entonces supongo que escucharé tu linda risa un rato más, ¿eh?"

# game/Kyou 6.rpy:4265
translate spanish Day6_Con_Kyou_Nozomi_Trance_ebbb4870:

    # "My short pause is enough for her to catch her breath, but not enough for her to answer me back as I run my tips teasingly along the sides of each foot in turn."
    "Mi corta pausa es suficiente para permitirle recuperar el aliento, pero no para que me responda, pues de repente paso mis dedos por los costados de ambos pies."

# game/Kyou 6.rpy:4266
translate spanish Day6_Con_Kyou_Nozomi_Trance_11d190d8:

    # n "Ehehehehe... eheh...e-ehehehehehee!"
    n "Jejejejeje... jeje... ¡e-ejejejejejee!"

# game/Kyou 6.rpy:5097
translate spanish Day6_Con_Kyou_Nozomi_Trance_7a624136:

    # k "Just tell me what I want to hear, Nozomi. It's all you've got to do."
    k "Solo dime lo que quiero oír, Nozomi. Eso es todo lo que tienes que hacer."

# game/Kyou 6.rpy:4268
translate spanish Day6_Con_Kyou_Nozomi_Trance_b39cc016:

    # "Nozomi giggles and shakes her head, but we both know she's flagging."
    "Nozomi se ríe y sacude la cabeza, pero ambos sabemos que está cediendo."

# game/Kyou 6.rpy:4269
translate spanish Day6_Con_Kyou_Nozomi_Trance_9e64fa6a:

    # "All that struggling she did trying to break out of her \"ropes\" before, and now I'm making her laugh herself to exhaustion as I tickle over her quivering arches..."
    "Con todo ese forcejeo para escapar de las \"cuerdas\" de hace un momento, y que ahora la esté haciendo reír hasta el cansancio haciéndole cosquillas en sus temblantes arcos..."

# game/Kyou 6.rpy:4270
translate spanish Day6_Con_Kyou_Nozomi_Trance_60f34585:

    # n "Nyayahahahaha! Haaah!"
    n "¡Najajajajaja! ¡Aaah! "

# game/Kyou 6.rpy:4271
translate spanish Day6_Con_Kyou_Nozomi_Trance_840e443a:

    # "She's got to break. She has to."
    "Debe romperse. Tiene que."

# game/Kyou 6.rpy:4273
translate spanish Day6_Con_Kyou_Nozomi_Trance_c872cb9c:

    # n "Pthh-okay! Hahahaha!" with dissolve
    n "¡Pff-está bien! ¡Jajajaja!" with dissolve

# game/Kyou 6.rpy:4274
translate spanish Day6_Con_Kyou_Nozomi_Trance_73bd12fe:

    # n "O-O-OKAY!" with vpunch
    n "¡E-E-ESTÁ BIEN!" with vpunch

# game/Kyou 6.rpy:4275
translate spanish Day6_Con_Kyou_Nozomi_Trance_86cd167a:

    # "Grinning widely, I withdraw my fingers just a little from her tortured feet."
    "Sonriendo de oreja a oreja, alejo mis dedos solo un poco de sus torturados pies."

# game/Kyou 6.rpy:4276
translate spanish Day6_Con_Kyou_Nozomi_Trance_1d4a94bc:

    # ks smirk "Alright, Nozo. I'm waiting."
    ks smirk "Muy bien, Nozo. Estoy esperando."

# game/Kyou 6.rpy:4277
translate spanish Day6_Con_Kyou_Nozomi_Trance_3e6deeb5:

    # "She takes a shuddered breath as she composes herself..."
    "Respira estremecida, intentando componerse..."

# game/Kyou 6.rpy:4279
translate spanish Day6_Con_Kyou_Nozomi_Trance_7bb6e4b9:

    # "And just as she's about to speak, I give her soles a quick tap." with dissolve
    "Y justo cuando está a punto de hablar, les doy a sus plantas un toquecito." with dissolve

# game/Kyou 6.rpy:4280
translate spanish Day6_Con_Kyou_Nozomi_Trance_692b62f4:

    # "It makes her emit a panicked squeal as she hurries to breathe out her surrender."
    "La hace emitir un chillido de pánico y se apresura a soltar su rendición."

# game/Kyou 6.rpy:4281
translate spanish Day6_Con_Kyou_Nozomi_Trance_9d7a4d1d:

    # n sigh "Pffththth! Y-you win, Kyou. Ahahah..." with dissolve
    n sigh "¡Pffftt! T-tú ganas, Kyou. Jajaja..." with dissolve

# game/Kyou 6.rpy:4282
translate spanish Day6_Con_Kyou_Nozomi_Trance_c1aad867:

    # ks smirk "So you're giving up?"
    ks smirk "¿Entonces te rindes?"

# game/Kyou 6.rpy:4283
translate spanish Day6_Con_Kyou_Nozomi_Trance_63f92ca0:

    # n "Haaah... y-yeah..."
    n "Haaah... s-sí..."

# game/Kyou 6.rpy:4284
translate spanish Day6_Con_Kyou_Nozomi_Trance_21426134:

    # ks "I won fair and square, right?"
    ks "Gané justa y limpiamente, ¿cierto?"

# game/Kyou 6.rpy:4285
translate spanish Day6_Con_Kyou_Nozomi_Trance_d9db45b8:

    # n "*sigh* Right..."
    n "*suspiro* Cierto..."

# game/Kyou 6.rpy:4286
translate spanish Day6_Con_Kyou_Nozomi_Trance_f28d4f3c:

    # ks "And you proclaim me king of the settlers?"
    ks "¿Y me proclamas rey de los colonos?"

# game/Kyou 6.rpy:4287
translate spanish Day6_Con_Kyou_Nozomi_Trance_49deec80:

    # n irritated "Ugh, o-oh my god just take the win. Don't milk it." with dissolve
    n irritated "Aj, p-por Dios, solo quédate con la victoria. No la exprimas." with dissolve

# game/Kyou 6.rpy:4288
translate spanish Day6_Con_Kyou_Nozomi_Trance_e1d60f65:

    # "I can't resist giving her toes another sly teasing."
    "No me puedo resistir a darles a sus dedos otro toque furtivo."

# game/Kyou 6.rpy:4289
translate spanish Day6_Con_Kyou_Nozomi_Trance_8139cc69:

    # n surprised "E-eep! I-I proclaim you king of the settlers now please stop!" with dissolve
    n surprised "¡Eeh! ¡T-te proclamo rey de los colonos, ahora para!" with dissolve

# game/Kyou 6.rpy:4296
translate spanish Day6_Con_Kyou_Nozomi_Trance_4618f1e4:

    # n shocked blush "Y-Youch!" with vpunch
    n shocked blush "¡A-auch!" with vpunch

# game/Kyou 6.rpy:4297
translate spanish Day6_Con_Kyou_Nozomi_Trance_b3f37c99:

    # ks casual frown "O-oh, come on, that wasn't even hard."
    ks casual frown "O-oh, vamos, eso no estuvo tan fuerte."

# game/Kyou 6.rpy:4298
translate spanish Day6_Con_Kyou_Nozomi_Trance_5c3ee94f:

    # "Honestly, I think the anticipation of being spanked got to her more than my hand on her did."
    "Honestamente, creo que la anticipación de ser nalgueada la afectó más que mi mano."

# game/Kyou 6.rpy:4299
translate spanish Day6_Con_Kyou_Nozomi_Trance_4341dc12:

    # n front determined "That's SO not the point!" with dissolve
    n front determined "¡Ese NO es el punto!" with dissolve

# game/Kyou 6.rpy:4300
translate spanish Day6_Con_Kyou_Nozomi_Trance_cbd0b9eb:

    # ks "And what WAS the point? Oh yeah..."
    ks "¿Y cuál SÍ es el punto? Ah, sí..."

# game/Kyou 6.rpy:4302
translate spanish Day6_Con_Kyou_Nozomi_Trance_b473e244:

    # n irritated "E-Eep!" with vpunch
    n irritated "¡A-ay!" with vpunch

# game/Kyou 6.rpy:4303
translate spanish Day6_Con_Kyou_Nozomi_Trance_d94305c5:

    # "I put another, I think slightly harder, swat down on her rump."
    "Le pongo otra, creo que un poquito más fuerte, directo en su rabadilla."

# game/Kyou 6.rpy:4304
translate spanish Day6_Con_Kyou_Nozomi_Trance_cd4cce42:

    # ks smirk "The point is you're not accepting your position, Miss Akemi."
    ks smirk "El punto es que no está aceptando su posición, Señorita Akemi."

# game/Kyou 6.rpy:4305
translate spanish Day6_Con_Kyou_Nozomi_Trance_e225b77c:

    # "Nozomi growls as she wriggles under my grasp."
    "Nozomi gruñe, meneándose bajo mi agarre."

# game/Kyou 6.rpy:4306
translate spanish Day6_Con_Kyou_Nozomi_Trance_e4aab252:

    # "Her balled hands shake with impotent fury as she obviously attempts to part them so she can punch me or something."
    "Sus manos cerradas se sacuden con imponente furia, pues obviamente intenta apartarlas para poder golpearme o algo."

# game/Kyou 6.rpy:4307
translate spanish Day6_Con_Kyou_Nozomi_Trance_59120292:

    # ks "See, that right there? That's bad."
    ks "¿Ves? De eso hablo. Eso está mal."

# game/Kyou 6.rpy:4309
translate spanish Day6_Con_Kyou_Nozomi_Trance_5d37d9fd:

    # n pain "AHH!" with vpunch
    n pain "¡AAH!" with vpunch

# game/Kyou 6.rpy:4310
translate spanish Day6_Con_Kyou_Nozomi_Trance_ebae8ff3:

    # "I slap my hand down swiftly, this time on her other cheek. It leaves a bunch of little prickling feelings on my palm that feels oddly satisfying."
    "Doy velozmente otro manotazo, esta vez en su otra mejilla. Eso deja la sensación de un montón de pequeños pinchazos en mi palma que son extrañamente satisfactorios."

# game/Kyou 6.rpy:4311
translate spanish Day6_Con_Kyou_Nozomi_Trance_a78e4d44:

    # n determined "St-stop that!" with dissolve
    n determined "¡P-para ya!" with dissolve

# game/Kyou 6.rpy:4312
translate spanish Day6_Con_Kyou_Nozomi_Trance_7929588e:

    # ks surprised blush "But... but, Nozomi, you're the one who can make this stop."
    ks surprised blush "Pero... pero, Nozomi, tú eres quien puede hacer que esto pare."

# game/Kyou 6.rpy:4313
translate spanish Day6_Con_Kyou_Nozomi_Trance_604ab1ba:

    # "I'm glad she can't see my face from here. I must be blushing pretty hard."
    "Me alegra que no pueda ver mi rostro desde aquí. De seguro estoy muy sonrojado."

# game/Kyou 6.rpy:4314
translate spanish Day6_Con_Kyou_Nozomi_Trance_a6392e38:

    # "Like, man, I don't know why I thought to suggest spanking her, other than I read somewhere that people who like being controlled can be into this kind of thing."
    "Caray, no sé cómo se me ocurrió sugerir darle nalgadas, además de haber leído en algún lado que a la gente a la que le gusta ser controlada también puede gustarle esto."

# game/Kyou 6.rpy:4315
translate spanish Day6_Con_Kyou_Nozomi_Trance_61796a52:

    # "And for her part, Nozomi didn't straight up reject me treating her like this."
    "Y por su parte, Nozomi no me rechazó de inmediato por tratarla así."

# game/Kyou 6.rpy:4316
translate spanish Day6_Con_Kyou_Nozomi_Trance_15384b4c:

    # "Her outrage seems kinda... half-hearted?"
    "Su ira parece un poco... ¿a medias?"

# game/Kyou 6.rpy:4317
translate spanish Day6_Con_Kyou_Nozomi_Trance_2cb66edf:

    # n irritated "I'm not letting a cheater win, if that's what you mean." with dissolve
    n irritated "No dejaré que un tramposo gane, si a eso te refieres." with dissolve

# game/Kyou 6.rpy:4318
translate spanish Day6_Con_Kyou_Nozomi_Trance_82b59dd7:

    # "As she replies defiantly, I make a show of smoothing her skirt over to make sure it's covering her panties."
    "Luego de su desafiante respuesta, aliso su falda para asegurarme de que esté cubriendo sus bragas."

# game/Kyou 6.rpy:4319
translate spanish Day6_Con_Kyou_Nozomi_Trance_66a5a45a:

    # "I mean, the thought occurred to me to go under the skirt but... I'm seriously pushing my luck enough as it is."
    "Digo, se me ocurrió que podría ir bajo su falda, pero... ya estoy tentando mucho mi suerte con esto."

# game/Kyou 6.rpy:4320
translate spanish Day6_Con_Kyou_Nozomi_Trance_3419a47b:

    # n frown "Ugh, what are you even doing?!" with dissolve
    n frown "Aj, ¡¿qué estás haciendo?!" with dissolve

# game/Kyou 6.rpy:4321
translate spanish Day6_Con_Kyou_Nozomi_Trance_0507c655:

    # ks frown blush "This? This is more about what you're NOT doing!"
    ks frown blush "¿Esto? ¡Esto se trata más bien de lo que tú NO estás haciendo!"

# game/Kyou 6.rpy:4323
translate spanish Day6_Con_Kyou_Nozomi_Trance_81bdc984:

    # n shocked "EEK!" with vpunch
    n shocked "¡IIH!" with vpunch

# game/Kyou 6.rpy:4324
translate spanish Day6_Con_Kyou_Nozomi_Trance_f428faca:

    # "My palm cracks down on her vulnerable backside and she winces audibly. She definitely felt that one."
    "Mi palma se estrella con su vulnerable retaguarda y ella se estremece. Ese definitivamente sí lo sintió."

# game/Kyou 6.rpy:4325
translate spanish Day6_Con_Kyou_Nozomi_Trance_9b5528c1:

    # n pain "Tststststs..." with dissolve
    n pain "Tststststs..." with dissolve

# game/Kyou 6.rpy:4326
translate spanish Day6_Con_Kyou_Nozomi_Trance_7f05d210:

    # ks smirk "Tell me I won."
    ks smirk "Dime que gané."

# game/Kyou 6.rpy:4327
translate spanish Day6_Con_Kyou_Nozomi_Trance_725335b3:

    # n angry "Go to hell!" with dissolve
    n angry "¡Vete al diablo!" with dissolve

# game/Kyou 6.rpy:4329
translate spanish Day6_Con_Kyou_Nozomi_Trance_540bb5b0:

    # n pain "OW! {w=0.5}{nw}" with vpunch
    n pain "¡AU! {w=0.5}{nw}" with vpunch

# game/Kyou 6.rpy:4331
translate spanish Day6_Con_Kyou_Nozomi_Trance_b3608eff:

    # extend "OW! {w=0.5}{nw}" with vpunch
    extend "¡AU! {w=0.5}{nw}" with vpunch

# game/Kyou 6.rpy:4333
translate spanish Day6_Con_Kyou_Nozomi_Trance_64ee605c:

    # extend "OW!" with vpunch
    extend "¡AU!" with vpunch

# game/Kyou 6.rpy:4334
translate spanish Day6_Con_Kyou_Nozomi_Trance_701b96f5:

    # "I don't know if I'm settling into character or what, but her stubbornness is getting tiresome."
    "No sé si me estoy metiendo en personaje o algo, pero su terquedad me está cansando."

# game/Kyou 6.rpy:4335
