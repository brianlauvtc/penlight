translate spanish Day6_Con_Kyou_Sayori_Alter_Switch_7f3c65b3:

    # "But these are... they're MY hands!?"
    "Pero estas son... ¡¿son MIS manos!?"

# game/Kyou 6.rpy:9342
translate spanish Day6_Con_Kyou_Sayori_Alter_Switch_7bbd9be2:

    # n "Oh my god he's really doing it!" with dissolve
    n "¡Oh, por Dios, en serio lo está haciendo!" with dissolve

# game/Kyou 6.rpy:9343
translate spanish Day6_Con_Kyou_Sayori_Alter_Switch_69c8ed64:

    # ks angry "Haaah! N-no!"
    ks angry "¡Aaah! ¡N-no!"

