translate spanish Day6_Con_Kyou_Sayori_Alter_Switch_e5f755f4:

    # "I'm not doing this. I'm not..."
    "No estoy haciendo esto. No estoy..."

# game/Kyou 6.rpy:9345
translate spanish Day6_Con_Kyou_Sayori_Alter_Switch_63f93dea:

    # ks "Stop! F-fucking... no, STOP!" with vpunch
    ks "¡Alto! M-mierda... ¡no, ALTO!" with vpunch

# game/Kyou 6.rpy:9347
translate spanish Day6_Con_Kyou_Sayori_Alter_Switch_2497f7c8:

    # ks "NOOOOOOOOOOOOOOOOOOOOOOOOOOOOOOOOOOOOOOOOOOO!" with shake
    ks "¡NOOOOOOOOOOOOOOOOOOOOOOOOOOOOOOOOOOOOOOOOOOO!" with shake

# game/Kyou 6.rpy:9348
translate spanish Day6_Con_Kyou_Sayori_Alter_Switch_072f2e6e:

    # "My breath catches as I register the sight of the penlight's frame splintering in front of me as it visibly bends in two before my very eyes."
    "Recuperando el aliento, observo la linterna partirse frente a mí, doblándose visiblemente por la mitad frente a mis ojos."

# game/Kyou 6.rpy:9351
translate spanish Day6_Con_Kyou_Sayori_Alter_Switch_4079abbe:

    # "Surely there's no way this thing can ever work the way it did ever again." with dissolve
    "De ninguna forma esta cosa volverá a funcionar como antes." with dissolve

# game/Kyou 6.rpy:9352
translate spanish Day6_Con_Kyou_Sayori_Alter_Switch_3bcc208e:

    # ks surprised "Haaah.. h-haaah..."
    ks surprised "Haaah... a-aaah..."

# game/Kyou 6.rpy:9353
translate spanish Day6_Con_Kyou_Sayori_Alter_Switch_c055de34:

    # "And it's only then, as I draw a shuddered breath into my lungs, that my arms can finally relax."
    "Y no es hasta entonces que inhalo con cansancio y mis brazos pueden relajarse."

# game/Kyou 6.rpy:9355
translate spanish Day6_Con_Kyou_Sayori_Alter_Switch_08b1cd08:

    # "For a moment the room falls silent as I stare at the bent-up penlight in my hands; now little more than a broken tube."
    "Por un momento, la habitación se queda en silencio, y yo me quedo mirando la linterna doblada en mis manos; ahora es poco más que un tubo roto."

# game/Kyou 6.rpy:9358
translate spanish Day6_Con_Kyou_Sayori_Alter_Switch_7efb9263:

    # "And I..."
    "Y yo..."

# game/Kyou 6.rpy:9364
translate spanish Day6_Con_Kyou_Sayori_Alter_Switch_241695cd:

    # ks angry "Wh-what the HELL, you guys?!" with dissolve
    ks angry "¡¿Qu-qué DEMONIOS fue eso?!" with dissolve

# game/Kyou 6.rpy:9365
translate spanish Day6_Con_Kyou_Sayori_Alter_Switch_f19b02b0:

    # "I can't take this."
    "No puedo soportar esto."

# game/Kyou 6.rpy:9367
translate spanish Day6_Con_Kyou_Sayori_Alter_Switch_316334ef:

    # ks "This was your plan all along, Sayori? Just break my creation without telling me? That was your big fucking resolution?"
    ks "¿Este fue tu plan desde el principio, Sayori? ¿Romper mi creación así nada más sin decirme? ¿Esa era tu puta gran solución?"

# game/Kyou 6.rpy:9368
translate spanish Day6_Con_Kyou_Sayori_Alter_Switch_38ff76df:

    # n concerned "Kyou? H-hey, please calm down, okay?" with dissolve
    n concerned "¿Kyou? O-oye, por favor, cálmate, ¿sí?" with dissolve

# game/Kyou 6.rpy:9370
translate spanish Day6_Con_Kyou_Sayori_Alter_Switch_0be6b9a1:

    # "Nozomi skittishly looks to the door, like she wants to run away... or she's afraid her mom will burst in at any moment."
    "Nozomi voltea a ver la puerta con miedo, como si quisiera huir... o como si temiera que su mamá fuera a entrar en cualquier momento."

# game/Kyou 6.rpy:9087
translate spanish Day6_Con_Kyou_Sayori_Alter_Switch_238b820d:

    # s concerned_right "My apologies. I know it was unseemly of me, but I fear you would not be convinced otherwise." with dissolve
    s concerned_right "Mis disculpas. Sé que fue impropio de mi parte, pero me temo que no había otra forma de convencerte." with dissolve

# game/Kyou 6.rpy:9372
translate spanish Day6_Con_Kyou_Sayori_Alter_Switch_970314dd:

    # "Yeah, I know I gotta cool this down. Take a breath."
    "Sí, sé que debo calmarme. Tomar aire."

# game/Kyou 6.rpy:9373
translate spanish Day6_Con_Kyou_Sayori_Alter_Switch_4b9729c2:

    # ks frown "Man, whatever. But you had no fucking right, Sayori, just because you're freaking out over this thing."
    ks frown "Sí, como sea. Pero no tenías el puto derecho, Sayori, solo porque esto te asustaba."

# game/Kyou 6.rpy:9374
translate spanish Day6_Con_Kyou_Sayori_Alter_Switch_cd51fdbb:

    # "But what the goddamn hell do they expect if they're gonna pull this shit?"
    "Pero ¿qué diablos esperan si me salen con esta mierda?"

# game/Kyou 6.rpy:9375
translate spanish Day6_Con_Kyou_Sayori_Alter_Switch_f380df41:

    # ks frown "You think you're so smart, tricking me into doing that? Well, I got the schematics written up on my computer."
    ks frown "¿Crees que eres muy lista, engañándome para hacer esto? Bueno, tengo los planos en mi computadora."

# game/Kyou 6.rpy:9376
translate spanish Day6_Con_Kyou_Sayori_Alter_Switch_cf552007:

    # s surprised_right "K-Kyou, you wouldn't..." with dissolve
    s surprised_right "K-Kyou, no lo harías..." with dissolve

# game/Kyou 6.rpy:9377
translate spanish Day6_Con_Kyou_Sayori_Alter_Switch_640e4849:

    # ks "I mean, it'd take a lot of effort, but I could. I could make another one..."
    ks "Digo, haría falta mucho esfuerzo, pero podría. Podría hacer otra."

# game/Kyou 6.rpy:9380
translate spanish Day6_Con_Kyou_Sayori_Alter_Switch_6ff33623:

    # s scared_right "Kyou please, NO!" with dissolve
    s scared_right "¡Kyou, por favor, NO!" with dissolve

# game/Kyou 6.rpy:9381
translate spanish Day6_Con_Kyou_Sayori_Alter_Switch_c3f9e2ee:

    # "But just then I see that look in Sayori's eyes."
    "Pero en ese momento, veo la mirada en los ojos de Sayori."

# game/Kyou 6.rpy:9382
translate spanish Day6_Con_Kyou_Sayori_Alter_Switch_55cc83e4:

    # s casual_handup "Y-you were not tricked! Don't you see?" with dissolve
    s casual_handup "¡N-no fuiste engañado! ¿No lo ves?" with dissolve

# game/Kyou 6.rpy:9383
translate spanish Day6_Con_Kyou_Sayori_Alter_Switch_4253174a:

    # "And it stops me cold. There's no arrogance in that expression at all."
    "Y me hace detenerme. No hay nada de arrogancia en esa expresión."

# game/Kyou 6.rpy:9385
translate spanish Day6_Con_Kyou_Sayori_Alter_Switch_475753ee:

    # s casual "You moved to destroy your own creation, even though every part of your conscious will was screaming to stop!" with dissolve
    s casual "¡Destruiste tu propia creación con tus manos, a pesar de que cada parte de tu consciente gritaba que te detuvieras!" with dissolve

# game/Kyou 6.rpy:9386
translate spanish Day6_Con_Kyou_Sayori_Alter_Switch_c36ac4c4:

    # "There's only that same frightened girl I witnessed back in the classroom that day."
    "Solo esa chica atemorizada que presencié aquel día en el salón de clases."

# game/Kyou 6.rpy:9387
translate spanish Day6_Con_Kyou_Sayori_Alter_Switch_090e572d:

    # s concerned_right "Surely you can see what this means? There was no trick in what I did to you." with dissolve
    s concerned_right "Debes poder ver lo que significa. No hubo ningún truco en lo que te hice." with dissolve

# game/Kyou 6.rpy:9389
translate spanish Day6_Con_Kyou_Sayori_Alter_Switch_d8a4efff:

    # "And I'm forced to admit the truth as I hang my head and allow the bent remains of my penlight to slip through my fingers."
    "Y me veo obligado a admitir la verdad. Cabizbajo, dejo que los restos de mi linterna caigan de mis dedos."

# game/Kyou 6.rpy:9390
translate spanish Day6_Con_Kyou_Sayori_Alter_Switch_0ad91ccc:

    # ks sigh "So it really does control minds..."
    ks sigh "De modo que en verdad controla mentes..."

# game/Kyou 6.rpy:9391
translate spanish Day6_Con_Kyou_Sayori_Alter_Switch_376c5ea5:

    # "For a moment, no one seems to know what to say. But as I stand there motionless I feel a warmth as Sayori suddenly moves to embrace me."
    "Por un momento, nadie parece saber qué decir. Pero estando de pie sin moverme, siento un calor, pues Sayori repentinamente me envuelve en un abrazo."

# game/Kyou 6.rpy:9109
translate spanish Day6_Con_Kyou_Sayori_Alter_Switch_81d57b2a:

    # s "I truly am sorry you had to experience that."
    s "En verdad lamento que hayas tenido que pasar por esa experiencia."

# game/Kyou 6.rpy:9393
translate spanish Day6_Con_Kyou_Sayori_Alter_Switch_a3872e24:

    # s "The fear. The anger. The realization that you lost your entire sense of agency in a manner that defies all rational explanation. And that you were helpless to stop it."
    s "El miedo. La ira. El descubrir que perdiste todo tu sentido de agencia, desafiando toda explicación racional. Y que no podías hacer nada para detenerlo."

# game/Kyou 6.rpy:9394
translate spanish Day6_Con_Kyou_Sayori_Alter_Switch_e3a152eb:

    # s sleepy "Believe me, I am familiar." with dissolve
    s sleepy "Créeme, estoy familiarizada." with dissolve

# game/Kyou 6.rpy:9113
translate spanish Day6_Con_Kyou_Sayori_Alter_Switch_19a1cc26:

    # ks casual sigh "Yeah... yeah, I get it."
    ks casual sigh "Sí... sí, lo entiendo."

# game/Kyou 6.rpy:9396
translate spanish Day6_Con_Kyou_Sayori_Alter_Switch_d5eb713f:

    # "Much as I hate to admit it, I know that thing had to go."
    "Por mucho que odie admitirlo, sé que esa cosa tenía que irse."

# game/Kyou 6.rpy:9115
translate spanish Day6_Con_Kyou_Sayori_Alter_Switch_4a57d3c4:

    # s concerned_right "You understand now, don't you. You realize the danger it presents anyone that is subject to it. And the sheer temptation it presents to any who would use it with that knowledge."
    s concerned_right "Ahora lo entiendes, ¿no? Te das cuenta del peligro al que somete a cualquiera que sea sujeto de ella. Y la tentación que presenta ante cualquiera que la use a sabiendas."

# game/Kyou 6.rpy:9399
translate spanish Day6_Con_Kyou_Sayori_Alter_Switch_0e52701d:

    # s casual_handup "For all our sakes, it simply had to be destroyed." with dissolve
    s casual_handup "Por el bien de todos, simplemente tenía que ser destruida." with dissolve

# game/Kyou 6.rpy:9400
translate spanish Day6_Con_Kyou_Sayori_Alter_Switch_3fa6ada1:

    # "I can't argue with her. All I can do is sigh as we all look down upon the ruined penlight that lay discarded on the floor."
    "No puedo discutir con ella. No puedo hacer más que suspirar mientras miramos la arruinada linterna yacer en el suelo."

# game/Kyou 6.rpy:9401
translate spanish Day6_Con_Kyou_Sayori_Alter_Switch_b6847553:

    # ks sigh "Man, I don't know if I could even remake this thing anyway. It was a freak accident I even did it the first time."
    ks sigh "Caray, ni siquiera sé si podría rehacer esa cosa de todos modos. Haberla hecho la primera vez fue un puro accidente."

# game/Kyou 6.rpy:9402
translate spanish Day6_Con_Kyou_Sayori_Alter_Switch_4537485a:

    # ks "But yeah... maybe it's best I don't find out."
    ks "Pero sí... tal vez sea mejor no averiguarlo."

# game/Kyou 6.rpy:9404
translate spanish Day6_Con_Kyou_Sayori_Alter_Switch_641e1339:

    # "For a while we all just look at the ground. No one really seems to know what to do now this chapter in our lives has surely come to an end."
    "Por un rato, todos nos quedamos mirando al suelo. Nadie parece saber qué hacer ahora que este capítulo de nuestras vidas ha llegado a su fin."

# game/Kyou 6.rpy:9406
translate spanish Day6_Con_Kyou_Sayori_Alter_Switch_aa108ac0:

    # n "So..." with dissolve
    n "Y..." with dissolve

# game/Kyou 6.rpy:9407
translate spanish Day6_Con_Kyou_Sayori_Alter_Switch_823f2c6b:

    # "Eventually, Nozomi begins to speak as she poses the question on everyone's lips."
    "Eventualmente, Nozomi comienza a hablar y hace la pregunta que todos estamos pensando."

# game/Kyou 6.rpy:9408
translate spanish Day6_Con_Kyou_Sayori_Alter_Switch_8d4eb438:

    # n sad "What now?" with dissolve
    n sad "¿Ahora qué?" with dissolve

# game/Kyou 6.rpy:9410
translate spanish Day6_Con_Kyou_Sayori_Alter_Switch_e66f68be:

    # "I don't really have an answer to that. But after another moment's silence, Sayori turns from us to gather her things from the floor." with dissolve
    "No tengo una respuesta. Pero tras un momento de silencio, Sayori se da la vuelta para recoger sus cosas del suelo." with dissolve

# game/Kyou 6.rpy:9411
translate spanish Day6_Con_Kyou_Sayori_Alter_Switch_4eed7eeb:

    # n sad_side "Sayori?" with dissolve
    n sad_side "¿Sayori?" with dissolve

# game/Kyou 6.rpy:9412
translate spanish Day6_Con_Kyou_Sayori_Alter_Switch_d421d1af:

    # s concerned "My apologies once again. But now is the time I take back control of my life." with dissolve
    s concerned "Me disculpo nuevamente. Pero ya es hora de retomar el control de mi vida." with dissolve

# game/Kyou 6.rpy:9140
translate spanish Day6_Con_Kyou_Sayori_Alter_Switch_7e340d00:

    # ks casual confused "What do you mean?"
    ks casual confused "¿Qué quieres decir?"

# game/Kyou 6.rpy:9414
translate spanish Day6_Con_Kyou_Sayori_Alter_Switch_db068f71:

    # "She stands up with a grunt as she cradles her textbooks in her hands."
    "Se levanta con un gruñido, cargando sus libros en brazos."

# game/Kyou 6.rpy:9415
translate spanish Day6_Con_Kyou_Sayori_Alter_Switch_d3a952e7:

    # s casual_folded sleeptalk "Have you forgotten already? As fun and... frightening today has been, I still have work to do. And I have disappointed my father far too many times this week." with dissolve
    s casual_folded sleeptalk "¿Ya lo olvidaron? Por divertido y... aterrador que haya sido este día, aún tengo trabajo que hacer. Y ya decepcioné a mi padre demasiadas veces esta semana." with dissolve

# game/Kyou 6.rpy:9416
translate spanish Day6_Con_Kyou_Sayori_Alter_Switch_3c968934:

    # ks "You're seriously going back to cram school?"
    ks "¿En serio vas a regresar a los cursos nocturnos?"

# game/Kyou 6.rpy:9417
translate spanish Day6_Con_Kyou_Sayori_Alter_Switch_0fbf6bc4:

    # n shocked_side "In your condition? Sayori, you barely made it back here, how on earth do you think you can carry on like this?" with dissolve
    n shocked_side "¿En tu condición? Sayori, apenas pudiste llegar aquí, ¿cómo rayos piensas seguir así?" with dissolve

# game/Kyou 6.rpy:9418
translate spanish Day6_Con_Kyou_Sayori_Alter_Switch_4cdb8f7b:

    # s "I-I... rrrng..."
    s "P-puedo... mmgr..."

