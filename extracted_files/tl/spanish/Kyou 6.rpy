    # a smile "Like smoking. I know some people get hypnotherapy for that." with dissolve
    a smile "Como fumar. Sé que hay gente que recibe hipnoterapia para eso." with dissolve

# game/Kyou 6.rpy:6243
translate spanish Day6_Redemption_4bc48c09:

    # ks smile "Exactly."
    ks smile "Exacto."

