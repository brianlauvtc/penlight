    s "Mmnnn..."

# game/Kyou 6.rpy:2989
translate spanish Day6_Villain_Kyou_eba4325c:

    # "She's so pathetically weak that I can hold her in place with little trouble at all as she clenches her eyes shut."
    "Es tan patéticamente débil que puedo sujetarla sin ningún problema, pero está cerrando los ojos."

# game/Kyou 6.rpy:2990
translate spanish Day6_Villain_Kyou_a145a6c8:

    # ks "It's alright, you don't need to see the light if you don't want to. You can simply listen and obey instead."
    ks "Está bien, no hace falta que mires la luz si no quieres. En vez de eso, puedes simplemente escuchar y obedecer."

# game/Kyou 6.rpy:2991
translate spanish Day6_Villain_Kyou_a9e4c41c:

    # h "L-listen and obey."
    h "E-escuchar y obedecer."

# game/Kyou 6.rpy:2992
translate spanish Day6_Villain_Kyou_e46ebc21:

    # s "Please st- stop this madness..."
    s "Por favor, d-detén esta locura..."

# game/Kyou 6.rpy:2993
translate spanish Day6_Villain_Kyou_8eb5e588:

    # ks "It's you who needs to stop, Sayori. Stop thinking. Just listen and obey my words, letting them take you into a deep state of hypnotic trance for me."
    ks "Tú eres la que necesita detenerse, Sayori. No hace falta pensar más. Solo escuchar y obedecer mis palabras, guiándolas a un profundo estado de trance hipnótico."

# game/Kyou 6.rpy:2994
translate spanish Day6_Villain_Kyou_6fbf1793:

    # s "Uh... n-no..."
    s "Ah... n-no..."

# game/Kyou 6.rpy:2995
translate spanish Day6_Villain_Kyou_e9cc7cb1:

    # ks frown "You don't need to fight anymore, girls. You just need to listen and obey."
    ks frown "Ya no tienen que pelear, chicas. Solo tienen que escuchar y obedecer."

# game/Kyou 6.rpy:2996
translate spanish Day6_Villain_Kyou_fc8c55e3:

    # s "{size=16}Listen...{/size}"
    s "{size=16}Escuchar...{/size}"

# game/Kyou 6.rpy:2997
translate spanish Day6_Villain_Kyou_1691c851:

    # h "Listen and obey."
    h "Escuchar y obedecer."

# game/Kyou 6.rpy:2998
translate spanish Day6_Villain_Kyou_be2ec69e:

    # ks "Open your eyes now, Sayori. Listen and obey."
    ks "Ahora abre los ojos, Sayori. Debes escuchar y obedecer."

# game/Kyou 6.rpy:3001
translate spanish Day6_Villain_Kyou_6b34009c:

    # t "Listen and obey..." with dissolve
    t "Escuchar y obedecer..." with dissolve

# game/Kyou 6.rpy:3002
translate spanish Day6_Villain_Kyou_7c86ff7a:

    # ks smirk "Good girls."
    ks smirk "Buenas chicas."

# game/Kyou 6.rpy:3039
translate spanish Day6_Villain_Kyou_45663ebc:

    # "The two of them stand there subdued, their blank stares gazing emptily into oblivion as I take a moment to catch my breath." with dissolve
    "Las dos se encuentran ahora sometidas; sus miradas inertes, perdidas en el vacío del olvido. Por fin puedo tomarme un respiro." with dissolve

# game/Kyou 6.rpy:3040
translate spanish Day6_Villain_Kyou_b7567736:

    # "Now that the danger's passed, I can allow myself to get angry again."
    "Ahora que el peligro ha pasado, puedo permitirme enojarme otra vez."

# game/Kyou 6.rpy:3041
translate spanish Day6_Villain_Kyou_b3168a51:

    # ks frown "Man, the fuck do you two think you are? Thinking you can take this all away from me?"
    ks frown "Pero ¿quién carajo creen que son? ¿Pensaron que podían arrebatármelo todo?"

# game/Kyou 6.rpy:3042
translate spanish Day6_Villain_Kyou_1bb01731:

    # t "..."
    t "..."

# game/Kyou 6.rpy:3043
translate spanish Day6_Villain_Kyou_9a9228e0:

    # ks angry "How fucking- {w=1.0}{nw}"
    ks angry "¿Cómo carajos- {w=1.0}{nw}"

# game/Kyou 6.rpy:3046
translate spanish Day6_Villain_Kyou_248dc9d6:

    # "Huh?" with vpunch
    "¿Eh?" with vpunch

# game/Kyou 6.rpy:3047
translate spanish Day6_Villain_Kyou_8c3abdb0:

    # "Wait, was that the door just now?"
    "Espera, ¿esa fue la puerta?"

# game/Kyou 6.rpy:3048
translate spanish Day6_Villain_Kyou_2741e14f:

    # "... \"The two of them\"?"
    "... ¿\"Las dos\"?"

# game/Kyou 6.rpy:3050
translate spanish Day6_Villain_Kyou_dcd34728:

    # ks surprised "No... Where's Nozomi?"
    ks surprised "No... ¿Dónde está Nozomi?"

# game/Kyou 6.rpy:3051
translate spanish Day6_Villain_Kyou_ee1454f9:

    # "Amidst all the fighting and adrenaline I completely forgot about her."
    "Con la pelea y toda la adrenalina me olvidé por completo de ella."

# game/Kyou 6.rpy:3054
translate spanish Day6_Villain_Kyou_4edaf1dc:

    # "As I rush to the window, I see her immediately as she paces away in a fright while holding her phone to her ear."
    "Me acerco a la ventana y la veo de inmediato, corriendo despavorida con su teléfono en la oreja."

# game/Kyou 6.rpy:3055
translate spanish Day6_Villain_Kyou_d64eb40e:

    # "Fuck..."
    "Mierda..."

# game/Kyou 6.rpy:3056
translate spanish Day6_Villain_Kyou_28c3b9d7:

    # ks angry "FUCK!" with vpunch
    ks angry "¡MIERDA!" with vpunch

# game/Kyou 6.rpy:3057
translate spanish Day6_Villain_Kyou_8d3d061a:

    # "Okay, okay, what do I do? I can't just run out there and grab her in broad daylight."
    "Muy bien, muy bien, ¿qué hago ahora? No puedo ir allá afuera y agarrarla a plena luz del día."

# game/Kyou 6.rpy:3060
translate spanish Day6_Villain_Kyou_4ed7a57f:

    # "But what if I were to message her? She'll see my command and come straight back, won't she?"
    "Pero ¿qué tal si le envío un mensaje? Verá la orden y vendrá de regreso, ¿no?"

# game/Kyou 6.rpy:3061
translate spanish Day6_Villain_Kyou_ddcd2de9:

    # "{color=#4B9374}\"Calmly return to Kyou's house and let him hypnotize you.\"{/color}"
    "{color=#4B9374}\"Regresa tranquilamente a casa de Kyou y deja que te hipnotice.\"{/color}"

# game/Kyou 6.rpy:3064
translate spanish Day6_Villain_Kyou_7fba6278:

    # "All Nozomi has to do is read the message... Just one look at her phone screen and surely she'll be helplessly walking herself right back here."
    "Nozomi solo debe leer el mensaje... Solo una mirada a la pantalla de su teléfono y no podrá hacer nada más que volver a mí."

# game/Kyou 6.rpy:3065
translate spanish Day6_Villain_Kyou_41c4964b:

    # "Only as I watch, she seems to be ignoring her notifications, instead pleading with whoever's on the line to help her."
    "Pero al verla, parece ignorar sus notificaciones, suplicándole a quien sea que esté en la línea que la ayude."

# game/Kyou 6.rpy:3066
translate spanish Day6_Villain_Kyou_96a3cbba:

    # "... Shit, that's right. I only conditioned these two to read their messages immediately."
    "... Mierda, es cierto. Solo acondicioné a estas dos para que leyeran sus mensajes de inmediato."

# game/Kyou 6.rpy:3067
translate spanish Day6_Villain_Kyou_cf0116c5:

    # "As Nozomi stands on the other side of the street, her phone still pressed feverishly to her cheek, I wonder what other mistakes I made that allowed all this to happen."
    "Viendo a Nozomi de pie del otro lado de la calle, aún sosteniendo firmemente su teléfono en su mejilla, me pregunto qué otros errores cometí para que esto pasara."

# game/Kyou 6.rpy:3068
translate spanish Day6_Villain_Kyou_fa41d128:

    # "But no. No, I can't think about how she fucking got away from me."
    "Pero no. No, no puedo ponerme a pensar en cómo carajos se me escapó."

# game/Kyou 6.rpy:3069
translate spanish Day6_Villain_Kyou_72334b67:

    # "I need to move fast before she brings the cops down on me or whatever it is she's doing."
    "Tengo que actuar rápido antes de que traiga a la policía o lo que sea que esté tramando."

# game/Kyou 6.rpy:3074
translate spanish Day6_Villain_Kyou_de831645:

    # "Turning away from the window, I bring my attention back on the two girls I have in my thrall."
    "Alejándome de la ventana, vuelvo mi atención a las dos chicas que tengo en mi poder."

# game/Kyou 6.rpy:3075
translate spanish Day6_Villain_Kyou_0c88a710:

    # ks frown "Okay, uhh..."
    ks frown "Muy bien, eeeh..."

# game/Kyou 6.rpy:3076
translate spanish Day6_Villain_Kyou_7616c5a3:

    # "I take a breath, then gently place my hands on their shoulders as I address them calmly."
    "Tomo aire, luego pongo suavemente mis manos sobre sus hombros, dirigiéndome a ellas con calma."

# game/Kyou 6.rpy:3077
translate spanish Day6_Villain_Kyou_5ff7f5d5:

    # ks "Going deeper now, girls. Just listen and obey, letting yourselves go so, so very deep for me."
    ks "Ahora vayan más profundo, chicas. Solo hay que escuchar y obedecer. Déjense llevar; más y más profundo."

# game/Kyou 6.rpy:3078
translate spanish Day6_Villain_Kyou_1e6126c3:

    # ks "And as deep as you are, I want you to consider a few things for me."
    ks "Y estando así de profundo, quiero que consideren unas cuantas cosas."

# game/Kyou 6.rpy:3079
translate spanish Day6_Villain_Kyou_33b0948c:

    # ks "First, consider your true motivations for coming to my house today. Do you know why you're here, girls?"
    ks "Primero, consideren sus verdaderas motivaciones para venir a mi casa hoy. ¿Saben por qué están aquí, chicas?"

# game/Kyou 6.rpy:3080
translate spanish Day6_Villain_Kyou_090cadd2:

    # s entranced_talk_right "We are here to stop you from abusing us." with dissolve
    s entranced_talk_right "Para detener tu abuso." with dissolve

# game/Kyou 6.rpy:3082
translate spanish Day6_Villain_Kyou_e3fb4d95:

    # h entranced_talk "H-here to stop you..." with dissolve
    h entranced_talk "D-detenerte..." with dissolve

# game/Kyou 6.rpy:3084
translate spanish Day6_Villain_Kyou_269171eb:

    # ks smirk "You think that now, but if I were to say you are in fact here as guests of your own free will, you may want to consider how true that is." with dissolve
    ks smirk "Eso piensan ahora, pero si dijera que vinieron de visita por voluntad propia, tal vez quieran considerar lo cierto que es." with dissolve

# game/Kyou 6.rpy:3085
translate spanish Day6_Villain_Kyou_1c2c4eb0:

    # ks "Because that's the real reason you're here. You're both at my house to relax and have fun with me, and forget your worries for a little while."
    ks "Pues esa es la verdadera razón por la que están aquí. Vinieron a mi casa a relajarse y divertirse conmigo, y olvidar sus preocupaciones por un rato."

# game/Kyou 6.rpy:3086
translate spanish Day6_Villain_Kyou_e7a4ceb4:

    # ks "And the more you think on this, the more true it becomes, pushing out anything else that may be floating around in those heads of yours."
    ks "Y entre más lo piensan, más cierto se vuelve, y expulsa cualquier otra cosa que pueda estar flotando en sus cabezas."

# game/Kyou 6.rpy:3087
translate spanish Day6_Villain_Kyou_9098f4ca:

    # "I can almost see their minds working behind those empty faces, taking in my every word into their subconscious in spite of themselves."
    "Casi puedo ver sus mentes trabajando detrás de esos rostros vacíos, grabando cada una de mis palabras en su subconsciente, así lo quieran o no."

# game/Kyou 6.rpy:3088
translate spanish Day6_Villain_Kyou_7984e08b:

    # "And despite everything that just happened, I'm confident that they'll have no trouble at all accepting their new reality."
    "Y a pesar de todo lo que pasó, confío en que no tendrán problemas en aceptar su nueva realidad."

# game/Kyou 6.rpy:3089
translate spanish Day6_Villain_Kyou_e9014dc5:

    # ks frown "That's right, girls, you remember now. During our lunch yesterday, I asked if you wanted to hang out this weekend, and you agreed along with Nozomi."
    ks frown "Eso es, chicas, ya lo recuerdan. Ayer, durante el almuerzo, les pregunté si querían venir este fin de semana, y tanto ustedes como Nozomi accedieron."

# game/Kyou 6.rpy:3090
translate spanish Day6_Villain_Kyou_09606126:

    # ks "So you all arrived together and we're just having a great time, even if Nozomi totally got the wrong idea about our play fighting just now."
    ks "Llegaron todas juntas, y nos la pasamos genial, aunque Nozomi malinterpretó nuestro juego de luchitas."

# game/Kyou 6.rpy:3091
translate spanish Day6_Villain_Kyou_5462c102:

    # ks "But let's not worry about Nozomi for now. You're here with me, and you're very comfortable and happy to be here, enjoying your time with me."
    ks "Pero no nos preocupemos por Nozomi por ahora. Están aquí conmigo, muy cómodas y felices de estar aquí, disfrutando pasar su tiempo conmigo."

# game/Kyou 6.rpy:3092
translate spanish Day6_Villain_Kyou_32bc4294:

    # ks "You're having such a good, happy time at my home, aren't you, girls?"
    ks "Están muy felices y se la están pasando muy bien en mi casa, ¿no es cierto, chicas?"

# game/Kyou 6.rpy:3093
translate spanish Day6_Villain_Kyou_32973a27:

    # s entranced_talk_right "Yes... Such a good, happy time..." with dissolve
    s entranced_talk_right "Sí... Muy bien, muy felices..." with dissolve

# game/Kyou 6.rpy:3094
translate spanish Day6_Villain_Kyou_469b8e45:

    # h entranced_talk "So good..." with dissolve
    h entranced_talk "Muy bien..." with dissolve

# game/Kyou 6.rpy:3097
translate spanish Day6_Villain_Kyou_fa4acc9b:

    # "Gotta say, their easy compliance is encouraging. And it gives me another thought." with dissolve
    "Debo decir que verlas obedecer tan fácilmente es alentador. Y eso me hace pensar:" with dissolve

# game/Kyou 6.rpy:3098
translate spanish Day6_Villain_Kyou_4d0a85e3:

    # "I want to break these girls. I want to make sure they never even think of opposing me ever again."
    "Quiero romper a estas chicas. Quiero asegurarme de que nunca vuelvan a pensar en oponerse a mí."

# game/Kyou 6.rpy:3099
translate spanish Day6_Villain_Kyou_0dc2aca0:

    # "And perhaps I may even break Nozomi in the bargain..."
    "Y quizá también pueda romper a Nozomi en el proceso..."

# game/Kyou 6.rpy:3100
translate spanish Day6_Villain_Kyou_da0af27a:

    # ks smirk "Perhaps you should both try laughing, to show me how much fun you're having."
    ks smirk "Tal vez ambas deberían reír, para demostrar cuánto se están divirtiendo."

# game/Kyou 6.rpy:3101
translate spanish Day6_Villain_Kyou_211a5032:

    # ks "So easy to laugh now. Feeling so happy, so free of cares or worries."
    ks "Es muy fácil reír cuando se sienten tan felices, tan libres de angustias y preocupaciones."

# game/Kyou 6.rpy:3102
translate spanish Day6_Villain_Kyou_c7aeec3b:

    # ks "Just laughing so naturally now. Easiest thing in the world, as you let your every remaining thought leave your heads with your free and easy laughter."
    ks "Ahora mismo, reír es tan natural. Es lo más fácil del mundo dejar que cualquier pensamiento que les quede desaparezca de sus cabezas con una risa liberadora."

# game/Kyou 6.rpy:3111
translate spanish Day6_Villain_Kyou_9e27fcc5:

    # "The two of them erupt almost simultaneously as I watch; their light and happy giggles in stark contrast to the emptiness of their eyes." with dissolve
    "Las dos estallan casi simultáneamente mientras las observo; sus brillantes y alegres carcajadas contrastan con el vacío de sus ojos." with dissolve

# game/Kyou 6.rpy:3112
translate spanish Day6_Villain_Kyou_489034e8:

    # ks smirk "That's right, and as you laugh so freely, you can imagine all your hostility and resistance to me ebbing away."
    ks smirk "Eso es. Y al reír tan libremente, imaginen toda su hostilidad y resistencia contra mí menguándose."

# game/Kyou 6.rpy:3113
translate spanish Day6_Villain_Kyou_a1334ce8:

    # h "Ahahahahahahaha~"
    h "Jajajajajajajaja."

# game/Kyou 6.rpy:3114
translate spanish Day6_Villain_Kyou_b1bb588c:

    # s "Hehe... Eheheheheh~"
    s "Jeje... Jejejejeje."

# game/Kyou 6.rpy:3115
translate spanish Day6_Villain_Kyou_e1265504:

    # ks "Just laughing it all away now... good girls."
    ks "Que la risa lo saque todo... buenas chicas."

# game/Kyou 6.rpy:3117
translate spanish Day6_Villain_Kyou_0d5bbb35:

    # "Satisfied, I then move back to my living room window before pulling it open, as I still spy Nozomi across the street."
    "Satisfecho, regreso a la ventana de mi sala y la abro. Aún puedo ver a Nozomi cruzando la calle."

# game/Kyou 6.rpy:3118
translate spanish Day6_Villain_Kyou_a1334ce8_1:

    # h "Ahahahahahahaha~"
    h "Jajajajajajajaja."

# game/Kyou 6.rpy:3119
translate spanish Day6_Villain_Kyou_c5be64cb:

    # "She's still anxiously waiting with her phone pressed against her ear, but looks across to me startled as the helpless giggling of my thralls spill out of the house."
    "Sigue esperando ansiosamente con su teléfono en la oreja, pero me mira atemorizada, escuchando las risas desamparadas de mis esclavas emanando de mi casa."

# game/Kyou 6.rpy:3121
translate spanish Day6_Villain_Kyou_7955576d:

    # ks frown "Yeah, listen to that, Nozomi."
    ks frown "Sí, escúchalo bien, Nozomi."

# game/Kyou 6.rpy:3122
translate spanish Day6_Villain_Kyou_44bb39d4:

    # s "Heeheehehehehee~"
    s "Jijijejejee."

# game/Kyou 6.rpy:3123
translate spanish Day6_Villain_Kyou_433b68a4:

    # ks "You really think you can stop me? Like those cops are gonna do shit? Don't make me laugh."
    ks "¿De verdad crees que puedes detenerme? Como si esos policías fueran a hacer una mierda. No me hagas reír. "

# game/Kyou 6.rpy:3124
translate spanish Day6_Villain_Kyou_735c72d3:

    # h "AAAHAHAHAHAHAHAHA!!" with vpunch
    h "¡¡AAAJAJAJAJAJAJAJA!!" with vpunch

# game/Kyou 6.rpy:3125
translate spanish Day6_Villain_Kyou_8c393c3c:

    # ks "I'll deal with them, and then you'll find out how helpless you really are..."
    ks "Me encargaré de ellas, y entonces sabrás lo impotente que realmente eres..."

# game/Kyou 6.rpy:3135
translate spanish Day6_Villain_Kyou_66435268:

    # s "... So I am sorry to say that you were called out here for nothing, officer."
    s "... Así que lamento que haya tenido que venir para nada, oficial."

# game/Kyou 6.rpy:3136
translate spanish Day6_Villain_Kyou_38b23feb:

    # "Yeah, it turned out Nozomi really did try to sic the cops on me."
    "Sí, al final Nozomi sí trató de acusarme con la policía."

# game/Kyou 6.rpy:3138
translate spanish Day6_Villain_Kyou_a8445f3f:

    # t "So you're telling me the four of you were just hanging out, then you and the little lady here started roughhousing. That's it?"
    t "De modo que ustedes cuatro solo estaban pasando el rato, y entonces la señorita empezó a jugar rudo. ¿Eso es todo?"

# game/Kyou 6.rpy:3140
translate spanish Day6_Villain_Kyou_627add3e:

    # ks casual frown "That's it, officer." with dissolve
    ks casual frown "Así es, oficial." with dissolve

# game/Kyou 6.rpy:3141
translate spanish Day6_Villain_Kyou_a7b90324:

    # t "Pretty nasty bruise you got there, sweetheart."
    t "Tienes un moretón muy grande, cariño."

# game/Kyou 6.rpy:3531
translate spanish Day6_Villain_Kyou_bca6bce8:

    # h sad "Yeah, I got my nose bopped. It was an accident but ain't gonna lie, it hurts like a bitch." with dissolve
    h sad "Seh, me pegué en la nariz. Fue un accidente, pero no mentiré, dolió como el carajo." with dissolve

# game/Kyou 6.rpy:3143
translate spanish Day6_Villain_Kyou_109d77b3:

    # "Just as well I had plenty of time to prepare the girls before they got here."
    "Lo bueno es que tuve tiempo de sobra para preparar a las chicas antes de que llegara."

# game/Kyou 6.rpy:3144
translate spanish Day6_Villain_Kyou_d5739bf0:

    # h sleeptalk_concerned "I screamed pretty loud when I took the hit and, uh, Nozo seriously freaked out when I did." with dissolve
    h sleeptalk_concerned "Grité muy fuerte cuando me golpeé y, eh, Nozo sí que se paniqueó." with dissolve

# game/Kyou 6.rpy:3145
translate spanish Day6_Villain_Kyou_7037ac9b:

    # s casual_folded concerned_right "That seems to be the case. I have no doubt that Nozomi genuinely felt she was witnessing an assault in progress." with dissolve
    s casual_folded concerned_right "Ese parece ser el caso. No tengo duda de que Nozomi genuinamente sintió que estaba presenciando una agresión en progreso." with dissolve

# game/Kyou 6.rpy:3146
translate spanish Day6_Villain_Kyou_27239a83:

    # h surprised "But I'm tellin' you, it was totally an accident! Nozo's just being dumb." with dissolve
    h surprised "¡Pero se lo juro que fue un accidente! Nozo solo está tonteando." with dissolve

# game/Kyou 6.rpy:3147
translate spanish Day6_Villain_Kyou_039a0df9:

    # s sleeptalk_concerned "There was surely no ill-intent on her part. Just a terrible misunderstanding." with dissolve
    s sleeptalk_concerned "No tuvo malas intenciones. Solo fue un terrible malentendido." with dissolve

# game/Kyou 6.rpy:3148
translate spanish Day6_Villain_Kyou_99377a74:

    # t "*sigh* Alright, gotcha. Seems there's nothing to investigate, but if any of you feel like talking drop by at the station anytime."
    t "*suspiro* Muy bien, entiendo. Perece que no hay nada que investigar, pero si alguna de ustedes tiene ganas de hablar, pueden ir a la estación cuando quieran."

# game/Kyou 6.rpy:3151
translate spanish Day6_Villain_Kyou_86b1babf:

    # "Obviously he directed that at the girls. Maybe he didn't completely buy Hiroko's roughhousing excuse; her nose really is bruising up now." with dissolve
    "\"Alguna\". Tal vez no se tragó por completo la excusa de Hiroko jugando rudo; el moretón de su nariz sí que es bastante grande." with dissolve

# game/Kyou 6.rpy:3152
translate spanish Day6_Villain_Kyou_bd9d21c5:

    # t "Hey, before I go... You're Watanabe's kid, aren't you?"
    t "Oye, antes de que me vaya... Tú eres la hija de Watanabe, ¿no?"

# game/Kyou 6.rpy:3153
translate spanish Day6_Villain_Kyou_6d561bf8:

    # s smile_right "Ah, yes I am." with dissolve
    s smile_right "Ah, sí, esa soy yo." with dissolve

# game/Kyou 6.rpy:3154
translate spanish Day6_Villain_Kyou_c1d6ed5b:

    # ks casual surprised "Huh?"
    ks casual surprised "¿Eh?"

# game/Kyou 6.rpy:3155
translate spanish Day6_Villain_Kyou_6cc67f56:

    # s casual "My dad is a sergeant at our local police department, Kyou." with dissolve
    s casual "Mi papá es sargento en el departamento de policía local, Kyou." with dissolve

# game/Kyou 6.rpy:3156
translate spanish Day6_Villain_Kyou_8b2a417f:

    # "Shit, seriously? That's interesting... Maybe I can use that."
    "Mierda, ¿en serio? Qué interesante... Eso podría serme útil."

# game/Kyou 6.rpy:3157
translate spanish Day6_Villain_Kyou_a6c84704:

    # t "In that case he can do the paperwork on this. I'm outta here."
    t "En ese caso, que él haga el papeleo. Yo me voy."

# game/Kyou 6.rpy:3158
translate spanish Day6_Villain_Kyou_b40a505a:

    # t "Stay safe, kids."
    t "Quédense a salvo, niños."

# game/Kyou 6.rpy:3159
translate spanish Day6_Villain_Kyou_4f92e095:

    # h smile "Seeya." with dissolve
    h smile "’Ta luego." with dissolve

# game/Kyou 6.rpy:3161
translate spanish Day6_Villain_Kyou_d457ee06:

    # "As the inquisition leaves us I breathe a heavy sigh of relief."
    "Cuando la investigación termina, suelto un fuerte suspiro de alivio."

# game/Kyou 6.rpy:3163
translate spanish Day6_Villain_Kyou_67f417ff:

    # s concerned "We should talk to Nozomi. I am sure she feels awful about all of this." with dissolve
    s concerned "Deberíamos hablar con Nozomi. Estoy segura de que se siente terrible con todo esto." with dissolve

# game/Kyou 6.rpy:3164
translate spanish Day6_Villain_Kyou_79412c42:

    # h sad_side "Yeah. I'm gonna give her a call right n-{w=1.0}{nw}" with dissolve
    h sad_side "Sí. Voy a llamarla ahora m-{w=1.0}{nw}" with dissolve

# game/Kyou 6.rpy:3167
translate spanish Day6_Villain_Kyou_e84459a7:

    # "And just then the pair of them feel my hands as I slap them down on their shoulders." with vpunch
    "De pronto, el par siente mis manos sobre sus hombros." with vpunch

# game/Kyou 6.rpy:3168
translate spanish Day6_Villain_Kyou_ef0f3150:

    # s "Kyou?!"
    s "¡¿Kyou?!"

# game/Kyou 6.rpy:3169
translate spanish Day6_Villain_Kyou_c801caa7:

    # ks frown "Listen and obey, and be quiet."
    ks frown "Es hora de escuchar y obedecer, y guardar silencio."

# game/Kyou 6.rpy:3172
translate spanish Day6_Villain_Kyou_7eff629c:

    # "Any hint of questioning or protest dies on their lips as their expressions almost immediately fall slack." with dissolve
    "Toda señal de duda y protesta perece en sus labios, y sus expresiones casi inmediatamente se apagan." with dissolve

# game/Kyou 6.rpy:3173
translate spanish Day6_Villain_Kyou_a468fe06:

    # "It's been a shitty morning, but at least I can take some satisfaction in that."
    "Ha sido una mañana de mierda, pero esto al menos me trae algo de satisfacción."

# game/Kyou 6.rpy:3174
translate spanish Day6_Villain_Kyou_869bc2fd:

    # ks "That's right, girls. It's so instinctual to drop deep the moment you hear me speak that phrase now."
    ks "Eso es, chicas. Es instintivo caer muy profundo en cuanto me escuchan decir esa frase."

# game/Kyou 6.rpy:3175
translate spanish Day6_Villain_Kyou_a891d864:

    # ks "So natural to listen to my voice, my words, finding yourself so incredibly attentive to anything I have to say."
    ks "Es muy natural escuchar mi voz, mis palabras, y prestar mucha atención a todo lo que digo."

# game/Kyou 6.rpy:3176
translate spanish Day6_Villain_Kyou_d1967382:

    # ks "And as attentive as you are, you'll find you have no trouble accepting the fact that you no longer care about Nozomi."
    ks "Y al prestar tanta atención, no tendrán ningún problema en aceptar el hecho de que ya no les importa Nozomi."

# game/Kyou 6.rpy:3177
translate spanish Day6_Villain_Kyou_5ece33ef:

    # ks "There's no need to feel concern for her. No need to contact her."
    ks "No hay necesidad de preocuparse por ella. No hay necesidad de contactarla."

# game/Kyou 6.rpy:3178
translate spanish Day6_Villain_Kyou_1e3ed05f:

    # ks "She is just another classmate to you now. Nothing more. Understand, girls?"
    ks "Es simplemente una compañera más. Solo eso. ¿Comprenden, chicas?"

# game/Kyou 6.rpy:3181
translate spanish Day6_Villain_Kyou_9eb50284:

    # h "Yeah..." with dissolve
    h "Seh..." with dissolve

# game/Kyou 6.rpy:3182
translate spanish Day6_Villain_Kyou_08384980:

    # s "Just another classmate..."
    s "Una compañera más..."

# game/Kyou 6.rpy:3185
translate spanish Day6_Villain_Kyou_f19c4c0c:

    # "I mean, let's face it. She'll never confide in you two again anyway. Not until I get her back. You'd just get in my way." with dissolve
    "Digo, afrontémoslo. Nunca volverá a confiar en ustedes dos de todos modos. No hasta que la recupere. Solo se meterían en mi camino." with dissolve

# game/Kyou 6.rpy:3186
translate spanish Day6_Villain_Kyou_38b428fe:

    # ks "That's right. There's no need to think, just understand this is how it is."
    ks "Eso es. No hace falta pensar, solo comprender que así es como son las cosas."

# game/Kyou 6.rpy:3188
translate spanish Day6_Villain_Kyou_34282241:

    # "Besides, I have better uses for you two..."
    "Además, tengo un mejor uso para ustedes dos..."

# game/Kyou 6.rpy:3191
translate spanish Day6_Villain_Kyou_51c4650b:

    # nvl_narrator "The days started to pass quickly as I threw myself into my work."
    nvl_narrator "Los días comenzaron a pasar rápidamente cuando me puse a trabajar."

# game/Kyou 6.rpy:3192
translate spanish Day6_Villain_Kyou_a652091a:

    # nvl_narrator "Now fully confident of my ability to insert whatever realities I wished into my hypnotized subjects, I used Sayori and Hiroko to gather information for me and isolate the members of their respective school clubs for me to hypnotize."
    nvl_narrator "Ahora, teniendo completa confianza en mi habilidad para insertar la realidad que me plazca en mis sujetos con hipnosis, usé a Sayori y Hiroko para reunir información para mí y aislar a los miembros de sus respectivos clubes para hipnotizarlos."

# game/Kyou 6.rpy:3193
translate spanish Day6_Villain_Kyou_34cd7d2e:

    # nvl_narrator "Every new subject that came into my reach proved just as easy to hypnotize with the penlight. Just as easy to manipulate into becoming another of my sleeper agents."
    nvl_narrator "Cada nuevo sujeto que llegaba a mis garras probó ser igual de fácil de hipnotizar con mi linterna. Igual de fácil de manipular y de convertir en otro de mis agentes durmientes."

# game/Kyou 6.rpy:3195
translate spanish Day6_Villain_Kyou_595a555a:

    # nvl clear
    # nvl_narrator "Every new acquisition made the next one easier. And the next one... Before too long I had every student and faculty member in my thrall."
    nvl clear
    nvl_narrator "Cada nueva adquisición hizo que la siguiente fuera más fácil. Y la siguiente... No tardé mucho en tener a cada estudiante de la facultad a mi servicio."

# game/Kyou 6.rpy:3197
translate spanish Day6_Villain_Kyou_1f99f76d:

    # nvl_narrator "... Except for Nozomi. I never saw her again after that day. I found out that she somehow convinced her parents to pull her out of school and go into private tutoring or something. By the end of the year they moved out of town."
    nvl_narrator "... Excepto a Nozomi. No la volví a ver después de ese día. Descubrí que logró convencer a sus padres de sacarla de la escuela y mandarla a tutorías privadas o algo. Para el final del año, se mudaron de la ciudad."

# game/Kyou 6.rpy:3198
translate spanish Day6_Villain_Kyou_b9bc7c22:

    # nvl_narrator "It shouldn't bother me because I have bigger fish to fry, but... It fucking does. She got away from me."
    nvl_narrator "No debería importarme, pues tengo un pez más gordo, pero... mierda, claro que me importa. Dejé que se me escapara."

# game/Kyou 6.rpy:3200
translate spanish Day6_Villain_Kyou_76b2fe88:

    # nvl clear
    nvl clear

# game/Kyou 6.rpy:3202
translate spanish Day6_Villain_Kyou_1f549c87:

    # nvl_narrator "Now that I have full run of the school I'm going to see where else I can go. Maybe get into local government. I could rule this whole town and beyond and no one would need to consciously know anything about it if I keep careful."
    nvl_narrator "Ahora que tengo control total de la escuela, veré adónde más puedo llegar. Tal vez me adentre al gobierno local. Podría gobernar toda la ciudad y más, y nadie tendrá que saberlo consicentemente, si tengo cuidado."

# game/Kyou 6.rpy:3203
translate spanish Day6_Villain_Kyou_a6e107bc:

    # nvl_narrator "I mean, if I can just keep going like this, I could be a genuine ruler from the shadows."
    nvl_narrator "Quiero decir, si sigo así, puedo ser un verdadero gobernante desde las sombras."

# game/Kyou 6.rpy:3205
translate spanish Day6_Villain_Kyou_76b2fe88_1:

    # nvl clear
    nvl clear

# game/Kyou 6.rpy:3207
translate spanish Day6_Villain_Kyou_b24864ee:

    # nvl_narrator "It won't matter then, if people still ignore me. I'll have the real power around here."
    nvl_narrator "Entonces no importará si la gente me sigue ignorando. Yo tendré el verdadero poder por aquí."

# game/Kyou 6.rpy:3208
translate spanish Day6_Villain_Kyou_cf2df8d9:

    # nvl_narrator "It's fine if the only ones who'll hang on my every word are the ones who fell under the full glow of my penlight."
    nvl_narrator "Está bien si los únicos que atenderán cada una de mis palabras son aquellos que cayeron bajo el brillo de mi linterna."

# game/Kyou 6.rpy:3209
translate spanish Day6_Villain_Kyou_bc4f2d51:

    # nvl_narrator "Who cares if people still treat me with contempt in public? I could have them destroyed with just a few words to my loyal agents."
    nvl_narrator "¿A quién le importa si la gente sigue tratándome con desprecio en público? Podría hacer que mis leales agentes los destruyan a todos con unas cuantas palabras."

# game/Kyou 6.rpy:3211
translate spanish Day6_Villain_Kyou_ef2bff18:

    # nvl clear
    # nvl_narrator "I don't NEED anyone to love me anymore. Not Nozomi, not the dozens of cute girls I now have in my service. No one."
    nvl clear
    nvl_narrator "Ya no NECESITO que nadie me ame. Ni Nozomi, ni las otras docenas de chicas lindas que tengo a mi servicio. Nadie."

# game/Kyou 6.rpy:3213
translate spanish Day6_Villain_Kyou_4f63bd25:

    # nvl_narrator "I have a power no one else has. That'll always make me somebody."
    nvl_narrator "Tengo un poder que nadie más tiene. Eso siempre me hará alguien."

# game/Kyou 6.rpy:3214
translate spanish Day6_Villain_Kyou_0ed79932:

    # nvl_narrator "That'll always... that'll always be good enough for me..."
    nvl_narrator "Eso siempre... eso siempre será suficiente para mí..."

