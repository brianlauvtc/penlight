    # extend "SO fucked up!" with vpunch
    extend "JODAS!" with vpunch

# game/Kyou 6.rpy:3224
translate spanish Day6_Con_Kyou_Nozomi_6b676527:

    # h sad_side "And, uh, wait, is he controlling you right now or what?" with dissolve
    h sad_side "Y, eh, espera, ¿te está controlando la mente ahora o qué?" with dissolve

# game/Kyou 6.rpy:3226
translate spanish Day6_Con_Kyou_Nozomi_f29f7024:

    # n casual side sad "Uh, no. Like I said, he gave me a way of undoing everything he did in our sessions. And I made use of it right before you entered." with dissolve
    n casual side sad "Eh, no. Como dije, me dio una forma de deshacer todo lo que hizo en nuestras sesiones. E hice use de ella justo antes de que entraran." with dissolve

# game/Kyou 6.rpy:3227
translate spanish Day6_Con_Kyou_Nozomi_0a878bc1:

    # s frown "... Does it, though?" with dissolve
    s frown "... ¿Y funciona?" with dissolve

# game/Kyou 6.rpy:3228
translate spanish Day6_Con_Kyou_Nozomi_3344d30e:

    # n sad_side "What do you mean?" with dissolve
    n sad_side "¿A qué te refieres?" with dissolve

# game/Kyou 6.rpy:3229
translate spanish Day6_Con_Kyou_Nozomi_7d4f3dbd:

    # s "I admit I know little of hypnosis, so perhaps I am off base here..."
    s "Admito que sé poco sobre hipnosis, así que puede que me equivoque..."

# game/Kyou 6.rpy:3230
translate spanish Day6_Con_Kyou_Nozomi_694716e4:

    # s annoyed "But do you not think it possible that you merely BELIEVE everything has been undone?" with dissolve
    s annoyed "¿Pero crees que sea posible que simplemente CREAS que todo ha sido deshecho?" with dissolve

# game/Kyou 6.rpy:3231
translate spanish Day6_Con_Kyou_Nozomi_30731dea:

    # s "Because what you have told us suggests he has had unfettered access to your mind."
    s "Porque lo que me has dicho siguiere que tiene acceso a tu mente sin restricciones."

# game/Kyou 6.rpy:3233
translate spanish Day6_Con_Kyou_Nozomi_3d8c8d43:

    # s "He was able to make you forget something as fundamental as a number, and he can compel you to do things even if you actively resist."
    s "Fue capaz de hacerte olvidar algo tan fundamental como un número, y puede obligarte a hacer cosas a las que activamente te resistas."

# game/Kyou 6.rpy:3235
translate spanish Day6_Con_Kyou_Nozomi_bb6d4208:

    # s "He was able to make you forget something as fundamental as your own name, and he can compel you to do things even if you actively resist."
    s "Fue capaz de hacerte olvidar algo tan fundamental como tu propio nombre, y puede obligarte a hacer cosas a las que activamente te resistas."

# game/Kyou 6.rpy:3236
translate spanish Day6_Con_Kyou_Nozomi_f7fc9616:

    # s frown_right "So tell me, what was stopping him from making you merely believe you're free of his control? Can either of you answer me that?" with dissolve
    s frown_right "Así que dime, ¿qué lo detenía de hacerte simplemente creer que estás libre de su control? ¿Puede alguno de ustedes contestarme eso?" with dissolve

# game/Kyou 6.rpy:3237
translate spanish Day6_Con_Kyou_Nozomi_2cfe36eb:

    # n "Uh... w-well..."
    n "Eh... p-pues..."

# game/Kyou 6.rpy:3238
translate spanish Day6_Con_Kyou_Nozomi_c04f25d1:

    # ks sigh "Nothing. Nothing was stopping me."
    ks sigh "Nada. Nada me detenía."

# game/Kyou 6.rpy:3240
translate spanish Day6_Con_Kyou_Nozomi_3f2fa74d:

    # n front concerned casual "Kyou..." with dissolve
    n front concerned casual "Kyou..." with dissolve

# game/Kyou 6.rpy:3241
translate spanish Day6_Con_Kyou_Nozomi_3d9fa7f8:

    # ks "It's true though, isn't it? I didn't think about it to start, because I always thought you could protect yourself if I tried anything you didn't want."
    ks "Pero es cierto, ¿no? No pensaba en ello al principio, porque siempre creí que podrías protegerte si intentaba algo que no quisieras."

# game/Kyou 6.rpy:3242
translate spanish Day6_Con_Kyou_Nozomi_cfa7e785:

    # n "You mean like, a hidden observer effect? I was thinking that too."
    n "¿Te refieres al efecto del observador oculto? Yo también estaba pensando en eso."

# game/Kyou 6.rpy:3243
translate spanish Day6_Con_Kyou_Nozomi_4bbd92f1:

    # h frown "What're you talking about? \"Hidden observer\"?" with dissolve
    h frown "¿De qué hablan? ¿\"Observador oculto\"?" with dissolve

# game/Kyou 6.rpy:3244
translate spanish Day6_Con_Kyou_Nozomi_c552c62f:

    # n pout_left "Uh... Well, it's like how even when you're hypnotized there's still a part of you that's aware of everything that's happening?" with dissolve
    n pout_left "Eh... Pues es como, aunque estés hipnotizado, siempre hay una parte de ti que sabe qué está pasando." with dissolve

# game/Kyou 6.rpy:3245
translate spanish Day6_Con_Kyou_Nozomi_a1456d8b:

    # n "So if your hypnotist tries to suggest something unethical or just something you disagree with you still have the ability to ignore the suggestion, or explicitly reject it."
    n "Así que si tu hipnotista intenta sugerir algo que no sea ético o algo con lo que no estés de acuerdo, tienes la habilidad de ignorar la sugestión o rechazarla explícitamente."

# game/Kyou 6.rpy:3246
