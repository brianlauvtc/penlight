    # ks surprised "H-hey Nozomi, shh, calm down. We're in public."
    ks surprised "E-ey, Nozomi, chist, cálmate. Estamos en público."

# game/Kyou 6.rpy:1189
translate spanish Day6_Villain_Kyou_83dd00d2:

    # n "You hurt one of my closest friends, Kyou. Because you couldn't have ME!"
    n "Le hiciste daño a una de mis más cercanas amigas, Kyou. ¡Porque no podías tenerme a MÍ!"

# game/Kyou 6.rpy:1188
translate spanish Day6_Villain_Kyou_c53314f3:

    # ks frown "Hey, when I said calm, I meant it. Please? We're just calmly having a conversation here."
    ks frown "Oye, cuando dije que te calmaras, era en serio. ¿Por favor? Simplemente estamos teniendo una conversación calmada."

# game/Kyou 6.rpy:1189
translate spanish Day6_Villain_Kyou_c8aeb1a6:

    # n irritated "How is she, anyway?" with dissolve
    n irritated "¿Cómo está?, a todo esto." with dissolve

# game/Kyou 6.rpy:1190
translate spanish Day6_Villain_Kyou_c59976f5:

    # ks "Who?"
    ks "¿Quién?"

# game/Kyou 6.rpy:1196
translate spanish Day6_Villain_Kyou_a048ec9c:

    # n "Hiroko. I heard she's your number one fan now. Can't imagine how that happened."
    n "Hiroko. Escuché que ahora es tu fan número uno. No me puedo imaginar cómo pasó."

# game/Kyou 6.rpy:1198
translate spanish Day6_Villain_Kyou_8ceaed3a:

    # n "She even tried to lure me to my favourite karaoke place. Just me and her. You wouldn't happen to know about that, would you?" with dissolve
    n "Hasta intentó atraerme a mi karaoke favorito. Solo ella y yo. De casualidad no sabrás algo de eso, ¿o sí?" with dissolve

# game/Kyou 6.rpy:1195
translate spanish Day6_Villain_Kyou_b9eeffa3:

    # ks neutral "I don't see the problem. You like karaoke, right? Sounds like she was thinking to calm you down."
    ks neutral "No veo el problema. Te gusta el karaoke, ¿verdad? Me suena a que tenía pensado calmarte."

# game/Kyou 6.rpy:1196
translate spanish Day6_Villain_Kyou_98c9751f:

    # n frown "The problem is she wouldn't take no for an answer. But she's always respected my wishes in the past." with dissolve
    n frown "El problema es que no aceptaba un no por respuesta. Pero siempre ha respetado mis deseos en el pasado." with dissolve

# game/Kyou 6.rpy:1197
translate spanish Day6_Villain_Kyou_578d2bb2:

    # ks "Are you sure you weren't overthinking things? It sounds to me like you just saw her in a bad light."
    ks "¿Estás segura de que no lo estás pensando demasiado? Tal vez tu visión estaba un poco distorsionada."

# game/Kyou 6.rpy:1204
translate spanish Day6_Villain_Kyou_00dd337a:

    # n "Don't patronize me. I KNOW Hiroko." with dissolve
    n "No me seas condescendiente. Yo CONOZCO a Hiroko." with dissolve

# game/Kyou 6.rpy:1199
translate spanish Day6_Villain_Kyou_36686e6b:

    # ks "I'm sorry. I just want you to think things through calmly, and not make any rash judgements."
    ks "Lo siento. Solo quiero que pienses las cosas con calma, y que no hagas ningún juicio precipitado."

# game/Kyou 6.rpy:1207
translate spanish Day6_Villain_Kyou_365a1a9a:

    # n "I'm not doing anything rash. If anything I'm being far too reasonable giving you the time of day like this." with dissolve
    n "No estoy haciendo nada precipitado. Si acaso estoy siendo demasiado razonable al cederte así mi tiempo." with dissolve

# game/Kyou 6.rpy:1201
translate spanish Day6_Villain_Kyou_35faf5cc:

    # ks "Were you calm when you decided to quit school because of me?"
    ks "¿Estabas calmada cuando decidiste dejar la escuela por causa mía?"

# game/Kyou 6.rpy:1202
translate spanish Day6_Villain_Kyou_46523e13:

    # n surprised "... How do you know about that?" with dissolve
    n surprised "... ¿Cómo sabes eso?" with dissolve

# game/Kyou 6.rpy:1203
translate spanish Day6_Villain_Kyou_63faad25:

    # ks "Calm yourself, it doesn't matter. All that matters is that you stay calm for me."
    ks "Calma, eso no importa. Lo único que importa es que estés calmada para mí."

# game/Kyou 6.rpy:1204
translate spanish Day6_Villain_Kyou_ab199b00:

    # n neutral "I'm not... I'm not doing this; how are you doing this?" with dissolve
    n neutral "No... No pienso hacer esto; ¿cómo estás haciendo esto?" with dissolve

# game/Kyou 6.rpy:1205
translate spanish Day6_Villain_Kyou_54bc03c5:

    # ks "Shh, there's no need to worry about that, Nozomi. You just need to stay calm. Calmer, as your mind and body drop down. Dropping deep..."
    ks "Shh, no hace falta preocuparse por eso, Nozomi. Solo tienes que estar calmada. Más y más calmada. Y dejar que tu cuerpo y tu mente caigan. Que caigan muy profundo…"

# game/Kyou 6.rpy:1217
translate spanish Day6_Villain_Kyou_4707b871:

    # n drowsy "I... S-somebody help..."
    n drowsy "Ah… Qu-que alguien… me ayude…"

# game/Kyou 6.rpy:1207
translate spanish Day6_Villain_Kyou_6307b64b:

    # ks "Deeper. Even the hustle and bustle around us is making you calm, Nozomi. Helping you drop even deeper."
    ks "Más y más profundo. Hasta el ajetreo y el bullicio a nuestro alrededor hace que estés más calmada, Nozomi. Te ayuda a caer más profundo. "

# game/Kyou 6.rpy:1220
translate spanish Day6_Villain_Kyou_63610f95:

    # ks "Keeping your eyes wide open and your body stuck to the chair,{nw}" with dissolve
    ks "Mantén tus ojos bien abiertos y tu cuerpo firme en la silla, {nw}" with dissolve

# game/Kyou 6.rpy:1223
translate spanish Day6_Villain_Kyou_80e8eddb:

    # extend "staying nice and calm as you... {w=0.5}{nw}"
    extend "completamente calmada y… {w=0.5}{nw}"

# game/Kyou 6.rpy:1230
translate spanish Day6_Villain_Kyou_adaafcad:

    # extend "{w=0.2}{nw}"
    extend "{w=0.2}{nw}"

# game/Kyou 6.rpy:1238
translate spanish Day6_Villain_Kyou_7354df5d:

    # extend " sleep for me."
    extend " duerme para mí."

# game/Kyou 6.rpy:1214
translate spanish Day6_Villain_Kyou_4dc0b55a:

    # "As I snap my fingers I smile delightedly as Nozomi's arms untangle and fall into her lap while her eyes quickly glaze over."
    "Y al chasquear los dedos, sonrío encantado de ver los brazos de Nozomi desenredarse y caer en su regazo, mientras que sus ojos sin demora se ponen vidriosos."

# game/Kyou 6.rpy:1216
translate spanish Day6_Villain_Kyou_622c4d76:

    # ks smile "Very good, Nozomi. We look just like any other young couple on a date."
    ks smile "Muy bien, Nozomi. Parecemos una pareja teniendo una cita como cualquier otra."

# game/Kyou 6.rpy:1217
translate spanish Day6_Villain_Kyou_403033d9:

    # ks "So long as we don't raise our voice or make any rash movements we'll be beneath anyone's notice."
    ks "Siempre y cuando no alces la voz y no hagas ningún movimiento brusco, nadie nos notará."

# game/Kyou 6.rpy:1218
translate spanish Day6_Villain_Kyou_2fe7b5ab:

    # ks "And you won't be doing that now, will you, Nozomi? No, you won't."
    ks "Y no harás eso ahora, ¿o sí, Nozomi? No, claro que no."

# game/Kyou 6.rpy:1219
translate spanish Day6_Villain_Kyou_108ce133:

    # "It's true. There are people walking past us in the street, people coming and going from the café, but no-one seems to be doing more than glance our way."
    "Es cierto. Hay transeúntes rodeándonos, gente entrando y saliendo del café, pero nadie parece hacer más que darnos uno que otro vistazo."

# game/Kyou 6.rpy:1220
translate spanish Day6_Villain_Kyou_c4c05041:

    # "And I gotta say, all this power-tripping I've been doing over the last few days has done wonders for my social anxiety."
    "Y he de decir que este viaje en busca de poder que he estado haciendo estos últimos días ha hecho maravillas con mi ansiedad social."

# game/Kyou 6.rpy:1246
translate spanish Day6_Villain_Kyou_26ed7633:

    # ks "I'm sure somewhere in there you're wondering how this happened."
    ks "Estoy seguro de que, por ahí, en algún lado, te sigues preguntando cómo es que esto pasó."

# game/Kyou 6.rpy:1222
translate spanish Day6_Villain_Kyou_7f967fb4:

    # ks "But you don't need to worry, Nozomi. Everything is fine. Just focus on dropping deeper for me."
    ks "Pero no tienes que preocuparte, Nozomi. Todo está bien. Solo concéntrate en caer más profundo para mí."

# game/Kyou 6.rpy:1223
translate spanish Day6_Villain_Kyou_75156f9e:

    # ks "Feeling so good. Feeling so right. Letting the ambient noise of the street pull you deeper. Always deeper."
    ks "Se siente tan bien. Se siente tan correcto. Deja que el sonido de ambiente de las calles te lleve más profundo. Siempre más profundo."

# game/Kyou 6.rpy:1224
translate spanish Day6_Villain_Kyou_5f5449d8:

    # ks "And as you go deeper, feel the corners of your mouth curling upwards. So easy to form a smile on your lips as you stay deeply asleep."
    ks "Y mientras caes más profundo, siente cómo las esquinas de tu boca se curvan hacia arriba. Es tan fácil dibujar una sonrisa en tus labios, siguiendo profundamente dormida."

# game/Kyou 6.rpy:1226
translate spanish Day6_Villain_Kyou_40469e39:

    # ks "That's it, Nozomi. So easy to smile. And now when you feel me take your hand you're going to rise slowly from your chair and let me guide you forward." with dissolve
    ks "Eso es, Nozomi. Es tan fácil sonreír. Y ahora, cuando sientas que tomo tu mano, te levantarás de tu asiento y me dejarás guiarte." with dissolve

# game/Kyou 6.rpy:1229
translate spanish Day6_Villain_Kyou_9308f833:

    # ks "Moving forward with me now. Still deeply asleep, just following my lead as we walk. Very good."
    ks "Ahora camina hacia adelante conmigo. Todavía profundamente dormida, simplemente siguiendo mis pasos al caminar. Muy bien."

# game/Kyou 6.rpy:1232
translate spanish Day6_Villain_Kyou_343b7700:

    # "Very good."
    "Muy bien."

# game/Kyou 6.rpy:1239
translate spanish Day6_Villain_Kyou_7c0d97ea:

    # n "Wha... Wh-what is this? Where am I...?"
    n "¿Qué… qu-qué es esto? ¿Dónde estoy...?"

# game/Kyou 6.rpy:1240
translate spanish Day6_Villain_Kyou_fe915072:

    # ks casual smirk "You're in my house, Nozomi. We walked here, don't you remember?"
    ks casual smirk "Estás en mi casa, Nozomi. Caminamos hasta aquí, ¿no lo recuerdas?"

# game/Kyou 6.rpy:1241
translate spanish Day6_Villain_Kyou_5a6a68e4:

    # n "I... Oh no."
    n "Yo… Oh, no."

# game/Kyou 6.rpy:1242
translate spanish Day6_Villain_Kyou_1c7e115c:

    # ks "Yes, you remember. You may also realize that you are still quite deeply hypnotized."
    ks "Sí, lo recuerdas. Puede que también te des cuenta de que sigues muy profundamente hipnotizada."

# game/Kyou 6.rpy:1243
translate spanish Day6_Villain_Kyou_9e028a9b:

    # ks "That's why you won't be able to raise your voice beyond a normal speaking volume, or be able to move from your seat."
    ks "Es por eso que no podrás elevar el volumen de tu voz más de lo normal, ni podrás moverte de tu asiento. "

# game/Kyou 6.rpy:1244
translate spanish Day6_Villain_Kyou_1e6f5c73:

    # ks "You know I'm not going to hurt you anyway, Nozomi. You're perfectly safe here."
    ks "De todos modos, sabes que no voy a hacerte daño, Nozomi. Estás perfectamente segura aquí."

# game/Kyou 6.rpy:1276
translate spanish Day6_Villain_Kyou_ae90155e:

    # n "I still don't..." with dissolve
    n "Aún no..." with dissolve

# game/Kyou 6.rpy:1246
translate spanish Day6_Villain_Kyou_7d94efeb:

    # ks "Don't what?"
    ks "¿No qué?"

# game/Kyou 6.rpy:1279
translate spanish Day6_Villain_Kyou_8a325757:

    # n "Don't understand. How?" with dissolve
    n "No lo entiendo. ¿Cómo?" with dissolve

# game/Kyou 6.rpy:1248
translate spanish Day6_Villain_Kyou_3a5d33f4:

    # ks "How you were hypnotized in the first place? You weren't supposed to know, but I guess there's no point in hiding it from you now."
    ks "¿Cómo fuiste hipnotizada en primer lugar? No se suponía que lo supieras, pero supongo que ya no tiene sentido ocultártelo."

# game/Kyou 6.rpy:1249
translate spanish Day6_Villain_Kyou_6ed68229:

    # ks "Think back, Nozomi. Thinking back... It was around five hours ago."
    ks "Recuerda, Nozomi. Recuerda… Fue hace unas cinco horas."

# game/Kyou 6.rpy:1250
translate spanish Day6_Villain_Kyou_3e550c76:

    # ks "You were relaxing at home, in your room. There was a phone call..."
    ks "Estabas relajándote en casa, en tu habitación. Recibiste una llamada…"

# game/Kyou 6.rpy:1251
translate spanish Day6_Villain_Kyou_8a127cb0:

    # ks "It's okay to remember, Nozomi. Tell me what happened."
    ks "Está bien recordar, Nozomi. Dime lo que pasó."

# game/Kyou 6.rpy:1252
translate spanish Day6_Villain_Kyou_bb2cf764:

    # n "..."
    n "…"

# game/Kyou 6.rpy:1254
translate spanish Day6_Villain_Kyou_30504aa3:

    # n front surprised "Ah!" with dissolve
    n front surprised "¡Ah!" with dissolve

# game/Kyou 6.rpy:1265
translate spanish Day6_Villain_Kyou_33d36d5f:

    # n "Huh?"
    n "¿Eh?"

# game/Kyou 6.rpy:1267
