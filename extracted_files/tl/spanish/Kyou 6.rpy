translate spanish Day6_Con_Kyou_Hiroko_Penlight_530a04e3:

    # "So... yeah, I know what I'll do to you."
    "Así que... sí, sé lo que haré contigo."

# game/Kyou 6.rpy:9678
translate spanish Day6_Con_Kyou_Hiroko_Penlight_5e1ea593:

    # ks "It's perfectly reasonable and correct of you to believe this... right?"
    ks "Es perfectamente razonable y correcto creer esto... ¿cierto?"

# game/Kyou 6.rpy:9679
translate spanish Day6_Con_Kyou_Hiroko_Penlight_e84302df:

    # h sleeptalk "Right..." with dissolve
    h sleeptalk "Cierto..." with dissolve

# game/Kyou 6.rpy:9680
translate spanish Day6_Con_Kyou_Hiroko_Penlight_384720ee:

    # "This'll barely count as me getting on revenge on you; I'm practically doing you a favour here."
    "Esto apenas si contará como venganza; prácticamente te estoy haciendo un favor."

# game/Kyou 6.rpy:9683
translate spanish Day6_Con_Kyou_Hiroko_Penlight_ebc9cd6b:

