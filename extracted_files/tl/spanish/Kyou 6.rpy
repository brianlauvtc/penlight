    ks casual smile "Gracias por aceptar venir a verme."

# game/Kyou 6.rpy:1165
translate spanish Day6_Villain_Kyou_96e8f655:

    # n frown "Yeah. In a public place, so don't try anything." with dissolve
    n frown "Sí. En un lugar público, así que no intentes nada." with dissolve

# game/Kyou 6.rpy:1166
translate spanish Day6_Villain_Kyou_96fc59e4:

