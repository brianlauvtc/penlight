    s sleeptalk "Oh, vamos, Nozomi, esto no tenía que concernir a ninguno de ustedes. Fue mi decisión." with dissolve

# game/Kyou 6.rpy:8202
translate spanish Day6_Con_Kyou_Sayori_Alter_Switch_c1f72c7a:

    # s smile "It is my decision to live in the moment. You only live once, as they say." with dissolve
    s smile "Es mi decisión vivir el momento. Solo se vive una vez, como dicen." with dissolve

# game/Kyou 6.rpy:8203
translate spanish Day6_Con_Kyou_Sayori_Alter_Switch_d1f557a1:

    # s laugh "And the consequences? Well, they are future [alt_name]'s problem~" with dissolve
    s laugh "¿Y las consecuencias? Bueno, ese es problema de la [alt_name] del futuro." with dissolve

# game/Kyou 6.rpy:8204
translate spanish Day6_Con_Kyou_Sayori_Alter_Switch_81470ece:

