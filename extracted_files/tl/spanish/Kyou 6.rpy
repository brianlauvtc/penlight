translate spanish Day6_Con_Kyou_Sayori_Alter_Switch_831e92e9:

    # n sad_side "I'm sorry, but you're a total wreck, Sayori. You can't go back there!" with dissolve
    n sad_side "Lo siento, pero estás hecha polvo, Sayori. ¡No puedes volver allá!" with dissolve

# game/Kyou 6.rpy:9435
translate spanish Day6_Con_Kyou_Sayori_Alter_Switch_a71c09bb:

    # nm "I'm afraid I have to agree."
    nm "Me temo que estoy de acuerdo."

# game/Kyou 6.rpy:9439
translate spanish Day6_Con_Kyou_Sayori_Alter_Switch_a8adfc83:

    # n "MOM!" with vpunch
    n "¡MAMÁ!" with vpunch

