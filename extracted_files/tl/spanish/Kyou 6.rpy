    a neutral "O, tal vez, al sentir que estaba en una posición donde podía hablar sin inhibiciones, ¿empezó a considerar una respuesta que la sorprendió?" with dissolve

# game/Kyou 6.rpy:6188
translate spanish Day6_Redemption_d004ce16:

    # ks sigh "Man, I don't know, 'Kiko. Things got crazy after that."
    ks sigh "Cielos, no sé, 'Kiko, Todo ha sido una locura desde entonces."

# game/Kyou 6.rpy:6189
translate spanish Day6_Redemption_328fdbf2:

    # a sad_side "Yeah..." with dissolve
    a sad_side "Sí..." with dissolve

