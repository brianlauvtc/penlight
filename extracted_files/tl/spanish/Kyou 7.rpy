    n sad "... ¿Hazlo por mí?" with dissolve

# game/Kyou 7.rpy:1330
translate spanish Day7_Con_Kyou_Nozomi_Reversal_694c2fda:

    # "I don't know what Nozomi was thinking, bringing me out here." with dissolve
    "No sé en qué estaba pensando Nozomi, trayéndome aquí afuera." with dissolve

# game/Kyou 7.rpy:1331
translate spanish Day7_Con_Kyou_Nozomi_Reversal_e214d2ef:

    # "{cps=15}But as my chest continues to tighten-{/cps}{w=1.0}{nw}"
