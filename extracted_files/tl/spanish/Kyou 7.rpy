# game/Kyou 7.rpy:1262
translate spanish Day7_Con_Kyou_Nozomi_Reversal_83d497cf:

    # "In any case, she somewhat reluctantly slides one of the mics towards the other tennis player while giving hers to Hiroko."
    "En todo caso, de manera un poco reluctante, desliza uno de los micrófonos a la otra tenista mientas le da el suyo a Hiroko."

# game/Kyou 7.rpy:1325
translate spanish Day7_Con_Kyou_Nozomi_Reversal_ef019489:

    # n neutral "Go on. Take it." with dissolve
    n neutral "Vamos. Tómalo." with dissolve

# game/Kyou 7.rpy:1326
translate spanish Day7_Con_Kyou_Nozomi_Reversal_23390470:

    # "I can't..."
    "No puedo..."

# game/Kyou 7.rpy:1327
