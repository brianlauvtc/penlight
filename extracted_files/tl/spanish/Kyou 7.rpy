    ncg stern_closed "Por supuesto que no estás literalmente controlando mi mente…" with dissolve

# game/Kyou 7.rpy:2150
translate spanish Day7_Con_Kyou_Nozomi_Trance_cf4a80a8:

    # ncg drooping sleeptalk "... B-But wouldn't it be fun to pretend you could?"
    ncg drooping sleeptalk "… P-pero ¿no sería divertido fingir que sí puedes?"

# game/Kyou 7.rpy:2157
