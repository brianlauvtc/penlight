# game/Kyou 7.rpy:26
translate spanish Day7_Con_Kyou_Sayori_Alter_fc1a9684:

    # s "Kyouuuuu!"
    s "¡Kyouuuuu!"

# game/Kyou 7.rpy:27
translate spanish Day7_Con_Kyou_Sayori_Alter_134279b8:

    # "My heart practically jumps out of my mouth as I hear a familiar voice from behind."
