    h nervous_side "Tú sabes que sí." with dissolve

# game/Kyou 7.rpy:3899
translate spanish Day7_Con_Kyou_Hiroko_Trickster2_edb184e7:

    # n smile_side "Alright. This will be a good experience, I promise." with dissolve
    n smile_side "Muy bien. Esto será una buena experiencia, lo prometo." with dissolve

# game/Kyou 7.rpy:3900
translate spanish Day7_Con_Kyou_Hiroko_Trickster2_e5a7156c:

    # n neutral "Now... Kyou?" with dissolve
    n neutral "Entonces... ¿Kyou?" with dissolve

# game/Kyou 7.rpy:3901
