    # ks "Whatever you say, assistant. Now let's get this show started."
    ks "Lo que tú digas, asistente. Ahora, que comience el espectáculo."

# game/Kyou 7.rpy:3475
translate spanish Day7_Con_Kyou_Hiroko_Trickster_22f3489f:

    # "So if I want to do what I planned, I'd better do it now."
    "Así que, si quiero hacer lo que planeé, será mejor que lo haga ahora."

# game/Kyou 7.rpy:3479
translate spanish Day7_Con_Kyou_Hiroko_Trickster_fa464733:

    # h surprised "A-ahh..." with dissolve
    h surprised "A-aah..." with dissolve

# game/Kyou 7.rpy:3480
translate spanish Day7_Con_Kyou_Hiroko_Trickster_1a44140a:

    # ks "That's it, Hiroko. Notice how automatic that was."
    ks "Eso es, Hiroko. Puedes notar cómo ya es automático."

# game/Kyou 7.rpy:3484
translate spanish Day7_Con_Kyou_Hiroko_Trickster_a797581e:

    # ks "I shine the light and you look." with dissolve
    ks "Enciendo la luz, y tú observas." with dissolve

# game/Kyou 7.rpy:3487
translate spanish Day7_Con_Kyou_Hiroko_Trickster_b6551d2d:

    # ks "I shine the light, and you look. There's no need for you to spend any conscious effort thinking about it." with dissolve
    ks "Enciendo la luz, y tú observas. No hace falta que hagas ningún esfuerzo consciente pensando en eso." with dissolve

# game/Kyou 7.rpy:3488
translate spanish Day7_Con_Kyou_Hiroko_Trickster_d03d4117:

    # "Even as worn out and stressed as she is, she's still so responsive to this light in my hand."
    "Por desgastada y estresada que esté, sigue igual de responsiva a esta luz que tengo en mi mano."

# game/Kyou 7.rpy:3489
translate spanish Day7_Con_Kyou_Hiroko_Trickster_0e32da63:

    # "Not that I can tell her, but it really is impressive."
    "No es que pueda decírselo, pero es realmente impresionante."

# game/Kyou 7.rpy:3491
translate spanish Day7_Con_Kyou_Hiroko_Trickster_faa065df:

    # ks smile "Look. And breathe in..."
    ks smile "Observa. E inhala."

# game/Kyou 7.rpy:3493
translate spanish Day7_Con_Kyou_Hiroko_Trickster_535c5cfd:

    # ks "Out..."
    ks "Exhala..."

# game/Kyou 7.rpy:3494
translate spanish Day7_Con_Kyou_Hiroko_Trickster_9945cc79:

    # h sleepy "Mrrn..." with dissolve
    h sleepy "Mmn..." with dissolve

# game/Kyou 7.rpy:3495
translate spanish Day7_Con_Kyou_Hiroko_Trickster_676f6cbb:

    # ks "That's right. Just look, and relax, and breathe..."
    ks "Eso es. Mira, y relájate, y respira..."

# game/Kyou 7.rpy:3497
translate spanish Day7_Con_Kyou_Hiroko_Trickster_20c7c996:

    # ks "Letting all that pent-up rage and embarrassment out with every breath now."
    ks "Dejando ir toda esa ira y vergüenza acumuladas mientras respiras."

# game/Kyou 7.rpy:3498
translate spanish Day7_Con_Kyou_Hiroko_Trickster_916efaef:

    # "As Hiroko wobbles on her feet, I switch my penlight off and place my hands gently upon her shoulders."
    "Hiroko se tambalea sobre sus pies. Yo apago mi linterna y coloco mis manos suavemente sobre sus hombros."

# game/Kyou 7.rpy:3499
translate spanish Day7_Con_Kyou_Hiroko_Trickster_cc797abb:

    # "She's completely spaced out already, but I need her on the bed for what I'm about to do."
    "Ya está totalmete ensimismada, pero la necesito en la cama para lo que estoy por hacer."

# game/Kyou 7.rpy:3500
translate spanish Day7_Con_Kyou_Hiroko_Trickster_ed333b1e:

    # ks frown "{cps=20}Becoming completely relaxed and falling deep into trance. {w=0.5}Falling and falling, and- {/cps}{nw}"
    ks frown "{cps=20}Completamente relajada y cayendo en un profundo trance. {w=0.5}Cayendo y cayendo, y- {/cps}{nw}"

# game/Kyou 7.rpy:3510
translate spanish Day7_Con_Kyou_Hiroko_Trickster_bf36b48a:

    # extend "SLEEP!{w=1.0}{nw}"
    extend "¡DUERME!{w=1.0}{nw}"

# game/Kyou 7.rpy:3515
translate spanish Day7_Con_Kyou_Hiroko_Trickster_2fded262:

    # h "..."
    h "..."

# game/Kyou 7.rpy:3516
translate spanish Day7_Con_Kyou_Hiroko_Trickster_94402a37:

    # "Pushing her firmly down towards the bed, I smile as the little shock of gravity, twinned with my yelled command, was enough to send her consciousness away."
    "Empujándola firmemente contra la cama, sonrío al ver que el pequeño impacto, combinado con mi orden a todo volumen, bastó para esfumar su consciencia."

# game/Kyou 7.rpy:3517
translate spanish Day7_Con_Kyou_Hiroko_Trickster_78454323:

    # ks neutral "Deep asleep. And as you fall into this deeply relaxing trance, I want you to imagine yourself completely frozen in place. Staying completely upright on the bed."
    ks neutral "Profundamente dormida. Y al caer en este relajante trance, quiero que te imagines completamente congelada en tu posición. Completamente erguida en la cama."

# game/Kyou 7.rpy:3522
translate spanish Day7_Con_Kyou_Hiroko_Trickster_d3ede570:

    # "As I tentatively release my grip on her she remains sat up rather than flopping down on the sheets. Good."
    "Cuando la suelto cuidadosamente, se mantiene sentada y no se cae sobre las sábanas. Bien."

# game/Kyou 7.rpy:3523
translate spanish Day7_Con_Kyou_Hiroko_Trickster_c2c60cf2:

    # "She'll need to stay up so my webcam can see her. And on that topic, I turn to my computer and start to type out an announcement in the public chat."
    "Tendrá que quedarse así para que mi cámara web pueda verla. Y ya en ese tema, me acerco a mi computadora y comienzo a escribir un anuncio en el chat público."

# game/Kyou 7.rpy:3524
translate spanish Day7_Con_Kyou_Hiroko_Trickster_3b97c966:

    # "{color=#FFFFFF}\"Hey, it's me again. Remember that girl I was telling you about? The one I hypnotized?\"{/color}"
    "{color=#FFFFFF}\"Hola, soy yo otra vez. ¿Recuerdan esa chica de la que les hablé? ¿A la que hipnoticé?\"{/color}"

# game/Kyou 7.rpy:3525
translate spanish Day7_Con_Kyou_Hiroko_Trickster_51197e70:

    # "{color=#FFFFFF}\"Well we're about to do a live hypno show. Let me know if you want to watch, we're starting in five minutes.\"{/color}"
    "{color=#FFFFFF}\"Bueno, estamos a punto de dar un espectáculo de hipnosis en vivo. Avísenme los que quieran mirar, empezamos en cinco minutos.\"{/color}"

# game/Kyou 7.rpy:3526
translate spanish Day7_Con_Kyou_Hiroko_Trickster_a7667c1b:

    # "These guys may have doubted me before, but now they'll all see firsthand what I'm capable of..."
    "Estos sujetos habrán dudado antes de mí, pero ahora todos verán de primera mano de lo que soy capaz..."

# game/Kyou 7.rpy:3527
translate spanish Day7_Con_Kyou_Hiroko_Trickster_4c9ecfc8:

    # "Anyway, while I'm waiting for their responses I return to my entranced assistant, still sat rigidly on the bed."
    "En fin, mientras espero por sus respuestas, devuelvo mi atención a mi hipnotizada asistente, quien sigue rígidamente sentada en la cama."

# game/Kyou 7.rpy:3528
translate spanish Day7_Con_Kyou_Hiroko_Trickster_4dde5eb4:

    # "If I'm going to be talking to Hiroko and making suggestions in front of all these strangers I'll need to refer to her by name."
    "Si voy a estar hablando con Hiroko y dándole sugestiones delante de todos estos extraños, tendré que dirigirme a ella por su nombre."

# game/Kyou 7.rpy:3529
translate spanish Day7_Con_Kyou_Hiroko_Trickster_1a8b163a:

    # "Seems like a bad idea to out her in front of people from all around the country, though."
    "Pero parece una mala idea exponerla delante de gente de todo el país."

# game/Kyou 7.rpy:3530
translate spanish Day7_Con_Kyou_Hiroko_Trickster_5b38e089:

    # "She needs, like, a stage name for this stuff."
    "Necesita, pues, un nombre artístico para estas cosas."

# game/Kyou 7.rpy:3531
translate spanish Day7_Con_Kyou_Hiroko_Trickster_42f3aaa6:

    # "So how about..."
    "¿Qué tal...?"

# game/Kyou 7.rpy:3536
translate spanish Day7_Con_Kyou_Hiroko_Trickster_9a8ba7ec:

    # "With a hand gently on Hiroko's shoulder, I start to speak calmly once more."
    "Con una mano puesta suavemente en el hombro de Hiroko, comienzo a hablar tranquilamente una vez más."

# game/Kyou 7.rpy:3537
translate spanish Day7_Con_Kyou_Hiroko_Trickster_192df6cf:

    # ks smile "Now, Hiroko, while you're still so deeply hypnotized and suggestible, I'd like you to remember something."
    ks smile "Bien, Hiroko, mientras sigues tan profundamente hipnotizada y sugestionable, quisiera que recuerdes algo."

# game/Kyou 7.rpy:3538
translate spanish Day7_Con_Kyou_Hiroko_Trickster_e4c686db:

    # ks "Whenever I refer to you by the name \"[stagename]\", whether you're deeply hypnotized or wide awake, you will respond as if it were your own name."
    ks "Cada vez que me dirija a ti por el nombre \"[stagename]\", así estés profundamente hipnotizada o despierta, responderás como si fuera tu propio nombre."

# game/Kyou 7.rpy:3539
translate spanish Day7_Con_Kyou_Hiroko_Trickster_9d510bcb:

    # ks "You won't need to think about it. My calling you [stagename] will feel completely natural and correct to you."
    ks "No tendrás que pensar en ello. Que te llame [stagename] se sentirá completamente natural y correcto para ti."

# game/Kyou 7.rpy:3540
translate spanish Day7_Con_Kyou_Hiroko_Trickster_2b67cb2a:

    # ks "Do you understand, [stagename]?"
    ks "¿Comprendes, [stagename]?"

# game/Kyou 7.rpy:3541
translate spanish Day7_Con_Kyou_Hiroko_Trickster_8305537b:

    # h sleeptalk "Y-yeah... understand." with dissolve
    h sleeptalk "S-seh... comprendo." with dissolve

# game/Kyou 7.rpy:3544
translate spanish Day7_Con_Kyou_Hiroko_Trickster_72b0dc99:

    # "Satisfied, I turn back to the computer and already see a few dozen people wanting my attention." with dissolve
    "Satisfecho, regreso a la computadora y ya puedo ver unas cuantas docenas de personas pidiendo mi atención." with dissolve

# game/Kyou 7.rpy:3547
translate spanish Day7_Con_Kyou_Hiroko_Trickster_7cbc7e8f:

    # "It's a little more than I expected, so I quickly set up a private chat group and start sending out invites."
    "Es un poco más de lo que esperaba, así que rápidamente creo un grupo de chat privado y comienzo a mandar invitaciones."

# game/Kyou 7.rpy:3548
translate spanish Day7_Con_Kyou_Hiroko_Trickster_5fd00a26:

    # "Once the five minutes have passed, I seem to have a pretty good audience of chatroom regulars and relative newbies alike."
    "Una vez pasados los cinco minutos, parece que tengo una muy buena audiencia de usuarios regulares y casi recién llegados por igual."

# game/Kyou 7.rpy:3549
translate spanish Day7_Con_Kyou_Hiroko_Trickster_9cc371de:

    # "So now with everyone in attendance, I make sure my webcam is pointed directly on my entranced assistant before beginning the stream..."
    "Así que ahora, teniendo la atención de todos, me aseguro de que la cámara apunte directamente a mi hipnotizada asistente antes de iniciar la transmisión..."

# game/Kyou 7.rpy:3550
translate spanish Day7_Con_Kyou_Hiroko_Trickster_2fded262_1:

    # h "..."
    h "..."

# game/Kyou 7.rpy:3551
translate spanish Day7_Con_Kyou_Hiroko_Trickster_5b3859ca:

    # "Almost immediately the chat lights up with comments about Hiroko."
    "Casi inmediatamente el chat se ilumina de comentarios sobre Hiroko."

# game/Kyou 7.rpy:3552
translate spanish Day7_Con_Kyou_Hiroko_Trickster_fa4b8cff:

    # "Yeah, yeah, you think she's cute. But you guys don't know her like I do..."
    "Seh, seh, creen que es linda. Pero ustedes no la conocen como yo..."

# game/Kyou 7.rpy:3540
translate spanish Day7_Con_Kyou_Hiroko_Trickster_5078396c:

    # ks casual smile "... What's her name? This is H-... [stagename]. And I can assure you all that she's very deeply hypnotized right now."
    ks casual smile "... ¿Cómo se llama? Ella es H-... [stagename]. Y puedo asegurarles que se encuentra profundamente hipnotizada en este momento."

# game/Kyou 7.rpy:3554
translate spanish Day7_Con_Kyou_Hiroko_Trickster_e4208cbb:

    # "The comment flood continues..."
    "El diluvio de comentarios continúa..."

# game/Kyou 7.rpy:3555
translate spanish Day7_Con_Kyou_Hiroko_Trickster_515ab10f:

    # ks frown "\"Is she really hypnotized or are you guys just doing a bit?\""
    ks frown "\"¿En serio está hipnotizada o solo están fingiendo?\""

# game/Kyou 7.rpy:3556
translate spanish Day7_Con_Kyou_Hiroko_Trickster_f26de1bd:

    # "Still they doubt me. Well, now it's time I showed these skeptical assholes."
    "Aún dudan de mí. Bueno, ahora es tiempo de mostrarles a estos cabrones escépticos."

# game/Kyou 7.rpy:3557
translate spanish Day7_Con_Kyou_Hiroko_Trickster_b66b113a:

    # ks neutral "Y-yeah, so I'm gonna start now. I'll try to speak up so you guys can hear what I'm saying from over here."
    ks neutral "S-sí, pues voy a comenzar ahora. Trataré de hablar alto para que puedan oír lo que digo desde aquí."

# game/Kyou 7.rpy:3558
translate spanish Day7_Con_Kyou_Hiroko_Trickster_e8463729:

    # "And with that I leave them watching as I step over towards the bed and rejoin \"[stagename]\", sitting by her side and just out of sight of the camera."
    "Y con eso, los dejo mirando para acércame a la cama y reunirme con \"[stagename]\", sentándome a su lado, apenas fuera de la vista de la cámara."

# game/Kyou 7.rpy:3559
translate spanish Day7_Con_Kyou_Hiroko_Trickster_ffbb8c1f:

    # ks smile "[stagename], I'd like you to imagine a piece of string is tied around your left wrist. And on the other end of that string... is a balloon."
    ks smile "[stagename], quiero que te imagines un trozo de hilo atado a tu muñeca izquierda. Y en el otro extremo del hilo... hay un globo."

# game/Kyou 7.rpy:3560
translate spanish Day7_Con_Kyou_Hiroko_Trickster_a0fb9160:

    # "Yeah, let's start to silence the doubters with a basic suggestibility test."
    "Sí, a silenciar las dudas con una prueba básica de sugestionabilidad."

# game/Kyou 7.rpy:3561
translate spanish Day7_Con_Kyou_Hiroko_Trickster_2b90c19a:

    # "We know how fantastically suggestible you are, Hiroko, so this should be child's play for someone like you."
    "Sabemos lo asombrosamente sugestionable que eres, Hiroko, por lo que esto debería ser un juego de niños para alguien como tú."

# game/Kyou 7.rpy:3562
translate spanish Day7_Con_Kyou_Hiroko_Trickster_0788f1fc:

    # ks "The balloon is full of helium, [stagename], and it's rising. And as it rises, you can feel the string tugging against your wrist."
    ks "El globo está lleno de helio, [stagename], y se está elevando. Y al elevarse, puedes sentir el hilo triando de tu muñeca."

# game/Kyou 7.rpy:3563
translate spanish Day7_Con_Kyou_Hiroko_Trickster_2972b277:

    # ks "Can you feel it, [stagename]?"
    ks "¿Puedes sentirlo, [stagename]?"

# game/Kyou 7.rpy:3564
translate spanish Day7_Con_Kyou_Hiroko_Trickster_f08fd86d:

    # h sleeptalk "Mm... yeah..." with dissolve
    h sleeptalk "Mm... seh..." with dissolve

# game/Kyou 7.rpy:3566
translate spanish Day7_Con_Kyou_Hiroko_Trickster_b16f91b5:

    # "Sure enough, I can notice her hand begin to twitch as it rests by the bed. Not enough for anyone else to notice her movement, but they will soon." with dissolve
    "Y por supuesto, puedo notar que su mano empieza a contraerse sobre la cama. No lo suficiente para que nadie más note el movimiento, pero pronto lo verán." with dissolve

# game/Kyou 7.rpy:3567
translate spanish Day7_Con_Kyou_Hiroko_Trickster_5c211632:

    # ks "And that balloon just keeps rising. Keeps pulling against your wrist and before you know it, you're going to find your hand beginning to rise along with it."
    ks "Y ese globo sigue subiendo. Sigue tirando de tu muñeca y, antes de que te des cuenta, notarás que tu mano empieza a elevarse con él."

# game/Kyou 7.rpy:3560
translate spanish Day7_Con_Kyou_Hiroko_Trickster_5766ac0d:

    # ks "{cps=25}Rising with the balloon as the string pulls against your wrist. {w=0.5}Lifting your hand up, up, {/cps}{nw}"
    ks "{cps=25}Se eleva con el globo mientras el hilo jala tu muñeca. {w=0.5}Jalando tu mano hacia arriba, arriba, {/cps}{nw}"

# game/Kyou 7.rpy:3571
translate spanish Day7_Con_Kyou_Hiroko_Trickster_585d5bb4:

    # extend "up..."
    extend "arriba..."

# game/Kyou 7.rpy:3572
translate spanish Day7_Con_Kyou_Hiroko_Trickster_1b0d67f2:

    # "I spare a sidewards glance at the monitor, and notice my viewers haven't stayed silent as they chatter amongst themselves."
    "Le doy al monitor una mirada de soslayo, y noto que los espectadores no han estado en silencio, y conversan entre ellos."

# game/Kyou 7.rpy:3573
translate spanish Day7_Con_Kyou_Hiroko_Trickster_6120c534:

    # ks "Your hand feeling so light as it's lifted by the string, [stagename]. So, so light, lifting it so high above your head now... that's right."
    ks "Tu mano se siente tan ligera al ser levantada por el hilo, [stagename]. Tan, tan ligera, que ahora se alza por encima de tu cabeza..."

# game/Kyou 7.rpy:3574
translate spanish Day7_Con_Kyou_Hiroko_Trickster_33df55bb:

    # "Hiroko looks a sight. While her left hand reaches as high as it can, the rest of her body appears slouched and heavy; her head hanging leaden around her shoulders."
    "Hiroko luce hecha polvo. Mientras que su mano se eleva tan alto como puede, el resto de su cuerpo parece desgarbado y pesado; su cabeza cuelga como plomo junto a sus hombros."

# game/Kyou 7.rpy:3575
translate spanish Day7_Con_Kyou_Hiroko_Trickster_417c6bc3:

    # ks "That's wonderful, Hir- [stagename]. Your hand so naturally floating there now. Naturally held up right where it is by that string. By that balloon."
    ks "Maravilloso, Hir- [stagename]. Tu mano flota de forma tan natural. Naturalmente sostenida en su lugar por el hilo. Por el globo."

# game/Kyou 7.rpy:3576
translate spanish Day7_Con_Kyou_Hiroko_Trickster_6d432f0b:

    # "Leaving her side for a moment, I dash back to the computer and have a read at the comments people are leaving..."
    "Yéndome de su lado por un momento, vuelvo a la computadora y leo los comentarios de las personas..."

# game/Kyou 7.rpy:3570
translate spanish Day7_Con_Kyou_Hiroko_Trickster_75e53422:

    # ks casual smirk "You guys believe me now, right?"
    ks casual smirk "Ahora sí me creen, ¿verdad?"

# game/Kyou 7.rpy:3578
translate spanish Day7_Con_Kyou_Hiroko_Trickster_32134346:

    # "They do, save for a couple of idiot contrarions who nonetheless are still sticking around to watch this thing."
    "Me creen, salvo por un par de idiotas contreras que aun así se quedan a ver."

# game/Kyou 7.rpy:3579
translate spanish Day7_Con_Kyou_Hiroko_Trickster_ce236426:

    # "The rush of validation I'm getting now... Nobody paid attention to me before, but it feels like these people are starting to appreciate me."
    "La descarga de validación me está emocionando... Nadie me prestaba atención antes, pero parece que estas personas comienzan a apreciarme."

# game/Kyou 7.rpy:3580
translate spanish Day7_Con_Kyou_Hiroko_Trickster_800487e8:

    # "They want more. I want more."
    "Quieren más. Yo quiero más."

# game/Kyou 7.rpy:3581
translate spanish Day7_Con_Kyou_Hiroko_Trickster_99961aba:

    # ks smile "Yeah, I said we were putting on a show for you guys, didn't I? Well, watch this..."
    ks smile "Sí, dije que les daríamos un espectáculo, ¿no? Bueno, observen esto."

# game/Kyou 7.rpy:3582
translate spanish Day7_Con_Kyou_Hiroko_Trickster_0520c652:

    # "Returning to Hiroko's side, I reach up and take her raised hand gently in mine."
    "Volviendo al costado de Hiroko, tomo suavemente su mano levantada en la mía."

# game/Kyou 7.rpy:3578
translate spanish Day7_Con_Kyou_Hiroko_Trickster_62040e9a:

    # ks casual smile "Alright, [stagename], that's very good. Now I want you to imagine the helium leaving the balloon. Your left wrist starting to get a little heavier..."
    ks casual smile "Genial, [stagename], muy bien. Ahora quiero que imagines que el helio sale del globo. Tu muñeca izquierda se pone un poco más pesada..."

# game/Kyou 7.rpy:3580
translate spanish Day7_Con_Kyou_Hiroko_Trickster_7d7831c5:

    # h "{size=16}Mmrn...{/size}" with dissolve
    h "{size=16}Mmnn...{/size}" with dissolve

# game/Kyou 7.rpy:3585
translate spanish Day7_Con_Kyou_Hiroko_Trickster_d5771ded:

    # ks "{cps=25}And a little heavier. Your hand starting to fall down, down...{w=0.5}{/cps}{nw}"
    ks "{cps=25}Y un poco más pesada. Tu mano va hacia abajo, abajo...{w=0.5}{/cps}{nw}"

# game/Kyou 7.rpy:3588
translate spanish Day7_Con_Kyou_Hiroko_Trickster_81eceebf:

    # extend " down.{w=0.5} That's good, [stagename]."
    extend " abajo.{w=0.5}Muy bien, [stagename]. "

# game/Kyou 7.rpy:3589
translate spanish Day7_Con_Kyou_Hiroko_Trickster_3d477ca5:

    # "Guiding her arm back to rest at her side, I think briefly about what I've planned for our main event."
    "Guiando su brazo para posarlo junto a ella, pienso brevemente en lo que planeé para el evento principal."

# game/Kyou 7.rpy:3590
translate spanish Day7_Con_Kyou_Hiroko_Trickster_ca790260:

    # "Man, you'd better be up to this, Hiroko. Don't let me down in front of all our new fans..."
    "Vaya, más te vale hacer esto bien, Hiroko. No me defraudes en frente de todos nuestros nuevos fans..."

# game/Kyou 7.rpy:3591
translate spanish Day7_Con_Kyou_Hiroko_Trickster_9f6e16dd:

    # ks "You're doing so well, [stagename]. Staying so deeply hypnotized and letting me speak to your subconscious like this."
    ks "Lo estás haciendo muy bien, [stagename]. Aún profundamente hipnotizada y dejándome hablar así con tu subconsciente."

# game/Kyou 7.rpy:3592
translate spanish Day7_Con_Kyou_Hiroko_Trickster_32e0039e:

    # ks "And while I'm speaking to you like this, let me impress something else on you."
    ks "Y mientras te hablo así, déjame decirte algo más."

# game/Kyou 7.rpy:3593
translate spanish Day7_Con_Kyou_Hiroko_Trickster_9d3910cb:

    # ks "When you next hear me snap my fingers, you'll find yourself waking up from this state of hypnosis, just for a little while."
    ks "Cuando me escuches chasquear los dedos, despertarás de este estado de hipnosis, solo por un rato."

# game/Kyou 7.rpy:3594
translate spanish Day7_Con_Kyou_Hiroko_Trickster_7f7d9aec:

    # ks "And while you wake, you'll think you're in your favourite karaoke booth with all your friends."
    ks "Y mientras estés despierta, creerás que estás en tu cabina de karaoke favorita con tus amigas."

# game/Kyou 7.rpy:3595
translate spanish Day7_Con_Kyou_Hiroko_Trickster_ef642d36:

    # ks "You will believe that this bed you're sitting on is actually a platform for dancing, and this thing I'm placing in your hand..."
    ks "Creerás que esta cama en la que estás sentada es de hecho la plataforma para bailar, y esto que estoy colocando en tu mano..."

# game/Kyou 7.rpy:3598
translate spanish Day7_Con_Kyou_Hiroko_Trickster_43565b53:

    # "With a grin, I take my penlight and slide it against the palm of her left hand."
    "Con una sonrisa, tomo mi linterna y la pongo en la palma de su mano izquierda."

# game/Kyou 7.rpy:3599
translate spanish Day7_Con_Kyou_Hiroko_Trickster_957ea11d:

    # ks smirk "You'll absolutely believe this is a karaoke mic, [stagename]. And you need to hold onto it."
    ks smirk "Creerás con toda certeza que esto es un micrófono de karaoke, [stagename]. Y debes sostenerlo."

# game/Kyou 7.rpy:3601
translate spanish Day7_Con_Kyou_Hiroko_Trickster_33354517:

    # "As her fingers close around my device I keep talking; building this little world for her to inhabit for the next few minutes."
    "Cuando sus dedos se cierran en mi dispositivo, continúo hablando; construyendo este pequeño mundo para que lo habite por los próximos minutos."

# game/Kyou 7.rpy:3300
translate spanish Day7_Con_Kyou_Hiroko_Trickster_d8cadd42:

    # ks "What's more, [stagename], when you next hear me snap my fingers, you will also realize your favourite song is just about to play and it's your turn to sing!"
    ks "Es más, [stagename], cuando me oigas chasquear los dedos, ¡te darás cuenta de tu canción favorita está a punto de sonar y es tu turno de cantar!"

# game/Kyou 7.rpy:3603
translate spanish Day7_Con_Kyou_Hiroko_Trickster_33877d61:

    # ks "You'll feel the most powerful urge to jump onto the platform and sing and dance your heart out in front of all your friends, just having the best time."
    ks "Sentirás unas inmensas ganas de saltar a la plataforma y cantar y bailar con el corazón delante de todas tus amigas, pasándotela de lo mejor."

# game/Kyou 7.rpy:3604
translate spanish Day7_Con_Kyou_Hiroko_Trickster_ca989f5c:

    # ks "When your song ends, you'll sit back down and ask who's turn it is to sing next, and hold the mic out for someone to take."
    ks "Cuando tu canción termine, volverás a sentarte y preguntarás quién cantará después, y ofrecerás el micrófono para que alguien lo tome."

# game/Kyou 7.rpy:3605
translate spanish Day7_Con_Kyou_Hiroko_Trickster_715f59d6:

    # ks "Finally, as soon as the mic leaves your hands you will find yourself drawn back down into this deep, pleasant hypnotic trance, just like you are now."
    ks "Finalmente, tan pronto como el micrófono escape de tus manos, regresarás a un profundo y placentero estado de trance, como en el que estás ahora."

# game/Kyou 7.rpy:3606
translate spanish Day7_Con_Kyou_Hiroko_Trickster_f7d07058:

    # ks "Did you understand all of that, [stagename]?"
    ks "¿Comprendiste todo eso, [stagename]?"

# game/Kyou 7.rpy:3607
translate spanish Day7_Con_Kyou_Hiroko_Trickster_221fc0f9:

    # h sleeptalk "Mmrn, yeah... understand..." with dissolve
    h sleeptalk "Mmnn, seh... comprendo..." with dissolve

# game/Kyou 7.rpy:3610
translate spanish Day7_Con_Kyou_Hiroko_Trickster_0aa52618:

    # "I really hope you did, Hiroko. Because it's time you showed everybody just how suggestible you really are." with dissolve
    "Espero que sí, Hiroko. Porque es hora de que les muestres a todos lo sugestionable que realmente eres." with dissolve

# game/Kyou 7.rpy:3615
translate spanish Day7_Con_Kyou_Hiroko_Trickster_bed60d77:

    # ks casual smile "{cps=25}That's wonderful, [stagename]. And now... {w=0.5}{/cps}{nw}"
    ks casual smile "{cps=25}Maravilloso, [stagename]. Y ahora... {w=0.5}{/cps}{nw}"

# game/Kyou 7.rpy:3615
translate spanish Day7_Con_Kyou_Hiroko_Trickster_ba38f40b:

    # extend "*snap*" with vpunch
    extend "*chas*" with vpunch

# game/Kyou 7.rpy:3616
translate spanish Day7_Con_Kyou_Hiroko_Trickster_d22d143b:

    # "Just as I snap my fingers by her ear, I back away from my assistant and watch alongside my remote audience."
    "En cuanto trueno mis dedos junto a su oreja, me alejo de mi asistente y observo junto a mi audiencia remota."

# game/Kyou 7.rpy:3617
translate spanish Day7_Con_Kyou_Hiroko_Trickster_c0fd7bc7:

    # "And for the first time since I started this stream, Hiroko lifts her head while sleepily blinking some life back into her eyes in front of the camera."
    "Y por primera vez desde que comencé esta transmisión, Hiroko levanta la cabeza mientras parpada soñolienta, volviendo sus ojos a la vida frente a la cámara."

# game/Kyou 7.rpy:3618
translate spanish Day7_Con_Kyou_Hiroko_Trickster_2b3191ce:

    # h surprised "Wha- w-w-what's going on?! This's..." with dissolve
    h surprised "¡¿Qu- q-q-qué está pasando?! Esta..." with dissolve

# game/Kyou 7.rpy:3619
translate spanish Day7_Con_Kyou_Hiroko_Trickster_66cac7fb:

    # h casual_armup laugh "{cps=25}Ahaha, oh my gawd, {/cps}{nw}" with dissolve
    h casual_armup laugh "{cps=25}Ajaja, oh, por Dios, {/cps}{nw}" with dissolve

# game/Kyou 7.rpy:3621
translate spanish Day7_Con_Kyou_Hiroko_Trickster_c1b8e90f:

    # extend "THIS'S MY SONG, YOU GUYS!" with vpunch
    extend "¡ESTA ES MI CANCIÓN, CHICAS!" with vpunch

# game/Kyou 7.rpy:3653
translate spanish Day7_Con_Kyou_Hiroko_Trickster_e6f1ac0f:

    # "With an excited giggle, Hiroko clambers up onto the bedsheets with a little stumble, then turns to face the camera while clutching the penlight in her hands excitedly."
    "Con una risa emocionada, Hiroko se trepa a las sábanas un poco vacilante, luego se da la vuelta hacia la cámara, sujetando la linterna entre sus manos con entusiasmo."

# game/Kyou 7.rpy:3655
translate spanish Day7_Con_Kyou_Hiroko_Trickster_1a0b7c77:

    # "Bobbing to a beat no one else can hear, Hiroko sways a little on the spot as she starts to break into song." with dissolve
    "Danzando al son que nadie más puede oír, Hiroko se balancea ligeramente en su lugar y comienza a adentrarse a la canción." with dissolve

# game/Kyou 7.rpy:3656
translate spanish Day7_Con_Kyou_Hiroko_Trickster_76f82b20:

    # "... What IS her favourite song, anyway? The words she's singing sound like they're from some kinda cheesy pop ditty, but she's really getting into it."
    "... Por cierto, ¿CUÁL es su canción favorita? Las palabras que está cantando suenan a alguna clase de pop cursi, pero ella no para."

# game/Kyou 7.rpy:3658
translate spanish Day7_Con_Kyou_Hiroko_Trickster_dddade7f:

    # "Didn't think she'd be into stuff like this, but she's belting out the lyrics like she's having the time of her life up there." with dissolve
    "No pensé que le gustaran cosas así, pero está entonando la letra como si se estuviera divirtiendo más que nunca en su vida." with dissolve

# game/Kyou 7.rpy:3540
translate spanish Day7_Con_Kyou_Hiroko_Trickster_90352553:

    # "And as she sings, she steps rhythmically back and forth on the bed for a while, before doing a little twirl as she comes to the chorus."
    "Y mientras canta, pisotea rítmicamente de un lado a otro sobre la cama por un rato, para luego dar un pequeño giro en el coro."

# game/Kyou 7.rpy:3665
translate spanish Day7_Con_Kyou_Hiroko_Trickster_71eba10d:

    # "The movement causes her to stumble a bit and she stutters over her words for a second; a small act of rebellion from her exhausted body."
    "El movimiento la hace tropezar un poco y tartamudea por un segundo; un pequeño acto de rebelión de su agotado cuerpo."

# game/Kyou 7.rpy:3669
translate spanish Day7_Con_Kyou_Hiroko_Trickster_62fa0ed7:

    # "Still, she recovers quickly and cheerfully bounces up and down on my mattress while she draws a deep breath and follows through with the rest of her song..." with dissolve
    "Aun así, se recupera rápido y rebota alegremente en mi colchón, tomando aire y prosiguiendo con el resto de la canción." with dissolve

# game/Kyou 7.rpy:3686
translate spanish Day7_Con_Kyou_Hiroko_Trickster_1d9330ea:

    # "... Finishing by dropping to her knees and looking back to her \"friends\", nailing the last vocal with whatever breath she had left in her lungs."
    "... Para terminar se arroja de rodillas y vuelve a mirar a sus \"amigas\", soltando la última vocal con el poco aliento que le quedaba en los pulmones."

# game/Kyou 7.rpy:3687
translate spanish Day7_Con_Kyou_Hiroko_Trickster_e15f2ec4:

    # "Hiroko giggles weakly in triumph, unable to hide how totally shattered she is but refusing to let it stop her fun as she moves to sit back down on the bed."
    "Hiroko se ríe débilmente con triunfo, incapaz de ocultar lo totalmente destrozada que está, pero se reúsa a ponerle fin a su diversión, y vuelve a sentarse en la cama."

# game/Kyou 7.rpy:3679
translate spanish Day7_Con_Kyou_Hiroko_Trickster_45f01fd3:

    # "As she does so, I spare a glance at the chat window. And at all the messages these few dozen guys are leaving me."
    "Cuando lo hace, yo echo un vistazo a la ventana de chat. Y a todos los mensajes que unas cuantas docenas de personas estan dejando."

# game/Kyou 7.rpy:3680
translate spanish Day7_Con_Kyou_Hiroko_Trickster_db204dea:

    # "Some are making fun of her awful, tired dancing and choice of song."
    "Algunos se burlan de su horrible y cansado baile, y elección de canción."

# game/Kyou 7.rpy:3681
translate spanish Day7_Con_Kyou_Hiroko_Trickster_bce335da:

    # "A couple more forward types want to know if \"[stagename]\" has her own account on the chatroom that they can hit up later..."
    "Otro par de emocionados quiere saber si \"[stagename]\" tiene su propia cuenta en la sala de chat con la que pudieran charlar más tarde..."

# game/Kyou 7.rpy:3682
translate spanish Day7_Con_Kyou_Hiroko_Trickster_a89dd8cf:

    # "But I gotta admit I have to agree with a lot of these other comments here."
    "Pero debo admitir que estoy de acuerdo con muchos de estos otros comentarios."

# game/Kyou 7.rpy:3693
translate spanish Day7_Con_Kyou_Hiroko_Trickster_84da0a6b:

    # ks casual smirk "Yeah, she's got a decent set of pipes, huh."
    ks casual smirk "Sí, qué buenas cuerdas vocales tiene, ¿eh?"

# game/Kyou 7.rpy:3665
translate spanish Day7_Con_Kyou_Hiroko_Trickster_829f3be4:

    # "I figured she'd screech through all of her song, but even exhausted as she was, I gotta admit Hiroko carries a tune pretty well."
    "Me imaginé que chillaría toda la canción, pero incluso así de exhausta, he de admitir que Hiroko lleva muy bien la melodía."

# game/Kyou 7.rpy:3685
translate spanish Day7_Con_Kyou_Hiroko_Trickster_b2e13593:

    # h laugh "S-so... haah... haaah... w-who's up next?" with dissolve
    h laugh "E-entonces... haah... haaah... ¿qu-quién sigue?" with dissolve

# game/Kyou 7.rpy:3686
translate spanish Day7_Con_Kyou_Hiroko_Trickster_44fc0841:

    # "As I turn back around, I see Hiroko holding my penlight up for someone else to take off of her."
    "Volviéndome a dar la vuelta, veo a Hiroko sujetando mi linterna para que alguien más la tome."

# game/Kyou 7.rpy:3688
translate spanish Day7_Con_Kyou_Hiroko_Trickster_cb122df8:

    # "Right, of course. Showtime's over."
    "Sí, por supuesto. Terminó el espectáculo."

# game/Kyou 7.rpy:3689
translate spanish Day7_Con_Kyou_Hiroko_Trickster_f805fbc9:

    # "So as I go back to her side, I close a hand around the penlight..."
    "Así que, me acerco a su lado, tomo la linterna entre sus dedos..."

# game/Kyou 7.rpy:3690
translate spanish Day7_Con_Kyou_Hiroko_Trickster_e46fdb39:

    # ks smile "Yeah I'll take it from here, [stagename]."
    ks smile "Sí, yo me encargo desde aquí, [stagename]."

# game/Kyou 7.rpy:3691
translate spanish Day7_Con_Kyou_Hiroko_Trickster_d2f4918d:

    # "... Before yanking it from out of her grasp at the same time as I push her head down gently."
    "... Y entonces la arranco de su agarre a la vez que empujo suavemente su cabeza hacia abajo."

# game/Kyou 7.rpy:3695
translate spanish Day7_Con_Kyou_Hiroko_Trickster_d8111240:

    # ks "Now sleep. Deep asleep once again, [stagename], back into this comforting state of hypnosis... That's right."
    ks "Ahora duerme. Duerme profundamente otra vez, [stagename], de vuelta a un reconfortante estado de hipnosis... Eso es."

# game/Kyou 7.rpy:3696
translate spanish Day7_Con_Kyou_Hiroko_Trickster_9db89830:

    # "Hiroko lets out a sleepy sigh as the joy drops from her face almost immediately, replaced by an empty calm as she drifts back into a full trance."
    "Hiroko suelta un soñoliento suspiro mientras la alegría se desvanece de su rostro casi de inmediato, reemplazada por una vacía calma, y cae de nuevo en trance."

# game/Kyou 7.rpy:3697
translate spanish Day7_Con_Kyou_Hiroko_Trickster_8d5ebe39:

    # "I stay with her a moment to make sure she stays upright, then walk back to my viewers one last time."
    "Me quedo con ella por un momento para asegurarme de que no se caiga, luego regreso con los espectadores una última vez."

# game/Kyou 7.rpy:3698
translate spanish Day7_Con_Kyou_Hiroko_Trickster_6d84573c:

    # "The feeling of pride must be written all over my face as I look to the camera."
    "Debo tener el sentimiento de orgullo escrito en toda la cara cuando miro a la cámara."

# game/Kyou 7.rpy:3699
translate spanish Day7_Con_Kyou_Hiroko_Trickster_1d271daa:

    # ks smirk "Still, uh... still think we're doing a bit, guys?"
    ks smirk "¿Aún, eh... aún creen que estamos fingiendo, chicos?"

translate spanish strings:

    # game/Kyou 7.rpy:3532
    old "Ayumu"
    new "Ayumu"

    # game/Kyou 7.rpy:3754
    old " (disabled)Let her go"
    new "Dejarla ir"

    # game/Kyou 7.rpy:3754
    old "Finish what I started"
    new "Terminar lo que empecé"

