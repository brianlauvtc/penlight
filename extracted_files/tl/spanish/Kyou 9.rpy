    # "She's accepting it all. Completely unresisting to having her entire sense of self completely re-written." with dissolve
    "Lo está aceptando todo. Sin mostrar la más mínima resistencia a la reescritura total de su sentido del yo." with dissolve

# game/Kyou 9.rpy:1144
translate spanish Day9_Redemption_Spiral_043837d3:

    # ks smirk "That's a good little [hypno6]. You won't defy me any more, will you?"
    ks smirk "Buen[genero_a] [hypno6!t!l]. Ya no volverás a desafiarme, ¿o sí?"

# game/Kyou 9.rpy:1146
translate spanish Day9_Redemption_Spiral_e6f50a49:

    # a "No, administrator." with dissolve
    a "No, administrador." with dissolve

# game/Kyou 9.rpy:1148
