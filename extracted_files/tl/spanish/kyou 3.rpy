# game/kyou 3.rpy:3067
translate spanish Day3_Con_Kyou_Sayori_Switch_47e14530:

    # s "And you might even be right. On both counts." with dissolve
    s "Y puede que incluso tengas razón. En los dos puntos." with dissolve

