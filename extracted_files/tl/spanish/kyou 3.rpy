    # ks smile "Well, I was just wondering..."
    ks smile "Pues, me preguntaba..."

# game/kyou 3.rpy:3025
translate spanish Day3_Con_Kyou_Hiroko_1f4ab4d0:

    # ks "Uh..."
    ks "Eh..."

# game/kyou 3.rpy:3026
translate spanish Day3_Con_Kyou_Hiroko_142ff63a:

    # "Hopefully she doesn't react too badly to what I'm about to ask her."
    "Espero que no reaccione muy mal a lo que estoy por decirle."

# game/kyou 3.rpy:3027
translate spanish Day3_Con_Kyou_Hiroko_81a68924:

    # "I mean, it's a pretty innocent thing..."
    "Digo, es algo muy inocente..."

# game/kyou 3.rpy:3030
translate spanish Day3_Con_Kyou_Hiroko_d77f38c7:

    # h "Oh my fucking god, {w=0.2}{nw}"
    h "Ay, puta madre, {w=0.2}{nw}"

# game/kyou 3.rpy:3031
translate spanish Day3_Con_Kyou_Hiroko_deb5fe14:

    # extend "WHAT?" with vpunch
    extend "¿QUÉ?" with vpunch

# game/kyou 3.rpy:3032
translate spanish Day3_Con_Kyou_Hiroko_3e4a2a0c:

    # ks sigh "U-uh... are you ticklish?"
    ks sigh "E-eh... ¿eres cosquilluda?"

# game/kyou 3.rpy:3033
translate spanish Day3_Con_Kyou_Hiroko_42b43932:

    # h frown "..." with dissolve
    h frown "..." with dissolve

# game/kyou 3.rpy:3034
translate spanish Day3_Con_Kyou_Hiroko_c374f8a2:

    # "She stares at me uncomfortably for a moment while I notice her lips quiver."
    "Me mira incómodamente por un momento mientras noto que sus labios se estremecen."

# game/kyou 3.rpy:3036
translate spanish Day3_Con_Kyou_Hiroko_3ed3b745:

    # ks frown "Okay, so you know how it feels. I figured I could make you think you were ticklish somewhere you're not?"
    ks frown "Bien, entonces sabes cómo se siente. ¿Imagino que podría hacerte creer que tienes cosquillas donde realmente no?"

# game/kyou 3.rpy:3037
translate spanish Day3_Con_Kyou_Hiroko_33fff227:

    # h annoyed "And where's that?" with dissolve
    h annoyed "¿Y dónde sería eso?" with dissolve

# game/kyou 3.rpy:3038
translate spanish Day3_Con_Kyou_Hiroko_effae8c6:

    # ks "I was thinking..."
    ks "Estaba pensando en..."

# game/kyou 3.rpy:3039
translate spanish Day3_Con_Kyou_Hiroko_7ba35809:

    # "Even bringing up the subject of tickling seems to have put Hiroko on full alert, so I'm on thin ice here."
    "Tan solo traer el tema de las cosquillas parece haber puesto a Hiroko en alerta, por lo que estoy sobre hielo delgado."

# game/kyou 3.rpy:3040
translate spanish Day3_Con_Kyou_Hiroko_7318d538:

    # "I can't suggest anywhere even remotely suspect. So..."
    "No puedo sugerir nada ni remotamente sospechoso. Así que..."

# game/kyou 3.rpy:3041
translate spanish Day3_Con_Kyou_Hiroko_8c8304ea:

    # ks smile "The palms of your hands?"
    ks smile "¿Las palmas de tus manos?"

# game/kyou 3.rpy:3042
translate spanish Day3_Con_Kyou_Hiroko_ca68d946:

    # "Hiroko brings her hands together and starts to rub her fingertips over her palms as she frowns at me."
    "Hiroko junta sus manos y empieza a frotar sus palmas con las puntas de sus dedos frunciéndome el ceño."

# game/kyou 3.rpy:3043
translate spanish Day3_Con_Kyou_Hiroko_f626ffb1:

    # h frown noblush "'Kay... That ain't so weird, I guess. But I got a question for ya." with dissolve
    h frown noblush "Bien... Eso no es tan raro, supongo. Pero te tengo una pregunta." with dissolve

# game/kyou 3.rpy:3044
translate spanish Day3_Con_Kyou_Hiroko_d3d9a80f:

    # ks neutral "Sure."
    ks neutral "Claro."

# game/kyou 3.rpy:3045
translate spanish Day3_Con_Kyou_Hiroko_78157a2a:

    # h annoyed "You really think it's gonna work?" with dissolve
    h annoyed "¿En serio crees que funcionará?" with dissolve

# game/kyou 3.rpy:3942
translate spanish Day3_Con_Kyou_Hiroko_0db72d0d:

    # ks confused "Huh? Well, you took to the other things, so I don't see why not?"
    ks confused "¿Eh? Pues, las otras cosas te sirvieron; no veo por qué no."

# game/kyou 3.rpy:3048
translate spanish Day3_Con_Kyou_Hiroko_5dbca756_1:

    # extend "WANTED that. This is just some bullshit for your hypno show." with vpunch
    extend "QUERÍA eso. Esto es solo una mierda para tu hipno-teatrito." with vpunch

# game/kyou 3.rpy:3049
translate spanish Day3_Con_Kyou_Hiroko_074fa391:

    # ks neutral "Yeah..."
    ks neutral "Sí..."

# game/kyou 3.rpy:3050
translate spanish Day3_Con_Kyou_Hiroko_c2e32c6f:

    # "Damn, that's true. Is she really going to co-operate with me this time? She's not motivated to do this at all."
    "Demonios, es cierto. ¿De verdad cooperará esta vez? No tiene ninguna motivación para hacerlo."

# game/kyou 3.rpy:3571
translate spanish Day3_Con_Kyou_Hiroko_11f53caa:

    # ks sigh "Well... could you at least humour me on this?"
    ks sigh "Pues... ¿Podrías al menos concederme esto?"

# game/kyou 3.rpy:3052
translate spanish Day3_Con_Kyou_Hiroko_2c2783c0:

    # ks "Let me hypnotize you again and see how you feel then."
    ks "Déjame hipnotizarte otra vez y veamos cómo te sientes."

# game/kyou 3.rpy:3055
translate spanish Day3_Con_Kyou_Hiroko_0507c391:

    # "Hiroko lets out a theatrical sigh as she crosses her arms."
    "Hiroko suelta un suspiro teatral y se cruza de brazos."

# game/kyou 3.rpy:3056
translate spanish Day3_Con_Kyou_Hiroko_5133fdb8:

    # h "Fiiine."
    h "Bieeen."

# game/kyou 3.rpy:3057
translate spanish Day3_Con_Kyou_Hiroko_6370e7ff:

    # h annoyed_up "Do what you want, just get this shit over with so I can go home." with dissolve
    h annoyed_up "Haz lo que tengas que hacer, solo termina con esta mierda para que me pueda ir a casa." with dissolve

# game/kyou 3.rpy:3060
translate spanish Day3_Con_Kyou_Hiroko_2f13bf8d:

    # ks smile "Okay, so make yourself comfortable and we'll get started."
    ks smile "Muy bien, ponte cómoda y vamos a empezar."

# game/kyou 3.rpy:4221
translate spanish Day3_Con_Kyou_Hiroko_99cd1c7b:

    # "Hiroko nods, and I watch as her eyes are immediately drawn to the penlight when I produce it from my pocket once more."
    "Hiroko asiente, y veo cómo sus ojos son inmediatamente atraídos a la linterna en cuanto la saco de mi bolsillo una vez más."

# game/kyou 3.rpy:3066
translate spanish Day3_Con_Kyou_Hiroko_7756601d:

    # ks "Look familiar?"
    ks "¿Te es familiar?"

# game/kyou 3.rpy:3067
translate spanish Day3_Con_Kyou_Hiroko_56741bf8:

    # h angry "Just get on with it." with dissolve
    h angry "Hazlo y ya." with dissolve

# game/kyou 3.rpy:3070
translate spanish Day3_Con_Kyou_Hiroko_6a5757fc:

    # "I chuckle and do as she demands, flicking the light on and passing it gently across her angry eyes."
    "Me río y hago lo que ordena, encendiendo la luz y pasándola con gentileza por sus airados ojos."

# game/kyou 3.rpy:3071
translate spanish Day3_Con_Kyou_Hiroko_b39b6402:

    # ks "Alright then, Hiroko. You know just what to do."
    ks "Está bien, Hiroko. Sabes exactamente qué hacer."

# game/kyou 3.rpy:3073
translate spanish Day3_Con_Kyou_Hiroko_ddbaf2e2:

    # ks "Letting yourself look into the light as it takes you down so familiarly."
    ks "Tan solo mira la luz y deja que te lleve esa sensación tan familiar."

# game/kyou 3.rpy:3076
translate spanish Day3_Con_Kyou_Hiroko_253af4ba:

    # h "S-stupid... pretty light..." with dissolve
    h "E-estúpida... luz bonita..." with dissolve

# game/kyou 3.rpy:3077
translate spanish Day3_Con_Kyou_Hiroko_7b2d37ef:

    # "I chuckle softly as I playfully pass the light across her face again."
    "Dejo salir una suave risa y vuelvo a pasar traviesamente la luz por su rostro."

# game/kyou 3.rpy:3078
translate spanish Day3_Con_Kyou_Hiroko_c75f9429:

    # ks "It's very pretty. And you might find now how much easier it is to relax, to sink, to drop under this pretty light."
    ks "Es muy bonita. Y puede que te sea más fácil relajarte, sumirte, caer más profundo bajo esta luz tan bonita."

# game/kyou 3.rpy:3082
translate spanish Day3_Con_Kyou_Hiroko_d2719f7a:

    # ks "How very natural it has become to let every muscle in your body, from your head and neck, all the way down to your toes..."
    ks "Se ha vuelto tan natural dejar que cada músculo de tu cuerpo, desde tu cabeza y cuello, hasta los dedos de tus pies..."

# game/kyou 3.rpy:3084
translate spanish Day3_Con_Kyou_Hiroko_e88baa1f:

    # ks "... to just effortlessly and automatically become loose, limp, and completely and utterly relaxed."
    ks "... se pongan flojitos, muy fácil y automáticamente, relajándote por completo."

# game/kyou 3.rpy:3089
translate spanish Day3_Con_Kyou_Hiroko_a89bc062:

    # "I was half-teasing her, but sure enough she seems to be getting very good at dropping under the penlight."
    "En parte estaba jugando, pero en definitiva se está volviendo muy buena en caer bajo la linterna."

# game/kyou 3.rpy:3090
translate spanish Day3_Con_Kyou_Hiroko_541f3442:

    # ks "Yes, Hiroko, exactly like that. Feeling so deeply relaxed, going so automatically into trance for me now."
    ks "Sí, Hiroko, exactamente así. Sintiéndote tan profundamente relajada, entrando automáticamente en trance."

# game/kyou 3.rpy:3092
translate spanish Day3_Con_Kyou_Hiroko_1b83c964:

    # ks "Letting those tired, droopy, sleepy eyelids close as you let yourself go so deep. Deep asleep now, Hiroko."
    ks "Deja que esos cansados, caídos y adormecidos párpados se cierren para que puedas ir muy profundo. Profundamente dormida, Hiroko."

# game/kyou 3.rpy:3095
translate spanish Day3_Con_Kyou_Hiroko_811a46af:

    # ks neutral "That's right, Hiroko. Deep asleep." with dissolve
    ks neutral "Eso es, Hiroko. Profundamente dormida." with dissolve

# game/kyou 3.rpy:3097
translate spanish Day3_Con_Kyou_Hiroko_76df4db0:

    # h drooping "..."
    h drooping "..."

# game/kyou 3.rpy:3098
translate spanish Day3_Con_Kyou_Hiroko_a8e1c044:

    # ks "Going so much deeper now. Feeling so safe. So relaxed. So ready to listen to my voice, which takes you even deeper."
    ks "Mucho más profundo ahora. Sintiéndote segura. Tan relajada. Lista para escuchar mi voz, la cual te lleva más profundo aún."

# game/kyou 3.rpy:3100
translate spanish Day3_Con_Kyou_Hiroko_4916156c:

    # ks "And as you listen to me, you may find it harder to remember some of the things we talked about tonight."
    ks "Y mientras me escuchas, puede que te sea más difícil recordar algunas de las cosas de las que hablamos esta noche."

# game/kyou 3.rpy:3101
translate spanish Day3_Con_Kyou_Hiroko_07961174:

    # ks "As a matter of fact, you may find it extremely easy to forget our talk of the fun suggestion I had planned for you."
    ks "A decir verdad, puede que te sea extremadamente fácil olvidar nuestra charla sobre la divertida sugestión que planeé para ti."

# game/kyou 3.rpy:3102
translate spanish Day3_Con_Kyou_Hiroko_5efe62d2:

    # ks "So easy, so natural to let it slip completely from your memory."
    ks "Muy fácil, muy natural dejarla escapar de tu memoria."

# game/kyou 3.rpy:3103
translate spanish Day3_Con_Kyou_Hiroko_ff73dfb1:

    # ks "Isn't that right, Hiroko?"
    ks "¿No es cierto, Hiroko?"

# game/kyou 3.rpy:3104
translate spanish Day3_Con_Kyou_Hiroko_5c05cf6d:

    # h sleeptalk "Right... so easy..." with dissolve
    h sleeptalk "Cierto... muy fácil..." with dissolve

# game/kyou 3.rpy:3106
translate spanish Day3_Con_Kyou_Hiroko_ce755dfc:

    # ks "So very right. So very natural. So very easy to let it all slip from your mind." with dissolve
    ks "Muy, muy cierto. Muy natural. Muy fácil dejarlo todo salir de tu mente." with dissolve

# game/kyou 3.rpy:3107
translate spanish Day3_Con_Kyou_Hiroko_0b7e1e29:

    # "There. What with how good she is at visualizing these suggestions I'm pretty confident she'll think she really has forgotten."
    "Listo. Con lo buena que es visualizando estas sugestiones, confío en que creerá que en serio lo olvidó."

# game/kyou 3.rpy:3108
translate spanish Day3_Con_Kyou_Hiroko_1ef28388:

    # "This really could be a lot of fun."
    "Esto podría ser muy divertido."

# game/kyou 3.rpy:3109
translate spanish Day3_Con_Kyou_Hiroko_42ab5e6b:

    # ks "And now I want you to imagine that your feet, flat on the floor as they are, may no longer be able to move from their position."
    ks "Y ahora quiero que imagines que tus pies, que están bien puestos ahí en el suelo, tal vez ya no sean capaces de moverse de donde están."

# game/kyou 3.rpy:3110
translate spanish Day3_Con_Kyou_Hiroko_4dfef345:

    # ks "And the more you imagine this, the more you visualize your feet sticking solidly to the floor, being unable to free them, the more real it becomes."
    ks "Y entre más lo imaginas, entre más visualizas tus pies pegándose al suelo con fuerza, sin poder liberarlos, más real se vuelve eso."

# game/kyou 3.rpy:3111
translate spanish Day3_Con_Kyou_Hiroko_4980197d:

    # ks "You might struggle to lift your feet from the floor, but you know deep down that the more you struggle, the more solidly your feet remain fused to the ground."
    ks "Puedes hacer un esfuerzo por levantar tus pies del suelo, pero sabes en el fondo que entre más lo intentas, tus pies se funden más sólidamente en el piso."

# game/kyou 3.rpy:3112
translate spanish Day3_Con_Kyou_Hiroko_2dbb14bd:

    # ks "The more you try to free yourself, the more impossible it becomes to break free. As if your feet have become a part of the floor itself."
    ks "Entre más intentas liberarte, se vuelve más imposible. Como si tus pies se hubieran vuelto parte del mismo suelo."

# game/kyou 3.rpy:3114
translate spanish Day3_Con_Kyou_Hiroko_11771bc2:

    # "She might not be totally on board with my idea, but if she's still comfortable enough to drop into a trance for me, I think I can convince her to work with me here."
    "Puede que no sea del todo fan de la idea, pero si está cómoda dejándome ponerla en trance, creo que puedo convencerla de trabajar conmigo en esto."

# game/kyou 3.rpy:3115
translate spanish Day3_Con_Kyou_Hiroko_01267dec:

    # ks "And now that you're listening to my voice, so deep in hypnotic trance, I want you to recall a time when you were tickled."
    ks "Y ahora que escuchas mi voz, en un profundo trance hipnótico, quiero que recuerdes las veces en las que te han dado cosquillas."

# game/kyou 3.rpy:3116
translate spanish Day3_Con_Kyou_Hiroko_2639d4aa:

    # ks "Think back to your most ticklish memory, when someone tickled you and you couldn't help but laugh and giggle in response."
    ks "Piensa en las cosquillas más intensas que recuerdes, esa vez que alguien te hizo cosquillas y no pudiste evitar reírte."

# game/kyou 3.rpy:3117
translate spanish Day3_Con_Kyou_Hiroko_c6bf96d2:

    # ks "Can you think of a time like that, Hiroko?"
    ks "¿Puedes pensar en un momento así, Hiroko?"

# game/kyou 3.rpy:3118
translate spanish Day3_Con_Kyou_Hiroko_46c324b7:

    # h sleeptalk "Yeah..." with dissolve
    h sleeptalk "Seh..." with dissolve

# game/kyou 3.rpy:3120
translate spanish Day3_Con_Kyou_Hiroko_db923772:

    # ks smile "Good. Now, I want to touch your hands so I can do what we talked about just now. Is that okay?" with dissolve
    ks smile "Bien. Y ahora, quisiera tocar tus manos para poder hacer lo que discutimos. ¿Te parece bien?" with dissolve

# game/kyou 3.rpy:3121
translate spanish Day3_Con_Kyou_Hiroko_c51bbe39:

    # h sleeptalk "... Okay." with dissolve
    h sleeptalk "... Bien." with dissolve

# game/kyou 3.rpy:3123
translate spanish Day3_Con_Kyou_Hiroko_020b725c:

    # "Smiling at her co-operativeness, I gently take her left hand and turn it to expose her palm before teasing my fingertips back and forth across it." with dissolve
    "Sonriendo ante su cooperación, tomo gentilmente su mano izquierda y de doy la vuelta, exponiendo su palma; luego, con delicadeza, la tiento con las yemas de mis dedos." with dissolve

# game/kyou 3.rpy:3124
translate spanish Day3_Con_Kyou_Hiroko_b91d581d:

    # ks "Very good, Hiroko. Now, I want you to keep thinking about how ticklish you were while I stroke your palm like this."
    ks "Muy bien, Hiroko. Ahora, quiero que pienses en el cosquilleo que sentiste cuando rocé así tu palma."

# game/kyou 3.rpy:3125
translate spanish Day3_Con_Kyou_Hiroko_34e03051:

    # ks "And as you continue to think about your ticklishness, you may find it so easy to find that same ticklish feeling apply to your palms now."
    ks "Y mientras sigues pensando en tus cosquillas, puede que te sea muy fácil notar que esa misma sensación ahora también aplica a tus palmas."

# game/kyou 3.rpy:3126
translate spanish Day3_Con_Kyou_Hiroko_6c794b12:

    # "Setting her left hand down on her lap, I then hold her right hand, turning it gently upwards before starting to swirl my fingertip in its palm."
    "Tras colocar su mano izquierda en su regazo, levanto su mano derecha, volteándola gentilmente hacia arriba, y empiezo a menear mis dedos en sobre su palma."

# game/kyou 3.rpy:3127
translate spanish Day3_Con_Kyou_Hiroko_3b20b3ce:

    # "Hopefully that's helping to stimulate her imagination. Although I think I can do more than that if she's feeling co-operative and suggestible..."
    "Espero que eso la ayude a estimular su imaginación. Aunque creo que puedo hacer más que eso, ya que está cooperando y está tan sugestionable..."

# game/kyou 3.rpy:3128
translate spanish Day3_Con_Kyou_Hiroko_9382c1f0:

    # ks "In fact, you may find it so easy to associate this ticklishness with the palms of your hands that they feel ten times more sensitive. Ten times more ticklish."
    ks "De hecho, puede que te sea fácil asociar estas cosquillas con las palmas de tus manos, las cuales son diez veces más sensibles. Diez veces más cosquilludas."

# game/kyou 3.rpy:3129
translate spanish Day3_Con_Kyou_Hiroko_398b04f5:

    # ks "Can you imagine how ticklish your palms are now, Hiroko? How even the slightest contact can compel you to laugh and giggle?"
    ks "¿Puedes imaginar lo cosquilludas que ahora son tus palmas, Hiroko? ¿Cómo el toque más mínimo te hace reír y carcajearte?"

# game/kyou 3.rpy:3130
translate spanish Day3_Con_Kyou_Hiroko_e82ba104:

    # h sleeptalk "Kehe... hehe..." with dissolve
    h sleeptalk "Ñeje... jeje..." with dissolve

# game/kyou 3.rpy:3131
translate spanish Day3_Con_Kyou_Hiroko_48d02106:

    # "I'm startled by the light chuckle that Hiroko responds with as she starts to reply, jerking my hand away from hers as it twitches."
    "La risita con la que Hiroko responde me pega un susto, y alejo mi mano de golpe mientras que la suya se retuerce."

# game/kyou 3.rpy:3132
translate spanish Day3_Con_Kyou_Hiroko_98aa4203:

    # h "Y-y... yeah..."
    h "S-s... seh..."

# game/kyou 3.rpy:3135
translate spanish Day3_Con_Kyou_Hiroko_2fc43f54:

    # "It makes me grin. I thought she wasn't up for doing this, but once we got down to it, Hiroko's become very game indeed."
    "Me hace sonreír. Creí que no quería hacer esto, pero ya que nos pusimos manos a la obra, sí que lo está haciendo muy bien."

# game/kyou 3.rpy:3136
translate spanish Day3_Con_Kyou_Hiroko_18caff5d:

    # ks "That's right, Hiroko. The palms of your hands really are as incredibly ticklish and sensitive as you're imagining right now."
    ks "Eso es, Hiroko. Las palmas de tus manos realmente sí son tan cosquilludas y sensibles como las imaginas."

# game/kyou 3.rpy:3138
translate spanish Day3_Con_Kyou_Hiroko_2ef4c5b3:

    # ks "And on a count of three, you are going to wake up and accept this new reality, Hiroko."
    ks "Y a la cuenta de tres, despertarás aceptando esta nueva realidad, Hiroko."

# game/kyou 3.rpy:3142
translate spanish Day3_Con_Kyou_Hiroko_1fbede45:

    # ks "One, letting yourself breathe and accept the reality of my words."
    ks "Uno, toma aire y acepta la realidad de mis palabras."

# game/kyou 3.rpy:3143
translate spanish Day3_Con_Kyou_Hiroko_1e305f43:

    # ks "Two, testing your eyelids and letting the rest of the world come back to you."
    ks "Dos, tus párpados comienzan a moverse, permitiendo que el resto del mundo regrese a ti."

# game/kyou 3.rpy:3146
translate spanish Day3_Con_Kyou_Hiroko_104d4307:

    # ks "And three, wide awake now, Hiroko."
    ks "Y tres, despierta ahora, Hiroko."

# game/kyou 3.rpy:3149
translate spanish Day3_Con_Kyou_Hiroko_295fd1f0:

    # h relaxed sleepy_up_open "Mmmrn..."
    h relaxed sleepy_up_open "Mmmn..."

# game/kyou 3.rpy:3151
translate spanish Day3_Con_Kyou_Hiroko_831822d6:

    # "I grin at her as she comes to."
    "Le sonrío al verla volver en sí."

# game/kyou 3.rpy:3152
translate spanish Day3_Con_Kyou_Hiroko_2713c14f:

    # ks smile "And how are we feeling this time?"
    ks smile "¿Y cómo te sientes esta vez?"

# game/kyou 3.rpy:3153
translate spanish Day3_Con_Kyou_Hiroko_eef0e3aa:

    # "She blinks sleepily and arches her back against the couch."
    "Parpadea soñolienta y arquea su espalda contra el sofá."

# game/kyou 3.rpy:3154
translate spanish Day3_Con_Kyou_Hiroko_5558e4a8:

    # h neutral "Huh. Pretty good, actually. What'd you do?" with dissolve
    h neutral "Eh. Bastante bien, de hecho. ¿Qué hiciste?" with dissolve

# game/kyou 3.rpy:3155
translate spanish Day3_Con_Kyou_Hiroko_3d0d61a5:

    # ks "Oh, just what we agreed on. You remember, right?"
