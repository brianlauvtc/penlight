# game/kyou 3.rpy:2203
translate spanish Con_Kyou_Nozomi_Day3_HypnoSesh_c4901017:

    # "Holy shit, she really IS slurring her speech! So this is what she imagines being a zombie is like. And she's letting it play out in front of me!"
