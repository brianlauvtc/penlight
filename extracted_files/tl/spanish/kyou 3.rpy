    # n "If she doesn't want to talk about it, we can't force her, Hiroko." with dissolve
    n "Si no quiere hablar de eso, no podemos obligarla, Hiroko." with dissolve

# game/kyou 3.rpy:2257
translate spanish Day3_Con_Kyou_Sayori_e242788b:

    # n sad_closed "But Sayori, if there's anything we can do to help, you only have to tell us." with dissolve
    n sad_closed "Pero, Sayori, si hay algo que podamos hacer para ayudar, solo dínoslo." with dissolve

# game/kyou 3.rpy:2258
translate spanish Day3_Con_Kyou_Sayori_35f75897:

    # n smile_side "You've done so much to help me, after all." with dissolve
    n smile_side "Después de todo, has hecho mucho para ayudarme a mí." with dissolve

# game/kyou 3.rpy:2259
translate spanish Day3_Con_Kyou_Sayori_4ccf374e:

    # h uniform_arm smile_side "Yeah, same. Sure I would've flunked out of here a couple times without you, Sayori." with dissolve
    h uniform_arm smile_side "Sí, igual. Ya habría reprobado un par de veces de no ser por ti, Sayori." with dissolve

# game/kyou 3.rpy:2260
translate spanish Day3_Con_Kyou_Sayori_3f52feb8:

    # s alert_smile "This really was just a blip, but I appreciate the sentiment. Thank you, both of you." with dissolve
    s alert_smile "Solo fueron un par de cositas de nada, pero aprecio la intención. Gracias a las dos." with dissolve

# game/kyou 3.rpy:2414
translate spanish Day3_Con_Kyou_Sayori_95386dab:

    # "Her friends seem to drop the issue after that, but you can tell they're not satisfied. I guess they know better than to press her on it, though."
    "Después de eso, sus amigas parecen dejar el asunto, pero se nota que no están satisfechas. Supongo que prefieren no presionarla."

# game/kyou 3.rpy:2268
translate spanish Day3_Con_Kyou_Sayori_a8556830:

    # "The rest of the day passes without any other drama."
    "El resto del día transcurre sin ningún otro drama."

# game/kyou 3.rpy:2269
translate spanish Day3_Con_Kyou_Sayori_100816bb:

    # "I try to catch Sayori's attention when I can, but I may as well have not been there as far as she was concerned."
    "Intento atrapar la atención de Sayori cuando puedo, pero bien podría no haber estado presente en lo que a ella concierne."

# game/kyou 3.rpy:2584
translate spanish Day3_Con_Kyou_Sayori_f2d16c0e:

    # "And I don't dare approach her. Not with her friends around; that'd just cause more trouble for both of us."
    "Y no me atrevo a acercarme. No con sus amigas a su lado; eso solo nos daría más problemas ambos."

# game/kyou 3.rpy:2272
translate spanish Day3_Con_Kyou_Sayori_ba8b64c2:

    # "All I can think of is to swing by her club room again later, like last time. She'll have to talk to me then."
    "Lo único que se me ocurre es pasar por el salón de su club más tarde, igual que la última vez. Entonces tendrá que hablar conmigo."

# game/kyou 3.rpy:2274
translate spanish Day3_Con_Kyou_Sayori_7f7af2e9:

    # "So... okay, yeah, I'll just head home for now."
    "Así que... muy bien, sí, solo iré a mi casa por ahora."

# game/kyou 3.rpy:2276
translate spanish Day3_Con_Kyou_Sayori_f3fa85aa:

    # "Just got a couple hours to kill until-{w=0.8}{nw}"
    "Tengo un par de horas que matar hasta-{w=0.8}{nw}"

# game/kyou 3.rpy:2279
translate spanish Day3_Con_Kyou_Sayori_e4c20aaf:

    # "Huh? Someone's at the door? I literally just got home."
    "¿Eh? ¿Hay alguien en la puerta? Literalmente acabo de llegar a casa."

# game/kyou 3.rpy:2283
translate spanish Day3_Con_Kyou_Sayori_7205d8e7:

    # ks surprised "Sayori?!" with vpunch
    ks surprised "¡¿Sayori?!" with vpunch

# game/kyou 3.rpy:2284
translate spanish Day3_Con_Kyou_Sayori_84399a8b:

    # s "Kyou."
    s "Kyou."

# game/kyou 3.rpy:2288
translate spanish Day3_Con_Kyou_Sayori_5f3f8a01:

    # s alert_concerned_right "Is now a good time?" with dissolve
    s alert_concerned_right "¿Es un buen momento?" with dissolve

# game/kyou 3.rpy:2652
translate spanish Day3_Con_Kyou_Sayori_d569c5cf:

    # ks confused "It's, uh... it's a great time, actually. No one else is here."
    ks confused "Es, eh... es un muy buen momento, de hecho. No hay nadie más aquí."

# game/kyou 3.rpy:2604
translate spanish Day3_Con_Kyou_Sayori_69c9251c:

    # s uniform_handup alert_surprised_right "That does seem fortuitous." with dissolve
    s uniform_handup alert_surprised_right "Eso sí que suena fortuito." with dissolve

# game/kyou 3.rpy:2291
translate spanish Day3_Con_Kyou_Sayori_3f739ce1:

    # "I sigh."
    "Suspiro."

# game/kyou 3.rpy:2292
translate spanish Day3_Con_Kyou_Sayori_29af0b51:

    # ks sigh "Yeah, well, one parent doesn't live here and the other's married to his job, so I'm usually alone."
    ks sigh "Sí, pues, uno de mis padres ya no vive aquí y el otro está casado con su trabajo, por lo que casi siempre estoy solo."

# game/kyou 3.rpy:2293
translate spanish Day3_Con_Kyou_Sayori_e8672d00:

    # s alert_concerned_right "Oh... that was more information than I expected. I apologize." with dissolve
    s alert_concerned_right "Oh... esa fue más información de la que esperaba. Me disculpo." with dissolve

# game/kyou 3.rpy:2294
translate spanish Day3_Con_Kyou_Sayori_30a262d6:

    # "She considers for a moment, then adds:"
    "Se toma un momento para considerarlo, luego añade:"

# game/kyou 3.rpy:2549
translate spanish Day3_Con_Kyou_Sayori_36d77879:

    # s uniform alert_sleeptalk_concerned "I am also sorry for following you home. I did not know what else to do." with dissolve
    s uniform alert_sleeptalk_concerned "También lamento haberte seguido a casa. No sabía qué más hacer." with dissolve

# game/kyou 3.rpy:2296
translate spanish Day3_Con_Kyou_Sayori_7bef0626:

    # ks neutral "Yeah, uh... you wanna sit down?"
    ks neutral "Sí, eh... ¿quieres sentarte?"

# game/kyou 3.rpy:2299
translate spanish Day3_Con_Kyou_Sayori_b70107d6:

    # "I motion towards the couch in the living room and she nods before seating herself."
    "Con una seña la invito al sofá de la sala y ella asiente para luego tomar asiento."

# game/kyou 3.rpy:2300
translate spanish Day3_Con_Kyou_Sayori_dd742b5a:

    # ks "So what happened exactly?"
    ks "¿Y qué ocurrió, exactamente?"

# game/kyou 3.rpy:2303
translate spanish Day3_Con_Kyou_Sayori_001b93af:

    # s alert_annoyed_right "As though you could not figure it out." with dissolve
    s alert_annoyed_right "Como si no pudieras deducirlo." with dissolve

# game/kyou 3.rpy:2304
translate spanish Day3_Con_Kyou_Sayori_e7292cc6:

    # s "I went to bed at my usual time last night, but what happened after was far from usual."
    s "Me fui a la cama anoche, como es lo usual, pero lo que sucedió después estuvo lejos de ser usual."

# game/kyou 3.rpy:2305
translate spanish Day3_Con_Kyou_Sayori_c5b7f4b5:

    # s alert_surprised_right "The moment I climbed into bed and rested my head upon the pillow was the last thing I remember." with dissolve
    s alert_surprised_right "El momento en el que me recosté y reposé mi cabeza sobre la almohada es lo último que recuerdo." with dissolve

# game/kyou 3.rpy:2616
translate spanish Day3_Con_Kyou_Sayori_1aadbc7f:

    # s "As if every light in my mind had been simultaneously and abruptly switched off." with dissolve
    s "Como si cada luz en mi cabeza hubiese sido simultánea y abruptamente apagada." with dissolve

# game/kyou 3.rpy:2673
translate spanish Day3_Con_Kyou_Sayori_2a709c50:

    # ks confused "And then what? You overslept?"
    ks confused "¿Y luego qué? ¿Te quedaste dormida hasta tarde?"

# game/kyou 3.rpy:2308
translate spanish Day3_Con_Kyou_Sayori_a090a2fc:

    # s alert_annoyed_right "Of course I overslept. What did you think happened in class this morning?" with dissolve
    s alert_annoyed_right "Claro que me quedé dormida hasta tarde. ¿Qué crees que pasó en clase esta mañana?" with dissolve

# game/kyou 3.rpy:2621
translate spanish Day3_Con_Kyou_Sayori_e7c85ca7:

    # s "That I would simply surrender my perfect attendance record and the respect of my fellow students out of whimsy?" with dissolve
    s "¿Que simplemente dejaría ir mi récord perfecto de asistencia y el respeto de mis compañeros estudiantes por mero capricho?" with dissolve

# game/kyou 3.rpy:2310
translate spanish Day3_Con_Kyou_Sayori_50d18dca:

    # "... I think it'll take more than being late to class once to lose anyone's respect for you, Sayori."
    "... Creo que hará falta más que llegar tarde a clase una vez para que alguien pierda el respeto hacia ti, Sayori."

# game/kyou 3.rpy:2311
translate spanish Day3_Con_Kyou_Sayori_ffeb90d6:

    # s alert_annoyed "I have never felt so humiliated. But explaining to my parents why I skipped school entirely would have been so much worse." with dissolve
    s alert_annoyed "Nunca me sentí tan humillada. Pero explicarles a mis padres por qué omití un día de escuela en su totalidad habría sido mucho peor." with dissolve

# game/kyou 3.rpy:2312
translate spanish Day3_Con_Kyou_Sayori_9d9cd624:

    # s "I just hope my infraction does not reach their ears."
    s "Solo espero que mi infracción no llegue a sus oídos."

# game/kyou 3.rpy:2313
translate spanish Day3_Con_Kyou_Sayori_f5969f28:

    # ks "So, what, you slept through your alarm?"
    ks "¿Y qué? ¿No te despertó la alarma?"

# game/kyou 3.rpy:2314
translate spanish Day3_Con_Kyou_Sayori_3b9167df:

    # s alert_sleep "Ugh. I do not set an alarm. There has been no need, as I always wake at the crack of dawn regardless." with dissolve
    s alert_sleep "Aj. Yo no pongo alarma. No ha habido necesidad. Siempre despierto muy temprano en la mañana." with dissolve

# game/kyou 3.rpy:2357
translate spanish Day3_Con_Kyou_Sayori_47620bf4:

    # s alert_sleeptalk "Anyway, what is important here is whatever you did had a dramatic effect on me that I find equal parts fascinating and disturbing." with dissolve
    s alert_sleeptalk "En fin, lo importante aquí es que lo que sea que hiciste tuvo un efecto dramático en mí que encuentro fascinante al mismo nivel que perturbador." with dissolve

# game/kyou 3.rpy:2316
translate spanish Day3_Con_Kyou_Sayori_82109f0d:

    # s alert_surprised_right "You were not supposed to succeed, Kyou." with dissolve
    s alert_surprised_right "No se suponía que tuvieras éxito, Kyou." with dissolve

# game/kyou 3.rpy:2317
translate spanish Day3_Con_Kyou_Sayori_705ab8d7:

    # "She did say that yesterday, but..."
    "Eso mismo dijo ayer, pero..."

# game/kyou 3.rpy:2690
translate spanish Day3_Con_Kyou_Sayori_083de0a0:

    # ks "Why did you agree to it if you didn't think it could work?"
    ks "¿Por qué aceptaste hacerlo si no pensaste que funcionaría?"

# game/kyou 3.rpy:2583
translate spanish Day3_Con_Kyou_Sayori_ac697ac8:

    # s alert_sleep "I have observed you over the years. I saw a self-pitying ignoramus who never looked to improve himself beyond a narrow self-interest." with dissolve
    s alert_sleep "Te he observado con el pasar de los años. Vi a un ignorante autocompasivo que nunca buscó mejorar más allá de en pos de limitados intereses personales." with dissolve

# game/kyou 3.rpy:2320
translate spanish Day3_Con_Kyou_Sayori_6929fcc4:

    # s alert_concerned "So when you made an earnest offer to assist me? Impotent as it was, I still wanted to encourage that behaviour." with dissolve
    s alert_concerned "Por lo que, cuando mostraste interés en ofrecerme asistencia, por impotente que fuera, quise fomentar ese comportamiento." with dissolve

# game/kyou 3.rpy:2321
translate spanish Day3_Con_Kyou_Sayori_4009e615:

    # s alert_concerned_right "But it seems I underestimated you." with dissolve
    s alert_concerned_right "Pero tal parece que te subestimé." with dissolve

# game/kyou 3.rpy:2322
translate spanish Day3_Con_Kyou_Sayori_71846403:

    # "Wait."
    "Espera."

# game/kyou 3.rpy:2323
translate spanish Day3_Con_Kyou_Sayori_b37fadb0:

    # ks "Back up a sec. What do you mean you observed me?"
    ks "Regresa un poco. ¿Cómo que me observaste?"

# game/kyou 3.rpy:2324
translate spanish Day3_Con_Kyou_Sayori_3616f0be:

    # s alert_annoyed_right "Oh, do not get indignant with me. You \"observed\" Nozomi for years. Did you really think no one would observe you back?" with dissolve
    s alert_annoyed_right "Oh, no te hagas el indignado conmigo. Tú \"observaste\" a Nozomi por años. ¿De verdad creías que nadie te observaría de regreso?" with dissolve

# game/kyou 3.rpy:2325
translate spanish Day3_Con_Kyou_Sayori_75180a47:

    # "Damn. All these years wishing Nozomi would talk to me and being ignored, yet this whole time the one interested in me was..."
    "Demonios. Tantos años deseando que Nozomi me hablara y siendo ignorado, y resulta que la que estaba interesada en mí era..."

# game/kyou 3.rpy:2326
translate spanish Day3_Con_Kyou_Sayori_55872b5c:

    # s alert_neutral_right "Anyway, we are getting sidetracked. We NEED to talk about what happened yesterday." with dissolve
    s alert_neutral_right "En fin, nos estamos desviando del tema. NECESITAMOS hablar de lo que ocurrió ayer." with dissolve

# game/kyou 3.rpy:2327
translate spanish Day3_Con_Kyou_Sayori_b7c2f716:

    # "And hey, I was right about her; she doesn't even look that bad after she's had a decent night's sleep."
    "Y oye, tenía razón; no se ve tan mal después de tener una noche decente de sueño."

# game/kyou 3.rpy:2328
translate spanish Day3_Con_Kyou_Sayori_2e0e6141:

    # s "Kyou?"
    s "¿Kyou?"

# game/kyou 3.rpy:2706
translate spanish Day3_Con_Kyou_Sayori_d34110d3:

    # ks neutral "Uh, right. Yesterday."
    ks neutral "Oh, cierto. Lo de ayer."

# game/kyou 3.rpy:2330
translate spanish Day3_Con_Kyou_Sayori_77a66d71:

    # s "Could you run me through what happened? I remember very little of what we did, besides some kind of light pen being involved."
    s "¿Podrías relatarme lo sucedido? Recuerdo muy poco de lo que hicimos, aparte de alguna clase de linterna tipo pluma involucrada."

# game/kyou 3.rpy:2333
translate spanish Day3_Con_Kyou_Sayori_1fd21d1d:

    # "As she mentions it, I pull the penlight out of my pocket and show it to her."
    "Cuando la menciona, saco la linterna de mi bolsillo y se la muestro."

# game/kyou 3.rpy:2334
translate spanish Day3_Con_Kyou_Sayori_aa952d28:

    # ks neutral "Yeah, this. I shone the light in your eyes while I was doing my induction on you. Seems like it worked pretty well."
    ks neutral "Sí, esta. Encendí esta linterna en tus ojos mientras te hacía mi inducción. Parece que funcionó bastante bien."

# game/kyou 3.rpy:2335
translate spanish Day3_Con_Kyou_Sayori_94f8ce8a:

    # s alert_surprised_right "I cannot dispute that after this morning. And what did you do during this \"induction\"?" with dissolve
    s alert_surprised_right "No puedo discutir eso tras lo de esta mañana. ¿Y qué hiciste durante dicha \"inducción\"?" with dissolve

# game/kyou 3.rpy:2337
translate spanish Day3_Con_Kyou_Sayori_7bfbd518:

    # ks "I, uh... pretty much did what we agreed, Sayori. I took you deep into a hypnotic trance, then I had you blank out all your thoughts and worries."
    ks "Yo, eh... básicamente lo que acordamos, Sayori. Te puse en un profundo trance hipnótico, luego apagué tus pensamientos y preocupaciones."

# game/kyou 3.rpy:2381
translate spanish Day3_Con_Kyou_Sayori_2635d5a6:

    # ks "And I told you to go back to that same blank state whenever you went to sleep at night." with dissolve
    ks "Y te dije que volvieras a ese mismo estado de serenidad siempre que te fueras a dormir por las noches." with dissolve

# game/kyou 3.rpy:2339
translate spanish Day3_Con_Kyou_Sayori_6218668a:

    # ks "Then I brought you out of trance and you woke up. That's it."
    ks "Luego te saqué del trance y te desperté. Eso fue todo."

# game/kyou 3.rpy:2383
translate spanish Day3_Con_Kyou_Sayori_c98dfb24:

    # s alert_surprised_right "That sounds... deceptively simple." with dissolve
    s alert_surprised_right "Suena... ilusoriamente simple." with dissolve

# game/kyou 3.rpy:2341
translate spanish Day3_Con_Kyou_Sayori_33ae1da5:

    # ks smile "I guess? I wasn't sure how well you'd take to it, especially because you didn't think it'd work."
    ks smile "¿Supongo? No estaba tan seguro de qué tan bien lo retendrías, sobre todo porque no creías que iba a funcionar."

# game/kyou 3.rpy:2342
translate spanish Day3_Con_Kyou_Sayori_eb689def:

    # ks "But once I got started you seemed to really get into it! And it didn't take too long to take you deep."
    ks "¡Pero en cuanto empecé, parecías estar muy metida en ello! Y poco después, ya habías ido muy profundo."

# game/kyou 3.rpy:2344
translate spanish Day3_Con_Kyou_Sayori_774f8748:

    # ks "Which is just as well, since we didn't have a lot of time." with dissolve
    ks "Lo cual vino muy bien, ya que no teníamos mucho tiempo." with dissolve

# game/kyou 3.rpy:2345
translate spanish Day3_Con_Kyou_Sayori_91c41792:

    # s uniform_folded "What do you mean that I was getting into it?" with dissolve
    s uniform_folded "¿A qué te refieres con que estaba muy metida en ello?" with dissolve

# game/kyou 3.rpy:2346
translate spanish Day3_Con_Kyou_Sayori_6dffe5c4:

    # ks surprised "Huh?"
    ks surprised "¿Eh?"

# game/kyou 3.rpy:2347
translate spanish Day3_Con_Kyou_Sayori_2d2815e1:

    # "I pause for a second. Why did I think she was... oh."
    "Me detengo por un segundo. ¿Por qué creí que estaba... oh."

# game/kyou 3.rpy:2348
translate spanish Day3_Con_Kyou_Sayori_29fc0b01:

    # ks smile "Yeah, I mean, you looked into the light and sorta gasped at it? Like you'd just seen the most amazing thing."
    ks smile "Sí, quiero decir, miraste la luz y... ¿soltaste un jadeo? Como si hubieras visto lo más asombroso del mundo."

# game/kyou 3.rpy:2349
translate spanish Day3_Con_Kyou_Sayori_88758aed:

    # s alert_neutral "I have no recollection of this." with dissolve
    s alert_neutral "No tengo ningún recuerdo de ello." with dissolve

# game/kyou 3.rpy:2350
translate spanish Day3_Con_Kyou_Sayori_769c618d:

    # ks "Huh. Well, it's true. And you know, when I think about it, it makes a lot of sense that you'd be easy to hypnotize."
    ks "Vaya. Pues, es verdad. Y, ¿sabes?, ahora que lo pienso, tiene mucho sentido que seas fácil de hipnotizar."

# game/kyou 3.rpy:2351
translate spanish Day3_Con_Kyou_Sayori_786f10b3:

    # s alert_annoyed_right "And where are you going with this, Kyou?" with dissolve
    s alert_annoyed_right "¿Y adónde quieres llegar con eso, Kyou?" with dissolve

# game/kyou 3.rpy:2352
translate spanish Day3_Con_Kyou_Sayori_e403fa7e:

    # "Agh, should've realized she'd take that bad. Think fast."
    "Aj, debí darme cuenta de que se lo tomaría a mal. Piensa rápido."

# game/kyou 3.rpy:2738
translate spanish Day3_Con_Kyou_Sayori_9766b902:

    # ks confused "I mean, uh... I've read that smart, creative, open-minded people are really hypnotizable."
    ks confused "Quiero decir, eh... Leí que las personas inteligentes, creativas y de mente abierta son muy fáciles de hipnotizar."

# game/kyou 3.rpy:2354
translate spanish Day3_Con_Kyou_Sayori_fec7d201:

    # ks "I get that you doubted me, but I think you still took me seriously. You were completely willing to be hypnotized by me, even if you didn't think it would work."
    ks "Sé que dudabas de mí, pero, aun así, creo que te lo tomaste en serio. Estabas completamente dispuesta a ser hipnotizada por mí, aunque creyeras que no funcionaría."

# game/kyou 3.rpy:2355
translate spanish Day3_Con_Kyou_Sayori_c4a3d801:

    # ks "So when I started my routine and you felt yourself going along with it, it wasn't hard for you to relax and just let it happen."
    ks "Así que, cuando empecé mi rutina y tú seguiste la corriente, no te fue difícil relajarte y dejarlo pasar."

# game/kyou 3.rpy:2356
translate spanish Day3_Con_Kyou_Sayori_b64793a0:

    # ks "And your intelligent and creative mind did the rest."
    ks "Y tu inteligente y creativa mente hizo el resto."

# game/kyou 3.rpy:2357
translate spanish Day3_Con_Kyou_Sayori_add23992:

    # s alert_neutral "Hmm..." with dissolve
    s alert_neutral "Mmm..." with dissolve

# game/kyou 3.rpy:2358
translate spanish Day3_Con_Kyou_Sayori_8894aee8:

    # "She chews her lip for a moment as she seems to think over what I just said."
    "Se muerde el labio un momento mientras parece pensar en lo que acabo de decir."

# game/kyou 3.rpy:2359
translate spanish Day3_Con_Kyou_Sayori_76b9431c:

    # s "Not to mention how tired I already was. So I can imagine how prepared I must have been to relax at your invitation."
    s "Sin mencionar lo cansada que estaba. Puedo imaginarme lo preparada que debí haber estado para relajarme ante tu invitación."

# game/kyou 3.rpy:2360
translate spanish Day3_Con_Kyou_Sayori_9054ceb0:

    # s "So... I suppose there were many factors working in your favour."
    s "Así que... supongo que hubo muchos factores trabajando a nuestro favor."

# game/kyou 3.rpy:2362
translate spanish Day3_Con_Kyou_Sayori_4386434a:

    # "Coming to this conclusion seems to please her." with dissolve
    "Llegar a esta conclusión parece complacerla." with dissolve

# game/kyou 3.rpy:2363
translate spanish Day3_Con_Kyou_Sayori_6c5d9147:

    # s "Thank you, Kyou. You have advanced my understanding somewhat."
    s "Gracias, Kyou. De cierta forma, has hecho un avance en mi entendimiento."

# game/kyou 3.rpy:2364
translate spanish Day3_Con_Kyou_Sayori_b4777197:

    # s alert_neutral "Still. It does bother me that I have been attempting to shut down my thoughts for years while you were able to do it for me with just a single brief hypnosis session." with dissolve
    s alert_neutral "No obstante, me molesta el hecho de que he intentado apagar mis pensamientos por años mientras que tú fuiste capaz de hacerlo con solo una breve sesión de hipnosis." with dissolve

# game/kyou 3.rpy:2365
translate spanish Day3_Con_Kyou_Sayori_784d932c:

    # s "I want to know more."
    s "Quiero saber más."

# game/kyou 3.rpy:2366
translate spanish Day3_Con_Kyou_Sayori_a34f756f:

    # ks smile "About hypnosis?"
    ks smile "¿Sobre hipnosis?"

# game/kyou 3.rpy:2710
translate spanish Day3_Con_Kyou_Sayori_bb4f50a9:

    # s alert_neutral_right "Yes. You have given me a new area of study that I need to pursue urgently. And in particular the effects of your hypnosis upon myself." with dissolve
    s alert_neutral_right "Sí. Me has otorgado una nueva área de estudio que necesito perseguir urgentemente. Y en particular, el efecto de tu hipnosis sobre mí." with dissolve

# game/kyou 3.rpy:2368
translate spanish Day3_Con_Kyou_Sayori_41365f5b:

    # s alert_surprised_right "For starters, what if I go to bed and just as I am settling to sleep I realize I must do something first." with dissolve
    s alert_surprised_right "Para empezar, ¿qué tal si me voy a la cama y al prepararme para dormir me doy cuenta de que tengo algo que hacer?" with dissolve

# game/kyou 3.rpy:2370
translate spanish Day3_Con_Kyou_Sayori_cbe98858:

    # s alert_neutral "Or maybe I just needed to pee." with dissolve
    s alert_neutral "O tal vez solo necesite hacer pipí." with dissolve

# game/kyou 3.rpy:2371
translate spanish Day3_Con_Kyou_Sayori_33dbf7e2:

    # s alert_surprised_right "Would I still be able to rouse my mind back into working or would it be too late to stop my descent into oblivion, completely helpless until morning comes?" with dissolve
    s alert_surprised_right "¿Sería aún capaz de volver a poner mi mente a trabajar o sería muy tarde para evitar mi descenso a la inconsciencia, totalmente desamparada hasta el amanecer?" with dissolve

# game/kyou 3.rpy:2372
translate spanish Day3_Con_Kyou_Sayori_88970ccc:

    # ks "Uh... I think you still could if you needed to?"
    ks "Eh... ¿creo que aún podrías si lo necesitas?"

# game/kyou 3.rpy:2373
translate spanish Day3_Con_Kyou_Sayori_68c2f550:

    # s alert_angry_right "You think? I need to KNOW, Kyou!" with dissolve
    s alert_angry_right "¿Crees? ¡Necesito SABER, Kyou!" with dissolve

# game/kyou 3.rpy:2374
translate spanish Day3_Con_Kyou_Sayori_7377aa45:

    # "Damn, I wish she'd stop getting agitated sometimes. It makes me nervous."
    "Demonios. Desearía que dejara de agitarse a veces. Me pone nervioso."

# game/kyou 3.rpy:2770
translate spanish Day3_Con_Kyou_Sayori_9ee8e318:

    # ks confused "It's... well, it's like I said. Hypnosis isn't magic or mind control." with dissolve
    ks confused "Es... pues, es como dije. La hipnosis no es magia ni control mental." with dissolve

# game/kyou 3.rpy:2376
translate spanish Day3_Con_Kyou_Sayori_56a190fa:

    # ks "It can guide you in the right direction, but you can't be forced into doing something you don't want to do."
    ks "Te puedo guiar en la dirección correcta, pero no puedo obligarte a hacer algo que no quieras hacer."

# game/kyou 3.rpy:2378
translate spanish Day3_Con_Kyou_Sayori_4de458a1:

    # ks "So sure, if you really needed to get up and take a piss or whatever, you'll still do it." with dissolve
    ks "Ten por seguro que, si necesitas hacer pis o lo que sea, lo harás de todos modos." with dissolve

# game/kyou 3.rpy:2379
translate spanish Day3_Con_Kyou_Sayori_08b88b74:

    # ks "But you really DID want to just turn your thoughts off and go to sleep last night, didn't you?"
    ks "Pero anoche SÍ querías apagar tus pensamientos e ir a dormir, ¿no?"

# game/kyou 3.rpy:2380
translate spanish Day3_Con_Kyou_Sayori_524bc27b:

    # s alert_concerned "Well... yes, of course. I was shattered. As I am most nights." with dissolve
    s alert_concerned "Pues... sí, desde luego. Estaba hecha polvo. Como casi todas las noches." with dissolve

# game/kyou 3.rpy:2381
translate spanish Day3_Con_Kyou_Sayori_e562d1f6:

    # "More like every night."
    "Más bien todas las noches."

# game/kyou 3.rpy:2425
translate spanish Day3_Con_Kyou_Sayori_9db4ce17:

    # s alert_sleeptalk "I was prepared for a frustrating hour of silencing the thoughts in my head..." with dissolve
    s alert_sleeptalk "Estaba preparada para pasar una frustrante hora silenciando los pensamientos de mi cabeza..." with dissolve

# game/kyou 3.rpy:2383
translate spanish Day3_Con_Kyou_Sayori_eac7c2fc:

    # s "Endlessly processing the events and concerns of the day whether I wanted to or not."
    s "Procesando incesantemente los eventos y las preocupaciones del día, así lo quisiera o no."

# game/kyou 3.rpy:2384
translate spanish Day3_Con_Kyou_Sayori_7a7a643e:

    # s alert_sleep "But as I said, the moment my head hit the pillow, there was nothing." with dissolve
    s alert_sleep "Pero como dije, en el momento en que mi cabeza tocó la almohada, ya no había nada." with dissolve

# game/kyou 3.rpy:2385
translate spanish Day3_Con_Kyou_Sayori_45f40b91:

    # s "I wanted to sleep, so I slept. I can accept that."
    s "Quería dormir, y dormí. Puedo aceptar eso."

# game/kyou 3.rpy:2785
translate spanish Day3_Con_Kyou_Sayori_2949bb9a:

    # ks neutral "So then, I'm really not like those \"malicious hypnotists\" you were talking about. I really wanted to help you, Sayori."
    ks neutral "Entonces, realmente no soy como uno de esos \"hipnotistas maliciosos\" de los que hablaste. En serio quería ayudarte, Sayori."

# game/kyou 3.rpy:2430
translate spanish Day3_Con_Kyou_Sayori_38c81f94:

    # s alert_neutral "I was not concerned about that. I just needed to be sure I was still in control of my actions, regardless of your intent." with dissolve
    s alert_neutral "No estaba preocupada por eso. Solo necesitaba estar segura de que aún tenía control sobre mis actos, sin importar tu intención." with dissolve

# game/kyou 3.rpy:2388
translate spanish Day3_Con_Kyou_Sayori_c8c4fd3f:

    # s alert_smile_right "Your explanations make sense, and they line up with my own research." with dissolve
    s alert_smile_right "Tus explicaciones tienen sentido, y coinciden con mi propia investigación." with dissolve

# game/kyou 3.rpy:2389
translate spanish Day3_Con_Kyou_Sayori_33098dca:

    # "As I return her smile, I take a moment to appreciate what is happening here."
    "Devolviéndole la sonrisa, me tomo un momento para apreciar lo que está pasando aquí."

# game/kyou 3.rpy:2390
translate spanish Day3_Con_Kyou_Sayori_b02f8015:

    # "Like, not only am I having a normal conversation with a girl and not fucking it up, but she's also taking an interest in something I introduced to her."
    "O sea, no solo estoy teniendo una conversación normal con una chica y no la estoy cagando, sino que también está interesada en algo a lo que la introduje."

# game/kyou 3.rpy:2391
translate spanish Day3_Con_Kyou_Sayori_8e39631e:

    # "Not to mention, after getting a little chance to put my penlight and my hypnosis study to practical use, there's no way I want to leave it at that."
    "Sin mencionar que, ahora que hallé una pequeña oportunidad de darles a mi linterna y a mis estudios en hipnosis un uso práctico, no pienso dejarla ir."

# game/kyou 3.rpy:2392
translate spanish Day3_Con_Kyou_Sayori_d02aad01:

    # "I HAVE to keep this going."
    "TENGO que seguir con esto."

# game/kyou 3.rpy:2393
translate spanish Day3_Con_Kyou_Sayori_22a665d6:

    # ks smile "So now that you know, would you like to try another hypnosis session while you're here?"
    ks smile "Pues, ahora que lo sabes, ¿te gustaría probar otra sesión de hipnosis, ya que estás aquí?"

# game/kyou 3.rpy:2394
translate spanish Day3_Con_Kyou_Sayori_6874d104:

    # s alert_surprised_right "I had not considered another session, honestly." with dissolve
    s alert_surprised_right "No tenía considerada otra sesión, honestamente." with dissolve

# game/kyou 3.rpy:2395
translate spanish Day3_Con_Kyou_Sayori_0f93d54f:

    # ks "Is there anything else you think you need help with?"
    ks "¿Hay algo más en lo que necesites ayuda?"

# game/kyou 3.rpy:2440
translate spanish Day3_Con_Kyou_Sayori_3903dfdb:

    # ks "Like, uhh... I dunno, are you eating enough greens? Do you chew your fingernails?" with dissolve
    ks "Como, eeeh... no sé, ¿comes suficientes verduras? ¿Te muerdes las uñas?" with dissolve

# game/kyou 3.rpy:2397
translate spanish Day3_Con_Kyou_Sayori_b58eb5a9:

    # s alert_annoyed_right "I do not have any bad habits that I am aware of, and my diet is fine." with dissolve
    s alert_annoyed_right "No tengo ningún mal hábito del que esté consciente, y mi dieta está bien." with dissolve

# game/kyou 3.rpy:2398
translate spanish Day3_Con_Kyou_Sayori_6c913b15:

    # "I think her working herself half to death counts as a \"bad habit\", but I think better of saying it."
    "Me parece que casi matarse trabajando cuenta como \"mal hábito\", pero creo que mejor no lo digo."

# game/kyou 3.rpy:2399
translate spanish Day3_Con_Kyou_Sayori_07ff4423:

    # ks "... Something fun, then?"
    ks "... ¿Entonces, algo divertido?"

# game/kyou 3.rpy:2400
translate spanish Day3_Con_Kyou_Sayori_4dd65ae0:

    # s alert_surprised_right "Fun?" with dissolve
    s alert_surprised_right "¿Divertido?" with dissolve

# game/kyou 3.rpy:2401
translate spanish Day3_Con_Kyou_Sayori_8ca82d96:

    # ks "Yeah. I guess like the \"stage tricks\" you thought this was gonna be, when I first talked about hypnotizing you."
    ks "Sí. Algo así como los \"trucos escénicos\" que creíste que iba a hacer cuando te mencioné la hipnosis por primera vez."

# game/kyou 3.rpy:2402
translate spanish Day3_Con_Kyou_Sayori_7f948269:

    # s alert_neutral "I did not come here for fun, Kyou." with dissolve
    s alert_neutral "No vine aquí por diversión, Kyou." with dissolve

# game/kyou 3.rpy:2447
translate spanish Day3_Con_Kyou_Sayori_9c9ef5d8:

    # s alert_concerned "Besides, I already feel terrible about shirking my study club commitments to come visit you for personal reasons." with dissolve
    s alert_concerned "Además, ya me siento terrible por eludir mis compromisos del club de estudio para venir a visitarte por motivos personales." with dissolve

# game/kyou 3.rpy:2430
translate spanish Day3_Con_Kyou_Sayori_7ef0ad55:

    # s alert_concerned_right "What kind of person would I be if I waived my responsibilities to enjoy myself?" with dissolve
    s alert_concerned_right "¿Qué clase de persona sería si renunciara a mis responsabilidades solo por gozo?" with dissolve

# game/kyou 3.rpy:2405
translate spanish Day3_Con_Kyou_Sayori_009e2ee0:

    # ks "Eh, I dunno. Human, maybe?"
    ks "Eh, no sé. ¿Humana, tal vez?"

# game/kyou 3.rpy:2406
translate spanish Day3_Con_Kyou_Sayori_1f837aa2:

    # s alert_annoyed_right "Oh, you are just hilarious." with dissolve
    s alert_annoyed_right "Oh, eres hilarante." with dissolve

# game/kyou 3.rpy:2407
translate spanish Day3_Con_Kyou_Sayori_e22132ba:

    # ks "No, but really! When was the last time you took some time off to enjoy yourself?"
    ks "¡No, pero en serio! ¿Cuándo fue la última vez que tomaste un rato libre para divertirte?"

# game/kyou 3.rpy:2408
translate spanish Day3_Con_Kyou_Sayori_dc235e71:

    # s alert_annoyed "..." with dissolve
    s alert_annoyed "..." with dissolve

# game/kyou 3.rpy:2409
translate spanish Day3_Con_Kyou_Sayori_c614fe81:

    # ks "Are you trying to remember how long it's been? Because, uh..."
    ks "¿Estás tratando de recordar cuánto tiempo ha sido? Porque, eh..."

# game/kyou 3.rpy:2412
translate spanish Day3_Con_Kyou_Sayori_04a8218a:

    # "I pull out my penlight with a grin."
    "Saco mi linterna con una sonrisa."

# game/kyou 3.rpy:2455
translate spanish Day3_Con_Kyou_Sayori_32ac9b1d:

    # ks happy "I could help you remember."
    ks happy "Puedo ayudarte a recordar."

# game/kyou 3.rpy:2414
translate spanish Day3_Con_Kyou_Sayori_fe9cbab1:

    # s alert_angry_right "I do not take time off, Kyou." with dissolve
    s alert_angry_right "Yo no tomo ratos libres, Kyou." with dissolve

# game/kyou 3.rpy:2458
translate spanish Day3_Con_Kyou_Sayori_1847903a:

    # ks surprised "What, never? Come on, everybody needs to take their mind off of things sometimes."
    ks surprised "¿Qué, nunca? Por favor, todo el mundo necesita despejar su mente de vez en cuando."

# game/kyou 3.rpy:2417
translate spanish Day3_Con_Kyou_Sayori_2b7f3b75:

    # s alert_annoyed "I distract myself by assisting others in their work." with dissolve
    s alert_annoyed "Me distraigo brindando asistencia a otros en su trabajo." with dissolve

# game/kyou 3.rpy:2418
translate spanish Day3_Con_Kyou_Sayori_e661e493:

    # ks "Th-that doesn't count!" with vpunch
    ks "¡E-eso no cuenta!" with vpunch

# game/kyou 3.rpy:2461
translate spanish Day3_Con_Kyou_Sayori_9baf47bb:

    # s alert_irritated "... I refer you to my previous statement." with dissolve
    s alert_irritated "... Te remito a mi afirmación anterior." with dissolve

# game/kyou 3.rpy:2420
translate spanish Day3_Con_Kyou_Sayori_67317f3f:

    # "She's so stubborn. But what if I could frame this differently?"
    "Qué obstinada. ¿Pero qué tal si lo pongo desde otro ángulo?"

# game/kyou 3.rpy:2421
translate spanish Day3_Con_Kyou_Sayori_b9176db7:

    # ks smile "Okay... well, what if I said you'd be assisting me in MY work?"
    ks smile "Muy bien... pues, ¿y si te dijera que me brindarías asistencia en MI trabajo?"

# game/kyou 3.rpy:2422
translate spanish Day3_Con_Kyou_Sayori_cd256155:

    # s alert_annoyed_right "What?" with dissolve
    s alert_annoyed_right "¿Qué?" with dissolve

# game/kyou 3.rpy:2423
translate spanish Day3_Con_Kyou_Sayori_726e63c5:

    # ks "I mean, you know what I can do, right? I could use this ability to help people or entertain them, especially with the culture fest coming up."
    ks "Digo, ya sabes lo que puedo hacer, ¿verdad? Puedo usar esta habilidad para ayudar a la gente o entretenerla, sobre todo con el próximo festival cultural."

# game/kyou 3.rpy:2424
translate spanish Day3_Con_Kyou_Sayori_6525f06a:

    # ks "Hell, I could do a hypnosis show like that guy did last year. Maybe keep that going."
    ks "Vaya, podría hacer un espectáculo de hipnosis como el chico del año pasado. Tal vez continuar después de eso."

# game/kyou 3.rpy:2467
translate spanish Day3_Con_Kyou_Sayori_62c36e8a:

    # s alert_neutral_right "Hmm... Well, Satoshi did graduate so that is a hole you could fill, I suppose. Although I am not sure our school needs a tradition of hypnotist shows." with dissolve
    s alert_neutral_right "Mmm... bueno, Satoshi se graduó, por lo que es un hueco que podrías llenar, supongo. Aunque no sé si nuestra escuela necesita una tradición de espectáculos de hipnosis." with dissolve

# game/kyou 3.rpy:2428
translate spanish Day3_Con_Kyou_Sayori_6b9359a9:

    # ks "It's not like I can walk up to just anyone and ask them to let me practice hypnosis on them, is it?"
    ks "No es como si pudiera acercarme a cualquiera y preguntarle si me deja practicar hipnosis en él, ¿o sí?"

# game/kyou 3.rpy:2429
translate spanish Day3_Con_Kyou_Sayori_a1d16756:

    # "I let out a sigh."
    "Dejo salir un suspiro."

# game/kyou 3.rpy:2430
translate spanish Day3_Con_Kyou_Sayori_57b3b2a1:

    # ks sigh "I mean, everyone else thinks I'm some kind of creeper, but you're the only one who knows I'm not like that."
    ks sigh "Es que, todos los demás creen que soy una especie de bicho espeluznante, pero tú eres la única que sabe que no soy así."

# game/kyou 3.rpy:2812
translate spanish Day3_Con_Kyou_Sayori_5f642c7c:

    # s alert_concerned_right "Kyou, not everyone thinks that of you, but you do come off as aloof and inherently unapproachable."
    s alert_concerned_right "Kyou, no todo el mundo piensa eso de ti, pero sí tiendes a distanciarte y es difícil acercarse."

# game/kyou 3.rpy:2474
translate spanish Day3_Con_Kyou_Sayori_9ead0a26:

    # s alert_irritated "At least when you are not hovering over girls that you wish would notice you. That does come off as creeper behaviour." with dissolve
    s alert_irritated "Al menos cuando no estás encima de chicas que quisieras que te notaran. Eso sí es un comportamiento espeluznante." with dissolve

# game/kyou 3.rpy:2433
translate spanish Day3_Con_Kyou_Sayori_f211465f:

    # ks frown "... Still, you have to admit no one else is likely to help me with this, right? Even if I asked them?"
    ks frown "... Aun así, debes admitir que es probable que nadie más me ayude con esto, ¿verdad? ¿Aunque se lo pidiera?"

# game/kyou 3.rpy:2434
translate spanish Day3_Con_Kyou_Sayori_4c3fb80d:

    # s alert_annoyed "I suppose..." with dissolve
    s alert_annoyed "Eso supongo..." with dissolve

# game/kyou 3.rpy:2864
translate spanish Day3_Con_Kyou_Sayori_2d4b67d6:

    # ks confused "And you said it yourself: You want to know more. What better way to learn about hypnosis than to be more involved in it?"
    ks confused "Y tú misma lo dijiste; quieres saber más. ¿Qué mejor forma de aprender sobre hipnosis que involucrándote?"

# game/kyou 3.rpy:2436
translate spanish Day3_Con_Kyou_Sayori_8e2f6795:

    # "She frowns at the wall for a few moments as she seems to think things over before looking back to me."
    "Frunce el ceño mirando la pared por unos momentos mientras lo piensa, para luego volver a verme a mí."

# game/kyou 3.rpy:2437
translate spanish Day3_Con_Kyou_Sayori_8fa51fd9:

    # s alert_annoyed_right "You may propose something \"fun\" and I will decide if I am keen." with dissolve
    s alert_annoyed_right "Puedes proponer algo \"divertido\" y yo decido si estoy interesada." with dissolve

# game/kyou 3.rpy:2438
translate spanish Day3_Con_Kyou_Sayori_f790861d:

    # ks smile "Okay! Well then, how about we try..."
    ks smile "¡Muy bien! Entonces, ¿qué tal si intentamos..."

# game/kyou 3.rpy:2442
translate spanish Day3_Con_Kyou_Sayori_b7a619ca:

    # ks "Just hear me out; wouldn't it be a fun trick if I got you to pretend to be a different person?"
    ks "Escucha esto; ¿no sería un truco muy divertido si te hago fingir que eres alguien diferente?"

# game/kyou 3.rpy:2443
translate spanish Day3_Con_Kyou_Sayori_722ed750:

    # s "What?"
    s "¿Qué?"

# game/kyou 3.rpy:2444
translate spanish Day3_Con_Kyou_Sayori_6c4ca7fb:

    # ks "Like, imagine if for a little while you had it in your head that you were someone more carefree and fun-loving? Like, someone who clearly isn't you?"
    ks "O sea, imagina que por un rato tuvieras en la cabeza que eres alguien despreocupada y amante de la diversión. ¿Alguien que claramente no eres tú?"

# game/kyou 3.rpy:2445
translate spanish Day3_Con_Kyou_Sayori_3b2a8ed6:

    # s alert_surprised_right "I am imagining it, and it sounds terrifying." with dissolve
    s alert_surprised_right "Lo estoy imaginando y suena aterrador." with dissolve

# game/kyou 3.rpy:2446
translate spanish Day3_Con_Kyou_Sayori_2f38f5f7:

    # "Her reply makes me chuckle."
    "Su respuesta me hace reír."

# game/kyou 3.rpy:2447
translate spanish Day3_Con_Kyou_Sayori_06f87a9d:

    # ks "Yeah, but it'd be a neat stage trick for anyone who knows you, wouldn't it? I-I mean, not that I'm asking you to do this in front of anybody."
    ks "Sí, pero sería un buen truco para cualquiera que te conozca, ¿no? D-digo, no es que te esté pidiendo hacerlo delante de nadie."

# game/kyou 3.rpy:2448
translate spanish Day3_Con_Kyou_Sayori_7be89ada:

    # ks "But if it worked on you, I could definitely try to do it with a volunteer on stage."
    ks "Pero si funciona en ti, definitivamente podría intentarlo con un voluntario en el escenario."

# game/kyou 3.rpy:2815
translate spanish Day3_Con_Kyou_Sayori_571a31a5:

    # s "And I would still be in control of myself?" with dissolve
    s "¿Y seguiría teniendo el control de mí misma?" with dissolve

# game/kyou 3.rpy:2450
translate spanish Day3_Con_Kyou_Sayori_93848e7f:

    # ks "Well, yeah. If you got too uncomfortable doing it, you'd snap right out of it, I'm sure. If the suggestions even took at all."
    ks "Pues, sí. Si te sientes incómoda haciéndolo, despertarás de inmediato, estoy seguro. Eso si las sugestiones siquiera tienen efecto."

# game/kyou 3.rpy:2451
translate spanish Day3_Con_Kyou_Sayori_3779a354:

    # ks "No matter what, you would always be you."
    ks "Sin importar qué, siempre serás tú."

# game/kyou 3.rpy:2453
translate spanish Day3_Con_Kyou_Sayori_af8d59fe:

    # "I can see she's seriously thinking of letting me try this, now that I've given her some assurance." with dissolve
    "Puedo ver que en serio está pensando en dejarme intentar esto, ahora que le di algo de garantía." with dissolve

# game/kyou 3.rpy:2822
translate spanish Day3_Con_Kyou_Sayori_5be1b25f:

    # s "Let us say I allow this. How would it be achieved?" with dissolve
    s "Digamos que lo permito. ¿Cómo se lograría dicho resultado?" with dissolve

# game/kyou 3.rpy:2455
translate spanish Day3_Con_Kyou_Sayori_ecd0dc25:

    # ks "Well, after I bring you into trance again, I tell you about this carefree, fun-loving person and give you a trigger phrase that would work while you're out of trance."
    ks "Bueno, después de ponerte en trance, te hablo de esa despreocupada persona que adora divertirse y la anclo a una frase que funcionaría mientras estés fuera del trance."

# game/kyou 3.rpy:2456
translate spanish Day3_Con_Kyou_Sayori_cd39d6f7:

    # ks "So when you come out of trance, and I say this phrase, you'd be compelled to think of yourself as this other person and act like they would."
    ks "Y así, cuando salgas del trance y yo diga la frase, te empezarías a considerar esa otra persona y actuarías como tal."

# game/kyou 3.rpy:2457
translate spanish Day3_Con_Kyou_Sayori_db5e5038:

    # s alert_sleep "It sounds very much like roleplay." with dissolve
    s alert_sleep "Suena a un juego de rol." with dissolve

# game/kyou 3.rpy:2458
translate spanish Day3_Con_Kyou_Sayori_2c909f0e:

    # ks "Yeah, I guess it is, kinda. Although if you really get into this I bet it's way more immersive. Like, for a while you could believe you really ARE this other person."
    ks "Sí, supongo que sí, más o menos. Aunque si lo haces bien, apuesto a que será mucho más inmersivo. Como si por un rato pudieras creer que realmente ERES esa otra persona."

# game/kyou 3.rpy:2459
translate spanish Day3_Con_Kyou_Sayori_b17bac72:

    # s alert_concerned_right "To be honest, I do not like the sound of that." with dissolve
    s alert_concerned_right "Para ser honesta, no me gusta cómo suena." with dissolve

# game/kyou 3.rpy:2460
translate spanish Day3_Con_Kyou_Sayori_2856375a:

    # ks "Yeah, I get how that could be a little troubling for you. But remember, I won't be able to do anything you seriously don't want, whether in or out of trance."
    ks "Sí, entiendo que puede ser algo problemático para ti. Pero recuerda, no podré hacer nada que en serio no quieras, ni dentro ni fuera del trance."

# game/kyou 3.rpy:2461
translate spanish Day3_Con_Kyou_Sayori_360d4660:

    # ks "And even if you're under the effects, you'll be able to stop anytime you need to."
    ks "E incluso si estás bajo los efectos, serás capaz de detenerte siempre que lo necesites."

# game/kyou 3.rpy:2462
translate spanish Day3_Con_Kyou_Sayori_9ee93fec:

    # "I smile in a way I hope she'll see as kindly as I say this. After all, helping your subjects feel at ease is just one more skill a good hypnotist needs."
    "Al decirlo, sonrío de una forma que espero que le parezca amable. Después de todo, ayudar a los sujetos a sentirse cómodos es otra habilidad que un buen hipnotista necesita."

# game/kyou 3.rpy:2463
translate spanish Day3_Con_Kyou_Sayori_943f2672:

    # ks "So how about we put you in trance and see how you feel about it then?"
    ks "Entonces, ¿qué tal si comenzamos la inducción y vemos cómo te sientes?"

# game/kyou 3.rpy:2465
translate spanish Day3_Con_Kyou_Sayori_76d04495:

    # "Sayori sighs a little as she turns her gaze from me." with dissolve
    "Sayori suspira levemente, desviándome la mirada." with dissolve

# game/kyou 3.rpy:2466
translate spanish Day3_Con_Kyou_Sayori_6de05e66:

    # s "I am not fully on board with this, but as you said the other day \"what's the worst that could happen from this?\"."
    s "No estoy convencida del todo, pero como dijiste el otro día: \"¿qué es lo peor que podría pasar?\"."

# game/kyou 3.rpy:2469
translate spanish Day3_Con_Kyou_Sayori_130a4219:

    # "I smile once more as I pull my penlight back from my pocket."
    "Sonrío una vez más, volviendo a sacar mi linterna del bolsillo."

# game/kyou 3.rpy:2471
translate spanish Day3_Con_Kyou_Sayori_e4f2ec3f:

    # ks "I promise you, Sayori, everything will be fine." with dissolve
    ks "Te prometo, Sayori, que todo estará bien." with dissolve

# game/kyou 3.rpy:2848
translate spanish Day3_Con_Kyou_Sayori_f2c5de90:

    # "As I switch the light on, I notice Sayori has adjusted herself on the couch to sit in a more comfortable resting position while looking up at me with just her eyes." with dissolve
    "Enciendo la linterna y noto que Sayori se ha acomodado en el sofá para sentarse en una posición más cómoda, mientras mira la linterna solamente con sus ojos." with dissolve

# game/kyou 3.rpy:2477
translate spanish Day3_Con_Kyou_Sayori_51d31271:

    # "It seems despite her misgivings she's still willing to let me do this."
    "Parece que, a pesar de sus dudas, sigue dispuesta a dejarme hacer esto."

# game/kyou 3.rpy:2484
translate spanish Day3_Con_Kyou_Sayori_aaa23be9:

    # ks "And because everything is fine, I think you will find yourself staring into the light once again with no trouble at all."
    ks "Y ya que todo está bien, creo que no tendrás problemas en observar la luz una vez más."

# game/kyou 3.rpy:2486
translate spanish Day3_Con_Kyou_Sayori_a676659b:

    # ks "Perhaps remembering how good it feels to have the light illuminate your face."
    ks "Y quizá empieces a recordar lo bien que se siente la luz iluminando tu rostro."

# game/kyou 3.rpy:2489
translate spanish Day3_Con_Kyou_Sayori_dab22f11:

    # ks "Seeing the pattern forming in your eyes as you focus for me." with dissolve
    ks "Ver el patrón que se forma ante tus ojos mientras te concentras en mí." with dissolve

# game/kyou 3.rpy:2491
translate spanish Day3_Con_Kyou_Sayori_700b9e50:

    # ks "And while you focus on that, Sayori, you may find it easier to listen to my words."
    ks "Y mientras te concentras en eso, Sayori, puede que te sea más fácil escuchar mis palabras."

# game/kyou 3.rpy:2493
translate spanish Day3_Con_Kyou_Sayori_acc3d46d:

    # ks "So easy to listen that you don't even need to consciously think about the words."
    ks "Tan fácil escuchar que ni siquiera necesitas pensar conscientemente en las palabras."

# game/kyou 3.rpy:2496
translate spanish Day3_Con_Kyou_Sayori_d4239263:

    # ks "All you need to do is focus on the light, and everything else will take care of itself." with dissolve
    ks "Solo necesitas concentrarte en la luz, y todo lo demás pasará por sí solo." with dissolve

# game/kyou 3.rpy:2498
translate spanish Day3_Con_Kyou_Sayori_2d5b6aca:

    # ks "Your feet, your ankles, your legs, they may lose all their tension; becoming loose and limp."
    ks "Tus pies, tus tobillos, tus piernas, pueden dejar ir toda la tensión; quedando muy flojitos."

# game/kyou 3.rpy:2500
translate spanish Day3_Con_Kyou_Sayori_d40a549d:

    # ks "Your hands, your arms and your chest may all relax themselves while you breathe so deeply. Still focusing your eyes on the pattern you see from my light."
    ks "Tus manos, tus brazos y tu torso pueden relajarse mientras respiras muy profundamente. Mantén los ojos en el patrón que hay en la luz."

# game/kyou 3.rpy:2810
translate spanish Day3_Con_Kyou_Sayori_addfb203:

    # ks "That's right, Sayori. Letting yourself go more and more with every breath you take."
    ks "Eso es, Sayori. Déjate llevar más y más con cada respiración."

# game/kyou 3.rpy:2505
translate spanish Day3_Con_Kyou_Sayori_461de1a0:

    # ks "Your neck may find itself coming to rest now, just as loose and limp and relaxed as the rest of your body."
    ks "Tu cuello puede descansar ahora, tan flojito y relajado como el resto de tu cuerpo."

# game/kyou 3.rpy:2816
translate spanish Day3_Con_Kyou_Sayori_a6d95736:

    # ks "But you don't need to worry about any of that. Just stay with the light, as long as you can, Sayori."
    ks "Pero no tienes que preocuparte por nada de eso. Solo sigue mirando la luz tanto como puedas, Sayori."

# game/kyou 3.rpy:2510
translate spanish Day3_Con_Kyou_Sayori_63e9f5db:

    # ks "Even as your head now may be feeling so very limp and loose, even your eyelids might find themselves falling closed as you feel so completely relaxed and safe."
    ks "Aunque sientas que tu cabeza se afloja cada vez más, aunque tus párpados, tal vez, empiecen a cerrarse, al sentirte tan segura y relajada."

# game/kyou 3.rpy:2822
translate spanish Day3_Con_Kyou_Sayori_237f787b:

    # ks "And if you find yourself no longer able to look at the light then that's fine, Sayori."
    ks "Y si de pronto ya no puedes mirar la luz, no te preocupes, Sayori."

# game/kyou 3.rpy:2514
translate spanish Day3_Con_Kyou_Sayori_b4c510ac:

    # ks "You can just drop deeper for me instead."
    ks "En vez de eso, puedes caer más profundo."

# game/kyou 3.rpy:2826
translate spanish Day3_Con_Kyou_Sayori_f8b45799:

    # ks "Feeling so incredibly deep and relaxed as you let my words carry you deeper."
    ks "Sintiéndote tan increíblemente relajada al dejar que mis palabras te lleven más profundo."

# game/kyou 3.rpy:2517
translate spanish Day3_Con_Kyou_Sayori_9d4a2135:

    # ks "But even as deep as you are, you will be able to respond to any questions I have, knowing that every time you respond will take you deeper still."
    ks "Pero por más profundo que vayas, podrás responder cualquiera de mis preguntas, sabiendo que, cada vez que respondas, irás todavía más profundo."

# game/kyou 3.rpy:2518
translate spanish Day3_Con_Kyou_Sayori_6cbdd3cd:

    # ks "Do you understand, Sayori?"
    ks "¿Comprendes, Sayori?"

# game/kyou 3.rpy:2520
translate spanish Day3_Con_Kyou_Sayori_e9934ec5:

    # scg alert_sleeptalk "I understand..." with dissolve
    scg alert_sleeptalk "Comprendo..." with dissolve

# game/kyou 3.rpy:2565
translate spanish Day3_Con_Kyou_Sayori_c9ef35a0:

    # "I smile at her responsiveness. Just like I told her, she's very hypnotizable." with dissolve
    "Sonrío al ver lo responsiva que es. Tal como dije, es muy hipnotizable." with dissolve

# game/kyou 3.rpy:2523
translate spanish Day3_Con_Kyou_Sayori_f02a6d04:

    # "As I look her over to make sure she's not uncomfortable slumped how she is, an idea pops into my head."
    "Cuando la reviso para asegurarme de que no esté incómoda ahí arrumbada, una idea se me viene a la cabeza."

# game/kyou 3.rpy:2524
translate spanish Day3_Con_Kyou_Sayori_3d6e9584:

    # ks "And if you find your body is experiencing discomfort, you will be able to effortlessly adjust yourself so that you remain fully comfortable."
    ks "Y si tu cuerpo experimenta incomodidad, verás que puedes acomodarte con facilidad hasta estar completamente cómoda."

# game/kyou 3.rpy:2525
translate spanish Day3_Con_Kyou_Sayori_b794dbd0:

    # ks "And in doing so, allow yourself to drop even deeper for me."
    ks "Y al hacerlo, vas a caer aún más profundo."

# game/kyou 3.rpy:2526
translate spanish Day3_Con_Kyou_Sayori_10c2d9e9:

    # "I watch her closely, and she does indeed shift her position on the couch; leaning her head and back against the cushion to reduce the tension on her neck and spine."
    "La observo de cerca y, en efecto, cambia un poco su posición en el sofá; apoyando su cabeza y espalda cobre el cojín para reducir la tensión de su cuello y columna."

# game/kyou 3.rpy:2527
translate spanish Day3_Con_Kyou_Sayori_5d7b6dec:

    # ks "Very good, Sayori. Deeper now as you feel so good about accepting my suggestions."
    ks "Muy bien, Sayori. Más profundo ahora. Se siente muy bien aceptar mis sugestiones."

# game/kyou 3.rpy:2528
translate spanish Day3_Con_Kyou_Sayori_09e1d735:

    # "So now is the moment of truth. Let's see how she takes to this."
    "Es el momento de la verdad. Veamos qué tal responde a esto."

# game/kyou 3.rpy:2529
translate spanish Day3_Con_Kyou_Sayori_bbee2d76:

    # ks "Now that you are so deep, so relaxed and so open to my suggestions, I want you to think about another person."
    ks "Ahora que estás tan profundamente relajada y abierta a mis sugestiones, quiero que pienses en cierta persona."

# game/kyou 3.rpy:2530
translate spanish Day3_Con_Kyou_Sayori_9c9918c4:

    # ks "This person, a woman, looks exactly like you, and knows everything that you do. However, you are different from her in a few very important ways."
    ks "Esta persona, una mujer, luce exactamente igual que tú, y sabe todo lo que tú sabes. Sin embargo, tú eres muy diferente a ella en un par de cositas muy importantes."

# game/kyou 3.rpy:2531
translate spanish Day3_Con_Kyou_Sayori_d6df7fba:

    # ks "For starters, she has no idea that you exist."
    ks "Para empezar, ella no tiene idea de que existes."

# game/kyou 3.rpy:2532
translate spanish Day3_Con_Kyou_Sayori_c52ecbf4:

    # ks "And unlike you, she always wants to be happy and carefree. She loves to smile and laugh and have fun all the time, and hates having to study."
    ks "Y a diferencia de ti, siempre quiere estar feliz y despreocupada. Adora sonreír y reír y divertirse todo el tiempo, y odia tener que estudiar."

# game/kyou 3.rpy:2533
translate spanish Day3_Con_Kyou_Sayori_2ce4b755:

    # "I watch her face for any sort of reaction, half expecting her lip to curl in disgust or something, yet she looks completely serene."
    "Observo su cara en busca de alguna reacción, en parte esperando que sus labios se ricen en disgusto o algo, pero luce completamente serena."

# game/kyou 3.rpy:2534
translate spanish Day3_Con_Kyou_Sayori_2197dcc4:

    # "Kinda makes me want to take it just a little bit further..."
    "Hasta me hace querer llevarlo un poco más allá..."

# game/kyou 3.rpy:2535
translate spanish Day3_Con_Kyou_Sayori_5f0cf5fc:

    # ks blush "S-... she also has a massive crush on me."
    ks blush "Y... y también está perdidamente enamorada de mí."

# game/kyou 3.rpy:2536
translate spanish Day3_Con_Kyou_Sayori_75273fb6:

    # "... Still nothing? Man, this'll be interesting."
    "... ¿Aún nada? Cielos, esto será interesante."

# game/kyou 3.rpy:2537
translate spanish Day3_Con_Kyou_Sayori_a5772c23:

    # ks noblush "This woman has a name, of course. And her name is..."
    ks noblush "Esta mujer tiene nombre, por supuesto. Y su nombre es..."

# game/kyou 3.rpy:2548
translate spanish Day3_Con_Kyou_Sayori_8806bb50:

    # ks "Can you visualize [alt_name] for me, Sayori?"
    ks "¿Puedes visualizar a [alt_name!t] por mí, Sayori?"

# game/kyou 3.rpy:2549
translate spanish Day3_Con_Kyou_Sayori_caee378e:

    # scg alert_sleeptalk "... Yes." with dissolve
    scg alert_sleeptalk "... Sí." with dissolve

# game/kyou 3.rpy:2551
translate spanish Day3_Con_Kyou_Sayori_5ed05695:

    # ks "Can you imagine how happy and carefree she is? How much she loves fun and hates study, and how much she has a crush on me?" with dissolve
    ks "¿Puedes imaginar lo feliz y despreocupada que es? ¿Lo mucho que ama la diversión y odia estudiar, y lo enamorada que está de mí?" with dissolve

# game/kyou 3.rpy:2552
translate spanish Day3_Con_Kyou_Sayori_a301173c:

    # scg alert_sleeptalk "I... y-yes..." with dissolve
    scg alert_sleeptalk "S-sí... s-sí..." with dissolve

# game/kyou 3.rpy:2554
translate spanish Day3_Con_Kyou_Sayori_557eaf3d:

    # ks "That's good, Sayori. Because from now on, whenever I say to you \"become [alt_name]\" you will immediately and automatically become [alt_name]." with dissolve
    ks "Muy bien, Sayori. Porque, de ahora en adelante, cada vez que te diga \"conviértete en [alt_name]\", inmediata y automáticamente te convertirás en [alt_name]." with dissolve

# game/kyou 3.rpy:2555
translate spanish Day3_Con_Kyou_Sayori_3b2642af:

    # "I hasten to add:"
    "Me apresuro a añadir:"

# game/kyou 3.rpy:2556
translate spanish Day3_Con_Kyou_Sayori_ea05b2c5:

    # ks "And that's okay, Sayori. Because even while you are [alt_name], you will always still be there in your mind."
    ks "Y no te preocupes, Sayori. Porque mientras seas [alt_name], tú siempre seguirás ahí en tu mente."

# game/kyou 3.rpy:2557
translate spanish Day3_Con_Kyou_Sayori_b9fbfc44:

    # ks "As soon as I say \"become Sayori\" you will immediately return to your original self."
    ks "Tan pronto como diga \"conviértete en Sayori\", regresarás inmediatamente a tu yo original."

# game/kyou 3.rpy:3029
translate spanish Day3_Con_Kyou_Sayori_26c24c2b:

    # ks "So once more, if I say \"become [alt_name]\", you will immediately become happy, fun-loving [alt_name]."
    ks "Una vez más, si yo digo \"conviértete en [alt_name]\", te convertirás inmediatamente en la alegre y divertida [alt_name]."

# game/kyou 3.rpy:2560
translate spanish Day3_Con_Kyou_Sayori_0144c712:

    # ks "Do you understand and accept what I have just told you, Sayori?"
    ks "¿Comprendes y aceptas lo que acabo de decir, Sayori?"

# game/kyou 3.rpy:2561
translate spanish Day3_Con_Kyou_Sayori_96613693:

    # scg alert_sleeptalk "..." with dissolve
    scg alert_sleeptalk "..." with dissolve

# game/kyou 3.rpy:2562
translate spanish Day3_Con_Kyou_Sayori_8a71c9bf:

    # scg "I... I understand..."
    scg "C-... comprendo..."

# game/kyou 3.rpy:2564
translate spanish Day3_Con_Kyou_Sayori_05d7eea2:

    # "I breathe out a little sigh. I really wondered if I was going too far for her, but it seems she might be game after all." with dissolve
    "Suelto un pequeño suspiro. Me estaba preguntando si estaba yendo muy lejos con ella, pero no parece tener problemas." with dissolve

# game/kyou 3.rpy:2565
translate spanish Day3_Con_Kyou_Sayori_6638bcd9:

    # ks "You are doing so well, Sayori. So in a moment, I am going to wake you up on a count of five."
    ks "Lo estás haciendo muy bien, Sayori. En un momento, contaré hasta cinco y te despertaré."

# game/kyou 3.rpy:2567
translate spanish Day3_Con_Kyou_Sayori_1c8b152d:

    # ks "Counting up from one... two... starting to test your limbs."
    ks "Ahora, uno... dos... comienza a mover tus brazos y piernas."

# game/kyou 3.rpy:2568
translate spanish Day3_Con_Kyou_Sayori_20f1f439:

    # ks "Three... four... your senses returning as you take a nice deep breath."
    ks "Tres... cuatro... respira hondo mientras tus sentidos regresan."

# game/kyou 3.rpy:2569
translate spanish Day3_Con_Kyou_Sayori_e6f34f3d:

    # ks "And five, waking happy and refreshed."
    ks "Y cinco, despierta fresca y contenta."

# game/kyou 3.rpy:2571
translate spanish Day3_Con_Kyou_Sayori_b20cbb1a:

    # "Sayori stirs from the couch as her eyelids flutter open, and I watch as she stretches her legs across the floor." with longdissolve
    "Sayori se mueve ligeramente en el sofá mientras sus ojos se abren, y veo cómo estira sus piernas." with longdissolve

# game/kyou 3.rpy:2573
translate spanish Day3_Con_Kyou_Sayori_4c7bedd1:

    # scg alert_drowsytalk "Uh... I feel so loose." with dissolve
    scg alert_drowsytalk "Eh... siento el cuerpo flojo." with dissolve

# game/kyou 3.rpy:2574
translate spanish Day3_Con_Kyou_Sayori_c645dfdd:

    # ks "Is that good?"
    ks "¿Eso es bueno?"

# game/kyou 3.rpy:2576
translate spanish Day3_Con_Kyou_Sayori_ba518367:

    # "She smiles a little as she arches her back, taking another deep breath." with dissolve
    "Arquea la espalda con una pequeña sonrisa, respirando hondo una vez más." with dissolve

# game/kyou 3.rpy:2577
translate spanish Day3_Con_Kyou_Sayori_74169904:

    # scg "I would say so. It is nicer than I feel when coming out of a nap most of the time."
    scg "Diría yo. Es más agradable que lo que siento tras la mayoría de mis siestas."

# game/kyou 3.rpy:2578
translate spanish Day3_Con_Kyou_Sayori_2dfa6f99:

    # "I'm happy that she feels good coming out of a trance, but I am just itching to see if what we did had any effect on her."
    "Me alegra que se sienta bien al salir de un trance, pero muero por ver si lo que hicimos tuvo algún efecto sobre ella."

# game/kyou 3.rpy:2579
translate spanish Day3_Con_Kyou_Sayori_99a97404:

    # ks smile "That's great, Sayori. But could you tell me something else?"
    ks smile "Eso es grandioso, Sayori. ¿Pero puedo pedirte una cosita más?"

# game/kyou 3.rpy:2580
translate spanish Day3_Con_Kyou_Sayori_cc0c411b:

    # scg alert_neutral "What is that?" with dissolve
    scg alert_neutral "¿Qué cosa?" with dissolve

# game/kyou 3.rpy:2581
translate spanish Day3_Con_Kyou_Sayori_7e540efc:

    # ks "Will you become [alt_name] for me?"
    ks "Conviértete en [alt_name], por favor."

# game/kyou 3.rpy:2954
translate spanish Day3_Con_Kyou_Sayori_8060d598:

    # s "!!" with dissolve
    s "!!" with dissolve

# game/kyou 3.rpy:2587
translate spanish Day3_Con_Kyou_Sayori_a4cbcac3:

    # ks "... Sayori?"
    ks "... ¿Sayori?"

# game/kyou 3.rpy:2588
translate spanish Day3_Con_Kyou_Sayori_a3d4cc4b:

    # s alert_concerned_right "Huh? Who are you talking to?" with dissolve
    s alert_concerned_right "¿Eh? ¿Con quién hablas?" with dissolve

# game/kyou 3.rpy:2589
translate spanish Day3_Con_Kyou_Sayori_8a59076a:

    # ks "Oh, sorry. Did I not say your name?"
    ks "Oh, lo siento. ¿Qué no dije tu nombre?"

# game/kyou 3.rpy:2592
translate spanish Day3_Con_Kyou_Sayori_059b8532:

    # "Sayori just giggles at me and gently shakes her head." with dissolve
    "Sayori simplemente se ríe y sacude gentilmente la cabeza." with dissolve

# game/kyou 3.rpy:2595
translate spanish Day3_Con_Kyou_Sayori_ecfd63e9:

    # s "I'm [alt_name], silly!"
    s "¡Soy [alt_name], tontito!"

# game/kyou 3.rpy:2596
translate spanish Day3_Con_Kyou_Sayori_2853cff5:

    # "Man, I am just grinning from ear to ear."
    "Caray, estoy sonriendo de oreja a oreja."

# game/kyou 3.rpy:2597
translate spanish Day3_Con_Kyou_Sayori_a2626b91:

    # ks smile "Eheh, of course you are. Sorry, [alt_name]."
    ks smile "Jeje, claro que sí. Perdón, [alt_name]."

# game/kyou 3.rpy:2598
translate spanish Day3_Con_Kyou_Sayori_0ecd8ad7:

    # s alert_smile_right "Mhmhm, it's fine~" with dissolve
    s alert_smile_right "Jijiji, no te preocupes." with dissolve

# game/kyou 3.rpy:2599
translate spanish Day3_Con_Kyou_Sayori_96d34e8b:

    # ks "It's great to see you really CAN let your hair down once in a while, if you put your mind to it."
    ks "Es muy bueno ver que sí PUEDES soltarte un poco de vez en cuando si te lo propones."

# game/kyou 3.rpy:2602
translate spanish Day3_Con_Kyou_Sayori_3b2c5ca9:

    # s alert_laugh "Ahaha, and what is that supposed to mean?" with dissolve
    s alert_laugh "Jajaja, ¿y eso qué significa?" with dissolve

# game/kyou 3.rpy:2603
translate spanish Day3_Con_Kyou_Sayori_1a6a1af7:

    # "I mean, obviously I had a doubt that she might just be \"roleplaying\" with me."
    "Claro, obviamente tenía la sospecha de que podría ser un simple \"juego de rol\"."

# game/kyou 3.rpy:2604
translate spanish Day3_Con_Kyou_Sayori_1ac72c00:

    # s alert_giggle "I am not some square. Do you even know me, Kyou?" with dissolve
    s alert_giggle "No soy tan cuadrada. ¿Siquiera me conoces, Kyou?" with dissolve

# game/kyou 3.rpy:2605
translate spanish Day3_Con_Kyou_Sayori_cd1af589:

    # "But even if she were the type to do that, there is just something in that playful giggle that I don't think she could pull off unless she was completely committed."
    "Pero, aunque decidiera hacer eso, hay algo en esa risita juguetona que no creo que pudiera lograr a no ser que estuviera completamente comprometida."

# game/kyou 3.rpy:2606
translate spanish Day3_Con_Kyou_Sayori_b1c27038:

    # ks "Sorry, I was just messing with you. Anyway, how long do you think you have before you need to leave?"
    ks "Lo siento, solo te estaba molestando. Como sea, ¿cuánto tiempo crees poderte quedar?"

# game/kyou 3.rpy:2981
translate spanish Day3_Con_Kyou_Sayori_80972eda:

    # s "How long before you kick me out?" with dissolve
    s "¿Cuánto tiempo crees poderme aguantar?" with dissolve

# game/kyou 3.rpy:2608
translate spanish Day3_Con_Kyou_Sayori_ef867b63:

    # "Damn, I really misjudged Sayori. She isn't just an excellent hypnotic subject, she's also really easy-going if she's seriously okay with this."
    "Diablos, sí que juzgué mal a Sayori. No solo es un gran sujeto hipnótico, sino que sí es capaz de tomarse las cosas con calma, viendo que esto no le molesta."

# game/kyou 3.rpy:2609
translate spanish Day3_Con_Kyou_Sayori_d3fdad59:

    # ks "A few more hours, I guess? I don't want to have an awkward convo with my dad about me having a girl over."
    ks "Un par de horas, ¿supongo? No quiero tener una incómoda charla con mi padre sobre haber traído a una chica."

# game/kyou 3.rpy:2610
translate spanish Day3_Con_Kyou_Sayori_2731eb54:

    # s alert_happy "Mhmhm, a few hours, then!" with dissolve
    s alert_happy "¡Jijiji, un par de horas serán!" with dissolve

# game/kyou 3.rpy:2611
translate spanish Day3_Con_Kyou_Sayori_31a7e6a5:

    # ks "A-Awesome!"
    ks "¡E-estupendo!"

# game/kyou 3.rpy:2612
translate spanish Day3_Con_Kyou_Sayori_d9dd1a23:

    # s alert_neutral "Oh, wait..." with dissolve
    s alert_neutral "Oh, espera..." with dissolve

# game/kyou 3.rpy:2613
translate spanish Day3_Con_Kyou_Sayori_e0afa1ad:

    # ks "What's the matter, Sayori?"
    ks "¿Qué sucede, Sayori?"

# game/kyou 3.rpy:2614
translate spanish Day3_Con_Kyou_Sayori_57f52352:

    # s uniform_folded alert_concerned_right "Hm? There is that name again. \"Sayori\"." with dissolve
    s uniform_folded alert_concerned_right "¿Mm? Ese nombre otra vez. \"Sayori\"." with dissolve

# game/kyou 3.rpy:2615
translate spanish Day3_Con_Kyou_Sayori_eba735b0:

