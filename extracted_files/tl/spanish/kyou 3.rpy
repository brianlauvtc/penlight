translate spanish Day3_Con_Kyou_Nozomi_d1b3f786:

    # ncg "And breathe out."
    ncg "Y exhala."

# game/kyou 3.rpy:1263
translate spanish Day3_Con_Kyou_Nozomi_667a7dc0:

    # "As the air leaves my lungs, I find myself looking up at the light without even realizing."
