# game/kyou 3.rpy:1225
translate spanish Day3_Con_Kyou_Nozomi_ae94d16c:

    # "... before gingerly handing it over to Nozomi as her curious eyes begin to examine it up close." with dissolve
    "... para luego pasársela delicadamente a Nozomi mientras sus ojos curiosos comienzan a examinarla de cerca." with dissolve

# game/kyou 3.rpy:1227
