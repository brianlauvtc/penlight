    # ks "Yeah. Just watching you go into a trance at my word felt pretty hot."
    ks "Sí. Verte caer en trance por mis palabras fue muy ardiente."

# game/kyou 3.rpy:1397
translate spanish Day3_Con_Kyou_Nozomi_c5f7bb18:

    # ncg standing casual laugh blush "Ahahaha~ Just... don't get too carried away, alright?" with dissolve
