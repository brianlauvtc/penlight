# game/kyou 3.rpy:3270
translate spanish Day3_Con_Kyou_Sayori_Switch_f148059e_1:

    # ks "Why not tomorrow? I'm free all day after school."
    ks "¿Por qué no mañana? Estaré libre todo el día después de la escuela."

# game/kyou 3.rpy:3271
translate spanish Day3_Con_Kyou_Sayori_Switch_ad7fd005_1:

    # s uniform alert_smile_right "I would like that, Kyou. Very much." with dissolve
    s uniform alert_smile_right "Eso me gustaría, Kyou. Bastante." with dissolve

