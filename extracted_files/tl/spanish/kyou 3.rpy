    # ncg "..."
    ncg ""

# game/kyou 3.rpy:2213
translate spanish Day3_Con_Kyou_Nozomi_6c3bf335:

    # ncg sleeptalk "No..." with dissolve
    ncg sleeptalk "" with dissolve

# game/kyou 3.rpy:2214
