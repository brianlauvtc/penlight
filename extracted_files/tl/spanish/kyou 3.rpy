# game/kyou 3.rpy:1377
translate spanish Day3_Con_Kyou_Nozomi_4f59a777:

    # ks confused "Do you even know how to hypnotize someone? Other than what you saw in that vid?"
    ks confused "¿Siquiera sabes hipnotizar a alguien? ¿Además de lo que viste en el video?"

# game/kyou 3.rpy:1220
translate spanish Day3_Con_Kyou_Nozomi_3dc0d617:

    # ncg stern "Or, er, light in this case. So to speak." with dissolve
    ncg stern "O, em, la linterna, en este caso. Por así decirlo." with dissolve

# game/kyou 3.rpy:1223
translate spanish Day3_Con_Kyou_Nozomi_56173a4b:

    # "Pulling my penlight out from my pocket, I turn it over in my fingers..."
