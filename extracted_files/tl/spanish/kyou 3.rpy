    # s uniform_folded "You guess. Do you guess that you may in some manner be responsible for their absence?" with dissolve
    s uniform_folded "Supones. ¿Y acaso supones que, de alguna manera, tuviste algo que ver con su ausencia?" with dissolve

# game/kyou 3.rpy:3910
translate spanish Day3_Redemption_0e5bd8fa:

    # s annoyed "I cannot imagine you would feel concern for Hiroko were it not for a guilty conscience..." with dissolve
    s annoyed "No puedo imaginarte sintiendo preocupación por Hiroko más que por un cargo de conciencia." with dissolve

