translate spanish Day3_Con_Kyou_Nozomi_00de4f1d:

    # ncg "So then, Kyou, if I could have your attention up here?"
    ncg "Entonces, Kyou, ¿tu atención aquí arriba, por favor?"

# game/kyou 3.rpy:1257
