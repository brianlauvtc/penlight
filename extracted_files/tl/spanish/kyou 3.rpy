# game/kyou 3.rpy:2259
translate spanish Con_Kyou_Nozomi_Day3_HypnoSesh_a1bab5b1:

    # n "BRAAAAIIIIIIN... URGH!" with vpunch
    n "¡CEREEEEEEEEBROOO... AAH!" with vpunch

# game/kyou 3.rpy:2260
translate spanish Con_Kyou_Nozomi_Day3_HypnoSesh_68569d89:

    # "Only my hand at her throat keeps her teeth from biting down on my face as she keeps pushing towards me with all her might."
    "Solo mi mano en su garganta evita que sus dientes muerdan mi rostro, mientras ella presiona contra mí tanto como puede."

# game/kyou 3.rpy:2261
translate spanish Con_Kyou_Nozomi_Day3_HypnoSesh_558ad21c:

    # ks angry "I said FUCKING WAKE UP!"
    ks angry "¡Dije que DESPIERTES DE UNA PUTA VEZ!"

# game/kyou 3.rpy:2267
translate spanish Con_Kyou_Nozomi_Day3_HypnoSesh_92c81b9e:

    # "I didn't want to do it... I really didn't." with vpunch
    "No quería hacerlo... En serio no quería hacerlo." with vpunch

# game/kyou 3.rpy:2269
translate spanish Con_Kyou_Nozomi_Day3_HypnoSesh_336d82fa:

    # ks surprised "S-shit, Nozo I'm sorry. I'm SORRY!"
    ks surprised "M-mierda, Nozo, lo siento. ¡Lo SIENTO!"

# game/kyou 3.rpy:2270
translate spanish Con_Kyou_Nozomi_Day3_HypnoSesh_b5ac5a8f:

    # "I stagger back to my feet and do the best that I can to smooth this over..."
