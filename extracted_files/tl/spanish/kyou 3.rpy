translate spanish Day3_Redemption_5b2454bf:

    # "It takes me out of the morning lessons. I can't focus at all."
    "Eso me distrae de las lecciones matutinas. No me puedo concentrar."

# game/kyou 3.rpy:3897
translate spanish Day3_Redemption_2f755b3b:

    # "And the bell sounding for lunch takes forever."
    "Y la campana del almuerzo tarda una eternidad en sonar."

