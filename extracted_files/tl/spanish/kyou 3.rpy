translate spanish Day3_Con_Kyou_Sayori_Switch_6a94d888:

    # s "But truly, to me your ability to influence me seems... total." with dissolve
    s "Pero, de verdad, para mí, tu habilidad para influenciarme parece... absoluta." with dissolve

