translate spanish Day3_Redemption_81a44768:

    # ks neutral "Hey. I just wanted to know if you heard from Nozomi?"
    ks neutral "Hola. Solo quería saber si has oído algo de Nozomi."

# game/kyou 3.rpy:3908
translate spanish Day3_Redemption_ef869aa8:

    # ks "Or, Hiroko. I guess."
    ks "O Hiroko, supongo."

# game/kyou 3.rpy:3909
