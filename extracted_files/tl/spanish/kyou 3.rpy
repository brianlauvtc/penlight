translate spanish Day3_Redemption_ee9896cc:

    # "What do I even do with myself for the rest of the day?"
    "¿Qué se supone que haga por el resto del día?"

# game/kyou 3.rpy:3900
translate spanish Day3_Redemption_1e910029:

    # "Maybe... yeah, her." with dissolve
    "Tal vez... sí, ella." with dissolve

# game/kyou 3.rpy:3901
translate spanish Day3_Redemption_2d2d658e:

    # "Sayori normally goes up to the roof with Nozomi and Hiroko, but without them she seems to be staying to lunch at her desk."
