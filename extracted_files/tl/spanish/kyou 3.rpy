# game/kyou 3.rpy:3904
translate spanish Day3_Redemption_c20c37ad:

    # "But if anyone knows about Nozomi and Hiroko it'll be her." with dissolve
    "Pero si alguien sabe de Nozomi y Hiroko, es ella." with dissolve

# game/kyou 3.rpy:3905
translate spanish Day3_Redemption_722ed750:

    # s "What?"
    s "¿Qué?"

# game/kyou 3.rpy:3906
translate spanish Day3_Redemption_6f08fe47:

    # "Her response to seeing me gets my back up. Just gotta power through it..."
    "Su respuesta al verme me irrita un poco. Voy a ignorar eso de momento..."

