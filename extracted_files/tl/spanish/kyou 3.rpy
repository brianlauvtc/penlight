    # ncg smile_closed "I don't know, really. Like I said, it's just a curiosity. I'm more than happy to be the subject again." with dissolve
    ncg smile_closed "No lo sé. Como dije, es solo curiosidad. Estoy más que feliz de ser el sujeto otra vez." with dissolve

# game/kyou 3.rpy:1210
translate spanish Day3_Con_Kyou_Nozomi_eed647e8:

    # ncg neutral "But what do you think about me being the hypnotist for tonight?" with dissolve
    ncg neutral "¿Pero a ti qué te parece si soy la hipnotista por esta noche?" with dissolve

