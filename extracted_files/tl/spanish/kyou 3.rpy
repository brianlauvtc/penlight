translate spanish Day3_Con_Kyou_Nozomi_7a99de91:

    # ncg "And I'd like you to take a nice deep breath as you relax your posture."
    ncg "Y quiero que respires profundamente y relajes tu postura."

# game/kyou 3.rpy:1260
translate spanish Day3_Con_Kyou_Nozomi_9332c442:

    # ncg "Holding your breath, feeling nice and comfortable."
    ncg "Sostén el aire y ponte muy cómodo."

