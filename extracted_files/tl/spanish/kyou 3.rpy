translate spanish Day3_Villain_Kyou_d8c96ebe:

    # s surprised_right "Wait, who is that?" with dissolve
    s surprised_right "Espera, ¿quién es ese?" with dissolve

# game/kyou 3.rpy:947
translate spanish Day3_Villain_Kyou_d6449912:

    # ks "All you need to concern yourselves with is how easy it is to focus on the light in your eyes." with dissolve
    ks "No se deben preocupar más que por lo fácil que es concentrarse en la luz que hay ante sus ojos." with dissolve

# game/kyou 3.rpy:804
