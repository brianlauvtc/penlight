# game/kyou 3.rpy:1214
translate spanish Day3_Con_Kyou_Nozomi_ad9b54c9:

    # ncg smile_closed "I can tell you're thinking about it~" with dissolve
    ncg smile_closed "Puedo ver que lo estás pensando..." with dissolve

