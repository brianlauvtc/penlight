    n "Por cierto, Kyou, me preguntaba..."

# game/Kyou 5.rpy:2842
translate spanish Day5_Con_Kyou_Sayori_Hypno_Nozomi_35ba8874:

    # "I mean, she's actually talking to me now and... huh?"
    "Quiero decir, ahora sí me está hablando y... ¿eh?"

# game/Kyou 5.rpy:2848
translate spanish Day5_Con_Kyou_Sayori_Hypno_Nozomi_e5decd5b:

    # n "Do you think we could..." with dissolve
    n "¿Crees que podríamos..." with dissolve

# game/Kyou 5.rpy:2849
translate spanish Day5_Con_Kyou_Sayori_Hypno_Nozomi_63996d19:

    # n chuckle "... do this again sometime?" with dissolve
    n chuckle "... hacer esto de nuevo alguna vez?" with dissolve

# game/Kyou 5.rpy:2853
translate spanish Day5_Con_Kyou_Sayori_Hypno_Nozomi_2ab06f86:

