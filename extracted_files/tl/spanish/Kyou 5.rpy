# game/Kyou 5.rpy:3388
translate spanish Day5_Con_Kyou_Hiroko_Trickster_887d315e:

    # "So what to do... I still want to punish her for all her bullshit, but she still needs to be fit for that tournament..." with dissolve
    "Entonces ¿qué hago?... Aún quiero castigarla por toda su mierda, pero aun así debe estar en forma para ese torneo..." with dissolve

