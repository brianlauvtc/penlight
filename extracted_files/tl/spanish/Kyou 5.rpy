# game/Kyou 5.rpy:2969
translate spanish Day5_Con_Kyou_Sayori_Alter_Switch_33bbacec:

    # n frown "And you'd BETTER stay away from her until then!" with dissolve
    n frown "¡Y más te VALE alejarte de ella hasta entonces!" with dissolve

# game/Kyou 5.rpy:2971
translate spanish Day5_Con_Kyou_Sayori_Alter_Switch_c4284eab:

    # "With that parting shot, Nozomi leaves to join the others and I..." with dissolve
    "Dicha esa última parte, Nozomi se retira para unirse a las otras y yo..." with dissolve

# game/Kyou 5.rpy:2972
translate spanish Day5_Con_Kyou_Sayori_Alter_Switch_ebbe4eac:

    # "I'm left with an intense feeling of dread."
    "Siento un intenso temor."

# game/Kyou 5.rpy:2977
translate spanish Day5_Con_Kyou_Sayori_Alter_Switch_f39e3cd3:

    # "(( AUTHOR'S NOTE: Outline to follow, as I try to work out what the hell's supposed to happen when Kyou tries to actually resolve this mess. ))"
    "(( NOTA DE LA AUTORA: Bosquejo a continuación, en lo que intento descifrar que demonios pasará cuando Kyou intente arreglar este desastre. ))"

# game/Kyou 5.rpy:2978
translate spanish Day5_Con_Kyou_Sayori_Alter_Switch_9529aa56:

    # "(( You're free to read on, of course. Otherwise, join us next month for the continuation of this story~ ))"
    "(( Siéntanse libres de leer, por supuesto. O si no, acompáñennos el próximo mes para la continuación de esta historia. ))"
    "(( Tener en cuenta, sin embargo, que dicho bosquejo no cuenta con traducción al español. ))"
