    extend "¡AH!" with vpunch

# game/Kyou 5.rpy:4429
translate spanish Hiroko_Trickster_SealTheDeal_e98621af:

    # "But when she does register me, she has no trouble finding her energy again."
    "Pero cuando por fin me registra, no le cuesta nada recuperar su energía."

# game/Kyou 5.rpy:4430
translate spanish Hiroko_Trickster_SealTheDeal_fcbfdbbb:

    # ks smirk "There she is. Welcome back."
    ks smirk "Ahí está. Bienvenida de vuelta."

# game/Kyou 5.rpy:4431
translate spanish Hiroko_Trickster_SealTheDeal_10b90031:

    # "And I gotta say, it's fun watching her reconnect the dots in her brain in real time as she thinks back to what just happened between us."
    "Y debo decir que es divertido verla volver a unir los puntos en su cerebro en tiempo real, recordando lo que acaba de pasar entre nosotros."

# game/Kyou 5.rpy:4432
translate spanish Hiroko_Trickster_SealTheDeal_bd41d8d8:

    # h "G-gawd, when the fuck did you..."
    h "A-ay, ¿cuándo carajos...?"

# game/Kyou 5.rpy:4437
translate spanish Hiroko_Trickster_SealTheDeal_0440c4af:

    # h "W-we were just talking about it, then you put a hand on me an' the next thing I know I'm napping again..." with dissolve
    h "E-estábamos hablando de eso, luego me pones una mano encima y cuando me doy cuenta ya estoy dormida otra vez..." with dissolve

# game/Kyou 5.rpy:4439
translate spanish Hiroko_Trickster_SealTheDeal_307fa1a4:

    # "She lets out a long, frustrated sigh." with dissolve
    "Suelta un largo y frustrado suspiro." with dissolve

# game/Kyou 5.rpy:4440
translate spanish Hiroko_Trickster_SealTheDeal_d7c3760b:

    # h "Ain't gonna lie, that's scary as fuck if you can just put me to sleep like that. It's gettin' worse..."
    h "No mentiré, qué puto miedo da que puedas ponerme a dormir así. Está empeorando..."

# game/Kyou 5.rpy:4441
translate spanish Hiroko_Trickster_SealTheDeal_55672485:

    # ks smile "I think you mean it's getting better."
    ks smile "Querrás decir que está mejorando."

# game/Kyou 5.rpy:4443
translate spanish Hiroko_Trickster_SealTheDeal_7d624d7c:

    # h "H'yeah, fuck that. I keep telling you I want out of this creepy shit, and you're..." with dissolve
    h "Seh, una puta mierda. Ya te dije que quiero salir de este cagadero y tú..." with dissolve

# game/Kyou 5.rpy:4448
translate spanish Hiroko_Trickster_SealTheDeal_4591fb70:

