# game/Kyou 5.rpy:1237
translate spanish Day5_Con_Kyou_Nozomi_Trance_ec74d149:

    # "But if I don't need it now, then..."
    "Pero si ya no la necesito…"

# game/Kyou 5.rpy:1239
