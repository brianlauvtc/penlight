# game/Kyou 5.rpy:3435
translate spanish Day5_Con_Kyou_Hiroko_Trickster_55672485:

    # ks smile "I think you mean it's getting better."
    ks smile "Querrás decir que está mejorando."

# game/Kyou 5.rpy:3437
translate spanish Day5_Con_Kyou_Hiroko_Trickster_7d624d7c:

    # h "H'yeah, fuck that. I keep telling you I want out of this creepy shit, and you're..." with dissolve
    h "Seh, una puta mierda. Ya te dije que quiero salir de este cagadero y tú..." with dissolve

# game/Kyou 5.rpy:3440
translate spanish Day5_Con_Kyou_Hiroko_Trickster_4591fb70:

