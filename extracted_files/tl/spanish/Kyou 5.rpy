translate spanish Hiroko_Trickster_SealTheDeal_8f3c0130:

    # h "A... a warm-up show...?" with dissolve
    h "¿Un... calentamiento...?" with dissolve

# game/Kyou 5.rpy:4404
translate spanish Hiroko_Trickster_SealTheDeal_67b9dfd0:

    # "I pause a moment. I don't think she's ever responded like that before, where she didn't just acknowledge and agree to what I told her." with dissolve
    "Hago una pausa. Creo que nunca había respondido así, no aceptando simplemente lo que le digo." with dissolve

# game/Kyou 5.rpy:4405
translate spanish Hiroko_Trickster_SealTheDeal_261602e8:

    # "Guess the prospect of being hypnotized before an audience really is that nerve-wracking for her. All the better to break her in gently, then."
    "Supongo que la idea de ser hipnotizada ante una audiencia sí la pone muy nerviosa. Entonces será mejor hacerlo con gentileza."

# game/Kyou 5.rpy:4406
translate spanish Hiroko_Trickster_SealTheDeal_3d0a901a:

    # ks smile "That's right. You need to be comfortable about being hypnotized in front of other people. You need practice, just like you needed to practice your tennis."
    ks smile "Así es. Debes estar cómoda siendo hipnotizada delante de otras personas. Debes practicar, así como necesitas practicar tu tenis."

# game/Kyou 5.rpy:4407
translate spanish Hiroko_Trickster_SealTheDeal_27a3e30b:

    # ks "And you'll be so full of confidence after your big win that this will be the best time to do it, don't you agree?"
    ks "Y estarás tan llena de confianza luego de tu gran victoria, que ese será el mejor momento para hacerlo, ¿no te parece?"

# game/Kyou 5.rpy:4409
translate spanish Hiroko_Trickster_SealTheDeal_c5f91373:

    # h "Y... yeah..." with dissolve
    h "S... sí..." with dissolve

# game/Kyou 5.rpy:4411
translate spanish Hiroko_Trickster_SealTheDeal_896be62a:

    # ks "Exactly. So if you win your tournament you'll be fully prepared to come here, willing to put on a show as my hypnotized assistant, won't you?" with dissolve
    ks "Exacto. Por lo que, si ganas tu torneo, estarás plenamente preparada para venir aquí, dispuesta a dar un espectáculo como mi asistente hipnotizada, ¿no es cierto?" with dissolve

# game/Kyou 5.rpy:4413
translate spanish Hiroko_Trickster_SealTheDeal_42e8b501:

    # h "... Yeah." with dissolve
    h "... Sí." with dissolve

# game/Kyou 5.rpy:4415
translate spanish Hiroko_Trickster_SealTheDeal_53feb188:

    # ks "Very good, Hiroko. Feeling so incredibly hypnotized. Feeling so incredibly easy to hypnotize." with dissolve
    ks "Muy bien, Hiroko. Te sientes increíblemente hipnotizada. Te sientes increíblemente fácil de hipnotizar." with dissolve

# game/Kyou 5.rpy:4416
translate spanish Hiroko_Trickster_SealTheDeal_bd4a75df:

    # ks "So as I count up to three, you're going to awaken from this deep trance, fully alert and consciously remembering everything that was said to you."
    ks "Y cuando cuente hasta tres, vas a despertar de este profundo trance, completamente alerta y recordando conscientemente todo lo que se te dijo."

# game/Kyou 5.rpy:4418
translate spanish Hiroko_Trickster_SealTheDeal_df7c50db:

    # ks "Waking up, nice and refreshed in one... two, and..."
    ks "Despertarás, sintiéndote muy fresca en uno... dos, y..."

# game/Kyou 5.rpy:4421
translate spanish Hiroko_Trickster_SealTheDeal_10928cc6:

    # ks "Three. Rise and shine."
    ks "Tres. Despierta ya."

# game/Kyou 5.rpy:4423
translate spanish Hiroko_Trickster_SealTheDeal_355b1d06:

    # h "{cps=15}Mrrrrn... w-wha?{/cps}" with dissolve
    h "{cps=15}Mnnñn… ¿qu-qué?{/cps}" with dissolve

# game/Kyou 5.rpy:4425
translate spanish Hiroko_Trickster_SealTheDeal_5259aaaf:

    # "I watch as Hiroko breathes deeply and leans back on the couch; her large eyes taking a moment to register me staring back at her."
    "Observo cómo Hiroko respira hondo y se reclina en el sofá; sus grandes ojos se toman un momento para registrarme mirándola."

# game/Kyou 5.rpy:4426
translate spanish Hiroko_Trickster_SealTheDeal_2c273c6a:

    # h "{cps=15}W-what's going... {/cps}{w=1.0}h-{nw}"
    h "{cps=15}¿Qu-qué está... {/cps}{w=1.0}a-{nw}"

# game/Kyou 5.rpy:4428
