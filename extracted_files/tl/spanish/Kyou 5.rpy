    # n "I mean, gosh, I can't believe how... um, immersive that was?" with dissolve
    n "Digo, cielos, no puedo creer lo... em, ¿inmersivo que fue?" with dissolve

# game/Kyou 5.rpy:2714
translate spanish Day5_Con_Kyou_Sayori_Hypno_Nozomi_4d3950e0:

