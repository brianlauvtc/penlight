# game/kyou 4.rpy:5586
translate spanish Day4_Con_Kyou_Sayori_43bce974:

    # "Yeah. Tempting as it is to keep this going, we should have a real talk about the past day now that we're back home." with dissolve
    "Sí. Por tentador que sea seguir con esto, deberíamos discutir seriamente las últimas veinticuatro horas ya que estamos otra vez en mi casa." with dissolve

# game/kyou 4.rpy:5588
translate spanish Day4_Con_Kyou_Sayori_e4ed41bf:

    # s "Ah, when you attempted to place that other person in my mind!" with dissolve
    s "¡Ah, cuando intentaste colocar otra persona en mi mente!" with dissolve

