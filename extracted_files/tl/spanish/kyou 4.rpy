# game/kyou 4.rpy:5898
translate spanish Day4_Redemption_f3afdcf9:

    # ks smile "But alright, then. Could you tell me about yourself?"
    ks smile "De acuerdo. Pues, entonces, ¿podrías hablarme de ti?"

# game/kyou 4.rpy:5900
