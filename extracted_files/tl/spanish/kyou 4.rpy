translate spanish Day4_Con_Kyou_Sayori_39f0045c:

    # "Sayori sighs, her right arm frozen in place as her hand hovers over her food." with dissolve
    "Sayori suspira. Su brazo derecho permanece inmóvil mientras su mano flota sobre su comida." with dissolve

# game/kyou 4.rpy:4671
translate spanish Day4_Con_Kyou_Sayori_401e0377:

    # "Kinda takes me back to our time together last night."
