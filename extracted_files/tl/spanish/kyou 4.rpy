translate spanish Day4_Con_Kyou_Nozomi_bd1f58cf:

    # ks "Now, I want you to say something for me, and I want you to say it calmly and quietly."
    ks "Ahora, quiero que digas algo por mí, y quiero que lo digas calmada y silenciosamente."

# game/kyou 4.rpy:2546
translate spanish Day4_Con_Kyou_Nozomi_a54d7866:

    # ks "Say \"I cannot raise my voice\"."
    ks "Di \"No puedo alzar la voz\"."

# game/kyou 4.rpy:2547
translate spanish Day4_Con_Kyou_Nozomi_4c8e0cc1:

    # ncg sleeptalk "{size=16}I cannot raise my voice...{/size}" with dissolve
    ncg sleeptalk "{size=16}No puedo alzar la voz...{/size}" with dissolve

# game/kyou 4.rpy:2549
translate spanish Day4_Con_Kyou_Nozomi_3c59989d:

    # "Her voice comes out soft, barely above a whisper. Perfect." with dissolve
    "Su voz brota suavemente, no mucho más fuerte que un susurro. Perfecto." with dissolve

# game/kyou 4.rpy:2550
translate spanish Day4_Con_Kyou_Nozomi_a98a970f:

    # ks "Now, Nozomi, you will find that while in we are alone this house you cannot raise your voice any louder than how you just spoke."
    ks "Ahora, Nozomi, te darás cuenta de que cuando estemos a solas en esta casa, no podrás elevar la voz más allá del volumen que acabas de usar."

# game/kyou 4.rpy:2551
translate spanish Day4_Con_Kyou_Nozomi_f8781909:

    # ks "If you attempt to do so, you will find it physically impossible. Do you understand?"
    ks "Si intentas hacerlo, te será físicamente imposible. ¿Comprendes?"

# game/kyou 4.rpy:2552
translate spanish Day4_Con_Kyou_Nozomi_e62339e2:

    # ncg sleeptalk "{size=16}I understand...{/size}" with dissolve
    ncg sleeptalk "{size=16}Comprendo...{/size}" with dissolve

