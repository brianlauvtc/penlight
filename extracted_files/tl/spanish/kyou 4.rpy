translate spanish Day4_Villain_Kyou_dd2ef52c:

    # n sleeptalk_concerned "That I am... a [hypno6]..." with dissolve
    n sleeptalk_concerned "Que soy... un[genero_a] [hypno6!t!l]..." with dissolve

# game/kyou 4.rpy:1237
