    # a sigh "I enjoy kendo, numbnuts. It's good mental prep." with dissolve
    a sigh "Disfruto el kendo, bobo. Es una buena preparación mental." with dissolve

# game/kyou 4.rpy:5908
translate spanish Day4_Redemption_945521e8:

    # a sleep "You don't like getting beat, of course. No one does. But you learn to appreciate how necessary it is." with dissolve
    a sleep "No es agradable que te golpeen, claro está. A nadie le gusta. Pero aprendes a apreciar lo necesario que es." with dissolve

# game/kyou 4.rpy:5910
translate spanish Day4_Redemption_e362af2a:

    # a uniform smile "Each and every time you fail you simply bow to your adversary, ready your sword and try again." with dissolve
    a uniform smile "Cada vez que fracasas, simplemente le haces una reverencia a tu adversario, preparas tu espada e intentas de nuevo." with dissolve

# game/kyou 4.rpy:5910
