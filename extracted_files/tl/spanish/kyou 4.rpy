    # h "What did you..." with dissolve
    h "¿Qué acabas de..." with dissolve

# game/kyou 4.rpy:5765
translate spanish Day4_Con_Kyou_Hiroko_a7eec11a:

    # ks "Relax, Hiroko. You know what I did."
    ks "Relájate, Hiroko. Tú sabes lo que hice."

# game/kyou 4.rpy:5767
translate spanish Day4_Con_Kyou_Hiroko_71c18338:

    # "I can see the frown on her face as the last few minutes likely flash through her mind, now that she has the luxury of thinking consciously about it." with dissolve
    "Veo su ceño fruncirse en cuanto los últimos minutos vuelven a ella, ahora que tiene el lujo de pensar en eso conscientemente." with dissolve

# game/kyou 4.rpy:5768
