translate spanish Day4_Redemption_28493f24:

    # ks smirk "And in somewhere better than a school toilet?"
    ks smirk "¿Y en un lugar mejor que un baño de la escuela?"

# game/kyou 4.rpy:5959
translate spanish Day4_Redemption_74aa5c4f:

    # a smirk "Works for me." with dissolve
    a smirk "Me parece bien." with dissolve

