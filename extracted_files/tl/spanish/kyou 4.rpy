    # ncg standing confused "{size=16}Ah, y-yes I'm awake.{/size}" with vpunch
    ncg standing confused "{size=16}Ah, s-sí, estoy despierta.{/size}" with vpunch

# game/kyou 4.rpy:2570
translate spanish Day4_Con_Kyou_Nozomi_0f1134b6:

    # ks "So you are. And quiet as a mouse. How are you feeling?"
    ks "Sí que lo estás. Y callada como un ratón. ¿Cómo te sientes?"

# game/kyou 4.rpy:2571
translate spanish Day4_Con_Kyou_Nozomi_5de4f8ef:

    # ncg "{size=16}A little nervous... was it really okay to do this?{/size}"
    ncg "{size=16}Un poco nerviosa... ¿de verdad estuvo bien hacer esto?{/size}"

# game/kyou 4.rpy:2572
translate spanish Day4_Con_Kyou_Nozomi_0564152d:

    # ks "It's what you wanted isn't it?"
    ks "Es lo que querías, ¿no?"

# game/kyou 4.rpy:2573
translate spanish Day4_Con_Kyou_Nozomi_9be9c9d3:

    # ncg sad "{size=16}Yes... yes, it was.{/size}" with dissolve
    ncg sad "{size=16}Sí... sí, lo era.{/size}" with dissolve

# game/kyou 4.rpy:2574
translate spanish Day4_Con_Kyou_Nozomi_16c83b3b:

    # ks "So, stop worrying about it." with dissolve
    ks "Deja de preocuparte por eso." with dissolve

# game/kyou 4.rpy:2575
translate spanish Day4_Con_Kyou_Nozomi_2d83a56f:

    # "I then add with a smirk:"
    "Y luego añado con una mueca."

# game/kyou 4.rpy:2576
translate spanish Day4_Con_Kyou_Nozomi_9d21a2bd:

    # ks smirk "That was an order, by the way. Stop worrying."
    ks smirk "Eso fue una orden, por cierto. Deja de preocuparte."

# game/kyou 4.rpy:2578
translate spanish Day4_Con_Kyou_Nozomi_d96e1851:

    # "And just like that she responds with an earnest smile." with dissolve
    "Y así nomás, responde con una sincera sonrisa." with dissolve

# game/kyou 4.rpy:2579
translate spanish Day4_Con_Kyou_Nozomi_dfc46b0b:

    # ncg "{size=16}Okay, Kyou.{/size}"
    ncg "{size=16}Está bien, Kyou.{/size}"

# game/kyou 4.rpy:2580
translate spanish Day4_Con_Kyou_Nozomi_f06f30dc:

    # ks smile "That's better. But you will call me \"Sir\" from now on."
    ks smile "Mucho mejor. Pero me llamarás \"Señor\" y me hablarás de usted de ahora en adelante."

# game/kyou 4.rpy:2581
translate spanish Day4_Con_Kyou_Nozomi_3bcfd398:

    # ncg "{size=16}Yes, Sir.{/size}"
    ncg "{size=16}Sí, Señor.{/size}"

# game/kyou 4.rpy:2582
translate spanish Day4_Con_Kyou_Nozomi_50d55b71:

    # ks "Man, you really are loving this aren't you."
    ks "Cielos, esto realmente te encanta, ¿no?"

# game/kyou 4.rpy:2583
