    # h "MRROAAW!"
    h "¡MUAAAU!"

# game/kyou 4.rpy:6138
translate spanish Day4_Con_Kyou_Hiroko_43e39ec2:

    # "After waving the light over the couch a few times to confuse her more, I bring it back down to the floor, and watch as she inevitably hops down to take a swipe at it." with dissolve
    "Luego de sacudir la luz en el sofá un par de veces para confundirla más, vuelvo a bajarla al suelo, y miro cómo inevitablemente salta junto a ella." with dissolve

# game/kyou 4.rpy:4646
translate spanish Day4_Con_Kyou_Hiroko_1761206d:

    # "There, I think I'd better switch the light off before I wear her out too much." with dissolve
    "Ya está bien, creo que será mejor apagar la linterna antes de cansarla demasiado." with dissolve

# game/kyou 4.rpy:6147
translate spanish Day4_Con_Kyou_Hiroko_52acc920:

    # "And as I look down at her pawing the ground where she last saw it, I really start to regret lacking the foresight to buy one of those cat ear headbands." with dissolve
    "Y mientras la observo gateando en el suelo donde la vi por última vez, empiezo a arrepentirme de que no se me ocurriera comprar una de esas diademas con orejas de gato." with dissolve

