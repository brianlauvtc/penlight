translate spanish Day4_Con_Kyou_Sayori_aba9565d:

    # s uniform_folded alert_laugh "Life! That's all it is~" with dissolve
    s uniform_folded alert_laugh "¡La vida! Eso es todo." with dissolve

# game/kyou 4.rpy:4185
translate spanish Day4_Con_Kyou_Sayori_e08bbb8c:

    # h smile_side uniform "Heh. Well, you stay perky and I'm gonna go to practice. Catch ya later~" with dissolve
    h smile_side uniform "Je. Pues, tú sigue así de contenta y yo iré a practicar. Nos vemos luego." with dissolve

# game/kyou 4.rpy:4186
translate spanish Day4_Con_Kyou_Sayori_beb4883c:

    # s alert_smile "Have fun." with dissolve
    s alert_smile "Diviértete." with dissolve

# game/kyou 4.rpy:4188
translate spanish Day4_Con_Kyou_Sayori_d658d412:

    # s alert_smile_right "... {w=1.0}{nw}" with dissolve
    s alert_smile_right "... {w=1.0}{nw}" with dissolve

# game/kyou 4.rpy:4190
translate spanish Day4_Con_Kyou_Sayori_afa8ab21:

    # "[alt_name] spares me another glance before taking her own leave." with dissolve
    "[alt_name] me observa una vez más antes de irse." with dissolve

# game/kyou 4.rpy:4193
translate spanish Day4_Con_Kyou_Sayori_e8062cbb:

    # "She'll make her excuses at her club, then hurry on over to me as soon as she can."
    "Le inventará alguna excusa a su club, luego vendrá conmigo tan rápido como pueda."

# game/kyou 4.rpy:4194
translate spanish Day4_Con_Kyou_Sayori_5b451f24:

    # "And then we can work on a routine for my hypnosis show at the culture festival!"
    "¡Y luego podremos trabajar en nuestra rutina para mi espectáculo de hipnosis del festival cultural!"

# game/kyou 4.rpy:4195
translate spanish Day4_Con_Kyou_Sayori_605f2f2c:

    # "I mean, I wasn't sure about going through with it before, but if [alt_name]'s on board, then..."
    "Quiero decir, no estaba seguro de seguir con eso, pero si [alt_name] está a bordo, pues..."

# game/kyou 4.rpy:4196
translate spanish Day4_Con_Kyou_Sayori_6af38df8:

    # "Or maybe we can do more than that..."
    "O tal vez podamos hacer más que eso..."

# game/kyou 4.rpy:4198
translate spanish Day4_Con_Kyou_Sayori_df8161bb:

    # "Ugh, no I can't think about that yet. At least not while she's living under her post-hypnotic suggestion."
    "Aj, no, no puedo pensar en eso aún. Al menos no mientras esté viviendo bajo esa sugestión posthipnótica."

# game/kyou 4.rpy:4199
translate spanish Day4_Con_Kyou_Sayori_ec24d7ed:

    # "... Shit, that's right. Somehow I almost forgot that she's not really \"[alt_name]\"."
    "... Mierda, es cierto. Casi se me olvida que no es realmente \"[alt_name]\"."

# game/kyou 4.rpy:4200
translate spanish Day4_Con_Kyou_Sayori_bcdc3dec:

    # "In all my excitement, that detail got really easy to overlook."
    "Con toda la emoción, es fácil pasar ese detalle por alto."

# game/kyou 4.rpy:4202
translate spanish Day4_Con_Kyou_Sayori_d107b756:

    # "But that's her at the door already. She REALLY must've wanted to get out of study club tonight; I've barely gotten home myself."
    "Pero ya está en la puerta. DE VERDAD debió tener ganas de salir del club de estudio hoy; yo apenas acabo de llegar."

# game/kyou 4.rpy:5357
translate spanish Day4_Con_Kyou_Sayori_c548864d:

    # s "Ahh, it feels so good to be out of there~"
    s "Aah, qué bien se siente salir de ahí."

# game/kyou 4.rpy:4208
translate spanish Day4_Con_Kyou_Sayori_e3d9be2e:

    # "I chuckle as I close the door behind her while she pops her shoes off."
    "Me río al dejarla pasar y cerrar la puerta, mientras ella se quita los zapatos."

# game/kyou 4.rpy:4209
translate spanish Day4_Con_Kyou_Sayori_3d641f73:

    # s alert_smile_right "I mean, I took your point about not quitting, but just to be able to do this once in a while." with dissolve
    s alert_smile_right "Pues, seguí tu consejo de no abandonar, pero solo para poder hacer esto de vez en cuando." with dissolve

# game/kyou 4.rpy:4210
translate spanish Day4_Con_Kyou_Sayori_bed0f3c9:

    # s alert_giggle "To be able to shirk my responsibilities!" with dissolve
    s alert_giggle "¡Para poder eludir mis responsabilidades!" with dissolve

# game/kyou 4.rpy:5333
translate spanish Day4_Con_Kyou_Sayori_b4fc5c4c:

    # s uniform_handup alert_laugh "Ahhh, it is so liberating~" with dissolve
    s uniform_handup alert_laugh "Aaah, es tan liberador." with dissolve

# game/kyou 4.rpy:4212
translate spanish Day4_Con_Kyou_Sayori_97d5aa3e:

    # ks smile "I... guess it must be after waiting so long to do it, heh."
    ks smile "Pues... supongo que debe serlo después de esperarlo por tanto tiempo, je."

# game/kyou 4.rpy:4213
translate spanish Day4_Con_Kyou_Sayori_a496b3bb:

    # "[alt_name] giggles in the affirmative as she skips into my living room."
    "[alt_name] se ríe afirmativamente y camina dando saltos hacia mi sala."

# game/kyou 4.rpy:4214
translate spanish Day4_Con_Kyou_Sayori_f92339df:

    # s alert_giggle uniform_folded "So what shall we do, Kyou? I have several hours of freedom and I have no intention of wasting them." with dissolve
    s alert_giggle uniform_folded "¿Y qué hacemos, Kyou? Tengo varias horas de libertad y no tengo intención de desperdiciarlas." with dissolve

# game/kyou 4.rpy:4215
translate spanish Day4_Con_Kyou_Sayori_17d7d51c:

    # ks "W-well... I was thinking we could try something for the hypnosis show like we talked about."
    ks "P-pues... estaba pensando que podríamos probar algo para el espectáculo de hipnosis del que hablamos."

# game/kyou 4.rpy:4216
translate spanish Day4_Con_Kyou_Sayori_d94fba50:

    # s alert_laugh "Oh, of course!" with dissolve
    s alert_laugh "¡Oh, desde luego!" with dissolve

# game/kyou 4.rpy:4217
translate spanish Day4_Con_Kyou_Sayori_5dce1b9e:

    # "But as I mention that, there's something else I remember."
    "Pero al mencionarlo, recuerdo una cosa más."

# game/kyou 4.rpy:4220
translate spanish Day4_Con_Kyou_Sayori_843fcf0b:

    # "As she goes to sit on my couch, I recall the little lie I told her about \"Sayori\" being a joke name for her."
    "Mientras se sienta en mi sofá, me acuerdo de la pequeña mentira que le conté sobre que \"Sayori\" es un nombre de broma."

# game/kyou 4.rpy:4223
translate spanish Day4_Con_Kyou_Sayori_55f3da59:

    # s alert_smile_right "So Kyou, did you come up with any ideas?" with dissolve
    s alert_smile_right "Así que, Kyou, ¿se te ocurrió alguna idea?" with dissolve

# game/kyou 4.rpy:4224
translate spanish Day4_Con_Kyou_Sayori_d8f64ede:

    # "And that if we wanted to continue this between us I'd have to deal with that somehow."
    "Y que, si queremos continuar con esto entre nosotros, tendré que encargarme de eso de algún modo."

# game/kyou 4.rpy:4225
translate spanish Day4_Con_Kyou_Sayori_6bbcdd46:

    # "Otherwise reality will force her out of her \"[alt_name]\" bubble whether she likes it or not."
    "De lo contrario, la realidad la sacará de su burbuja \"[alt_name]\" a la fuerza, le guste o no."

# game/kyou 4.rpy:5380
translate spanish Day4_Con_Kyou_Sayori_d2e20023:

    # ks confused "U-uh, well... can I ask you something first?"
    ks confused "E-eh, pues... ¿puedo preguntarte algo antes?"

# game/kyou 4.rpy:4227
translate spanish Day4_Con_Kyou_Sayori_ef8c6085:

    # s alert_happy "Ask away~" with dissolve
    s alert_happy "Pregunta." with dissolve

# game/kyou 4.rpy:4228
translate spanish Day4_Con_Kyou_Sayori_e26bec29:

    # "I mean, I could put a stop to this and force Sayori to return to her true self, but..."
    "Es decir, yo podría ponerle un alto a esto y obligar a Sayori a volver a su verdadero yo, pero..."

# game/kyou 4.rpy:4229
translate spanish Day4_Con_Kyou_Sayori_cba0a946:

    # ks "Are you... are you okay?"
    ks "¿Te... te encuentras bien?"

# game/kyou 4.rpy:4230
translate spanish Day4_Con_Kyou_Sayori_82718996:

    # s alert_surprised_right "Uh... yes? Why would I not be?" with dissolve
    s alert_surprised_right "Eh... ¿sí? ¿Por qué no estaría bien?" with dissolve

# game/kyou 4.rpy:4231
translate spanish Day4_Con_Kyou_Sayori_261e4b85:

    # "... she's held onto this suggestion for an entire day now."
    "... Ya se aferró a esta sugestión por un día entero."

# game/kyou 4.rpy:4232
translate spanish Day4_Con_Kyou_Sayori_fa931196:

    # ks neutral "So, like... I dunno, you're not feeling like you've forgotten anything or that something weird is going on?"
    ks neutral "Pues, este... no sé, ¿no sientes que estás olvidando algo o que algo extraño está pasando?"

# game/kyou 4.rpy:4233
translate spanish Day4_Con_Kyou_Sayori_ef6ca8c4:

    # s uniform alert_smile blush "I... n-no, nothing weird is going on with me. Absolutely not!" with dissolve
    s uniform alert_smile blush "Eh... n-no, no me está pasando nada extraño. ¡Absolutamente no!" with dissolve

# game/kyou 4.rpy:4234
translate spanish Day4_Con_Kyou_Sayori_575e330f:

    # "And come on, I only have to look at her to see she how comfortable she is to keep hold of it."
    "Y, vamos, solo tengo que mirarla para ver lo cómoda que está aferrándose a ella."

# game/kyou 4.rpy:4950
translate spanish Day4_Con_Kyou_Sayori_df1e3284:

    # s "What gave you that idea?" with dissolve
    s "¿De dónde sacas esa idea?" with dissolve

# game/kyou 4.rpy:4236
translate spanish Day4_Con_Kyou_Sayori_1811ce91:

    # "And I know I'm enjoying the hell out of seeing her like this."
    "Y sé que estoy disfrutando muchísimo verla así."

# game/kyou 4.rpy:4237
translate spanish Day4_Con_Kyou_Sayori_b1f421cb:

    # "So why not make sure we can keep it going together?"
    "¿Por qué no asegurarnos de poder continuar juntos?"

# game/kyou 4.rpy:4240
translate spanish Day4_Con_Kyou_Sayori_6e3650a0:

    # ks smile "I, uh... I just wanted to check, that's all. After the hypnosis session we did yesterday."
    ks smile "Yo, eh... solo quería comprobar, eso es todo. Luego de la sesión de hipnosis de ayer."

# game/kyou 4.rpy:4241
translate spanish Day4_Con_Kyou_Sayori_e3d1d78f:

    # s alert_smile_right noblush "Oh, when you were trying to put that other person in my mind." with dissolve
    s alert_smile_right noblush "Oh, cuando intentaste meter a esa otra persona en mi mente." with dissolve

# game/kyou 4.rpy:4242
translate spanish Day4_Con_Kyou_Sayori_f131b4a0:

    # ks "That's... right, yeah. Sayori."
    ks "Es... correcto, sí. Sayori."

# game/kyou 4.rpy:4243
translate spanish Day4_Con_Kyou_Sayori_ecee1b04:

    # s alert_rolleyes "Well, I have been getting some strange comments today, besides the silly name prank everyone's been doing." with dissolve
    s alert_rolleyes "Pues, he estado recibiendo algunos comentarios extraños hoy, además de esa tonta broma del nombre que todos están haciendo." with dissolve

# game/kyou 4.rpy:4438
translate spanish Day4_Con_Kyou_Sayori_ecd48663:

    # s "It is like they are always surprised to see me so \"chipper\" and \"full of energy\"."
    s "Es como si siempre se sorprendieran de verme tan \"animada\" y \"llena de energía\"."

# game/kyou 4.rpy:4245
translate spanish Day4_Con_Kyou_Sayori_a0dcb265:

    # s alert_smile_right "But I have been sleeping so much better thanks to you, Kyou. That must be what they're referring to." with dissolve
    s alert_smile_right "Pero he dormido mucho mejor gracias a ti, Kyou. De seguro a eso se refieren." with dissolve

# game/kyou 4.rpy:4246
translate spanish Day4_Con_Kyou_Sayori_e58f015d:

    # ks "Yeah. Still though, even though it didn't work, there might be some of \"Sayori\" in your head."
    ks "Sí. Pero, aunque no haya funcionado, puede que haya algo de \"Sayori\" en tu cabeza."

# game/kyou 4.rpy:4247
translate spanish Day4_Con_Kyou_Sayori_77a115b8:

    # ks "So I think I should put you under again and make sure hearing her name isn't messing with you in some way."
    ks "Así que, creo que deberíamos ponerte de nuevo en trance y asegurarnos de que oír su nombre no te esté afectando de alguna manera."

# game/kyou 4.rpy:4248
translate spanish Day4_Con_Kyou_Sayori_745aa1b0:

    # s alert_happy uniform_folded "That makes sense!" with dissolve
    s alert_happy uniform_folded "¡Tiene sentido!" with dissolve

# game/kyou 4.rpy:4254
translate spanish Day4_Con_Kyou_Sayori_864a9af6:

    # "[alt_name] smiles as I take the penlight from my pocket and click it on in front of her."
    "[alt_name] sonríe mientras saco la linterna de mi bolsillo y la enciendo en frente de ella."

# game/kyou 4.rpy:4255
translate spanish Day4_Con_Kyou_Sayori_3c5adbec:

    # ks smile "Great. So can you look up for me, please?"
    ks smile "Genial. Entonces, ¿podrías mirar aquí arriba, por favor?"

# game/kyou 4.rpy:4341
translate spanish Day4_Con_Kyou_Sayori_8f78149e:

    # "[alt_name] happily complies as I pass the penlight's beam gently across her eyesight."
    "[alt_name] sigue felizmente las instrucciones mientras paso el haz de la linterna por sus ojos."

# game/kyou 4.rpy:4259
translate spanish Day4_Con_Kyou_Sayori_a69d62c6:

    # ks "You're so responsive now, [alt_name]. It's like your eyes immediately jump to the light."
    ks "Ya eres muy responsiva, [alt_name]. Es como si tus ojos saltaran inmediatamente hacia la luz."

# game/kyou 4.rpy:4260
translate spanish Day4_Con_Kyou_Sayori_6b832f4b:

    # s "Ehehe... Well, it is very nice to look at, Kyou~"
    s "Jejeje... Pues, es agradable mirarla, Kyou."

# game/kyou 4.rpy:4262
translate spanish Day4_Con_Kyou_Sayori_3a92dff7:

    # ks "Yes it is. And the more you look, the more natural it is to continue looking, [alt_name]."
    ks "Sí que lo es. Y entre más la miras, es más natural seguir mirándola, [alt_name]."

# game/kyou 4.rpy:4264
translate spanish Day4_Con_Kyou_Sayori_396f3828:

    # ks "And the more natural it becomes to look, the easier it feels to accept how heavy your eyelids become from looking."
    ks "Y entre más natural es mirar, se siente más fácil aceptar lo pesados que están tus ojos de tanto mirar."

# game/kyou 4.rpy:4266
translate spanish Day4_Con_Kyou_Sayori_7a69e29b:

    # ks "But there's no need to think about any of that, [alt_name]. No need to think at all."
    ks "Pero no hace falta pensar en eso, [alt_name]. No hace falta pensar en nada."

# game/kyou 4.rpy:4268
translate spanish Day4_Con_Kyou_Sayori_63330381:

    # ks "All you need to do is stare, and what naturally will happen, will happen."
    ks "Solo debes mirar, y lo que pase naturalmente, pasará."

# game/kyou 4.rpy:4272
translate spanish Day4_Con_Kyou_Sayori_c4c670aa:

    # ks "Just how all that tension and pent-up energy is flowing out of your relaxed body."
    ks "Y toda esa tensión y energía acumulada empiezan a fluir por tu relajado cuerpo."

# game/kyou 4.rpy:4274
translate spanish Day4_Con_Kyou_Sayori_13240e1c:

    # ks "Naturally feeling it seep out of your loose, limp limbs as your eyes become heavier still."
    ks "Saliendo naturalmente de tus brazos y piernas, dejándolos tan flojitos, mientras tus párpados se ponen aun más pesados."

# game/kyou 4.rpy:4277
translate spanish Day4_Con_Kyou_Sayori_c393b154:

    # ks "Heavier still, [alt_name]. Much as you still want to stare at the light..." with dissolve
    ks "Más pesados, [alt_name]. Por mucho que aún quieras seguir viendo la luz..." with dissolve

# game/kyou 4.rpy:4280
translate spanish Day4_Con_Kyou_Sayori_f039b751:

    # ks "You may now find it impossible to keep those heavy eyelids of yours from closing completely."
    ks "Puede que te sea imposible evitar que esos ojitos tuyos se cierren por completo."

# game/kyou 4.rpy:4283
translate spanish Day4_Con_Kyou_Sayori_c16b73b6:

    # ks "Eyelids completely closed as you drift asleep, [alt_name]... That's right." with dissolve
    ks "Tus párpados se cierran completamente y tú te quedas dormida, [alt_name]... Eso es." with dissolve

# game/kyou 4.rpy:4286
translate spanish Day4_Con_Kyou_Sayori_14a15a62:

    # "So... if I've hypnotized her as [alt_name], then I guess any suggestions I give her will work on [alt_name] only, unless I tell her otherwise."
    "Pues... si la hipnoticé como [alt_name], supongo que cualquier sugestión que le dé funcionará únicamente en [alt_name], a no ser que le indique lo contrario."

# game/kyou 4.rpy:4287
translate spanish Day4_Con_Kyou_Sayori_b35b329f:

    # "I'm gonna try and make sure [alt_name] won't get tripped up by any references to her real name anymore."
    "Trataré de asegurarme de que [alt_name] ya no se confunda con ninguna referencia a su nombre real."

# game/kyou 4.rpy:4288
translate spanish Day4_Con_Kyou_Sayori_abbe0b5f:

    # ks "Drifting back into that nice, deep state of trance. Everything else fading into the background leaving only my voice."
    ks "Regresando a ese agradable y profundo estado de trance. Todo lo demás se desvanece en el fondo y no queda nada más que mi voz."

# game/kyou 4.rpy:4289
translate spanish Day4_Con_Kyou_Sayori_d50a9cb6:

    # ks "Isn't that right, [alt_name]?"
    ks "No es así, ¿[alt_name]?"

# game/kyou 4.rpy:4290
translate spanish Day4_Con_Kyou_Sayori_5be09509:

    # scg alert_sleeptalk "Right..." with dissolve
    scg alert_sleeptalk "Sí..." with dissolve

# game/kyou 4.rpy:4292
translate spanish Day4_Con_Kyou_Sayori_af3a7fc0:

    # ks "So right and natural, [alt_name]. And now it's just my voice, you'll be able to fully concentrate and absorb my words and accept them completely." with dissolve
    ks "Es muy natural, [alt_name]. Y ahora podrás concentrarte únicamente en mi voz y en absorber y aceptar cada una de mis palabras." with dissolve

# game/kyou 4.rpy:4293
translate spanish Day4_Con_Kyou_Sayori_764b7e85:

    # ks "Which is why when I say to you that every time you see or hear your name as \"Sayori\", what you consciously see or hear will in fact be \"[alt_name]\"..."
    ks "Y es por eso que, cuando diga que cada vez que veas o escuches tu nombre como \"Sayori\", lo que verás u oirás conscientemente será en realidad \"[alt_name]\"..."

# game/kyou 4.rpy:4294
translate spanish Day4_Con_Kyou_Sayori_079eb89e:

    # ks "... it will be completely true that you will only consciously see or hear \"[alt_name]\" whenever you are referred to as \"Sayori\"."
    ks "... será completamente cierto que conscientemente verás u oirás únicamente \"[alt_name]\" cada vez que se refieran a ti como \"Sayori\"."

# game/kyou 4.rpy:4295
translate spanish Day4_Con_Kyou_Sayori_a24e609c:

    # ks "It will simply not occur to your conscious mind that you could be called by any other name, so of course they mean \"[alt_name]\"."
    ks "Simplemente no se le ocurrirá a tu mente consciente que puedas ser llamada por otro nombre, así que, está claro que quisieron decir \"[alt_name]\"."

# game/kyou 4.rpy:4296
translate spanish Day4_Con_Kyou_Sayori_e869ab55:

    # "... Although subconsciously she'll still know the difference, is the unspoken implication I'm going for here."
    "... Aunque subconscientemente siga sabiendo la diferencia, aquí estoy yendo por la implicación no hablada."

# game/kyou 4.rpy:4297
translate spanish Day4_Con_Kyou_Sayori_40a7f940:

    # ks "Do you understand and accept what I have said, [alt_name]?"
    ks "¿Comprendes y aceptas lo que he dicho, [alt_name]?"

# game/kyou 4.rpy:4298
translate spanish Day4_Con_Kyou_Sayori_434ea0d9:

    # "So even now if I said to her \"Become Sayori\" she'd still realize the real Sayori needs to come back."
    "Así que, si le dijera \"Conviértete en Sayori\", aun así se daría cuenta de que la verdadera Sayori tiene que salir."

# game/kyou 4.rpy:4299
translate spanish Day4_Con_Kyou_Sayori_2d711b39:

    # scg alert_sleeptalk "Yes... understand and accept..." with dissolve
    scg alert_sleeptalk "Sí... comprendo y acepto..." with dissolve

# game/kyou 4.rpy:4301
translate spanish Day4_Con_Kyou_Sayori_a70c0aaf:

    # ks "Furthermore, whenever you need to refer to yourself in speech or in writing, and there are others besides me you're talking to..." with dissolve
    ks "Y, lo que es más, siempre que necesites referirte a ti misma al hablar o escribir, y estés hablando con gente además de mí..." with dissolve

# game/kyou 4.rpy:4302
translate spanish Day4_Con_Kyou_Sayori_7ccbc145:

    # ks "... you will unconsciously use the name \"Sayori\" instead of your own. Understand, [alt_name]?"
    ks "... inconscientemente usarás el nombre \"Sayori\" en lugar del tuyo. ¿Comprendes, [alt_name]?"

# game/kyou 4.rpy:4303
translate spanish Day4_Con_Kyou_Sayori_e9934ec5:

    # scg alert_sleeptalk "I understand..." with dissolve
    scg alert_sleeptalk "Comprendo..." with dissolve

# game/kyou 4.rpy:4305
translate spanish Day4_Con_Kyou_Sayori_476aa7b3:

    # "Perfect. She's been so good at absorbing my suggestions so far, I have no doubt that'll stop [alt_name] getting confused over her other personality." with dissolve
    "Perfecto. Hasta ahora ha hecho un gran trabajo absorbiendo mis sugestiones, y no tengo duda de que eso evitará que [alt_name] se confunda con su otra personalidad." with dissolve

# game/kyou 4.rpy:4306
translate spanish Day4_Con_Kyou_Sayori_69e7a42e:

    # "I mean, her real personality."
    "Quiero decir, su verdadera personalidad."

# game/kyou 4.rpy:4308
translate spanish Day4_Con_Kyou_Sayori_3aee4a04:

    # ks "That's great, [alt_name]. It's so natural to process and accept these truths as automatically as breathing."
    ks "Grandioso, [alt_name]. Es natural procesar y aceptar estas verdades de forma tan automática como respirar."

# game/kyou 4.rpy:4309
translate spanish Day4_Con_Kyou_Sayori_a2576542:

    # ks "So now we're going to wake you back up, counting up to three, upon which you'll awaken happy and refreshed once more."
    ks "Así que, ahora, volveremos a despertare, a la cuenta de tres, y despertarás fresca y contenta una vez más."

# game/kyou 4.rpy:4311
translate spanish Day4_Con_Kyou_Sayori_d844e22e:

    # ks "Counting up now... one, taking a nice deep rousing breath..."
    ks "Empezaré a contar ahora... uno, toma mucho aire..."

# game/kyou 4.rpy:4312
translate spanish Day4_Con_Kyou_Sayori_20b0d3d5:

    # ks "Two, letting the energy flow back into your waking body..."
    ks "Dos, deja que la energía fluya de vuelta a tu cuerpo..."

# game/kyou 4.rpy:4313
translate spanish Day4_Con_Kyou_Sayori_6d6a52ff:

    # ks "And three, wide-awake and refreshed, [alt_name]."
    ks "Y tres, despierta y fresca, [alt_name]."

# game/kyou 4.rpy:4316
translate spanish Day4_Con_Kyou_Sayori_0f386a7a:

