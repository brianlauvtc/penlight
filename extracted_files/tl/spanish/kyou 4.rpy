    # h tennis_armup angry "HSSS!" with dissolve
    h tennis_armup angry "¡JJJJS!" with dissolve

# game/kyou 4.rpy:6134
translate spanish Day4_Con_Kyou_Hiroko_736a6d00:

    # "With only a moment's pause, she leaps back onto the couch in pursuit and vainly cups her hands over the light as it shines on the couch cushion." with dissolve
    "Haciendo tan solo una pequeña pausa, la persigue dando un brinco de regreso al sofá y pone sus manos sobre la luz que brilla en los cojines." with dissolve

# game/kyou 4.rpy:4639
translate spanish Day4_Con_Kyou_Hiroko_8d521f60:

    # ks "Haha, what's the matter, kitty? Can't you catch it?"
    ks "Jaja, ¿qué sucede, gatita? ¿No puedes atraparla?"

# game/kyou 4.rpy:6136
