    # n pain "Please say you'll be my boyfriend!" with dissolve
    n pain "¡Por favor, dime que serás mi novio!" with dissolve

# game/kyou 4.rpy:1665
translate spanish Day4_Villain_Kyou_6a420f05:

    # "As she pleads, I embrace her gently and place my hand against the small of her back as I look down into those pleading eyes."
    "Mientras ella implora, la abrazo gentilmente y coloco mi mano contra su espalda baja, mirando esos suplicantes ojos."

# game/kyou 4.rpy:1666
translate spanish Day4_Villain_Kyou_902787af:

    # ks smile blush "Nozomi..."
    ks smile blush "Nozomi..."

# game/kyou 4.rpy:1667
translate spanish Day4_Villain_Kyou_e5ba9f06:

    # "I want to savour this moment."
    "Quiero saborear este momento."

# game/kyou 4.rpy:1668
translate spanish Day4_Villain_Kyou_065c6e11:

    # ks "You've been playing hard to get for all this time. I was starting to think you weren't interested in me at all."
    ks "Te has estado haciendo la difícil todo este tiempo. Empezaba a creer que no estabas ni un poco interesada en mí."

# game/kyou 4.rpy:1669
translate spanish Day4_Villain_Kyou_61054e21:

    # n shocked "No! I want you, Kyou!" with dissolve
    n shocked "¡No! ¡Yo te quiero, Kyou!" with dissolve

# game/kyou 4.rpy:1670
translate spanish Day4_Villain_Kyou_5f70eddb:

    # ks smirk "How do I know you're not playing with my feelings here?"
    ks smirk "¿Cómo sé que no estás jugando con mis sentimientos?"

# game/kyou 4.rpy:1671
translate spanish Day4_Villain_Kyou_cfa3e4bd:

    # n sleeptalk_concerned "L-listen... Kyou, I'm so sorry that I didn't listen to my feelings before. I'm so sorry it took me so long to realize what I've wanted all along!" with dissolve
    n sleeptalk_concerned "E-escucha... Kyou, lamento mucho no haber escuchado lo que sentía antes. ¡Siento haber tardado tanto en darme cuenta de que te quise desde el principio!" with dissolve

# game/kyou 4.rpy:1672
translate spanish Day4_Villain_Kyou_0f06d99b:

    # n "I must have hurt you a lot, but I..."
    n "Debo haberte lastimado mucho, pero..."

# game/kyou 4.rpy:1673
translate spanish Day4_Villain_Kyou_8a29f9ac:

    # n "I..."
    n "Pero..."

# game/kyou 4.rpy:1675
translate spanish Day4_Villain_Kyou_558dc31e:

    # "My words spur her into action, as she moves to prove herself by wrapping her arms around me and kissing me deeply."
    "Mis palabras la hacen actuar, pues para demostrar lo que dice, me envuelve en sus brazos y me da un profundo beso."

# game/kyou 4.rpy:1676
translate spanish Day4_Villain_Kyou_a71e9dab:

    # "Her warm lips press against mine, and in an instant all thoughts of teasing her into begging for my affections melt away."
    "Sus cálidos labios ejercen presión contra los míos, y en un instante, todos mis pensamientos sobre hacerme de rogar parecen derretirse."

# game/kyou 4.rpy:1677
translate spanish Day4_Villain_Kyou_dcbb0112:

    # "Nozomi... you're everything I've ever wanted."
    "Nozomi... eres todo lo que siempre quise."

# game/kyou 4.rpy:1678
translate spanish Day4_Villain_Kyou_53ebd4d7:

    # "And I'm going to be so good to you, now that you're mine."
    "Y seré muy bueno contigo, ahora que eres mía."

