translate spanish Day4_Con_Kyou_Nozomi_f9d92fe9:

    # ks "And do you accept everything you have been told so far?" with dissolve
    ks "¿Y aceptas todo lo que te he dicho hasta ahora?" with dissolve

# game/kyou 4.rpy:2542
translate spanish Day4_Con_Kyou_Nozomi_1c7fe4af_1:

    # ncg "Mhm..."
    ncg "Mjm..."

# game/kyou 4.rpy:2543
translate spanish Day4_Con_Kyou_Nozomi_c6ef83d8:

    # ks "Wonderful."
    ks "Maravilloso."

# game/kyou 4.rpy:2544
