translate spanish Day4_Con_Kyou_Nozomi_6e6f244c:

    # "I chuckle as I get to see her waking expression once again."
    "Me río al ver una vez más esa expresión que muestra al despertar."

# game/kyou 4.rpy:2567
translate spanish Day4_Con_Kyou_Nozomi_be9b325a:

    # ks "Wide awake, Nozomi."
    ks "Completamente despierta, Nozmi."

# game/kyou 4.rpy:2569
