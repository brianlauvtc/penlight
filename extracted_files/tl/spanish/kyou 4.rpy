translate spanish Day4_Villain_Kyou_afbad725:

    # "My plan also involved teasing her at first, refusing just so I could watch her beg; savour this moment."
    "Mi plan también involucraba hacerme el difícil un rato, reusarme solo para verla rogar; saborear el momento."

# game/kyou 4.rpy:1662
translate spanish Day4_Villain_Kyou_d88e8487:

    # "But this is too much..."
    "Pero esto es demasiado..."

# game/kyou 4.rpy:1665
translate spanish Day4_Villain_Kyou_24ac7ac7:

    # "We embrace, and we kiss, and it's everything I ever wanted." with dissolve
    "Nos abrasamos, nos besamos, y es todo lo que siempre quise." with dissolve

# game/kyou 4.rpy:1667
translate spanish Day4_Villain_Kyou_19866eb7:

    # "I'm going to be so good to you, Nozomi, now that you're mine."
    "Seré muy bueno contigo, Nozomi, ahora que eres mía."

# game/kyou 4.rpy:1668
