translate spanish Day4_Redemption_1bc8e7c1:

    # "And as she finishes in the stall she was in, our eyes meet as I stand frozen before her." with dissolve
    "Y una vez termina con ese cubículo, nuestras miradas se cruzan, y yo me quedo congelado frente a ella." with dissolve

# game/kyou 4.rpy:5926
translate spanish Day4_Redemption_d8c0edbc:

    # "What's she gonna think of me now?"
