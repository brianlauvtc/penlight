# game/kyou 4.rpy:778
translate spanish Day4_Villain_Kyou_9fd09827:

    # ks "Don't be creepy and focus. First I'm going to show you how to use it, by hypnotizing you with it again."
    ks "No te pongas espeluznante y enfócate. Primero te mostraré cómo se usa hipnotizándote otra vez con ella."

# game/kyou 4.rpy:780
