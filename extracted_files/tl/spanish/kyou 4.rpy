translate spanish Day4_Con_Kyou_Nozomi_145b1dbb:

    # "I have to lean in a little closer to make sure that she answered me in the affirmative." with dissolve
    "Tengo que inclinarme un poco hacia adelante para asegurarme de que me respondió afirmativamente." with dissolve

# game/kyou 4.rpy:2555
translate spanish Day4_Con_Kyou_Nozomi_dd78e65d:

    # ks "Very good, Nozomi. Now I want to remind you again; everything I have just told you, about obeying my commands, being unable to raise your voice..."
    ks "Muy bien, Nozomi. Ahora quiero recordártelo una vez más; todo lo que acabo de decirte, sobre obedecer mis órdenes, ser incapaz de alzar la voz..."

# game/kyou 4.rpy:2556
translate spanish Day4_Con_Kyou_Nozomi_820a406e:

    # ks "They are ONLY true for you while we are alone and in this house. If either of those conditions are false, you will not be bound by these rules in any way."
    ks "Son ciertas ÚNICAMENTE cuando estemos a solas en esta casa. Si alguna de esas condiciones no se cumple, no estarás atada a estas reglas."

# game/kyou 4.rpy:2557
translate spanish Day4_Con_Kyou_Nozomi_893e75c8:

    # ks "Is that clear, Nozomi?"
    ks "¿Quedó claro, Nozomi?"

