    # ks "Excellent. Now, it's time for you to wake up. I will count to three and you will awaken happy and refreshed once more." with dissolve
    ks "Excelente. Ahora, es momento de que despiertes. Contaré hasta tres y despertarás sintiéndote fresca y contenta una vez más." with dissolve

# game/kyou 4.rpy:2561
translate spanish Day4_Con_Kyou_Nozomi_a1dd9ce4:

    # ks "One... beginning to stir."
    ks "Uno... comienzas a moverte."

# game/kyou 4.rpy:2563
translate spanish Day4_Con_Kyou_Nozomi_1467c956:

    # ks "Two... fully accepting of everything you have been told."
    ks "Dos... aceptando por completo todo lo que te dije."

# game/kyou 4.rpy:2564
translate spanish Day4_Con_Kyou_Nozomi_a8ba6e02:

    # ks "And... three."
    ks "Y... tres."

# game/kyou 4.rpy:2565
translate spanish Day4_Con_Kyou_Nozomi_ce122a95:

    # ncg sleepy "{size=16}Mmm...{/size}" with dissolve
    ncg sleepy "{size=16}Mmm...{/size}" with dissolve

