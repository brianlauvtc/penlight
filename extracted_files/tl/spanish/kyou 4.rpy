translate spanish Day4_Redemption_8cc42fd8:

    # a neutral_side "That's... quite a leap from robots and gadgets, isn't it." with dissolve
    a neutral_side "Eso... sí que se aleja de los robots y artilugios, ¿no?" with dissolve

# game/kyou 4.rpy:5923
translate spanish Day4_Redemption_7e5a4783:

    # "But she was so encouraging and accommodating it completely lowered my guard."
