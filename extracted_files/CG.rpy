    layeredimage NozomiHypno folded:
        image_format "CG/Nozomi Hypno/Folded/{image}.png"
        group body:
            attribute uniform "Uniform" default
            attribute uniform2 "Uniform 2" #This second version has the light coming from the opposite side, which is necessary for some scenes
        group bruise:
            attribute bruise "Bruise"
        group blush:
            attribute noblush "Null" default
            attribute blush "Blush"
            attribute blush2 "Blush 2" #Again, I need a second version for when the light of the scene is on the other side
        group face:
            attribute angry "Angry"
            attribute angry2 "Angry 2" #And again, the shading needs to be different here for the lighting change
            attribute annoyed "Annoyed"
            attribute confused "Confused"
            attribute confused2 "Confused 2"
            attribute drowsy "Drowsy"
            attribute drowsytalk "Drowsy Talk"
            attribute entranced_neutral "Entranced Neutral"
            attribute entranced_talk "Entranced Talk"
            attribute neutral "Neutral" default
            attribute neutral2 "Neutral 2"
            attribute laugh "Laughing"
            attribute lookup "Looking Up"
            attribute lookup2 "Looking Up 2"
            attribute sad "Sad"
            attribute smile "Smiling"
            attribute smile2 "Smiling 2"
            attribute smile_closed "Smiling Closed"
            attribute stern "Stern"
            attribute stern2 "Stern 2"
            attribute stern_closed "Stern Closed"
            attribute surprised "Surprised"
            attribute surprised2 "Surprised 2"
            attribute surprised_falling "Surprised Falling"
        group glasses:
            attribute glasses "Glasses" default
            attribute noglasses "Null"


