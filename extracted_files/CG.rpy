transform cglight_right: #"Shines" a light to the right over a head-sized location (CG version)
    xpos light_x - 0.1
    ypos light_y
    linear 0.40 xalign light_x +0.35

transform cglight_left: #"Shines" a light to the left over a head-sized location (CG version)
    xpos light_x + 0.16
    ypos light_y
    linear 0.40 xalign light_x

label cglightshow:
    if ldirection == "right":
        if lnumber == 1:
            show cglight at cglight_right
            hide cglight with dissolve
        elif lnumber == 2:
            show cglight at cgdlight_right
            pause 0.4
            hide cglight with dissolve
        $ldirection = "left"
    else:
        if lnumber == 1:
            show cglight at cglight_left
            hide cglight with dissolve
        elif lnumber == 2:
            show cglight at cgdlight_left
            pause 0.4
            hide cglight with dissolve
        $ldirection = "right"
    return

label rehearsalflash(stage):
    if stage == 1:
        show HypnoRehearsal1 h_grumpy_light with dissolve
        show HypnoRehearsal1 h_grumpy with dissolve
        show HypnoRehearsal1 a_confused_light with dissolve
        show HypnoRehearsal1 a_confused with dissolve
        show HypnoRehearsal1 n_smile_light with dissolve
        show HypnoRehearsal1 n_smile with dissolve
        pause 1.0
        show HypnoRehearsal1 n_smile_light with dissolve
        show HypnoRehearsal1 n_smile with dissolve
        show HypnoRehearsal1 a_confused_light with dissolve
        show HypnoRehearsal1 a_confused with dissolve
        show HypnoRehearsal1 h_grumpy_light with dissolve
        show HypnoRehearsal1 h_grumpy with dissolve
    elif stage == 2:
        show HypnoRehearsal1 h_relaxed_light with dissolve
        show HypnoRehearsal1 h_relaxed with dissolve

    return
